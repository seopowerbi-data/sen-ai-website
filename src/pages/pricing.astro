---
/**
 * Pricing - Self-serve credit packs for AI Scan.
 *
 * UX Laws:
 * - Hick's Law: 3 tiers per credit type - minimal decision friction
 * - Von Restorff: best-value pack highlighted with border + badge
 * - Anchoring: show per-credit price to make bigger packs look cheaper
 * - Miller's Law: grouped into Scan vs Content sections
 * - Jakob's Law: standard pricing page layout users expect
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Pricing - sen-ai.fr" description="Simple, pay-as-you-go pricing. Buy credit packs to scan your AI visibility.">
  <Nav />
  <main class="pt-24 pb-20 px-4">
    <div class="max-w-5xl mx-auto">

      <!-- Hero -->
      <div class="text-center mb-16">
        <p class="text-coral uppercase tracking-[0.25em] text-sm font-medium mb-4">Pricing</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-charcoal-dark mb-4">
          Pay as you go
        </h1>
        <p class="text-lg text-charcoal-light max-w-2xl mx-auto">
          No subscription. Buy credit packs when you need them. Credits never expire.
        </p>
      </div>

      <!-- Free tier -->
      <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-6 mb-12 max-w-3xl mx-auto">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-emerald-800 mb-1">Free to start</h2>
            <p class="text-sm text-emerald-700">Every new account gets <span class="font-bold">50 free scan credits</span>. Analyze your domain, discover topics and brands, classify competitors - all free. Credits are only consumed when you launch an AI scan.</p>
          </div>
        </div>
      </div>

      <!-- How it works -->
      <div class="max-w-3xl mx-auto mb-14">
        <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-5 text-center">How it works</h2>
        <div class="grid grid-cols-4 gap-4">
          <div class="text-center">
            <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-2">
              <span class="text-sm font-bold text-charcoal-dark">1</span>
            </div>
            <p class="text-xs text-charcoal-dark font-medium">Enter your domain</p>
            <p class="text-[10px] text-charcoal-light mt-0.5">Free</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-2">
              <span class="text-sm font-bold text-charcoal-dark">2</span>
            </div>
            <p class="text-xs text-charcoal-dark font-medium">Review topics & brands</p>
            <p class="text-[10px] text-charcoal-light mt-0.5">Free</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 bg-coral/10 rounded-full flex items-center justify-center mx-auto mb-2">
              <span class="text-sm font-bold text-coral">3</span>
            </div>
            <p class="text-xs text-charcoal-dark font-medium">Launch AI scan</p>
            <p class="text-[10px] text-coral mt-0.5">Uses credits</p>
          </div>
          <div class="text-center">
            <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-2">
              <span class="text-sm font-bold text-charcoal-dark">4</span>
            </div>
            <p class="text-xs text-charcoal-dark font-medium">Get results & actions</p>
            <p class="text-[10px] text-charcoal-light mt-0.5">Included</p>
          </div>
        </div>
      </div>

      <!-- Scan Credits -->
      <div class="mb-14">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-charcoal-dark mb-2">Scan Credits</h2>
          <p class="text-charcoal-light">Measure your brand's visibility in AI responses (ChatGPT and Gemini)</p>
          <p class="text-sm text-charcoal-light mt-1">1 credit = 1 AI question asked about your brand</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          <!-- Starter -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Starter</h3>
            <p class="text-xs text-charcoal-light mb-4">Quick check on 1 topic</p>
            <div class="mb-4">
              <span class="text-3xl font-bold text-charcoal-dark">€40</span>
              <span class="text-sm text-charcoal-light ml-1">/ 5 credits</span>
            </div>
            <p class="text-[10px] text-charcoal-light mb-5">€8.00 per credit</p>
            <a href="/register" class="block w-full py-2.5 border-2 border-coral text-coral font-medium rounded-lg hover:bg-coral hover:text-white transition-all text-center text-sm">
              Get started
            </a>
          </div>

          <!-- Pro - highlighted -->
          <div class="bg-white rounded-2xl border-2 border-coral shadow-lg shadow-coral/10 p-6 relative">
            <div class="absolute -top-3 left-6 bg-coral text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wide">
              Best value
            </div>
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Pro</h3>
            <p class="text-xs text-charcoal-light mb-4">Full scan across 3-5 topics</p>
            <div class="mb-4">
              <span class="text-3xl font-bold text-charcoal-dark">€100</span>
              <span class="text-sm text-charcoal-light ml-1">/ 15 credits</span>
            </div>
            <p class="text-[10px] text-emerald-600 font-medium mb-5">€6.67 per credit - save 17%</p>
            <a href="/register" class="block w-full py-2.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark hover:shadow-md transition-all text-center text-sm">
              Get started
            </a>
          </div>

          <!-- Agency -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Agency</h3>
            <p class="text-xs text-charcoal-light mb-4">Multiple brands or deep scans</p>
            <div class="mb-4">
              <span class="text-3xl font-bold text-charcoal-dark">€250</span>
              <span class="text-sm text-charcoal-light ml-1">/ 50 credits</span>
            </div>
            <p class="text-[10px] text-emerald-600 font-medium mb-5">€5.00 per credit - save 38%</p>
            <a href="/register?intent=agency" class="block w-full py-2.5 border-2 border-coral text-coral font-medium rounded-lg hover:bg-coral hover:text-white transition-all text-center text-sm">
              Get started
            </a>
          </div>
        </div>

        <!-- Bridge to /agency for bigger volumes -->
        <div class="mt-6 text-center">
          <p class="text-sm text-charcoal-light">
            Need 5 000+ scan credits, shared workspaces, or volume pricing?
            <a href="/agency" class="text-coral hover:text-coral-dark font-medium">See agency packs →</a>
          </p>
        </div>
      </div>

      <!-- Content Credits -->
      <div class="mb-14">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-charcoal-dark mb-2">Content Credits</h2>
          <p class="text-charcoal-light">Generate optimized content to improve your AI visibility</p>
          <p class="text-sm text-charcoal-light mt-1">1 credit = 1 FAQ (Schema.org) · 3 credits = 1 article (800-1500 words)</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Starter</h3>
            <p class="text-xs text-charcoal-light mb-4">Fix a few gaps</p>
            <div class="mb-4">
              <span class="text-3xl font-bold text-charcoal-dark">€40</span>
              <span class="text-sm text-charcoal-light ml-1">/ 10 credits</span>
            </div>
            <p class="text-[10px] text-charcoal-light mb-5">€4.00 per credit</p>
            <a href="/register" class="block w-full py-2.5 border-2 border-charcoal-dark text-charcoal-dark font-medium rounded-lg hover:bg-charcoal-dark hover:text-white transition-all text-center text-sm">
              Get started
            </a>
          </div>

          <div class="bg-white rounded-2xl border-2 border-charcoal-dark shadow-lg p-6 relative">
            <div class="absolute -top-3 left-6 bg-charcoal-dark text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wide">
              Best value
            </div>
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Pro</h3>
            <p class="text-xs text-charcoal-light mb-4">Full content strategy</p>
            <div class="mb-4">
              <span class="text-3xl font-bold text-charcoal-dark">€100</span>
              <span class="text-sm text-charcoal-light ml-1">/ 30 credits</span>
            </div>
            <p class="text-[10px] text-emerald-600 font-medium mb-5">€3.33 per credit - save 17%</p>
            <a href="/register" class="block w-full py-2.5 bg-charcoal-dark text-white font-medium rounded-lg hover:bg-charcoal-dark/90 hover:shadow-md transition-all text-center text-sm">
              Get started
            </a>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <h3 class="text-lg font-bold text-charcoal-dark mb-1">Agency</h3>
            <p class="text-xs text-charcoal-light mb-4">Scale content production</p>
            <div class="mb-4">
              <span class="text-3xl font-bold text-charcoal-dark">€250</span>
              <span class="text-sm text-charcoal-light ml-1">/ 100 credits</span>
            </div>
            <p class="text-[10px] text-emerald-600 font-medium mb-5">€2.50 per credit - save 38%</p>
            <a href="/register?intent=agency" class="block w-full py-2.5 border-2 border-charcoal-dark text-charcoal-dark font-medium rounded-lg hover:bg-charcoal-dark hover:text-white transition-all text-center text-sm">
              Get started
            </a>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-charcoal-dark mb-6 text-center">Questions</h2>
        <div class="space-y-4">
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 transition-colors list-none flex justify-between items-center">
              What is a scan credit?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light">
              1 scan credit = 1 question asked to an AI model about your brand. A typical scan with 3 personas per topic and 15 questions per persona uses about 45 credits per topic. You choose how many topics and personas to include.
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 transition-colors list-none flex justify-between items-center">
              Do credits expire?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light">
              No. Credits never expire. Buy them once, use them whenever you need.
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 transition-colors list-none flex justify-between items-center">
              What's included for free?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light">
              Domain analysis, topic discovery, brand detection, competitor identification, and persona generation are all free. Credits are only used when you launch the actual AI scan (step 3).
            </div>
          </details>
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="px-6 py-4 cursor-pointer text-sm font-medium text-charcoal-dark hover:bg-gray-50 transition-colors list-none flex justify-between items-center">
              Can I re-scan the same domain?
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-charcoal-light">
              Yes. Each re-scan creates a new data point so you can track your visibility over time. Re-scans inherit your topic, brand, and persona setup - you only pay for the AI questions.
            </div>
          </details>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="text-center mt-16">
        <a href="/register" class="inline-flex items-center gap-2 px-8 py-4 bg-coral text-white font-medium rounded-xl text-lg hover:bg-coral-dark hover:shadow-lg hover:scale-[1.02] transition-all">
          Start your free AI scan
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
        <p class="text-sm text-charcoal-light mt-3">No credit card required. 50 free scan credits included.</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
