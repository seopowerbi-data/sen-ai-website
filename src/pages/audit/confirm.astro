---
/**
 * Magic-link landing for audit-gratuit confirmation.
 *
 * Flow:
 *   1. User clicks the link in their inbox → arrives here with ?token=xxx
 *   2. Client-side JS POSTs the token to the API
 *   3. Page renders one of: loading → success (Peak-End) | already-confirmed | error
 */
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const token = Astro.url.searchParams.get('token') || '';
---

<BaseLayout
  title="Confirmation - sen-ai.fr"
  description="Confirmez votre demande d'audit gratuit sen-ai.fr."
>
  <main class="min-h-screen flex items-center justify-center px-4 py-16 bg-gradient-to-br from-white via-white to-coral/5">
    <div class="w-full max-w-lg">
      <div class="text-center mb-8">
        <a href="/">
          <img src="/logo-sen-ai-fr.png" alt="sen-ai.fr" class="h-10 mx-auto mb-2" />
        </a>
      </div>

      {!token && (
        <div class="bg-white rounded-2xl shadow-lg p-8 text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-amber-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h1 class="text-xl font-bold text-charcoal-dark mb-2">Lien manquant</h1>
          <p class="text-sm text-charcoal-light">Cette page nécessite un lien valide envoyé par email.</p>
          <a href="/" class="inline-block mt-6 px-6 py-2.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-sm">
            Retour à l'accueil
          </a>
        </div>
      )}

      {token && (
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-10">
          <!-- Loading state (default visible) -->
          <div id="loading" class="text-center py-4">
            <div class="w-10 h-10 border-3 border-coral border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
            <p class="text-sm text-charcoal-dark">Confirmation de votre demande...</p>
          </div>

          <!-- Success state -->
          <div id="success" class="hidden text-center">
            <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-emerald/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-emerald" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-charcoal-dark mb-3">
              Demande confirmée
            </h1>
            <p class="text-charcoal-light mb-6">
              Votre audit IA sur <strong id="success-website" class="text-charcoal-dark"></strong>
              arrive sous 24h.
            </p>

            <div class="bg-gray-50 rounded-xl p-5 text-left mb-6">
              <p class="text-xs font-semibold text-charcoal-dark uppercase tracking-wide mb-3">
                Ce que vous allez recevoir
              </p>
              <ul class="space-y-2.5 text-sm text-charcoal-light">
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span>3 personas réalistes de vos clients sur le sujet <strong id="success-topic" class="text-charcoal-dark"></strong></span>
                </li>
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span>6 questions clés posées à ChatGPT et Gemini</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-coral mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span>Un mini-rapport actionable avec ce que dit l'IA de votre marque</span>
                </li>
              </ul>
            </div>

            <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-charcoal-light mb-6">
              <span class="flex items-center gap-1">📨 Réponse 24h</span>
              <span class="flex items-center gap-1">🔒 Données privées</span>
              <span class="flex items-center gap-1">✨ Sans engagement</span>
            </div>

            <a href="/" class="inline-block px-6 py-2.5 border-2 border-charcoal-light/30 text-charcoal hover:border-coral hover:text-coral font-medium rounded-lg transition-colors text-sm">
              Retour à l'accueil
            </a>
          </div>

          <!-- Already confirmed state -->
          <div id="already" class="hidden text-center py-4">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-emerald/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h1 class="text-xl font-bold text-charcoal-dark mb-2">Déjà confirmée</h1>
            <p class="text-sm text-charcoal-light mb-6">Votre demande a déjà été confirmée. On revient vers vous sous 24h.</p>
            <a href="/" class="inline-block px-6 py-2.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-sm">
              Retour à l'accueil
            </a>
          </div>

          <!-- Error state -->
          <div id="error" class="hidden text-center py-4">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h1 class="text-xl font-bold text-charcoal-dark mb-2">Lien invalide ou expiré</h1>
            <p id="error-detail" class="text-sm text-charcoal-light mb-6">
              Ce lien a expiré ou a déjà été utilisé.
            </p>
            <a href="/#engagement" class="inline-block px-6 py-2.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-sm">
              Faire une nouvelle demande
            </a>
          </div>
        </div>
      )}
    </div>
  </main>

  {token && (
    <script type="module" define:vars={{ token }}>
      (async () => {
        const $loading = document.getElementById('loading');
        const $success = document.getElementById('success');
        const $already = document.getElementById('already');
        const $error = document.getElementById('error');

        function show(el) {
          $loading?.classList.add('hidden');
          el.classList.remove('hidden');
        }

        try {
          const res = await fetch('/api/audit-requests/confirm', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token }),
          });
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            const msg = err.detail || 'Ce lien a expiré ou a déjà été utilisé.';
            const $detail = document.getElementById('error-detail');
            if ($detail) $detail.textContent = msg;
            show($error);
            return;
          }
          const data = await res.json();
          if (data.already_confirmed) {
            show($already);
            return;
          }
          // Populate Peak-End values
          const $w = document.getElementById('success-website');
          const $t = document.getElementById('success-topic');
          if ($w) $w.textContent = data.website || 'votre site';
          if ($t) $t.textContent = data.topic_focus || 'le sujet choisi';
          show($success);
        } catch (e) {
          const $detail = document.getElementById('error-detail');
          if ($detail) $detail.textContent = 'Erreur réseau. Réessayez.';
          show($error);
        }
      })();
    </script>
  )}
</BaseLayout>
