---
/**
 * Competitor reverse-engineering - Sprint 7.
 *
 * For each top competitor of the scan, surfaces : the questions they won,
 * the URLs LLMs cite for them, their GEO content score (Princeton patterns,
 * S5), their structured data score (JSON-LD, S6), Babbar backlink
 * authority (MR.1), and a pattern delta vs the user's own pages.
 *
 * Data source : GET /api/scans/{id}/competitor-reverse
 * Refresh    : POST /api/scans/{id}/competitor-reverse/refresh?reset=true
 *
 * Laws of UX :
 *  - Peak-End : per-competitor hero shows count of winning questions
 *    (their leverage) + pattern delta chip.
 *  - Jakob : expandable card pattern matches Schema + Page Audit tabs.
 *  - Von Restorff : delta chips coloured by deficit (red if competitor
 *    beats you by 10+, amber 0-10, emerald if you beat them).
 *  - Miller : top 5 competitors only by default ; per-competitor top 10
 *    URLs shown ; deeper drilldown via the URL link to the source page.
 *
 * Natural writing : no em-dashes, no LLM tells. See feedback_no_em_dash.md.
 */
export const prerender = false;
import ScanResultsLayout from '../../../../layouts/ScanResultsLayout.astro';
import Tip from '../../../../components/Tip.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');
const scanId = Astro.params.id as string;

const headers = { Cookie: `token=${token}` };
let data: any = null;
try {
  const res = await fetch(`http://api:8000/api/scans/${scanId}/competitor-reverse`, { headers });
  if (res.ok) data = await res.json();
} catch (_) {}

const competitors: any[] = data?.competitors || [];
const baseline = data?.baseline || {};
const summary = data?.summary || {};
const lastFetched = data?.last_fetched;

function timeAgo(iso?: string): string {
  if (!iso) return 'never';
  const t = new Date(iso).getTime();
  if (Number.isNaN(t)) return 'never';
  const mins = Math.round((Date.now() - t) / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins} min ago`;
  const hrs = Math.round(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.round(hrs / 24);
  if (days < 14) return `${days}d ago`;
  return new Date(iso).toISOString().slice(0, 10);
}

function scoreClasses(score?: number | null) {
  if (score == null) return { bg: 'bg-gray-100', text: 'text-charcoal-light', label: 'n/a' };
  if (score >= 70) return { bg: 'bg-emerald-100', text: 'text-emerald-700', label: 'strong' };
  if (score >= 40) return { bg: 'bg-amber-100', text: 'text-amber-700', label: 'partial' };
  return { bg: 'bg-red-100', text: 'text-red-700', label: 'weak' };
}

function deltaClasses(d?: number | null) {
  if (d == null) return 'bg-gray-100 text-charcoal-light';
  if (d >= 10) return 'bg-red-100 text-red-700';     // competitor crushes you
  if (d > 0)   return 'bg-amber-100 text-amber-700';  // competitor ahead
  return 'bg-emerald-100 text-emerald-700';           // you're ahead
}

function fmtDelta(d?: number | null) {
  if (d == null) return 'n/a';
  if (d > 0) return `+${d}`;
  return String(d);
}
---

<ScanResultsLayout scanId={scanId} activeTab="competitors">
  <div x-data="{ expanded: null, refreshing: false }">

    <p class="text-sm text-charcoal-light mb-6">
      Top competitors of this scan, reverse-engineered from the pages
      LLMs already cite for them. We audit each cited URL against the
      Princeton GEO patterns (content quality) and schema.org spec
      (structured data), pull Babbar authority when available, and
      surface what each competitor has that your own pages don't.
    </p>

    {/* Hero KPI banner */}
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-xl shadow-sm p-6 lg:col-span-2">
        <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-2">
          <Tip id="comp_audited_count">Competitors audited</Tip>
        </p>
        <div class="flex items-baseline gap-3">
          <span class="text-3xl font-bold text-charcoal-dark">{summary.competitors_audited || 0}</span>
          <span class="text-base text-charcoal-light">{summary.pages_audited || 0} page(s) audited</span>
        </div>
        {baseline.own_page_count > 0 && (
          <p class="text-xs text-charcoal-light mt-1">
            <Tip id="comp_baseline">
              Your baseline : {baseline.own_page_count} cited pages, avg GEO {baseline.own_geo_avg ?? '-'}/100,
              avg schema {baseline.own_schema_avg ?? '-'}/100.
            </Tip>
          </p>
        )}
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-2">
          <Tip id="comp_top_label">Top competitor</Tip>
        </p>
        {competitors.length > 0 ? (
          <>
            <p class="text-sm font-semibold text-charcoal-dark">{competitors[0].brand_name}</p>
            <p class="text-xs text-charcoal-light mt-1">{competitors[0].winning_questions_count} winning question(s)</p>
            <p class="text-[10px] text-charcoal-light mt-1">on {competitors[0].page_count} cited page(s)</p>
          </>
        ) : (
          <p class="text-sm text-charcoal-light mt-2">No competitor wins detected.</p>
        )}
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 flex flex-col justify-between">
        <div>
          <p class="text-[11px] text-charcoal-light uppercase tracking-wide mb-2">Last audit</p>
          <p class="text-sm text-charcoal-dark">{timeAgo(lastFetched)}</p>
          <p class="text-[10px] text-charcoal-light mt-1">Free of any LLM cost.</p>
        </div>
        <button
          @click={`if (refreshing) return; refreshing = true; fetch('/api/scans/${scanId}/competitor-reverse/refresh?reset=true', { method: 'POST' }).then(r => r.json()).then(_ => { setTimeout(() => location.reload(), 8000); }).catch(() => { refreshing = false; });`}
          :disabled="refreshing"
          class="mt-3 px-3 py-1.5 text-xs font-medium rounded-lg bg-coral text-white hover:bg-coral-dark disabled:bg-gray-300 transition-colors"
        >
          <span x-show="!refreshing">Refresh audit</span>
          <span x-show="refreshing">Running audit...</span>
        </button>
      </div>
    </div>

    {competitors.length === 0 && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-800">
        No competitor reverse-engineering data yet. Click <strong>Refresh audit</strong>
        above. The handler will identify the top 5 competitors of this scan and audit
        up to 10 cited pages each (50 fetches, around 25 seconds). Free of any LLM cost.
        Requires the Page Audit and Schema tabs to be already populated for the
        pattern delta vs your own pages to compute properly.
      </div>
    )}

    {competitors.length > 0 && (
      <div class="space-y-3">
        {competitors.map((c: any, ci: number) => {
          const cardKey = `c${ci}`;
          const geoCls = scoreClasses(c.geo_avg);
          const schemaCls = scoreClasses(c.schema_avg);
          const deltaGeoCls = deltaClasses(c.delta?.geo_vs_yours);
          const deltaSchemaCls = deltaClasses(c.delta?.schema_vs_yours);
          const newSchemas: string[] = c.delta?.schemas_they_have_you_dont || [];
          return (
            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
              <div class="px-6 py-4 cursor-pointer hover:bg-gray-50 transition-colors"
                   @click={`expanded = expanded === '${cardKey}' ? null : '${cardKey}'`}>
                <div class="flex items-center gap-3">
                  <span class="text-[11px] text-charcoal-light w-6 text-right shrink-0">{ci + 1}</span>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-semibold text-charcoal-dark truncate">{c.brand_name}</h3>
                    <p class="text-[10px] text-charcoal-light truncate">{c.domain || 'no domain on record'}</p>
                  </div>
                  <Tip id="comp_wins">
                    <span class="text-[10px] px-2 py-0.5 rounded bg-sky-50 text-sky-700 shrink-0">
                      {c.winning_questions_count} win(s)
                    </span>
                  </Tip>
                  <Tip id="comp_pages">
                    <span class="text-[10px] px-2 py-0.5 rounded bg-gray-100 text-charcoal-light shrink-0">
                      {c.page_count} page(s)
                    </span>
                  </Tip>
                  {c.geo_avg != null && (
                    <Tip id="comp_geo_avg">
                      <span class={`text-[10px] px-2 py-0.5 rounded font-semibold ${geoCls.bg} ${geoCls.text} shrink-0`}>
                        GEO {c.geo_avg}
                      </span>
                    </Tip>
                  )}
                  {c.schema_avg != null && (
                    <Tip id="comp_schema_avg">
                      <span class={`text-[10px] px-2 py-0.5 rounded font-semibold ${schemaCls.bg} ${schemaCls.text} shrink-0`}>
                        Schema {c.schema_avg}
                      </span>
                    </Tip>
                  )}
                  <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform" :class={`expanded === '${cardKey}' ? 'rotate-180' : ''`}
                       fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </div>

                {/* Pattern delta strip */}
                <div class="flex flex-wrap gap-2 mt-3 text-[10px]">
                  {c.delta?.geo_vs_yours != null && (
                    <Tip id="comp_geo_delta">
                      <span class={`px-2 py-0.5 rounded ${deltaGeoCls}`}>
                        GEO delta : {fmtDelta(c.delta.geo_vs_yours)}
                      </span>
                    </Tip>
                  )}
                  {c.delta?.schema_vs_yours != null && (
                    <Tip id="comp_schema_delta">
                      <span class={`px-2 py-0.5 rounded ${deltaSchemaCls}`}>
                        Schema delta : {fmtDelta(c.delta.schema_vs_yours)}
                      </span>
                    </Tip>
                  )}
                  {c.wikipedia_present && (
                    <Tip id="comp_wikipedia">
                      <span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-700">
                        Wikipedia ✓
                      </span>
                    </Tip>
                  )}
                  {c.backlinks?.da != null && (
                    <Tip id="comp_da">
                      <span class="px-2 py-0.5 rounded bg-indigo-50 text-indigo-700">
                        DA {c.backlinks.da}
                      </span>
                    </Tip>
                  )}
                  {newSchemas.length > 0 && (
                    <Tip id="comp_missing_schemas">
                      <span class="px-2 py-0.5 rounded bg-red-50 text-red-700">
                        Missing schemas : {newSchemas.slice(0, 3).join(', ')}{newSchemas.length > 3 ? ` +${newSchemas.length - 3}` : ''}
                      </span>
                    </Tip>
                  )}
                </div>
              </div>

              <div x-show={`expanded === '${cardKey}'`} x-transition class="border-t border-gray-100 px-6 py-4 bg-gray-50/30">

                {/* Winning questions list */}
                {c.winning_questions.length > 0 && (
                  <div class="mb-4">
                    <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">
                      Winning questions ({c.winning_questions.length})
                    </p>
                    <ul class="space-y-1">
                      {c.winning_questions.slice(0, 10).map((q: any) => (
                        <li class="text-[11px] text-charcoal-dark flex items-start gap-2">
                          <span class="text-[9px] px-1.5 py-0.5 rounded bg-gray-100 text-charcoal-light shrink-0 mt-0.5 uppercase">
                            {q.provider}
                          </span>
                          <span class="flex-1">{q.question}</span>
                        </li>
                      ))}
                      {c.winning_questions.length > 10 && (
                        <li class="text-[10px] text-charcoal-light italic">
                          +{c.winning_questions.length - 10} more.
                        </li>
                      )}
                    </ul>
                  </div>
                )}

                {/* Per-page list */}
                <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">
                  Cited pages ({c.pages.length})
                </p>
                <div class="space-y-2">
                  {c.pages.map((p: any, pi: number) => {
                    const pgeo = scoreClasses(p.geo_score);
                    const pschema = scoreClasses(p.schema_score);
                    let pathOnly = p.url;
                    try { pathOnly = new URL(p.url).pathname || '/'; } catch (_) {}
                    const validSchemas = (p.schemas || []).filter((s: any) => s.valid).map((s: any) => s.type);
                    return (
                      <div class="bg-white rounded-lg border border-gray-100 px-3 py-2">
                        <div class="flex items-center gap-2">
                          <span class="text-[10px] text-charcoal-light w-5 text-right shrink-0">{pi + 1}</span>
                          <div class="flex-1 min-w-0">
                            <a href={p.url} target="_blank" rel="noopener noreferrer" class="text-xs text-charcoal-dark hover:underline truncate block" title={p.url}>
                              {p.title || pathOnly}
                            </a>
                            <p class="text-[10px] text-charcoal-light truncate">{pathOnly}</p>
                          </div>
                          {p.fetch_error && p.audit_source === 'contexte' && (
                            <Tip id="comp_snippet_only">
                              <span class="text-[9px] px-1.5 py-0.5 rounded bg-amber-50 text-amber-700 shrink-0">
                                snippet-only
                              </span>
                            </Tip>
                          )}
                          {p.fetch_error && p.audit_source !== 'contexte' && (
                            <Tip id="comp_fetch_fail">
                              <span class="text-[9px] px-1.5 py-0.5 rounded bg-red-50 text-red-600 shrink-0">fetch fail</span>
                            </Tip>
                          )}
                          {p.citation_count > 0 && (
                            <Tip id="comp_citation_count">
                              <span class="text-[10px] text-charcoal-light shrink-0">
                                {p.citation_count} cite(s)
                              </span>
                            </Tip>
                          )}
                          {p.geo_score != null && (
                            <Tip id={p.audit_source === 'contexte' ? 'geo_page_score_contexte' : 'geo_page_score'}>
                              <span class={`text-[10px] px-2 py-0.5 rounded font-semibold ${pgeo.bg} ${pgeo.text} shrink-0`}>
                                GEO {p.geo_score}
                              </span>
                            </Tip>
                          )}
                          {p.schema_score != null && (
                            <Tip id="schema_page_score">
                              <span class={`text-[10px] px-2 py-0.5 rounded font-semibold ${pschema.bg} ${pschema.text} shrink-0`}>
                                S {p.schema_score}
                              </span>
                            </Tip>
                          )}
                        </div>
                        {validSchemas.length > 0 && (
                          <div class="flex flex-wrap gap-1 mt-1.5 pl-7">
                            {validSchemas.map((t: string) => (
                              <span class="text-[9px] px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700">{t}</span>
                            ))}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>

                {/* Pattern delta detail */}
                {newSchemas.length > 0 && (
                  <div class="mt-4">
                    <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">
                      What they have that you don't
                    </p>
                    <p class="text-xs text-charcoal-dark">
                      JSON-LD schema types found on this competitor's cited pages but
                      not on any of your own audited pages :
                    </p>
                    <div class="flex flex-wrap gap-1 mt-2">
                      {newSchemas.map((s: string) => (
                        <span class="text-[10px] px-2 py-0.5 rounded bg-red-50 text-red-700 border border-red-200">{s}</span>
                      ))}
                    </div>
                  </div>
                )}

              </div>
            </div>
          );
        })}
      </div>
    )}

  </div>
</ScanResultsLayout>
