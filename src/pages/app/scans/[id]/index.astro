---
/**
 * Scan Detail — Shows current scan state and next actions.
 * Redirects to results if completed.
 */
export const prerender = false;
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import Tip from '../../../../components/Tip.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const { id } = Astro.params;
const viewParam = Astro.url.searchParams.get('view'); // 'topics' | 'brands' | 'personas' | null

let scan = null;
let personasData: any = null;
let topics = [];
let brandsData = null;
try {
  const res = await fetch(`http://api:8000/api/scans/${id}`, {
    headers: { Cookie: `token=${token}` },
  });
  if (res.ok) scan = await res.json();

  if (scan?.status === 'completed' && !viewParam) {
    return Astro.redirect(`/app/scans/${id}/results`);
  }
} catch {}

if (!scan) return Astro.redirect('/app/scans');

// Auto-trigger topic classification if keywords are fetched but classify hasn't started.
// This handles the case where user leaves the /new wizard mid-process and returns via My Scans.
// The POST is idempotent (worker skips if classify is already running).
if (scan.status === 'keywords_fetched') {
  try {
    await fetch(`http://api:8000/api/scans/${id}/topics/auto-classify`, {
      method: 'POST',
      headers: { Cookie: `token=${token}` },
    });
  } catch {}
}

const steps = [
  { key: 'domain', label: 'Domain' },
  { key: 'topics', label: 'Topics' },
  { key: 'brands', label: 'Brands' },
  { key: 'personas', label: 'Personas' },
  { key: 'scan', label: 'Scan' },
  { key: 'results', label: 'Results' },
];

const statusToStep = {
  draft: 0, fetching_keywords: 0, keywords_fetched: 1, topics_ready: 1,
  assigning_keywords: 2, brands_ready: 2, generating_personas: 3, personas_ready: 3,
  scanning: 4, completed: 5, failed: 0,
};
const currentStep = statusToStep[scan.status] ?? 0;

// Fetch topics if user can see them (status reached topics_ready OR explicit ?view=topics)
const canSeeTopics = currentStep >= 1 || viewParam === 'topics';
if (canSeeTopics) {
  try {
    const tRes = await fetch(`http://api:8000/api/scans/${id}/topics`, {
      headers: { Cookie: `token=${token}` },
    });
    if (tRes.ok) {
      const tData = await tRes.json();
      topics = tData.topics || tData || [];
    }
  } catch {}
}

// Fetch brands if user can see them (status reached brands_ready OR explicit ?view=brands)
const canSeeBrands = currentStep >= 2 || viewParam === 'brands';
if (canSeeBrands) {
  try {
    const bRes = await fetch(`http://api:8000/api/scans/${id}/brands`, {
      headers: { Cookie: `token=${token}` },
    });
    if (bRes.ok) brandsData = await bRes.json();
  } catch {}
}

// Fetch personas if user can see them (status reached personas_ready OR explicit ?view=personas)
const canSeePersonas = currentStep >= 3 || viewParam === 'personas';
if (canSeePersonas) {
  try {
    const pRes = await fetch(`http://api:8000/api/scans/${id}/personas`, {
      headers: { Cookie: `token=${token}` },
    });
    if (pRes.ok) personasData = await pRes.json();
  } catch {}
}
const hasPersonas = personasData && (personasData.totals?.total_personas || 0) > 0;

// Pick a real example for the personas info banner — from the user's actual scan data.
// Prefer NON-BRANDED examples since the whole point of the AI scan is to measure whether
// the brand gets recommended on generic conversational questions (branded examples would
// mislead the user about what we're really testing).
//   - Question  : prefer type_question === 'basique' (Claude prompt explicitly forbids
//                 brand mentions in this type)
//   - Keyword   : prefer lowercase entries (brand product names are typically capitalised
//                 like "Effaclar"; generic SEO keywords like "acné inflammatoire" are not)
const personaBannerExample = (() => {
  if (!personasData?.topics) return null;
  for (const t of personasData.topics) {
    for (const p of (t.personas || [])) {
      if (!p.is_active || !p.data?.mots_cles_associes?.length || !p.questions?.length) continue;
      const basique = (p.questions || []).find((q: any) => q?.type_question === 'basique' && q?.is_active !== false);
      const question = basique?.question || p.questions[0]?.question;
      if (!question) continue;
      const lowercaseKw = (p.data.mots_cles_associes || []).find(
        (k: any) => typeof k === 'string' && k.length > 0 && k === k.toLowerCase()
      );
      const keyword = lowercaseKw || p.data.mots_cles_associes[0];
      return {
        personaName: p.name,
        topicName: t.topic_name,
        keyword,
        question,
      };
    }
  }
  return null;
})();

// Fetch domain brief
let briefData: any = null;
try {
  const bRes = await fetch(`http://api:8000/api/scans/${id}/brief`, {
    headers: { Cookie: `token=${token}` },
  });
  if (bRes.ok) briefData = await bRes.json();
} catch {}
const domainBrief = briefData?.domain_brief || null;
const briefStatus = briefData?.generation_status || null;
const briefBudget = {
  generations_used: briefData?.generations_used ?? 0,
  generations_cap: briefData?.generations_cap ?? 5,
  can_regenerate: briefData?.can_regenerate ?? true,
};

// Determine which view to render
// - If ?view= param set, show that view (back navigation)
// - Otherwise, show based on scan.status
const effectiveView =
  viewParam === 'topics' && topics.length > 0 ? 'topics' :
  viewParam === 'brands' && brandsData ? 'brands' :
  viewParam === 'personas' && hasPersonas ? 'personas' :
  null;  // null = render based on status as before

// Is the user reviewing a past step? (viewing something they've already validated)
const isReviewing = effectiveView !== null && (
  (effectiveView === 'topics' && currentStep > 1) ||
  (effectiveView === 'brands' && currentStep > 2) ||
  (effectiveView === 'personas' && currentStep > 3)
);
---

<DashboardLayout title={`Scan — ${scan.domain}`} activeSection="scans">
  <div class="p-8 max-w-3xl mx-auto">

    <!-- Stepper — completed steps AND the current step are clickable
         (current step clickable so user can return from a review view) -->
    <div class="flex items-center gap-2 mb-8">
      {steps.map((step, i) => {
        const done = i < currentStep;
        const current = i === currentStep;
        // URLs for navigation:
        // - `done` steps → go to their review view (?view=xxx)
        // - `current` step → go to the live page without ?view (shows current status naturally)
        // - future steps → not clickable
        const stepHref =
          step.key === 'topics' && done ? `/app/scans/${id}?view=topics` :
          step.key === 'brands' && done ? `/app/scans/${id}?view=brands` :
          step.key === 'personas' && done ? `/app/scans/${id}?view=personas` :
          current ? `/app/scans/${id}` :
          null;
        const clickable = stepHref !== null;
        const StepTag = clickable ? 'a' : 'div';
        return (
          <div class="flex items-center gap-2">
            <StepTag
              href={stepHref}
              title={clickable
                ? (done ? `Go back to ${step.label}` : `Go to ${step.label} (current step)`)
                : undefined}
              class:list={[
                'flex items-center gap-2',
                clickable ? 'cursor-pointer hover:opacity-80 transition-opacity group' : ''
              ]}
            >
              <div class:list={[
                'w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all',
                done ? 'bg-emerald-500 text-white' :
                current ? 'bg-coral text-white' :
                'bg-gray-200 text-gray-400',
                clickable && done ? 'group-hover:ring-2 group-hover:ring-emerald-300 group-hover:ring-offset-2' : '',
                clickable && current ? 'group-hover:ring-2 group-hover:ring-coral/40 group-hover:ring-offset-2' : ''
              ]}>
                {done ? '✓' : i + 1}
              </div>
              <span class:list={[
                'text-sm hidden sm:inline',
                current ? 'text-charcoal-dark font-medium' :
                clickable ? 'text-charcoal-light group-hover:text-charcoal-dark' :
                'text-charcoal-light'
              ]}>{step.label}</span>
            </StepTag>
            {i < steps.length - 1 && <div class="w-8 h-px bg-gray-200 hidden sm:block"></div>}
          </div>
        );
      })}

    </div>

    {/* Domain Brief — collapsible panel, always accessible */}
    <details class="mb-6 bg-white rounded-xl shadow-sm overflow-hidden group" open={!domainBrief && briefStatus === 'completed'}>
      <summary class="px-5 py-3 cursor-pointer hover:bg-gray-50 transition-colors flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-charcoal-light transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-sm font-medium text-charcoal-dark">Domain Brief</span>
          {domainBrief && <span class="text-[9px] px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-600 font-medium">Ready</span>}
          {briefStatus === 'pending' || briefStatus === 'running' ? <span class="text-[9px] px-1.5 py-0.5 rounded bg-blue-50 text-blue-600 font-medium animate-pulse">Generating...</span> : null}
          {!domainBrief && !briefStatus && <span class="text-[9px] px-1.5 py-0.5 rounded bg-gray-100 text-charcoal-light">Not generated</span>}
        </div>
        <span class="text-[10px] text-charcoal-light">Business context for AI analysis</span>
      </summary>
      <div class="px-5 py-4 border-t border-gray-100" x-data={`{
        brief: ${JSON.stringify(domainBrief || {})},
        budget: ${JSON.stringify(briefBudget)},
        // saveState : 'idle' | 'dirty' | 'saving' | 'saved' | 'error'.
        // Replaces the legacy 'saving' boolean : the UI used to flip from
        // "Saving..." straight back to "Auto-saved on edit" even when the
        // PUT failed silently (no try/catch, no status check), so users
        // got false-positive confirmation while their edits never reached
        // the DB. Tracking 5 explicit states + lastSaveError surfaces real
        // failure modes.
        saveState: 'idle',
        lastSaveError: '',
        _saveTimer: null,
        generating: ${briefStatus === 'pending' || briefStatus === 'running' ? 'true' : 'false'},
        async generateBrief() {
          if (!this.budget.can_regenerate) return;
          this.generating = true;
          const r = await fetch('/api/scans/${id}/generate-brief', { method: 'POST' });
          if (!r.ok && r.status === 429) {
            const body = await r.json().catch(() => ({}));
            const d = body.detail || body;
            this.budget = {
              generations_used: d.generations_used ?? this.budget.generations_used,
              generations_cap: d.cap ?? this.budget.generations_cap,
              can_regenerate: false,
            };
            this.generating = false;
            return;
          }
          const poll = setInterval(async () => {
            const res = await fetch('/api/scans/${id}/brief');
            if (res.ok) {
              const data = await res.json();
              if (data.domain_brief) {
                this.brief = data.domain_brief;
                this.budget = {
                  generations_used: data.generations_used ?? (this.budget.generations_used + 1),
                  generations_cap: data.generations_cap ?? this.budget.generations_cap,
                  can_regenerate: data.can_regenerate ?? (this.budget.generations_used + 1 < this.budget.generations_cap),
                };
                this.generating = false;
                clearInterval(poll);
              }
            }
          }, 2000);
        },
        // Debounced save : every keystroke marks dirty, then 700ms after
        // the last keystroke we PUT. Replaces blur-only save which never
        // fired when the user closed the <details> panel, reloaded, or
        // navigated away without first tabbing out of the field (observed
        // in prod : edited_by_user flag was NULL on a Ducray scan even
        // after the user reported editing fields).
        queueSave() {
          this.saveState = 'dirty';
          if (this._saveTimer) clearTimeout(this._saveTimer);
          this._saveTimer = setTimeout(() => this.saveBrief(), 700);
        },
        async saveBrief() {
          if (this._saveTimer) { clearTimeout(this._saveTimer); this._saveTimer = null; }
          this.saveState = 'saving';
          this.lastSaveError = '';
          try {
            const r = await fetch('/api/scans/${id}/brief', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ domain_brief: this.brief }),
            });
            if (!r.ok) {
              const body = await r.json().catch(() => ({}));
              this.lastSaveError = body.detail?.message || body.detail || ('HTTP ' + r.status);
              this.saveState = 'error';
              return;
            }
            this.saveState = 'saved';
          } catch (e) {
            this.lastSaveError = e.message || 'Network error';
            this.saveState = 'error';
          }
        }
      }`}>
        {/* Generating state */}
        <template x-if="generating">
          <div class="text-center py-8">
            <div class="inline-block w-6 h-6 border-2 border-coral border-t-transparent rounded-full animate-spin mb-3"></div>
            <p class="text-sm text-charcoal-light">Researching {scan.domain} via web search...</p>
            <p class="text-[10px] text-charcoal-light mt-1">This takes about 10 seconds</p>
          </div>
        </template>

        {/* No brief yet */}
        <template x-if="!generating && !brief.company">
          <div class="text-center py-6">
            <p class="text-sm text-charcoal-light mb-3">Generate a business brief to improve AI analysis quality</p>
            <button @click="generateBrief()" class="px-4 py-2 bg-coral text-white rounded-lg text-sm font-medium hover:bg-coral-dark transition-all">
              Generate Domain Brief
            </button>
            <p class="text-[10px] text-charcoal-light mt-2">Or fill in manually below</p>
          </div>
        </template>

        {/* Brief editor */}
        <template x-if="!generating && (brief.company || brief.description)">
          <div class="space-y-3">
            {/* Info banner: explain provenance + invite editing (Aesthetic-Usability + Doherty) */}
            <div class="flex items-start gap-2.5 px-3 py-2.5 rounded-lg bg-blue-50/60 border border-blue-100">
              <svg class="w-4 h-4 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
              <div class="text-xs text-blue-900 leading-relaxed">
                <p class="font-medium mb-0.5">Edit anything that's wrong or incomplete</p>
                <p class="text-blue-800">This brief was generated by an AI web search. It guides the next steps: topic classification, persona profiles, brand detection. The more accurate it is, the better the scan results.</p>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Company</label>
                <input type="text" x-model="brief.company" @input="queueSave()" @blur="saveBrief()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
              </div>
              <div>
                <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Industry</label>
                <input type="text" x-model="brief.industry" @input="queueSave()" @blur="saveBrief()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
              </div>
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Description</label>
              <textarea x-model="brief.description" @input="queueSave()" @blur="saveBrief()" rows="2" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral resize-y"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Own Brands (comma-separated)</label>
                <input type="text" :value="(brief.brands || []).join(', ')" @input="brief.brands = $event.target.value.split(',').map(s => s.trim()).filter(Boolean); queueSave()" @blur="saveBrief()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
              </div>
              <div>
                <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Product Lines (comma-separated)</label>
                <input type="text" :value="(brief.product_lines || []).join(', ')" @input="brief.product_lines = $event.target.value.split(',').map(s => s.trim()).filter(Boolean); queueSave()" @blur="saveBrief()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
              </div>
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Competitors (one per line: Name — Products)</label>
              <textarea x-effect="if (document.activeElement !== $el) $el.value = (brief.competitors || []).map(c => c.name + (c.products?.length ? ' — ' + c.products.join(', ') : '')).join('\n')"
                        @input="brief.competitors = $event.target.value.split('\n').map(line => { const parts = line.split(' — '); return { name: parts[0]?.trim(), products: parts[1] ? parts[1].split(',').map(s => s.trim()) : [] }; }).filter(c => c.name); queueSave()"
                        @blur="saveBrief()"
                        rows="4" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral resize-y font-mono text-xs">{(domainBrief?.competitors || []).map((c: any) => c.name + (c.products?.length ? ' — ' + c.products.join(', ') : '')).join('\n')}</textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Key Topics (comma-separated)</label>
                <input type="text" :value="(brief.topics || []).join(', ')" @input="brief.topics = $event.target.value.split(',').map(s => s.trim()).filter(Boolean); queueSave()" @blur="saveBrief()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
              </div>
              <div>
                <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Target Audience</label>
                <input type="text" x-model="brief.target_audience" @input="queueSave()" @blur="saveBrief()" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
              </div>
            </div>
            <div class="flex items-center justify-between pt-2">
              {/* Real save status — replaces the static "Auto-saved on edit"
                  label that always claimed success even on silent failure. */}
              <span class="text-[10px]" :class="{
                'text-charcoal-light': saveState === 'idle' || saveState === 'dirty',
                'text-charcoal-light animate-pulse': saveState === 'saving',
                'text-emerald-600': saveState === 'saved',
                'text-red-600 font-medium': saveState === 'error',
              }" :title="saveState === 'error' ? lastSaveError : ''">
                <span x-show="saveState === 'idle'">Auto-saved on edit</span>
                <span x-show="saveState === 'dirty'">Unsaved changes…</span>
                <span x-show="saveState === 'saving'">Saving…</span>
                <span x-show="saveState === 'saved'">✓ Saved</span>
                <span x-show="saveState === 'error'" x-text="'⚠ Save failed: ' + lastSaveError"></span>
              </span>
              <span class="flex items-center gap-2">
                {/* Regen budget counter (Tesler's). Same pattern as workspace
                     brief + FAQ rematch — surface budget BEFORE cap fires. */}
                <template x-if="budget.generations_used > 0">
                  <span class="text-[10px] tabular-nums"
                        :class="!budget.can_regenerate ? 'text-red-600 font-medium' : (budget.generations_cap - budget.generations_used <= 2 ? 'text-amber-700' : 'text-charcoal-light')"
                        :title="budget.generations_used + ' regenerations used out of ' + budget.generations_cap"
                        x-text="budget.generations_used + '/' + budget.generations_cap"></span>
                </template>
                <button @click="generateBrief()"
                        :disabled="!budget.can_regenerate || generating"
                        :class="(!budget.can_regenerate || generating) ? 'text-gray-400 cursor-not-allowed' : 'text-charcoal-light hover:text-coral transition-colors'"
                        class="text-[10px]"
                        :title="!budget.can_regenerate ? 'Regen cap reached — edit the brief manually above' : 'Regenerate this scan\\'s brief from web search (~10s, capped at ' + budget.generations_cap + ' per scan)'"
                        x-text="budget.can_regenerate ? 'Regenerate from web' : 'Cap reached — edit manually'"></button>
                <span class="text-[10px] text-charcoal-light cursor-help select-none"
                      :title="'This scan\\'s brief feeds AI analysis (topic classification, persona generation, brand detection). Regeneration capped at ' + budget.generations_cap + ' per scan to bound LLM cost. Edit fields above anytime — your edits are saved on blur.'">ⓘ</span>
              </span>
            </div>
          </div>
        </template>
      </div>
    </details>

    {isReviewing && scan.status !== 'completed' && (
      <div class="mb-6 bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 flex items-start gap-3">
        <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <div class="flex-1">
          <p class="text-sm font-medium text-blue-900">You're reviewing a previous step</p>
          <p class="text-xs text-blue-700 mt-0.5">This step was already validated. Use the stepper to navigate back to your current progress.</p>
        </div>
        <a href={`/app/scans/${id}`} class="text-xs font-medium text-blue-700 hover:text-blue-900 shrink-0 underline">Back to current step →</a>
      </div>
    )}

    {isReviewing && scan.status === 'completed' && (
      <div class="mb-6 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <div class="flex-1">
          <p class="text-sm font-medium text-amber-900">You're editing a completed scan</p>
          <p class="text-xs text-amber-800 mt-0.5">Changes to setup (brands, focus, topics, personas) are saved immediately, but the results below reflect the scan that already ran. To get fresh metrics under the new setup, run a rescan.</p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <a href={`/app/scans/${id}/results`} class="text-xs font-medium text-amber-700 hover:text-amber-900 underline whitespace-nowrap">View results</a>
          <button type="button"
                  onclick={`if(confirm('Start a new rescan of this tracker?')){fetch('/api/scans/${id}/rescan',{method:'POST'}).then(r=>r.ok?location.href='/app/scans':alert('Rescan failed'))}`}
                  class="text-xs font-medium px-3 py-1.5 bg-amber-500 text-white rounded-lg hover:bg-amber-600 transition-colors whitespace-nowrap">
            Rescan now →
          </button>
        </div>
      </div>
    )}

    <!-- Processing states — integrated into Topics section context (no separate "Processing" step) -->
    {!effectiveView && ['fetching_keywords', 'keywords_fetched', 'assigning_keywords', 'generating_personas'].includes(scan.status) && (
      <div>
        <h2 class="text-xl font-bold text-charcoal-dark mb-1">Analyzing <span class="text-coral">{scan.domain}</span></h2>
        {scan.status !== 'completed' && (
          <button
            type="button"
            onclick={`if(confirm('Delete this scan and start over with a different domain?')){fetch('/api/scans/${id}',{method:'DELETE'}).then(r=>r.ok?location.href='/app/scans/new':alert('Delete failed'))}`}
            class="text-[11px] text-charcoal-light/50 hover:text-coral transition-colors mb-4 inline-block"
          >Wrong domain? Start over</button>
        )}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 text-center">
          <svg class="w-12 h-12 mx-auto animate-spin text-coral/20 mb-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          {['fetching_keywords', 'keywords_fetched'].includes(scan.status) ? (
            <Fragment>
              <p class="text-charcoal-dark font-medium mb-1">{scan.progress_message || 'Fetching keyword data...'}</p>
              <p class="text-sm text-charcoal-light mb-6">This usually takes 1-2 minutes. You can leave this page.</p>
              {(() => {
                const s = scan.status;
                // Step 1 done as soon as fetch_keywords completes (status moved past fetching_keywords)
                const step1State = s !== 'fetching_keywords' ? 'done' : 'in_progress';
                // Step 2 (classify_topics) actively runs while status == 'keywords_fetched';
                // status flips to 'topics_ready' at completion, at which point this UI vanishes
                const step2State = s === 'keywords_fetched' ? 'in_progress' : 'pending';
                // Step 3 (detect_competitors + cleanup_brands) is chained AFTER classify_topics
                // and runs in the background while user reviews topics — never reaches in_progress
                // within this 3-step UI's visibility window. Stays pending as a "what's next" cue.
                const step3State = 'pending';

                const labelClass = (state: string) =>
                  state === 'done' ? 'text-emerald-700' :
                  state === 'in_progress' ? 'text-charcoal-dark font-medium' :
                  'text-charcoal-light';

                const renderStep = (state: string, label: string) => (
                  <div class:list={['flex items-center gap-3 text-sm', labelClass(state)]}>
                    {state === 'done' && (
                      <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                    )}
                    {state === 'in_progress' && (
                      <svg class="w-4 h-4 text-amber-500 animate-spin shrink-0" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                      </svg>
                    )}
                    {state === 'pending' && (
                      <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="9" stroke-dasharray="3 3"/>
                      </svg>
                    )}
                    <span>{label}</span>
                  </div>
                );

                return (
                  <div class="space-y-3 text-left max-w-xs mx-auto">
                    {renderStep(step1State, 'Fetching keywords from HaloScan')}
                    {renderStep(step2State, 'Classifying pages into topics')}
                    {renderStep(step3State, 'Detecting brands & competitors')}
                  </div>
                );
              })()}
            </Fragment>
          ) : (
            <Fragment>
              <p class="text-charcoal-dark font-medium mb-1">{scan.progress_message || 'Processing...'}</p>
              <p class="text-sm text-charcoal-light">This usually takes 30 seconds. You can leave this page.</p>
            </Fragment>
          )}
          <meta http-equiv="refresh" content="3" />
        </div>
      </div>
    )}

    <!-- Topics ready (Gate 1) — or reviewing topics via ?view=topics -->
    {(effectiveView === 'topics' || (!effectiveView && scan.status === 'topics_ready')) && topics.length > 0 && (
      <div x-data={`topicsWizard(${JSON.stringify(topics.map(t => ({
          id: t.id, name: t.name, description: t.description,
          keyword_count: t.keyword_count, active: t.is_active,
          top_keywords: t.top_keywords || [], top_urls: t.top_urls || [],
          total_urls: t.total_urls || 0, editing: false,
          allUrls: null, allKeywords: null
        })))}, '${id}')`}>
        <h2 class="text-xl font-bold text-charcoal-dark mb-1">Topics found on <span class="text-coral">{scan.domain}</span></h2>
        {scan.status !== 'completed' && (
          <button
            type="button"
            onclick={`if(confirm('Delete this scan and start over with a different domain?')){fetch('/api/scans/${id}',{method:'DELETE'}).then(r=>r.ok?location.href='/app/scans/new':alert('Delete failed'))}`}
            class="text-[11px] text-charcoal-light/50 hover:text-coral transition-colors mb-4 inline-block"
          >Wrong domain? Start over</button>
        )}
        <p class="text-charcoal-light mb-2">We grouped your keywords into themes. Each topic will get its own AI visibility analysis with tailored personas and questions.</p>
        <p class="text-sm text-charcoal-light mb-6"><span class="font-medium text-charcoal-dark">Review and fix misclassifications</span> before we generate personas. Toggle off topics you don't need.</p>

        <div class="space-y-2 mb-6">
          <template x-for="(topic, idx) in topics" :key="topic.id">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 transition-all"
                 :class="!topic.active ? 'opacity-50' : ''">

              <!-- Header (always visible) -->
              <div class="flex items-center gap-4 px-5 py-3.5 cursor-pointer hover:bg-gray-50 transition-colors"
                   @click="expanded = expanded === idx ? null : idx">
                <!-- Toggle -->
                <button @click.stop="toggleTopic(topic)"
                  :class="topic.active ? 'bg-coral' : 'bg-gray-300'"
                  class="relative w-10 h-6 rounded-full transition-colors shrink-0">
                  <span :class="topic.active ? 'translate-x-4' : 'translate-x-0'"
                    class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow transition-transform"></span>
                </button>

                <!-- Name + description -->
                <div class="flex-1 min-w-0">
                  <template x-if="!topic.editing">
                    <div class="group/name">
                      <div class="flex items-center gap-1.5">
                        <p class="text-sm font-medium text-charcoal-dark" x-text="topic.name"></p>
                        <button @click.stop="topic.editing = true" class="text-gray-300 hover:text-coral opacity-0 group-hover/name:opacity-100 transition-opacity">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                        </button>
                      </div>
                      <p class="text-xs text-charcoal-light" x-text="topic.description || topic.keyword_count + ' keywords'"></p>
                    </div>
                  </template>
                  <template x-if="topic.editing">
                    <input type="text" x-model="topic.name" @click.stop x-ref="editInput"
                           @keydown.enter="$event.target.blur()"
                           @keydown.escape="topic.editing = false"
                           @blur="topic.editing = false; const _n=(topic.name||'').trim(); if(!_n){alert('Topic name cannot be empty.');return;} topic.name=_n; fetch('/api/scans/' + scanId + '/topics/' + topic.id, {method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({name:_n})}).then(r => { if (!r.ok) r.text().then(t => alert('Rename failed: ' + r.status + ' ' + t)); }).catch(e => alert('Rename failed: ' + e.message))"
                           class="text-sm font-medium px-2 py-1 border border-coral rounded w-full" />
                  </template>
                </div>

                <!-- Stats -->
                <div class="text-right shrink-0">
                  <p class="text-xs font-medium text-charcoal-dark" x-text="topic.keyword_count + ' keywords'"></p>
                  <p class="text-[10px] text-charcoal-light" x-text="topic.total_urls + ' pages'"></p>
                </div>

                <!-- Expand arrow -->
                <svg class="w-4 h-4 text-gray-400 transition-transform shrink-0" :class="expanded === idx ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>

              <!-- Expanded content (Progressive Disclosure) -->
              <div x-show="expanded === idx" x-transition class="border-t border-gray-100 px-5 py-4"
                   x-data="{ showPages: false, showKeywords: false, pageSort: '', pageSortDir: 1, pageSearch: '', kwSort: '', kwSortDir: 1, kwSearch: '',
                     sortPages(arr) {
                       let filtered = this.pageSearch ? arr.filter(p => (typeof p === 'string' ? p : p.url).toLowerCase().includes(this.pageSearch.toLowerCase())) : arr;
                       if (!this.pageSort) return filtered;
                       return [...filtered].sort((a, b) => ((typeof a === 'object' ? a[this.pageSort] : 0) - (typeof b === 'object' ? b[this.pageSort] : 0)) * this.pageSortDir);
                     },
                     sortKw(arr) {
                       let filtered = this.kwSearch ? arr.filter(k => k.keyword.toLowerCase().includes(this.kwSearch.toLowerCase())) : arr;
                       if (!this.kwSort) return filtered;
                       return [...filtered].sort((a, b) => ((a[this.kwSort] || 0) - (b[this.kwSort] || 0)) * this.kwSortDir);
                     },
                     sortPageKw(arr) {
                       if (!arr || !this.pageSort) return arr;
                       const map = { search_volume: 'volume', avg_position: 'position', traffic: 'traffic' };
                       const k = map[this.pageSort];
                       if (!k) return arr;
                       return [...arr].sort((a, b) => ((a[k] || 0) - (b[k] || 0)) * this.pageSortDir);
                     },
                     toggleSort(type, col) {
                       if (type === 'page') { if (this.pageSort === col) { this.pageSortDir *= -1; } else { this.pageSort = col; this.pageSortDir = -1; } }
                       else { if (this.kwSort === col) { this.kwSortDir *= -1; } else { this.kwSort = col; this.kwSortDir = -1; } }
                     }
                   }">

                <!-- SECTION 1: Keywords used for personas (primary — drives downstream pipeline) -->
                <div class="mb-4">
                  <button @click.stop="showKeywords = !showKeywords" class="flex items-center gap-2 text-sm text-charcoal-dark hover:text-coral transition-colors mb-3 font-medium">
                    <svg class="w-3.5 h-3.5 transition-transform" :class="showKeywords ? 'rotate-90' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span x-text="'Keywords used for personas (' + topic.keyword_count + ')'"></span>
                  </button>

                  <div x-show="showKeywords" x-transition class="mt-2">
                    <!-- Search -->
                    <div class="mb-2">
                      <div class="relative" style="max-width:250px;">
                        <svg class="w-3.5 h-3.5 absolute left-2 top-1/2 -translate-y-1/2 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <input type="text" x-model="kwSearch" placeholder="Filter keywords..." class="w-full pl-7 pr-3 py-1 text-[11px] border border-gray-200 rounded focus:outline-none focus:border-coral/50" />
                      </div>
                    </div>
                    <!-- Column headers (sortable, aligned with Pages) -->
                    <div class="flex items-center gap-2 mb-1.5 text-[10px] text-charcoal-light font-medium select-none" style="padding-right: 15px;">
                      <span class="flex-1">Keyword</span>
                      <span class="w-12 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('kw','pages_count')">
                        Pages <span x-show="kwSort==='pages_count'" x-text="kwSortDir===1?'▲':'▼'" class="text-coral"></span>
                      </span>
                      <span class="w-16 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('kw','volume')">
                        # Searches <span x-show="kwSort==='volume'" x-text="kwSortDir===1?'▲':'▼'" class="text-coral"></span>
                      </span>
                      <span class="w-14 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('kw','traffic')">
                        Traffic <span x-show="kwSort==='traffic'" x-text="kwSortDir===1?'▲':'▼'" class="text-coral"></span>
                      </span>
                      <span class="w-12 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('kw','position')">
                        Position <span x-show="kwSort==='position'" x-text="kwSortDir===1?'▲':'▼'" class="text-coral"></span>
                      </span>
                      <span class="w-14"></span>
                    </div>
                    <div class="space-y-0.5 max-h-96 overflow-y-auto" style="scrollbar-gutter: stable;">
                      <template x-for="(kw, ki) in sortKw(topic.top_keywords)" :key="ki">
                        <div class="group/kw flex items-center gap-2 text-xs py-0.5 hover:bg-gray-50 rounded px-1 -mx-1 relative min-w-0">
                          <span class="text-charcoal-dark truncate flex-1 min-w-0" x-text="kw.keyword"></span>
                          <span class="text-[10px] w-12 text-right shrink-0" :class="(kw.pages_count || 0) > 1 ? 'text-coral font-medium' : 'text-charcoal-light'" x-text="kw.pages_count || '—'"></span>
                          <span class="text-charcoal-dark text-[10px] w-16 text-right shrink-0" x-text="kw.volume ? kw.volume.toLocaleString() : '—'"></span>
                          <span class="text-charcoal-dark text-[10px] w-14 text-right shrink-0" x-text="kw.traffic ? kw.traffic.toLocaleString() : '—'"></span>
                          <span class="text-charcoal-dark text-[10px] w-12 text-right shrink-0" x-text="kw.position || '—'"></span>
                          <div class="w-14 text-right shrink-0">
                            <button @click.stop="openMove('keyword', kw, topic)"
                                    class="text-[10px] text-charcoal-light hover:text-coral opacity-0 group-hover/kw:opacity-100 transition-opacity px-1">
                              Move →
                            </button>
                          </div>
                        </div>
                      </template>
                    </div>
                    <button x-show="topic.keyword_count > 5 && !topic.allKeywords"
                            @click.stop={`fetch('/api/scans/${id}/topics/' + topic.id + '/keywords?limit=500').then(r=>r.json()).then(data => { topic.allKeywords = data.keywords; topic.top_keywords = data.keywords; }).catch(e => console.error('Load keywords failed:', e))`}
                            class="text-[10px] text-coral hover:underline cursor-pointer mt-1"
                            x-text="'+ ' + (topic.keyword_count - topic.top_keywords.length) + ' more keywords'">
                    </button>
                    <button x-show="topic.allKeywords"
                            @click.stop="topic.top_keywords = topic.allKeywords.slice(0, 5); topic.allKeywords = null;"
                            class="text-[10px] text-charcoal-light hover:text-coral hover:underline cursor-pointer mt-1 transition-colors">
                      Show less
                    </button>
                  </div>
                </div>

                <!-- SECTION 2: Pages ranking for these keywords (drill-down / secondary) -->
                <div>
                  <button @click.stop="showPages = !showPages" class="flex items-center gap-2 text-sm text-charcoal-dark hover:text-coral transition-colors mb-3 font-medium">
                    <svg class="w-3.5 h-3.5 transition-transform" :class="showPages ? 'rotate-90' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span x-text="'Pages ranking for these keywords (' + topic.total_urls + ')'"></span>
                  </button>

                  <div x-show="showPages" x-transition>
                  <!-- Search input -->
                  <div class="flex items-center gap-2 mb-2">
                    <div class="relative flex-1">
                      <svg class="w-3.5 h-3.5 absolute left-2 top-1/2 -translate-y-1/2 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                      <input type="text" x-model="pageSearch" placeholder="Filter pages..." class="w-full pl-7 pr-3 py-1 text-[11px] border border-gray-200 rounded focus:outline-none focus:border-coral/50" />
                    </div>
                  </div>

                  <!-- Column headers (sortable) -->
                  <div class="flex items-center gap-2 mb-2 text-[10px] text-charcoal-light font-medium select-none" style="padding-right: 15px;">
                    <span class="flex-1"><Tip id="pages" position="bottom">Pages</Tip></span>
                    <span class="w-12 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('page','keywords_count')">
                      Keywords <span x-show="pageSort==='keywords_count'" x-text="pageSortDir===1?'▲':'▼'" class="text-coral"></span>
                    </span>
                    <span class="w-16 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('page','search_volume')">
                      # Searches <span x-show="pageSort==='search_volume'" x-text="pageSortDir===1?'▲':'▼'" class="text-coral"></span>
                    </span>
                    <span class="w-14 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('page','traffic')">
                      Traffic <span x-show="pageSort==='traffic'" x-text="pageSortDir===1?'▲':'▼'" class="text-coral"></span>
                    </span>
                    <span class="w-12 text-right cursor-pointer hover:text-charcoal-dark" @click="toggleSort('page','avg_position')">
                      Position <span x-show="pageSort==='avg_position'" x-text="pageSortDir===1?'▲':'▼'" class="text-coral"></span>
                    </span>
                    <span class="w-14"></span>
                  </div>

                  <div class="space-y-0 max-h-64 overflow-y-auto overflow-x-hidden" style="scrollbar-gutter: stable;">
                    <template x-for="page in sortPages(topic.allUrls || topic.top_urls)" :key="typeof page === 'string' ? page : page.url">
                      <div>
                        <!-- Page row (columns aligned with headers) -->
                        <div class="group/url flex items-center gap-2 py-1.5 hover:bg-gray-50 rounded px-1 -mx-1 relative min-w-0">
                          <!-- Short path -->
                          <a :href="typeof page === 'string' ? page : page.url" target="_blank" rel="noopener"
                             class="text-xs text-blue-600 hover:text-blue-800 hover:underline truncate flex-1 min-w-0 transition-colors"
                             x-text="(() => { const u = typeof page === 'string' ? page : page.url; try { return new URL(u.startsWith('http') ? u : 'https://' + u).pathname; } catch { return u; } })()"></a>

                          <!-- Keywords count (clickable with ▶) -->
                          <button @click.stop="page._expanded = !page._expanded"
                                  x-show="typeof page === 'object' && page.keywords_count"
                                  class="text-[10px] text-coral hover:underline w-12 text-right shrink-0 cursor-pointer flex items-center justify-end gap-0.5">
                            <svg class="w-2.5 h-2.5 transition-transform" :class="page._expanded ? 'rotate-90' : ''" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            <span x-text="page.keywords_count"></span>
                          </button>

                          <!-- Search Volume (sum) -->
                          <span class="text-[10px] text-charcoal-dark w-16 text-right shrink-0"
                                x-text="typeof page === 'object' && page.search_volume ? page.search_volume.toLocaleString() : '—'"></span>

                          <!-- Traffic (sum) -->
                          <span class="text-[10px] text-charcoal-dark w-14 text-right shrink-0"
                                x-text="typeof page === 'object' && page.traffic ? page.traffic.toLocaleString() : '—'"></span>

                          <!-- Avg Position -->
                          <span class="text-[10px] w-12 text-right shrink-0 text-charcoal-dark"
                                x-text="typeof page === 'object' && page.avg_position ? page.avg_position : '—'"></span>

                          <!-- Move button -->
                          <div class="w-14 text-right shrink-0">
                            <button @click.stop="openMove('page', page, topic)"
                                    class="text-[10px] text-charcoal-light hover:text-coral opacity-0 group-hover/url:opacity-100 transition-opacity px-1">
                              Move →
                            </button>
                          </div>
                        </div>

                        <!-- Keywords for this page — SAME columns as parent, no extra headers -->
                        <div x-show="page._expanded" x-transition class="mb-1">
                          <template x-for="kw in sortPageKw(page.top_keywords || [])" :key="kw.keyword">
                            <div class="flex items-center gap-2 text-[11px] py-0.5 pl-6 text-charcoal-light">
                              <span class="truncate flex-1" x-text="kw.keyword"></span>
                              <span class="w-12 text-right"></span>
                              <span class="w-16 text-right" x-text="kw.volume ? kw.volume.toLocaleString() : '—'"></span>
                              <span class="w-14 text-right" x-text="kw.traffic ? kw.traffic.toLocaleString() : '—'"></span>
                              <span class="w-12 text-right" x-text="kw.position || '—'"></span>
                              <span class="w-14"></span>
                            </div>
                          </template>
                        </div>
                      </div>
                    </template>
                  </div>
                  <button x-show="topic.total_urls > 5 && !topic.allUrls"
                          @click.stop={`fetch('/api/scans/${id}/topics/' + topic.id + '/urls').then(r=>r.json()).then(data => { topic.allUrls = data.urls; topic.top_urls = data.urls; })`}
                          class="text-[10px] text-coral hover:underline cursor-pointer mt-1"
                          x-text="'+ ' + (topic.total_urls - 5) + ' more pages'">
                  </button>
                  <button x-show="topic.allUrls"
                          @click.stop="topic.top_urls = topic.allUrls.slice(0, 5); topic.allUrls = null;"
                          class="text-[10px] text-charcoal-light hover:text-coral hover:underline cursor-pointer mt-1 transition-colors">
                    Show less
                  </button>
                </div>
                </div>

              </div>
            </div>
          </template>
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-between">
          <p class="text-sm text-charcoal-light">
            <span x-text="topics.filter(t => t.active).length" class="font-medium text-charcoal-dark"></span> topics selected
          </p>
          {isReviewing ? (
            <a href={`/app/scans/${id}?view=brands`} class="px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all flex items-center gap-2">
              Continue to Brands
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          ) : (
            <button
              @click="validateTopics()"
              class="px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all flex items-center gap-2"
            >
              Continue to Brands
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
          )}
        </div>

        <!-- Move Modal (shared for page + keyword moves) -->
        <div x-show="moveModal.open"
             x-transition.opacity
             @keydown.escape.window="closeMove()"
             style="display:none;"
             class="fixed inset-0 z-[100] flex items-start justify-center pt-24 px-4">
          <div @click="closeMove()" class="absolute inset-0 bg-charcoal-dark/40 backdrop-blur-sm"></div>
          <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg max-h-[70vh] flex flex-col overflow-hidden">
            <!-- Header -->
            <div class="px-5 py-4 border-b border-gray-100">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <p class="text-[10px] text-charcoal-light uppercase tracking-wide font-medium mb-0.5">
                    Move <span x-text="moveModal.type === 'keyword' ? 'keyword' : 'page'"></span> from <span class="text-charcoal-dark font-semibold" x-text="moveModal.sourceTopic ? moveModal.sourceTopic.name : ''"></span>
                  </p>
                  <h3 class="text-base font-semibold text-charcoal-dark truncate" x-text="moveModal.type === 'keyword' ? (moveModal.item ? moveModal.item.keyword : '') : (moveModal.item ? moveMdlPath(moveModal.item) : '')"></h3>
                  <p class="text-xs text-charcoal-light mt-1" x-text="moveModal.open ? moveMdlMeta() : ''"></p>
                </div>
                <button @click="closeMove()" class="text-charcoal-light hover:text-charcoal-dark text-2xl leading-none px-1 -mt-1">&times;</button>
              </div>
            </div>
            <!-- Search -->
            <div class="px-5 py-3 border-b border-gray-100">
              <div class="relative">
                <svg class="w-4 h-4 absolute left-2.5 top-1/2 -translate-y-1/2 text-charcoal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text"
                       x-ref="moveSearch"
                       x-model="moveModal.search"
                       @keydown.arrow-down.prevent="moveModal.selectedIdx = Math.min(moveModal.selectedIdx + 1, moveFilteredTopics().length - 1)"
                       @keydown.arrow-up.prevent="moveModal.selectedIdx = Math.max(moveModal.selectedIdx - 1, 0)"
                       @keydown.enter.prevent="(() => { const t = moveFilteredTopics()[moveModal.selectedIdx]; if(t) executeMove(t); })()"
                       placeholder="Search topics..."
                       class="w-full pl-8 pr-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:border-coral focus:ring-2 focus:ring-coral/20 transition-all" />
              </div>
            </div>
            <!-- Topic list -->
            <div class="overflow-y-auto flex-1" style="scrollbar-gutter: stable;">
              <template x-for="(t, idx) in moveFilteredTopics()" :key="t.id">
                <button @click="executeMove(t)"
                        @mouseenter="moveModal.selectedIdx = idx"
                        :class="idx === moveModal.selectedIdx ? 'bg-coral/10 border-l-2 border-coral' : 'border-l-2 border-transparent'"
                        class="w-full px-5 py-3 flex items-center justify-between gap-3 text-left hover:bg-gray-50 transition-colors">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-charcoal-dark truncate" x-text="t.name"></p>
                    <p class="text-xs text-charcoal-light truncate mt-0.5" x-text="t.description || ''"></p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-xs font-medium text-charcoal-dark" x-text="t.keyword_count + ' keywords'"></p>
                    <p class="text-[10px] text-charcoal-light" x-text="t.total_urls + ' pages'"></p>
                  </div>
                </button>
              </template>
              <div x-show="moveFilteredTopics().length === 0" class="px-5 py-10 text-center text-sm text-charcoal-light">
                No matching topics
              </div>
            </div>
            <!-- Footer hints -->
            <div class="px-5 py-2.5 border-t border-gray-100 bg-gray-50 text-[10px] text-charcoal-light flex items-center gap-4">
              <span><kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded text-charcoal-dark">↑↓</kbd> Navigate</span>
              <span><kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded text-charcoal-dark">⏎</kbd> Move</span>
              <span><kbd class="px-1.5 py-0.5 bg-white border border-gray-200 rounded text-charcoal-dark">Esc</kbd> Cancel</span>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Brands ready (Gate 2) — or reviewing brands via ?view=brands -->
    {(effectiveView === 'brands' || (!effectiveView && scan.status === 'brands_ready')) && brandsData && (
      <div x-data={`scanBrands(${JSON.stringify(brandsData)}, '${id}')`}>
        <h2 class="text-xl font-bold text-charcoal-dark mb-2">Classify brands for <span class="text-coral">{brandsData.scan_domain}</span></h2>
        <p class="text-charcoal-light mb-2">We detected brands from your keywords and SEO competitors. Classify each so we know which brands to track in the AI scan.</p>
        <p class="text-sm text-charcoal-light mb-6"><span class="font-medium text-charcoal-dark">Pick ONE focus brand</span> — it's the single brand whose visibility we'll measure. Add competitors to the right; anything irrelevant can be dragged into <em>Ignored</em> (collapsed strip at the bottom — items there stay silenced across rescans).</p>

        <!-- Focus brand missing banner -->
        <div x-show="!hasFocus" class="mb-6 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 flex items-start gap-3">
          <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <div class="flex-1">
            <p class="text-sm font-medium text-amber-900">No focus brand selected yet</p>
            <p class="text-xs text-amber-800 mt-0.5">In the <span class="font-medium">My Brands</span> column, click the star (☆) next to one brand to make it the focus. This is the single brand whose AI visibility we'll measure.</p>
          </div>
        </div>

        <!-- Unclassified inbox — collapsible to keep the page scannable post-scan.
             Default collapsed: most auto-detected brands are noise (the LLM
             over-extracts brand-like strings during run_llm_tests). Progressive
             disclosure + a one-click bulk-ignore covers the 80% case. -->
        <template x-if="flatUnclassified.length > 0">
          <div class="bg-amber-50 border border-amber-200 rounded-xl mb-6"
               @dragover.prevent="dragOver = 'unclassified'"
               @dragleave="dragOver = null"
               @drop.prevent="onDrop('unclassified')"
               :class="dragOver === 'unclassified' ? 'ring-2 ring-amber-400' : ''"
               x-data="{ inboxExpanded: false }">
            <!-- Header row: count + actions + chevron. Click toggles expand. -->
            <div class="flex items-center gap-3 px-5 py-3 cursor-pointer hover:bg-amber-100/30 rounded-xl transition-colors"
                 @click="inboxExpanded = !inboxExpanded">
              <svg class="w-4 h-4 text-amber-700 shrink-0 transition-transform"
                   :class="inboxExpanded ? 'rotate-90' : ''"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-amber-800">
                  <span x-text="flatUnclassified.length"></span> new brands detected
                  <template x-if="discoveredCount > 0">
                    <span class="text-[11px] font-normal text-amber-700 ml-1">
                      (<span x-text="discoveredCount"></span> 🔍 discovered)
                    </span>
                  </template>
                </p>
                <p class="text-[11px] text-amber-700/80">
                  Auto-extracted from AI responses. <strong>🔍 Discovered</strong> = commercial brand outside your watchlist — promote to track, or ignore.
                </p>
              </div>
              <template x-if="discoveredCount > 0">
                <button @click.stop="promoteAllDiscovered()"
                        :disabled="promotingDiscovered"
                        class="shrink-0 text-xs px-3 py-1.5 rounded-md border border-red-300 bg-white text-red-700 hover:bg-red-50 hover:border-red-400 transition-colors disabled:opacity-50 disabled:cursor-wait font-medium">
                  <span x-show="!promotingDiscovered">Promote all 🔍 to Competitors</span>
                  <span x-show="promotingDiscovered">Promoting…</span>
                </button>
              </template>
              <button @click.stop="bulkIgnoreUnclassified()"
                      :disabled="bulkIgnoringUnclassified"
                      class="shrink-0 text-xs px-3 py-1.5 rounded-md border border-amber-300 bg-white text-amber-800 hover:bg-amber-50 hover:border-amber-400 transition-colors disabled:opacity-50 disabled:cursor-wait font-medium">
                <span x-show="!bulkIgnoringUnclassified">Mark all as ignored</span>
                <span x-show="bulkIgnoringUnclassified">Ignoring…</span>
              </button>
            </div>
            <!-- Triage view (collapsed by default). Auto-groups discovered
                 brands by name-prefix so "Bondi Sands" parents the long
                 "Bondi Sands Technocolor Caramel Sérum Autobronzant Visage"
                 pill — visually halves the cognitive load. Per-row actions
                 replace the drag-only model: ✓ Track / ✗ Ignore in one click
                 (single item) or per-family for the grouped clusters. -->
            <div x-show="inboxExpanded" x-transition class="border-t border-amber-200 px-5 py-4">
              <!-- Search filter — Hick's Law: cut the visible set when the
                   inbox is long. Lowercase substring match on name. -->
              <div class="flex items-center gap-2 mb-4">
                <svg class="w-4 h-4 text-amber-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text" x-model="inboxFilter" placeholder="Filter discovered brands by name…"
                       class="flex-1 text-sm bg-white border border-amber-200 rounded-md px-3 py-1.5 outline-none focus:border-amber-400 placeholder-amber-500/60" />
                <template x-if="inboxFilter">
                  <button @click="inboxFilter = ''" class="text-xs text-amber-700 hover:text-amber-900 px-2">Clear</button>
                </template>
                <span class="text-[11px] text-amber-700/80" x-text="discoveredGrouped.length + ' famil' + (discoveredGrouped.length > 1 ? 'ies' : 'y')"></span>
              </div>

              <!-- Grouped rows. Each parent gets family-level actions. Children
                   inherit visual nesting + per-item actions. -->
              <div class="space-y-1.5">
                <template x-for="family in discoveredGrouped" :key="family.parent.brand_id">
                  <div>
                    <!-- Parent row -->
                    <div class="group/row flex items-center gap-2 py-1.5 px-2 -mx-2 rounded hover:bg-amber-100/40 transition-colors">
                      <span class="text-[10px] shrink-0" :title="family.parent.source === 'auto_discovered' ? 'Discovered commercial brand' : 'Auto-detected'">
                        <span x-show="family.parent.source === 'auto_discovered'">🔍</span>
                        <span x-show="family.parent.source !== 'auto_discovered'" class="text-amber-400">•</span>
                      </span>
                      <span draggable="true"
                            @dragstart="onDragStart($event, family.parent, 'unclassified')"
                            class="flex-1 min-w-0 text-sm text-charcoal-dark truncate cursor-move"
                            x-text="family.parent.name"></span>
                      <template x-if="family.children.length > 0">
                        <span class="shrink-0 text-[10px] text-amber-700 bg-amber-100 px-1.5 py-0.5 rounded-full" x-text="'+' + family.children.length"></span>
                      </template>
                      <button @click="promoteFamily(family)"
                              :title="family.children.length > 0 ? 'Track this brand + ' + family.children.length + ' product line(s)' : 'Track as competitor'"
                              class="shrink-0 text-[11px] px-2 py-1 rounded border border-red-200 text-red-700 bg-white hover:bg-red-50 hover:border-red-400 opacity-0 group-hover/row:opacity-100 transition-opacity font-medium">
                        ✓ <span x-text="family.children.length > 0 ? 'Track family' : 'Track'"></span>
                      </button>
                      <button @click="ignoreFamily(family)"
                              :title="family.children.length > 0 ? 'Ignore this brand + ' + family.children.length + ' product line(s)' : 'Ignore'"
                              class="shrink-0 text-[11px] px-2 py-1 rounded border border-gray-200 text-charcoal-light bg-white hover:bg-gray-50 opacity-0 group-hover/row:opacity-100 transition-opacity">
                        ✗ Ignore
                      </button>
                    </div>
                    <!-- Children (gammes / variants) -->
                    <template x-if="family.children.length > 0">
                      <div class="ml-6 border-l-2 border-amber-200 pl-3 space-y-1 mt-0.5 mb-1">
                        <template x-for="child in family.children" :key="child.brand_id">
                          <div class="group/child flex items-center gap-2 py-1 px-2 -mx-2 rounded hover:bg-amber-100/30 transition-colors">
                            <span class="shrink-0 text-[10px] text-amber-600">↳</span>
                            <span draggable="true"
                                  @dragstart="onDragStart($event, child, 'unclassified')"
                                  class="flex-1 min-w-0 text-xs text-charcoal-light truncate cursor-move"
                                  x-text="child.name"></span>
                            <button @click="promoteOne(child)"
                                    title="Track this product line as competitor"
                                    class="shrink-0 text-[10px] px-1.5 py-0.5 rounded border border-red-200 text-red-700 bg-white hover:bg-red-50 opacity-0 group-hover/child:opacity-100 transition-opacity">
                              ✓ Track
                            </button>
                            <button @click="ignoreOne(child)"
                                    title="Ignore"
                                    class="shrink-0 text-[10px] px-1.5 py-0.5 rounded border border-gray-200 text-charcoal-light bg-white hover:bg-gray-50 opacity-0 group-hover/child:opacity-100 transition-opacity">
                              ✗
                            </button>
                          </div>
                        </template>
                      </div>
                    </template>
                  </div>
                </template>
                <template x-if="discoveredGrouped.length === 0">
                  <p class="text-xs text-amber-700/70 italic text-center py-4">No matches for that filter.</p>
                </template>
              </div>

              <p class="text-[10px] text-amber-700/60 mt-4 text-center">
                Hover any row to reveal actions · drag pill text into a bucket below for fine control
              </p>
            </div>
          </div>
        </template>

        <!-- 2 main columns + Ignored as a collapsed footer strip below.
             Rationale (Law of UX): Ignored is "trash" — past decisions, not
             active triage. Equal-weight 3-column grid signalled "all three
             matter equally" which over-indexed Ignored visually. Now My
             Brands + Competitors get 50% width each (cleaner scan), Ignored
             becomes a Gmail-Spam-folder-style strip the user expands only
             when they need to surface a buried item. -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-3">

          <!-- My Brands column (hierarchical: parents + nested children) -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 min-h-[240px] transition-all"
               @dragover.prevent="dragOver = 'my_brand'"
               @dragleave="dragOver = null"
               @drop.prevent="onDrop('my_brand')"
               :class="dragOver === 'my_brand' ? 'ring-2 ring-emerald-400 border-emerald-200' : ''">
            <div class="flex items-center justify-between mb-3 pb-2 border-b border-gray-100">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                <h3 class="text-sm font-semibold text-charcoal-dark">My Brands</h3>
              </div>
              <span class="text-xs text-charcoal-light" x-text="myBrandsCount"></span>
            </div>
            <div class="space-y-2">
              <template x-for="brand in buckets.my_brand" :key="brand.brand_id">
                <div>
                  <!-- Parent brand row (can be focus, accepts drag-to-parent drops) -->
                  <div draggable="true"
                       @dragstart="onDragStart($event, brand, 'my_brand')"
                       @dragover.prevent.stop="dragged && dragged.brand_id !== brand.brand_id && draggedFrom === 'my_brand' ? dragOverParent = brand.brand_id : null"
                       @dragleave.stop="dragOverParent === brand.brand_id ? dragOverParent = null : null"
                       @drop.prevent.stop="onDropOnParent($event, brand, 'my_brand')"
                       :class="dragOverParent === brand.brand_id ? 'ring-2 ring-emerald-500 bg-emerald-100/60' : ''"
                       class="group flex items-center gap-2 bg-emerald-50/40 border border-emerald-100 rounded-lg px-3 py-2 cursor-move hover:border-emerald-300 hover:shadow-sm transition-all">
                    <!-- Focus star toggle (roots only) -->
                    <button @click.stop="toggleFocus(brand)"
                            :title="brand.is_focus ? 'This is the focus brand (its product lines are auto-included)' : 'Make this the focus brand — its product lines below will count as mentions too'"
                            class="shrink-0 text-lg leading-none transition-colors"
                            :class="brand.is_focus ? 'text-yellow-400 hover:text-yellow-500' : 'text-gray-300 hover:text-yellow-400'">
                      <span x-text="brand.is_focus ? '★' : '☆'"></span>
                    </button>
                    <!-- Expand/collapse chevron (only when children) -->
                    <button x-show="brand.children && brand.children.length > 0"
                            @click.stop="toggleBrandExpand(brand.brand_id)"
                            :title="isBrandExpanded(brand.brand_id) ? 'Collapse product lines' : 'Expand product lines'"
                            class="shrink-0 text-charcoal-light hover:text-coral transition-colors">
                      <svg class="w-3 h-3 transition-transform"
                           :class="isBrandExpanded(brand.brand_id) ? 'rotate-90' : ''"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                      </svg>
                    </button>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-charcoal-dark truncate" x-text="brand.name"></p>
                      <p x-show="brand.domain" class="text-[10px] text-charcoal-light truncate" x-text="brand.domain"></p>
                      <p x-show="brand.children && brand.children.length > 0"
                         class="text-[10px] text-emerald-700 mt-0.5"
                         x-text="brand.children.length + ' product line' + (brand.children.length > 1 ? 's' : '') + ' auto-included'"></p>
                    </div>
                    <button @click.stop="removeBrand(brand, 'my_brand')"
                            title="Move to ignored"
                            class="shrink-0 text-xs text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity px-1">
                      &times;
                    </button>
                  </div>

                  <!-- Children (product lines, indented, NOT focus-able) -->
                  <template x-if="brand.children && brand.children.length > 0 && isBrandExpanded(brand.brand_id)">
                    <div x-transition class="ml-4 mt-1 space-y-1 border-l-2 border-emerald-200 pl-3">
                      <template x-for="child in brand.children" :key="child.brand_id">
                        <div draggable="true"
                             @dragstart="onDragStart($event, child, 'my_brand')"
                             class="group flex items-center gap-2 bg-emerald-50/20 border border-emerald-50 rounded-md px-2 py-1 cursor-move hover:border-emerald-200 transition-all">
                          <span class="text-[10px] text-emerald-600 shrink-0">↳</span>
                          <div class="flex-1 min-w-0">
                            <p class="text-xs text-charcoal-dark truncate" x-text="child.name"></p>
                          </div>
                          <button @click.stop="removeBrand(child, 'my_brand')"
                                  title="Move to ignored (will detach from parent)"
                                  class="shrink-0 text-[10px] text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity">
                            &times;
                          </button>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <p x-show="buckets.my_brand.length === 0" class="text-xs text-charcoal-light italic text-center py-6">Drag brands here</p>
            </div>
          </div>

          <!-- Competitors column (hierarchical) -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 min-h-[240px] transition-all"
               @dragover.prevent="dragOver = 'competitor'"
               @dragleave="dragOver = null"
               @drop.prevent="onDrop('competitor')"
               :class="dragOver === 'competitor' ? 'ring-2 ring-red-400 border-red-200' : ''">
            <div class="flex items-center justify-between mb-3 pb-2 border-b border-gray-100">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-red-500"></span>
                <h3 class="text-sm font-semibold text-charcoal-dark">Competitors</h3>
              </div>
              <div class="flex items-center gap-2">
                <span class="kpi-tooltip" style="display:inline-flex;">
                  <button @click="refreshFromBrief()"
                          :disabled="refreshingFromBrief"
                          :class="refreshingFromBrief ? 'animate-spin text-coral' : 'text-gray-300 hover:text-coral'"
                          class="transition-colors cursor-pointer disabled:cursor-wait"
                          aria-label="Refresh competitors from brief">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                  </button>
                  <span class="kpi-tip" style="width:240px;">Refresh from brief — re-sync competitors and product lines from the Domain Brief above. Safe to re-click; your existing classifications stay intact.</span>
                </span>
                <span class="text-xs text-charcoal-light" x-text="bucketCount('competitor')"></span>
              </div>
            </div>
            <div class="space-y-2">
              <template x-for="brand in buckets.competitor" :key="brand.brand_id">
                <div>
                  <!-- Parent (accepts drag-to-parent drops from same bucket) -->
                  <div draggable="true"
                       @dragstart="onDragStart($event, brand, 'competitor')"
                       @dragover.prevent.stop="dragged && dragged.brand_id !== brand.brand_id && draggedFrom === 'competitor' ? dragOverParent = brand.brand_id : null"
                       @dragleave.stop="dragOverParent === brand.brand_id ? dragOverParent = null : null"
                       @drop.prevent.stop="onDropOnParent($event, brand, 'competitor')"
                       :class="dragOverParent === brand.brand_id ? 'ring-2 ring-red-500 bg-red-100/60' : ''"
                       class="group flex items-center gap-2 bg-red-50/30 border border-red-100 rounded-lg px-3 py-2 cursor-move hover:border-red-300 hover:shadow-sm transition-all">
                    <button x-show="brand.children && brand.children.length > 0"
                            @click.stop="toggleBrandExpand(brand.brand_id)"
                            :title="isBrandExpanded(brand.brand_id) ? 'Collapse product lines' : 'Expand product lines'"
                            class="shrink-0 text-charcoal-light hover:text-coral transition-colors">
                      <svg class="w-3 h-3 transition-transform"
                           :class="isBrandExpanded(brand.brand_id) ? 'rotate-90' : ''"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                      </svg>
                    </button>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-charcoal-dark truncate" x-text="brand.name"></p>
                      <p x-show="brand.domain" class="text-[10px] text-charcoal-light truncate" x-text="brand.domain"></p>
                      <p x-show="brand.children && brand.children.length > 0"
                         class="text-[10px] text-red-700 mt-0.5"
                         x-text="brand.children.length + ' product line' + (brand.children.length > 1 ? 's' : '')"></p>
                    </div>
                    <button @click.stop="removeBrand(brand, 'competitor')"
                            title="Move to ignored"
                            class="shrink-0 text-xs text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity px-1">
                      &times;
                    </button>
                  </div>
                  <!-- Children (gammes) -->
                  <template x-if="brand.children && brand.children.length > 0 && isBrandExpanded(brand.brand_id)">
                    <div x-transition class="ml-4 mt-1 space-y-1 border-l-2 border-red-200 pl-3">
                      <template x-for="child in brand.children" :key="child.brand_id">
                        <div draggable="true"
                             @dragstart="onDragStart($event, child, 'competitor')"
                             class="group flex items-center gap-2 bg-red-50/10 border border-red-50 rounded-md px-2 py-1 cursor-move hover:border-red-200 transition-all">
                          <span class="text-[10px] text-red-600 shrink-0">↳</span>
                          <div class="flex-1 min-w-0">
                            <p class="text-xs text-charcoal-dark truncate" x-text="child.name"></p>
                          </div>
                          <button @click.stop="removeBrand(child, 'competitor')"
                                  title="Move to ignored"
                                  class="shrink-0 text-[10px] text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity">
                            &times;
                          </button>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <p x-show="buckets.competitor.length === 0" class="text-xs text-charcoal-light italic text-center py-6">Drag brands here</p>
            </div>
          </div>

        </div>

        <!-- Ignored — sticky-to-bottom collapsible strip. Law of UX: this is
             a past-decisions bin (like Gmail Spam), so progressive disclosure
             keeps it out of the way visually, BUT we keep it always visible
             so users don't forget it exists. The drag-over auto-expands the
             panel — drop target works whether collapsed or open. -->
        <div x-data="{ ignoredExpanded: false }"
             @dragover.prevent="dragOver = 'ignored'; ignoredExpanded = true"
             @dragleave="dragOver = null"
             @drop.prevent="onDrop('ignored')"
             :class="dragOver === 'ignored' ? 'ring-2 ring-gray-400 border-gray-300' : ''"
             class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6 transition-all sticky bottom-2 z-10">
          <div class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-gray-50 rounded-xl transition-colors"
               @click="ignoredExpanded = !ignoredExpanded">
            <svg class="w-4 h-4 text-charcoal-light shrink-0 transition-transform"
                 :class="ignoredExpanded ? 'rotate-90' : ''"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="w-2 h-2 rounded-full bg-gray-400 shrink-0"></span>
            <h3 class="text-sm font-semibold text-charcoal-dark">Ignored</h3>
            <span class="text-xs text-charcoal-light" x-text="bucketCount('ignored')"></span>
            <span class="text-[11px] text-charcoal-light/70 hidden sm:inline">— past decisions, not tracked</span>
            <span class="flex-1"></span>
            <template x-if="bucketCount('ignored') > 0">
              <span class="kpi-tooltip" style="display:inline-flex;">
                <button @click.stop="emptyIgnored()"
                        :disabled="emptyingIgnored"
                        class="text-[10px] px-2 py-0.5 rounded border border-gray-200 text-charcoal-light hover:text-red-600 hover:border-red-200 hover:bg-red-50 transition-colors disabled:opacity-50 disabled:cursor-wait">
                  <span x-show="!emptyingIgnored">Empty</span>
                  <span x-show="emptyingIgnored">…</span>
                </button>
                <span class="kpi-tip" style="width:240px;">Removes all Ignored brands from this scan. The catalog stays — if the same brand is detected again on a rescan, it comes back in the inbox.</span>
              </span>
            </template>
          </div>
          <div x-show="ignoredExpanded" x-transition class="border-t border-gray-100 p-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
              <template x-for="brand in buckets.ignored" :key="brand.brand_id">
                <div>
                  <div draggable="true"
                       @dragstart="onDragStart($event, brand, 'ignored')"
                       class="group flex items-center gap-2 bg-gray-50 border border-gray-100 rounded-lg px-3 py-1.5 cursor-move hover:border-gray-300 hover:shadow-sm transition-all opacity-70">
                    <button x-show="brand.children && brand.children.length > 0"
                            @click.stop="toggleBrandExpand(brand.brand_id)"
                            :title="isBrandExpanded(brand.brand_id) ? 'Collapse product lines' : 'Expand product lines'"
                            class="shrink-0 text-charcoal-light hover:text-coral transition-colors">
                      <svg class="w-3 h-3 transition-transform"
                           :class="isBrandExpanded(brand.brand_id) ? 'rotate-90' : ''"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                      </svg>
                    </button>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs text-charcoal-dark truncate" x-text="brand.name"></p>
                      <p x-show="brand.children && brand.children.length > 0"
                         class="text-[10px] text-gray-500"
                         x-text="brand.children.length + ' product line' + (brand.children.length > 1 ? 's' : '')"></p>
                    </div>
                    <button @click.stop="deleteBrandFromScan(brand, 'ignored')"
                            title="Remove from this scan"
                            class="shrink-0 text-xs text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity px-1">
                      &times;
                    </button>
                  </div>
                  <template x-if="brand.children && brand.children.length > 0 && isBrandExpanded(brand.brand_id)">
                    <div x-transition class="ml-4 mt-1 space-y-1 border-l-2 border-gray-200 pl-3">
                      <template x-for="child in brand.children" :key="child.brand_id">
                        <div draggable="true"
                             @dragstart="onDragStart($event, child, 'ignored')"
                             class="group flex items-center gap-2 bg-gray-50/60 border border-gray-100 rounded-md px-2 py-1 cursor-move hover:border-gray-200 transition-all opacity-70">
                          <span class="text-[10px] text-gray-500 shrink-0">↳</span>
                          <div class="flex-1 min-w-0">
                            <p class="text-xs text-charcoal-light truncate" x-text="child.name"></p>
                          </div>
                          <button @click.stop="deleteBrandFromScan(child, 'ignored')"
                                  title="Remove from this scan"
                                  class="shrink-0 text-[10px] text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity">
                            &times;
                          </button>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
              <p x-show="buckets.ignored.length === 0" class="text-xs text-charcoal-light italic text-center py-6 col-span-full">Drag brands here</p>
            </div>
          </div>
        </div>

        <!-- Footer with Continue button -->
        <div class="flex items-center justify-between mt-6">
          <p class="text-sm text-charcoal-light">
            Focus: <span class="font-medium text-charcoal-dark" x-text="getFocusName()"></span>
          </p>
          {isReviewing ? (
            <a href={`/app/scans/${id}`} class="px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all flex items-center gap-2">
              Back to current step
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          ) : (
            <button @click="validateBrands()"
                    :disabled="!hasFocus || myBrandsCount === 0 || flatUnclassified.length > 0"
                    class="px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:hover:shadow-none">
              Continue to Personas
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
          )}
        </div>
      </div>
    )}

    <!-- Scanning in progress — transparent pipeline timeline.
         Polls /api/scans/{id}/pipeline every 3 s. Each step shows its status
         (done / running / pending), duration or elapsed time, and a heuristic
         ETA. When all steps finish the parent page auto-reloads to Results
         (status flip from `scanning` to `completed`). -->
    {!effectiveView && scan.status === 'scanning' && (
      <div x-data={`scanPipeline('${id}')`} x-init="start()"
           class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
        <div class="flex items-start justify-between mb-5 gap-4">
          <div>
            <h2 class="text-xl font-bold text-charcoal-dark mb-1">Scanning {scan.domain}</h2>
            <p class="text-sm text-charcoal-light">
              <span x-text="summary.completed + ' of ' + summary.total + ' steps done'"></span>
              <template x-if="summary.eta">
                <span> · ETA <span x-text="summary.eta"></span></span>
              </template>
            </p>
          </div>
          <div class="text-right shrink-0">
            <p class="text-2xl font-bold text-coral tabular-nums" x-text="overallPct + '%'"></p>
            <p class="text-[10px] text-charcoal-light" x-text="'Elapsed ' + elapsedDisplay"></p>
          </div>
        </div>

        <!-- Top-level progress bar -->
        <div class="w-full bg-gray-100 rounded-full h-2 mb-6 overflow-hidden">
          <div class="bg-coral h-2 rounded-full transition-all duration-500" :style="'width:' + overallPct + '%'"></div>
        </div>

        <!-- Step timeline -->
        <ol class="space-y-3">
          <template x-for="(step, idx) in steps" :key="step.job_type + idx">
            <li class="flex items-start gap-3">
              <!-- Status icon -->
              <div class="shrink-0 mt-0.5">
                <template x-if="step.status === 'completed'">
                  <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center">
                    <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                  </div>
                </template>
                <template x-if="step.status === 'running'">
                  <div class="w-5 h-5 rounded-full bg-coral/20 flex items-center justify-center">
                    <svg class="w-3 h-3 text-coral animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10" stroke-width="3" stroke-dasharray="40 60" stroke-linecap="round"/>
                    </svg>
                  </div>
                </template>
                <template x-if="step.status === 'failed'">
                  <div class="w-5 h-5 rounded-full bg-red-100 flex items-center justify-center">
                    <svg class="w-3 h-3 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
                  </div>
                </template>
                <template x-if="step.status === 'pending' || step.status === 'queued'">
                  <div class="w-5 h-5 rounded-full border-2 border-gray-200 bg-white"></div>
                </template>
              </div>
              <!-- Step body -->
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-2">
                  <p class="text-sm font-medium"
                     :class="{
                       'text-charcoal-dark': step.status === 'completed' || step.status === 'running',
                       'text-charcoal-light': step.status === 'pending' || step.status === 'queued',
                       'text-red-600': step.status === 'failed',
                     }"
                     x-text="step.label"></p>
                  <p class="text-[11px] tabular-nums shrink-0"
                     :class="step.status === 'running' ? 'text-coral font-medium' : 'text-charcoal-light'"
                     x-text="formatStepTime(step)"></p>
                </div>
                <template x-if="step.details">
                  <p class="text-[11px] text-charcoal-light mt-0.5" x-text="step.details"></p>
                </template>
                <template x-if="step.error">
                  <p class="text-[11px] text-red-500 mt-0.5" x-text="step.error"></p>
                </template>
                <template x-if="step.status === 'failed' && step.attempts > 1">
                  <p class="text-[10px] text-amber-600 mt-0.5" x-text="'Retried ' + step.attempts + ' times'"></p>
                </template>
              </div>
            </li>
          </template>
        </ol>

        <p class="text-[11px] text-charcoal-light text-center mt-6">
          You can leave this page. We'll keep scanning.
        </p>
      </div>
    )}

    <!-- Personas ready (Gate 3) — or reviewing personas via ?view=personas -->
    {(effectiveView === 'personas' || (!effectiveView && scan.status === 'personas_ready')) && personasData && (
      <div x-data={`personasWizard(${JSON.stringify(personasData)}, '${id}', ${JSON.stringify((scan.config || {}).providers || ['openai'])})`}>
        <h2 class="text-xl font-bold text-charcoal-dark mb-2">Personas & Questions on <span class="text-coral">{scan.domain}</span></h2>
        <p class="text-charcoal-light mb-2">For each topic, we generated personas — real people who'd ask questions about it — and the typical questions they'd ask an AI.</p>
        <p class="text-sm text-charcoal-light mb-4"><span class="font-medium text-charcoal-dark">Review and toggle off</span> what you don't need. Each active question counts as 1 scan credit when you launch.</p>

        {/* Pedagogical info banner: closes the trust gap for first-time users
            who might think "6 keywords per persona" feels too thin or arbitrary.
            Explains the design philosophy: persona = ONE archetype, questions
            cover semantic variations, not literal keyword bashing. */}
        <details class="mb-5 bg-blue-50/50 border border-blue-100 rounded-lg overflow-hidden group">
          <summary class="px-4 py-2.5 cursor-pointer hover:bg-blue-50 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500 shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            <span class="text-sm font-medium text-blue-900">Why these personas matter for your brand</span>
          </summary>
          <div class="px-4 py-3 border-t border-blue-100 text-xs text-blue-900/90 leading-relaxed space-y-2">
            <p>Each <strong>persona</strong> belongs to a <strong>topic</strong> and represents one type of user who'd ask ChatGPT or Gemini about that topic. The keywords show what they search for; the 15 questions test how they'd actually chat with AI — and whether <strong>your brand gets recommended</strong>.</p>
            {personaBannerExample ? (
              <p class="bg-white/60 rounded px-2.5 py-1.5 border border-blue-100">
                <span class="font-medium">Example from your scan</span> · For the topic <span class="font-medium">{personaBannerExample.topicName}</span>, the persona <span class="font-medium">{personaBannerExample.personaName}</span> might type <span class="font-mono">"{personaBannerExample.keyword}"</span> in a Google search. But on ChatGPT, the same persona asks <span class="font-mono">"{personaBannerExample.question}"</span> — without naming a single brand. We measure whether AI <strong>spontaneously recommends your brand</strong> in that kind of conversation.
              </p>
            ) : (
              <p class="bg-white/60 rounded px-2.5 py-1.5 border border-blue-100 italic text-blue-800/70">
                Generate at least one persona to see a real example from your own scan here.
              </p>
            )}
            <p>One persona = one angle on your topic. Click <button type="button"
              onclick="(function(){ const list = document.getElementById('topics-list'); if(list){ list.scrollIntoView({behavior:'smooth',block:'start'}); document.querySelectorAll('.js-add-persona-btn').forEach(b => { b.classList.add('animate-flash-coral'); setTimeout(()=>b.classList.remove('animate-flash-coral'), 1800); }); } })()"
              class="font-medium underline decoration-dotted decoration-1 underline-offset-2 hover:text-coral transition-colors cursor-pointer">+ Add persona</button> on a topic to test more types of users.</p>
          </div>
        </details>

        {/* Heuristic warnings (B.1 type inferences + B.2 coherence checks).
            Sorted by priority (critical → medium → low based on topic traffic share).
            Filter pills + per-warning Dismiss + bulk Dismiss. Non-blocking. */}
        {(() => {
          const warningsRaw = (scan.summary && Array.isArray(scan.summary.warnings)) ? scan.summary.warnings : [];
          if (warningsRaw.length === 0) return null;
          const totalQ = personasData?.totals?.total_questions || 0;
          // Priority order: critical > medium > low. Stable sort preserves order within group.
          const prioRank: any = { critical: 0, medium: 1, low: 2 };
          const warnings = [...warningsRaw].sort((a: any, b: any) =>
            (prioRank[a.priority] ?? 3) - (prioRank[b.priority] ?? 3)
          );
          const ratio = totalQ > 0 ? warnings.length / totalQ : 0;
          // Critical-count drives panel severity color (not just ratio): even 5%
          // critical warnings = red panel because they touch high-value topics.
          const critCount = warnings.filter((w: any) => w.priority === 'critical').length;
          const medCount = warnings.filter((w: any) => w.priority === 'medium').length;
          const lowCount = warnings.filter((w: any) => w.priority === 'low').length;
          const severity = critCount > 0 ? 'red' : (ratio >= 0.1 || medCount > 0) ? 'amber' : 'emerald';
          const colors: any = {
            emerald: { bg: 'bg-emerald-50/60', border: 'border-emerald-200', icon: 'text-emerald-600', text: 'text-emerald-900', subtext: 'text-emerald-700', innerBg: 'bg-white/40 border-emerald-200', hover: 'hover:bg-emerald-50' },
            amber:   { bg: 'bg-amber-50/60',   border: 'border-amber-200',   icon: 'text-amber-600',   text: 'text-amber-900',   subtext: 'text-amber-700',   innerBg: 'bg-white/40 border-amber-200',   hover: 'hover:bg-amber-50' },
            red:     { bg: 'bg-red-50/60',     border: 'border-red-200',     icon: 'text-red-600',     text: 'text-red-900',     subtext: 'text-red-700',     innerBg: 'bg-white/40 border-red-200',     hover: 'hover:bg-red-50' },
          };
          const c = colors[severity];
          const counts: any = {};
          for (const w of warnings) { const t = w.type || 'unknown'; counts[t] = (counts[t] || 0) + 1; }
          const labels: any = {
            type_inferred: 'type inferred',
            off_topic: 'off-topic',
            duplicate: 'duplicate',
          };
          const summaryText = Object.entries(counts).map(([t, n]) => `${n} ${labels[t] || t}`).join(' · ');
          // Pre-compute priority for each warning index (for x-show filter)
          const warningPrios = warnings.map((w: any) => w.priority || 'low');
          return (
            <details class:list={['mb-6 rounded-lg overflow-hidden group border', c.bg, c.border]}
                     x-data={`{
                       dismissed: {},
                       filter: 'all',
                       total: ${warnings.length},
                       prios: ${JSON.stringify(warningPrios)},
                       countFor(f) {
                         let n = 0;
                         for (let i = 0; i < this.total; i++) {
                           if (this.dismissed[i]) continue;
                           if (f === 'all' || this.prios[i] === f) n++;
                         }
                         return n;
                       }
                     }`}>
              <summary class:list={['px-4 py-2.5 cursor-pointer transition-colors flex items-center gap-2.5', c.hover]}>
                <svg class:list={['w-4 h-4 shrink-0 transition-transform group-open:rotate-90', c.icon]} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
                <svg class:list={['w-4 h-4 shrink-0', c.icon]} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                <span class:list={['text-sm font-medium', c.text]}>
                  <span x-text="countFor(filter)">{warnings.length}</span> of {totalQ} question{totalQ > 1 ? 's' : ''} flagged{ratio > 0 ? ` (${Math.round(ratio * 100)}%)` : ''}
                </span>
                <span class:list={['text-xs ml-auto', c.subtext]}>{summaryText}</span>
              </summary>
              <div class:list={['border-t px-4 py-3 max-h-96 overflow-y-auto', c.innerBg]}>
                {/* Priority filter pills + Dismiss-all */}
                <div class="flex items-center justify-between mb-3 gap-3 flex-wrap">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    {[
                      { key: 'all',      label: 'All',      dot: 'bg-charcoal-dark', activeBg: 'bg-charcoal-dark text-white border-charcoal-dark' },
                      { key: 'critical', label: 'Critical', dot: 'bg-red-500',       activeBg: 'bg-red-100 text-red-800 border-red-400' },
                      { key: 'medium',   label: 'Medium',   dot: 'bg-amber-500',     activeBg: 'bg-amber-100 text-amber-800 border-amber-400' },
                      { key: 'low',      label: 'Low',      dot: 'bg-gray-400',      activeBg: 'bg-gray-100 text-gray-700 border-gray-400' },
                    ].map(p => (
                      <button type="button"
                              @click={`filter = '${p.key}'`}
                              :class={`filter === '${p.key}' ? '${p.activeBg}' : 'bg-white/70 text-charcoal-light border-gray-200 hover:bg-white'`}
                              x-show={`countFor('${p.key}') > 0 || filter === '${p.key}'`}
                              class="text-[11px] px-2 py-1 rounded border transition-colors flex items-center gap-1.5">
                        {p.key !== 'all' && <span class={`w-1.5 h-1.5 rounded-full ${p.dot} shrink-0`}></span>}
                        <span class="font-medium">{p.label}</span>
                        <span class="text-[10px] opacity-70">(<span x-text={`countFor('${p.key}')`}></span>)</span>
                      </button>
                    ))}
                  </div>
                  <button type="button"
                          @click="(() => { const d = {...dismissed}; for (let i = 0; i < total; i++) { if (d[i]) continue; if (filter === 'all' || prios[i] === filter) d[i] = true; } dismissed = d; })()"
                          x-show="countFor(filter) > 0"
                          title="Hides these warnings from the panel only — questions stay active in the scan. Refresh the page to see them again. To actually skip a question in the scan, toggle it off in the personas list below."
                          class:list={['shrink-0 text-[11px] px-2 py-1 rounded transition-colors whitespace-nowrap', 'bg-white/70 hover:bg-white border', c.border, c.subtext]}>
                    Hide from this view
                  </button>
                </div>
                <p class:list={['text-[10px] mb-2 italic', c.subtext]}>
                  Priority weighted by topic traffic share (high-traffic topics → critical). Hide noise to focus, then toggle off questions you don't want in the scan via the personas list below.
                </p>
                <ul class="space-y-2">
                  {warnings.map((w: any, i: number) => {
                    const prioColors: any = {
                      critical: 'border-red-300 bg-red-50/40',
                      medium:   'border-amber-300 bg-amber-50/40',
                      low:      'border-gray-200 bg-white/40',
                    };
                    const prioPill: any = {
                      critical: 'bg-red-100 text-red-700',
                      medium:   'bg-amber-100 text-amber-700',
                      low:      'bg-gray-100 text-gray-600',
                    };
                    // Inline x-show condition with direct prop access — most reliable Alpine reactivity.
                    // The row's priority is server-side known, so we just compare filter to that constant.
                    const prio = w.priority || 'low';
                    // Resolve the persona's actual context (keywords + intentions + pains) to surface
                    // as a tooltip on the warning reason text — gives user the data behind the heuristic
                    // without forcing them to scroll down to find the persona.
                    const personaCtx = (() => {
                      if (!personasData?.topics) return null;
                      for (const t of personasData.topics) {
                        const p = (t.personas || []).find((pp: any) => pp.name === w.persona);
                        if (p) return p.data || null;
                      }
                      return null;
                    })();
                    const reasonTooltip = (() => {
                      if (!personaCtx) return w.reason || '';
                      const parts = [];
                      const kws = personaCtx.mots_cles_associes;
                      if (kws?.length) parts.push(`KEYWORDS (${kws.length}): ${kws.join(', ')}`);
                      const intents = personaCtx.intentions_recherche;
                      if (intents?.length) parts.push(`INTENTIONS: ${intents.join(' · ')}`);
                      const pains = personaCtx.points_douleur;
                      if (pains?.length) parts.push(`PAIN POINTS: ${pains.join(' · ')}`);
                      return parts.length ? parts.join('\n\n') : (w.reason || '');
                    })();
                    return (
                      <li class:list={['text-xs text-charcoal-dark flex gap-2 items-start group/row border rounded-md px-2 py-1.5', prioColors[prio]]}
                          x-show={`!dismissed[${i}] && (filter === 'all' || filter === '${prio}')`}>
                        <span class={`shrink-0 px-1.5 py-0.5 rounded text-[10px] font-medium uppercase tracking-wide ${prioPill[w.priority || 'low']}`}
                              title={`Topic share: ${w.topic_share_pct ?? '?'}% — ${w.priority || 'low'} priority`}>
                          {w.priority || 'low'}
                        </span>
                        <span class:list={['shrink-0 px-1.5 py-0.5 rounded text-[10px] font-medium uppercase tracking-wide', {
                          'bg-orange-100 text-orange-700': w.type === 'duplicate',
                          'bg-amber-100 text-amber-700': w.type === 'off_topic',
                          'bg-blue-100 text-blue-700': w.type === 'type_inferred',
                        }]}>{labels[w.type] || w.type}</span>
                        <div class="min-w-0 flex-1">
                          <p class="text-charcoal-light text-[10px]">
                            <span class="font-medium">{w.persona || '?'}</span>
                            {w.topic && <span> · {w.topic}</span>}
                            {w.topic_share_pct !== undefined && <span> · {w.topic_share_pct}% traffic share</span>}
                            {w.jaccard && <span> · Jaccard {w.jaccard}</span>}
                            {w.inferred && <span> · inferred as <span class="font-mono">{w.inferred}</span></span>}
                          </p>
                          {w.question && <p class="text-charcoal-dark/80 truncate" title={w.question}>{w.question}</p>}
                          {w.question_a && (
                            <div class="space-y-0.5 mt-0.5">
                              <p class="text-charcoal-dark/80 truncate" title={w.question_a}>A: {w.question_a}</p>
                              <p class="text-charcoal-dark/80 truncate" title={w.question_b}>B: {w.question_b}</p>
                            </div>
                          )}
                          {w.reason && (
                            <p class:list={['text-[10px] italic cursor-help underline decoration-dotted decoration-1 underline-offset-2', c.subtext]}
                               title={reasonTooltip}>
                              {w.reason}
                            </p>
                          )}
                        </div>
                        <button type="button"
                                @click={`dismissed = {...dismissed, [${i}]: true}`}
                                title="Hide from this view (does not disable the question — use the toggle in the personas list below to skip it in the scan)"
                                class="shrink-0 w-5 h-5 rounded text-charcoal-light hover:bg-gray-200 hover:text-charcoal-dark opacity-0 group-hover/row:opacity-100 transition-opacity flex items-center justify-center">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                      </li>
                    );
                  })}
                </ul>
                <p class:list={['text-[11px] mt-3 italic', c.subtext]} x-show="countFor(filter) === 0">
                  No warnings match the current filter.
                </p>
              </div>
            </details>
          );
        })()}

        <!-- Topic cards (same UX as Gate 1 Topics screen) -->
        <div id="topics-list" class="space-y-2 mb-6">
          <template x-for="(topic, idx) in topics" :key="topic.topic_id">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 transition-all"
                 :class="(topic.stats.active_personas === 0 || topic.stats.active_questions === 0) ? 'opacity-60' : ''">

              <!-- Topic header (clickable, toggle expanded) -->
              <div class="flex items-center gap-4 px-5 py-3.5 cursor-pointer hover:bg-gray-50 transition-colors rounded-xl"
                   @click="expandedTopic = expandedTopic === idx ? null : idx">

                <!-- Bulk toggle (cascade to all personas in topic) -->
                <button @click.stop="bulkToggleTopic(topic)"
                  :class="topic.stats.active_personas > 0 ? 'bg-coral' : 'bg-gray-300'"
                  class="relative w-10 h-6 rounded-full transition-colors shrink-0"
                  :title="topic.stats.active_personas > 0 ? 'Disable all personas in this topic' : 'Enable all personas in this topic'">
                  <span :class="topic.stats.active_personas > 0 ? 'translate-x-4' : 'translate-x-0'"
                    class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow transition-transform"></span>
                </button>

                <!-- Topic name + stats — editable in place (mirrors the Topics page UX) -->
                <div class="flex-1 min-w-0">
                  <template x-if="!topic.editing">
                    <div class="group/topicname flex items-center gap-1.5">
                      <p class="text-sm font-medium text-charcoal-dark truncate" x-text="topic.topic_name"></p>
                      <button @click.stop="topic.editing = true; $nextTick(() => $refs['topicNameInput_' + topic.topic_id]?.focus())"
                              title="Rename this topic"
                              class="text-gray-300 hover:text-coral opacity-0 group-hover/topicname:opacity-100 transition-opacity shrink-0">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                      </button>
                    </div>
                  </template>
                  <template x-if="topic.editing">
                    <input type="text" x-model="topic.topic_name"
                           :x-ref="'topicNameInput_' + topic.topic_id"
                           @click.stop
                           @keydown.enter="saveTopicName(topic)"
                           @keydown.escape="topic.editing = false"
                           @blur="saveTopicName(topic)"
                           class="text-sm font-medium px-2 py-1 border border-coral rounded w-full outline-none" />
                  </template>
                  <p class="text-xs text-charcoal-light">
                    <span x-text="topic.stats.active_personas + '/' + topic.stats.total_personas"></span> personas ·
                    <span x-text="topic.stats.active_questions + '/' + topic.stats.total_questions"></span> questions
                  </p>
                </div>

                <!-- Warning icon when topic has nothing active -->
                <span x-show="topic.stats.active_personas === 0 || topic.stats.active_questions === 0"
                      class="shrink-0 text-amber-500" title="This topic won't be scanned">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </span>

                <!-- Add persona button at topic header level (Fitts: always visible, no need to expand).
                     Disabled when the topic has no active personas (bulk toggle off) — user must
                     re-enable the topic first, otherwise adding a persona feels contradictory.
                     class js-add-persona-btn = used by banner anchor click to flash + scroll -->
                <button type="button"
                        @click.stop="addPersona(topic)"
                        :disabled="topic.stats.active_personas === 0"
                        :title="topic.stats.active_personas === 0
                                ? 'Enable this topic first (toggle on the left) before adding a persona'
                                : 'Add a custom persona to this topic'"
                        :class="topic.stats.active_personas === 0
                                ? 'opacity-40 cursor-not-allowed border-gray-200'
                                : 'border-gray-200 hover:border-coral hover:text-coral hover:bg-coral/5'"
                        class="js-add-persona-btn shrink-0 inline-flex items-center gap-1 text-[11px] px-2 py-1 rounded-md border bg-white text-charcoal-light transition-colors">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                  </svg>
                  <span>Add persona</span>
                </button>

                <!-- Expand chevron -->
                <svg class="w-4 h-4 text-gray-400 transition-transform shrink-0"
                     :class="expandedTopic === idx ? 'rotate-180' : ''"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>

              <!-- Expanded content: persona list -->
              <div x-show="expandedTopic === idx" x-transition class="border-t border-gray-100 px-5 py-4 space-y-2">
                <template x-for="persona in topic.personas" :key="persona.id">
                  <div class="border border-gray-100 rounded-lg transition-all"
                       :class="!persona.is_active ? 'opacity-50 bg-gray-50' : 'bg-white'">

                    <!-- Persona row (clickable, toggle expanded) -->
                    <div class="group flex items-center gap-3 px-3 py-2.5 cursor-pointer hover:bg-gray-50 transition-colors rounded-lg"
                         @click="expandedPersona[persona.id] = !expandedPersona[persona.id]">

                      <!-- Toggle -->
                      <button @click.stop="togglePersona(topic, persona)"
                        :class="persona.is_active ? 'bg-coral' : 'bg-gray-300'"
                        class="relative w-9 h-5 rounded-full transition-colors shrink-0">
                        <span :class="persona.is_active ? 'translate-x-4' : 'translate-x-0'"
                          class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform"></span>
                      </button>

                      <!-- Avatar (dicebear) -->
                      <img :src="'https://api.dicebear.com/9.x/personas/svg?seed=' + encodeURIComponent(persona.name) + '&backgroundColor=b6e3f4,c0aede,d1d4f9,ffd5dc,ffdfbf'"
                           alt="" class="w-9 h-9 rounded-full border border-gray-200 shrink-0" />

                      <!-- Name (inline edit on click) -->
                      <div class="flex-1 min-w-0">
                        <template x-if="editingPersonaId !== persona.id">
                          <div class="flex items-center gap-1">
                            <p class="text-sm font-medium text-charcoal-dark truncate" x-text="persona.name"></p>
                            <button @click.stop="startEditPersona(persona)"
                                    class="text-gray-400 hover:text-coral opacity-0 group-hover:opacity-100 transition-opacity shrink-0"
                                    title="Rename persona">
                              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                            </button>
                            <!-- Persona context tooltip (i) — same hover pattern as the per-question
                                 "Why this question?" tooltip. Surfaces 6 LLM-generated sections
                                 (Profile / Journey / Keywords / Intentions / Pain points /
                                 Opportunities) on hover. Visible when ANY section has data. -->
                            <template x-if="persona.data && (
                              persona.data.mots_cles_associes?.length ||
                              persona.data.intentions_recherche?.length ||
                              persona.data.points_douleur?.length ||
                              persona.data.opportunites?.length ||
                              persona.data.parcours_type ||
                              (persona.data.profil_demographique && (persona.data.profil_demographique.age || persona.data.profil_demographique.situation_professionnelle || persona.data.profil_demographique.niveau_expertise))
                            )">
                              <span class="kpi-tooltip shrink-0" style="display:inline-flex;" @click.stop>
                                <svg class="w-3.5 h-3.5 text-gray-300 hover:text-coral cursor-help transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <circle cx="12" cy="12" r="10" stroke-width="2"/>
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16v-4M12 8h.01"/>
                                </svg>
                                <span class="kpi-tip" style="width:400px;max-width:min(400px,calc(100vw - 32px));max-height:min(70vh,540px);overflow-y:auto;left:0;right:auto;transform:none;top:calc(100% + 8px);bottom:auto;">
                                  <!-- Profile (age / pro / expertise) -->
                                  <template x-if="persona.data?.profil_demographique && (persona.data.profil_demographique.age || persona.data.profil_demographique.situation_professionnelle || persona.data.profil_demographique.niveau_expertise)">
                                    <span style="display:block;margin-bottom:10px;">
                                      <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:4px;">Profile</span>
                                      <span style="display:flex;flex-wrap:wrap;gap:4px;">
                                        <template x-if="persona.data.profil_demographique.age">
                                          <span style="font-size:10px;padding:2px 7px;border-radius:9999px;background:#1e3a8a;color:#dbeafe;" x-text="persona.data.profil_demographique.age"></span>
                                        </template>
                                        <template x-if="persona.data.profil_demographique.situation_professionnelle">
                                          <span style="font-size:10px;padding:2px 7px;border-radius:9999px;background:#581c87;color:#f3e8ff;" x-text="persona.data.profil_demographique.situation_professionnelle"></span>
                                        </template>
                                        <template x-if="persona.data.profil_demographique.niveau_expertise">
                                          <span style="font-size:10px;padding:2px 7px;border-radius:9999px;background:#064e3b;color:#d1fae5;" x-text="'niveau ' + persona.data.profil_demographique.niveau_expertise"></span>
                                        </template>
                                      </span>
                                    </span>
                                  </template>
                                  <!-- Journey -->
                                  <template x-if="persona.data?.parcours_type">
                                    <span style="display:block;margin-bottom:10px;">
                                      <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:2px;">Parcours type</span>
                                      <span style="font-size:11px;line-height:1.45;display:block;" x-text="persona.data.parcours_type"></span>
                                    </span>
                                  </template>
                                  <!-- Keywords -->
                                  <template x-if="persona.data?.mots_cles_associes?.length">
                                    <span style="display:block;margin-bottom:10px;">
                                      <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:4px;">Keywords (<span x-text="persona.data.mots_cles_associes.length"></span>)</span>
                                      <span style="display:flex;flex-wrap:wrap;gap:4px;">
                                        <template x-for="kw in persona.data.mots_cles_associes" :key="kw">
                                          <span style="font-size:10px;padding:1px 6px;border-radius:4px;background:#334155;color:#e2e8f0;" x-text="kw"></span>
                                        </template>
                                      </span>
                                    </span>
                                  </template>
                                  <!-- Intentions de recherche -->
                                  <template x-if="persona.data?.intentions_recherche?.length">
                                    <span style="display:block;margin-bottom:10px;">
                                      <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:2px;">Intentions de recherche</span>
                                      <template x-for="intent in persona.data.intentions_recherche" :key="intent">
                                        <span style="display:block;font-size:11px;line-height:1.45;padding-left:8px;text-indent:-8px;" x-text="'· ' + intent"></span>
                                      </template>
                                    </span>
                                  </template>
                                  <!-- Points de douleur -->
                                  <template x-if="persona.data?.points_douleur?.length">
                                    <span style="display:block;margin-bottom:10px;">
                                      <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:2px;">Points de douleur</span>
                                      <template x-for="pain in persona.data.points_douleur" :key="pain">
                                        <span style="display:block;font-size:11px;line-height:1.45;padding-left:8px;text-indent:-8px;" x-text="'· ' + pain"></span>
                                      </template>
                                    </span>
                                  </template>
                                  <!-- Opportunities -->
                                  <template x-if="persona.data?.opportunites?.length">
                                    <span style="display:block;">
                                      <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:2px;">Opportunités</span>
                                      <template x-for="opp in persona.data.opportunites" :key="opp">
                                        <span style="display:block;font-size:11px;line-height:1.45;padding-left:8px;text-indent:-8px;color:#fbbf24;" x-text="'· ' + opp"></span>
                                      </template>
                                    </span>
                                  </template>
                                </span>
                              </span>
                            </template>
                          </div>
                        </template>
                        <template x-if="editingPersonaId === persona.id">
                          <input type="text" x-model="editingPersonaName"
                                 @click.stop
                                 @keydown.enter="savePersonaName(topic, persona)"
                                 @keydown.escape="editingPersonaId = null"
                                 @blur="savePersonaName(topic, persona)"
                                 x-init="$nextTick(() => $el.focus())"
                                 class="text-sm font-medium text-charcoal-dark w-full border border-coral rounded px-1.5 py-0.5 outline-none" />
                        </template>
                        <p class="text-xs text-charcoal-light truncate">
                          <span x-text="(persona.data && (persona.data.segment_principal || persona.data.profession || persona.data.contexte)) || ''"></span>
                        </p>
                      </div>

                      <!-- Active questions count -->
                      <div class="shrink-0 text-right">
                        <p class="text-xs font-medium"
                           :class="persona.stats.active_questions === 0 ? 'text-red-500' : (persona.stats.active_questions < persona.stats.total_questions ? 'text-coral' : 'text-charcoal-dark')">
                          <span x-text="persona.stats.active_questions + '/' + persona.stats.total_questions"></span>
                        </p>
                        <p class="text-[10px] text-charcoal-light">questions</p>
                      </div>

                      <!-- Delete persona -->
                      <button @click.stop="deletePersona(topic, persona)"
                              class="text-gray-400 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity shrink-0"
                              title="Delete persona">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>

                      <!-- Expand chevron -->
                      <svg class="w-4 h-4 text-gray-400 transition-transform shrink-0"
                           :class="expandedPersona[persona.id] ? 'rotate-180' : ''"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>

                    <!-- Expanded: persona context + questions grouped by type (Miller's Law: ~4 groups vs 15 flat items) -->
                    <div x-show="expandedPersona[persona.id]" x-transition class="border-t border-gray-100 px-3 py-3 space-y-3">
                      <!-- Generating spinner -->
                      <div x-show="generatingPersonaId === persona.id" class="flex items-center gap-2 py-3 justify-center">
                        <svg class="animate-spin h-4 w-4 text-coral" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                        <span class="text-xs text-charcoal-light">Generating 15 questions...</span>
                      </div>

                      <!-- Persona context moved to (i) tooltip next to the persona name — see
                           kpi-tooltip block above. Frees up the questions panel of a redundant
                           collapsible row and keeps the rich data on demand. -->

                      <!-- Custom persona without context (added via "+ Add persona") — show a lightweight hint -->
                      <template x-if="persona.data && !persona.data.mots_cles_associes?.length && !persona.data.intentions_recherche?.length && !persona.data.points_douleur?.length">
                        <div class="rounded-lg bg-blue-50/40 border border-blue-100 px-3 py-2 text-[11px] text-blue-900/80 italic">
                          Custom persona — no auto-generated context (keywords / intentions / pain points). Questions are generated from the topic context only.
                        </div>
                      </template>

                      <!-- Law of Common Region: each type group in its own container.
                           Note: `overflow-hidden` was here to clip hover backgrounds
                           against the rounded corners, but it also clipped the
                           "Why this question?" tooltip when it expanded upward past
                           the container top. Replaced with `rounded-t-lg` on the
                           header + `rounded-b-lg` on the questions panel so each
                           child clips its own corner and the container itself can
                           let overflow escape upward. -->
                      <template x-for="group in groupQuestionsByType(persona.questions)" :key="group.type">
                        <div class="rounded-lg border border-gray-100">
                          <!-- Type group header (collapsible).
                               Uses <div> (not <button>) on the outer wrapper so
                               the inner bulk-toggle <button> is valid HTML —
                               nested <button> elements get auto-closed by the
                               browser, which previously pushed the toggle onto
                               its own line below the label. -->
                          <div @click.stop="toggleTypeGroup(persona.id, group.type)"
                               role="button" tabindex="0"
                               @keydown.enter.stop="toggleTypeGroup(persona.id, group.type)"
                               @keydown.space.prevent.stop="toggleTypeGroup(persona.id, group.type)"
                               class="w-full flex items-center gap-2 px-2.5 py-2 text-left hover:bg-gray-50 transition-colors cursor-pointer select-none rounded-t-lg"
                               :class="!isTypeGroupOpen(persona.id, group.type) ? 'rounded-b-lg' : ''">
                            <svg class="w-3 h-3 text-gray-400 transition-transform shrink-0"
                                 :class="isTypeGroupOpen(persona.id, group.type) ? 'rotate-90' : ''"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                            </svg>
                            <span class="text-[10px] font-medium px-1.5 py-0.5 rounded shrink-0 uppercase tracking-wide"
                                  :class="{
                                    'bg-blue-50 text-blue-600': group.type === 'basique',
                                    'bg-purple-50 text-purple-600': group.type === 'technique',
                                    'bg-red-50 text-red-600': group.type === 'urgente',
                                    'bg-amber-50 text-amber-600': group.type === 'comparative',
                                    'bg-emerald-50 text-emerald-600': !['basique','technique','urgente','comparative'].includes(group.type)
                                  }"
                                  x-text="group.type"></span>
                            <span class="text-[11px] text-charcoal-light flex-1"
                                  x-text="group.activeCount + '/' + group.questions.length + ' active'"></span>
                            <!-- Bulk toggle type group -->
                            <button @click.stop="bulkToggleTypeGroup(persona, group)"
                                    :class="group.activeCount > 0 ? 'bg-coral' : 'bg-gray-300'"
                                    class="relative w-7 h-3.5 rounded-full transition-colors shrink-0"
                                    :title="group.activeCount > 0 ? 'Disable all ' + group.type : 'Enable all ' + group.type">
                              <span :class="group.activeCount > 0 ? 'translate-x-3.5' : 'translate-x-0'"
                                    class="absolute top-0.5 left-0.5 w-2.5 h-2.5 bg-white rounded-full shadow transition-transform"></span>
                            </button>
                          </div>
                          <!-- Questions in group -->
                          <div x-show="isTypeGroupOpen(persona.id, group.type)" x-transition
                               class="border-t border-gray-50 px-2.5 py-1.5 space-y-0.5 bg-gray-50/30 rounded-b-lg">
                            <template x-for="q in group.questions" :key="q.id">
                              <div class="group/q flex items-start gap-2 py-1 hover:bg-white rounded px-1.5 -mx-1 transition-colors">
                                <!-- Toggle -->
                                <button @click.stop="toggleQuestion(persona, q)"
                                  :class="q.is_active ? 'bg-coral' : 'bg-gray-300'"
                                  class="relative w-8 h-4 rounded-full transition-colors shrink-0 mt-0.5">
                                  <span :class="q.is_active ? 'translate-x-4' : 'translate-x-0'"
                                    class="absolute top-0.5 left-0.5 w-3 h-3 bg-white rounded-full shadow transition-transform"></span>
                                </button>
                                <!-- Question text (inline edit on double-click) -->
                                <template x-if="editingQuestionId !== q.id">
                                  <span class="text-xs text-charcoal-dark flex-1 min-w-0 cursor-text"
                                        :class="!q.is_active ? 'line-through text-charcoal-light' : ''"
                                        @dblclick.stop="startEditQuestion(q)"
                                        x-text="q.question"></span>
                                </template>
                                <template x-if="editingQuestionId === q.id">
                                  <input type="text" x-model="editingQuestionText"
                                         @click.stop
                                         @keydown.enter="saveQuestionText(persona, q)"
                                         @keydown.escape="editingQuestionId = null"
                                         @blur="saveQuestionText(persona, q)"
                                         x-init="$nextTick(() => $el.focus())"
                                         class="text-xs text-charcoal-dark flex-1 min-w-0 border border-coral rounded px-1.5 py-0.5 outline-none" />
                                </template>
                                <!-- Why this question? Progressive disclosure of LLM rationale -->
                                <template x-if="q.intention_cachee || q.signal_positif || q.signal_negatif">
                                  <span class="kpi-tooltip shrink-0 mt-0.5" style="display:inline-flex;">
                                    <svg class="w-3.5 h-3.5 text-gray-300 hover:text-coral cursor-help transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <circle cx="12" cy="12" r="10" stroke-width="2"/>
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16v-4M12 8h.01"/>
                                    </svg>
                                    <span class="kpi-tip" style="width:340px;max-width:min(340px,calc(100vw - 32px));right:0;left:auto;transform:none;">
                                      <template x-if="q.intention_cachee">
                                        <span style="display:block;margin-bottom:8px;">
                                          <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:2px;">Hidden intent</span>
                                          <span x-text="q.intention_cachee"></span>
                                        </span>
                                      </template>
                                      <template x-if="q.signal_positif">
                                        <span style="display:block;margin-bottom:6px;">
                                          <span style="color:#6ee7b7;">&#10003; Positive signal</span><br/>
                                          <span x-text="q.signal_positif"></span>
                                        </span>
                                      </template>
                                      <template x-if="q.signal_negatif">
                                        <span style="display:block;">
                                          <span style="color:#fca5a5;">&#10007; Negative signal</span><br/>
                                          <span x-text="q.signal_negatif"></span>
                                        </span>
                                      </template>
                                    </span>
                                  </span>
                                </template>
                                <!-- Delete question -->
                                <button @click.stop="deleteQuestion(persona, q)"
                                        class="text-gray-400 hover:text-red-500 opacity-0 group-hover/q:opacity-100 transition-opacity shrink-0 mt-0.5"
                                        title="Delete question">
                                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                </button>
                              </div>
                            </template>
                          </div>
                        </div>
                      </template>
                      <p x-show="persona.questions.length === 0 && generatingPersonaId !== persona.id" class="text-xs text-charcoal-light italic text-center py-4">
                        No questions for this persona
                      </p>
                      <!-- Add question button -->
                      <button @click.stop="addQuestion(persona)"
                              class="flex items-center gap-1 text-xs text-charcoal-light hover:text-coral transition-colors mt-1 px-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Add question
                      </button>
                    </div>
                  </div>
                </template>

                <p x-show="topic.personas.length === 0" class="text-xs text-charcoal-light italic text-center py-4">
                  No personas generated for this topic
                </p>
                <!-- Add persona button -->
                <button @click.stop="addPersona(topic)"
                        class="flex items-center gap-1.5 text-xs text-charcoal-light hover:text-coral transition-colors px-1 py-2">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                  Add persona
                </button>
              </div>
            </div>
          </template>

          <p x-show="topics.length === 0 && orphanPersonas.length === 0" class="text-sm text-charcoal-light text-center py-8">
            No topics with personas yet. Go back to Topics to validate some.
          </p>

          <!-- Orphan personas (not linked to any topic — segment_principal didn't match) -->
          <template x-if="orphanPersonas.length > 0">
            <div class="bg-white rounded-xl shadow-sm border border-amber-200 transition-all">
              <div class="flex items-center gap-4 px-5 py-3.5 cursor-pointer hover:bg-gray-50 transition-colors rounded-xl"
                   @click="expandedTopic = expandedTopic === 'orphans' ? null : 'orphans'">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-charcoal-dark">Unassigned personas</p>
                  <p class="text-xs text-amber-700">
                    <span x-text="orphanPersonas.length"></span> personas not linked to a specific topic
                  </p>
                </div>
                <svg class="w-4 h-4 text-gray-400 transition-transform shrink-0"
                     :class="expandedTopic === 'orphans' ? 'rotate-180' : ''"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
              <div x-show="expandedTopic === 'orphans'" x-transition class="border-t border-gray-100 px-5 py-4 space-y-2">
                <template x-for="persona in orphanPersonas" :key="persona.id">
                  <div class="border border-gray-100 rounded-lg transition-all"
                       :class="!persona.is_active ? 'opacity-50 bg-gray-50' : 'bg-white'">
                    <div class="flex items-center gap-3 px-3 py-2.5 cursor-pointer hover:bg-gray-50 transition-colors rounded-lg"
                         @click="expandedPersona[persona.id] = !expandedPersona[persona.id]">
                      <button @click.stop="togglePersona({personas: orphanPersonas}, persona)"
                        :class="persona.is_active ? 'bg-coral' : 'bg-gray-300'"
                        class="relative w-9 h-5 rounded-full transition-colors shrink-0">
                        <span :class="persona.is_active ? 'translate-x-4' : 'translate-x-0'"
                          class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform"></span>
                      </button>
                      <img :src="'https://api.dicebear.com/9.x/personas/svg?seed=' + encodeURIComponent(persona.name) + '&backgroundColor=b6e3f4,c0aede,d1d4f9,ffd5dc,ffdfbf'"
                           alt="" class="w-9 h-9 rounded-full border border-gray-200 shrink-0" />
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-charcoal-dark truncate" x-text="persona.name"></p>
                        <p class="text-xs text-charcoal-light truncate"
                           x-text="(persona.data && (persona.data.segment_principal || persona.data.profession || persona.data.contexte)) || ''"></p>
                      </div>
                      <div class="shrink-0 text-right">
                        <p class="text-xs font-medium"
                           :class="persona.stats.active_questions === 0 ? 'text-red-500' : 'text-charcoal-dark'">
                          <span x-text="persona.stats.active_questions + '/' + persona.stats.total_questions"></span>
                        </p>
                        <p class="text-[10px] text-charcoal-light">questions</p>
                      </div>
                      <svg class="w-4 h-4 text-gray-400 transition-transform shrink-0"
                           :class="expandedPersona[persona.id] ? 'rotate-180' : ''"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>
                    <div x-show="expandedPersona[persona.id]" x-transition class="border-t border-gray-100 px-3 py-3 space-y-1.5">
                      <template x-for="q in persona.questions" :key="q.id">
                        <div class="flex items-start gap-2 py-1 hover:bg-gray-50 rounded px-1 -mx-1 transition-colors">
                          <button @click.stop="toggleQuestion(persona, q)"
                            :class="q.is_active ? 'bg-coral' : 'bg-gray-300'"
                            class="relative w-8 h-4 rounded-full transition-colors shrink-0 mt-0.5">
                            <span :class="q.is_active ? 'translate-x-4' : 'translate-x-0'"
                              class="absolute top-0.5 left-0.5 w-3 h-3 bg-white rounded-full shadow transition-transform"></span>
                          </button>
                          <span class="text-[10px] font-medium px-1.5 py-0.5 rounded mt-0.5 shrink-0 uppercase tracking-wide"
                                :class="{
                                  'bg-blue-50 text-blue-600': q.type_question === 'basique',
                                  'bg-purple-50 text-purple-600': q.type_question === 'technique',
                                  'bg-red-50 text-red-600': q.type_question === 'urgente',
                                  'bg-amber-50 text-amber-600': q.type_question === 'comparative',
                                  'bg-emerald-50 text-emerald-600': !['basique','technique','urgente','comparative'].includes(q.type_question)
                                }"
                                x-text="q.type_question || 'validation'"></span>
                          <span class="text-xs text-charcoal-dark flex-1 min-w-0" :class="!q.is_active ? 'line-through text-charcoal-light' : ''" x-text="q.question"></span>
                          <template x-if="q.intention_cachee || q.signal_positif || q.signal_negatif">
                            <span class="kpi-tooltip shrink-0 mt-0.5" style="display:inline-flex;">
                              <svg class="w-3.5 h-3.5 text-gray-300 hover:text-coral cursor-help transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10" stroke-width="2"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16v-4M12 8h.01"/>
                              </svg>
                              <span class="kpi-tip" style="width:340px;">
                                <template x-if="q.intention_cachee">
                                  <span style="display:block;margin-bottom:8px;">
                                    <span style="display:block;font-size:10px;text-transform:uppercase;letter-spacing:0.05em;color:#94a3b8;margin-bottom:2px;">Hidden intent</span>
                                    <span x-text="q.intention_cachee"></span>
                                  </span>
                                </template>
                                <template x-if="q.signal_positif">
                                  <span style="display:block;margin-bottom:6px;">
                                    <span style="color:#6ee7b7;">&#10003; Positive signal</span><br/>
                                    <span x-text="q.signal_positif"></span>
                                  </span>
                                </template>
                                <template x-if="q.signal_negatif">
                                  <span style="display:block;">
                                    <span style="color:#fca5a5;">&#10007; Negative signal</span><br/>
                                    <span x-text="q.signal_negatif"></span>
                                  </span>
                                </template>
                              </span>
                            </span>
                          </template>
                        </div>
                      </template>
                    </div>
                  </div>
                </template>
              </div>
            </div>
          </template>
        </div>

        <!-- AI Providers selection (Hick's Law: 2 clear choices, Von Restorff: active = coral) -->
        <div class="bg-white rounded-xl border border-gray-100 p-5 mb-4">
          <h3 class="text-sm font-semibold text-charcoal-dark mb-1">AI Providers</h3>
          <p class="text-xs text-charcoal-light mb-4">Choose which AI models to test. Each question is tested against every selected provider.</p>
          <div class="flex items-center gap-3 mb-3">
            <!-- OpenAI pill -->
            <button @click="toggleProvider('openai')"
                    :class="selectedProviders.includes('openai')
                      ? 'bg-coral text-white shadow-sm'
                      : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'"
                    class="px-4 py-2.5 rounded-lg text-sm font-medium transition-all flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" :class="selectedProviders.includes('openai') ? 'bg-white' : 'bg-gray-300'"></span>
              OpenAI <span class="text-[10px] opacity-75">(GPT-4.1-mini)</span>
            </button>
            <!-- Gemini pill -->
            <button @click="toggleProvider('gemini')"
                    :class="selectedProviders.includes('gemini')
                      ? 'bg-coral text-white shadow-sm'
                      : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'"
                    class="px-4 py-2.5 rounded-lg text-sm font-medium transition-all flex items-center gap-2">
              <span class="w-2 h-2 rounded-full" :class="selectedProviders.includes('gemini') ? 'bg-white' : 'bg-gray-300'"></span>
              Gemini <span class="text-[10px] opacity-75">(2.5 Flash)</span>
            </button>
            <span x-show="savingProviders" class="text-[10px] text-charcoal-light">Saving...</span>
          </div>
          <p class="text-xs text-charcoal-light">
            <span x-text="totals.active_questions"></span> questions &times;
            <span x-text="selectedProviders.length"></span> provider<span x-show="selectedProviders.length > 1">s</span>
            = <span class="font-medium text-charcoal-dark" x-text="totals.active_questions * selectedProviders.length"></span> API calls
            (<span x-text="totals.active_questions"></span> credit<span x-show="totals.active_questions !== 1">s</span>)
          </p>
        </div>

        <!-- Footer with live count, cost estimate, Launch button -->
        <div class="bg-white rounded-xl border border-gray-100 p-5 flex items-center justify-between gap-4">
          <div class="flex-1 min-w-0">
            <p class="text-sm text-charcoal-dark font-medium">
              <span x-text="totals.active_personas"></span> personas ·
              <span x-text="totals.active_questions"></span> questions ·
              <span x-text="selectedProviders.length"></span> provider<span x-show="selectedProviders.length > 1">s</span>
            </p>
            <p class="text-xs text-charcoal-light mt-0.5">
              <span class="font-medium text-charcoal-dark" x-text="totals.active_questions * selectedProviders.length"></span> API calls ·
              <span class="font-medium text-charcoal-dark" x-text="totals.active_questions"></span> credit<span x-show="totals.active_questions !== 1">s</span>
            </p>
          </div>
          {isReviewing ? (
            <a href={`/app/scans/${id}`} class="px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all flex items-center gap-2 shrink-0">
              Back to current step
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          ) : (
            <button @click="launchScan()"
                    :disabled="!canLaunch"
                    :title="canLaunch ? 'Launch AI Scan with the current setup' : 'Need at least 1 active persona and 1 active question'"
                    class="px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all flex items-center gap-2 shrink-0 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:hover:shadow-none">
              Launch AI Scan
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
          )}
        </div>

        {/* + Add persona modal — replaces the legacy prompt() with a structured form.
            Quick-add stays one field (just name); power users can expand "Optional context"
            to pre-fill profile / intentions / pain points / keywords. Empty optional
            fields → worker generates questions from topic context only (legacy behavior). */}
        <div x-show="addPersonaModal.open"
             x-cloak
             @keydown.escape.window="closeAddPersonaModal()"
             class="fixed inset-0 z-50 flex items-start justify-center p-4 sm:p-8 bg-charcoal-dark/40 backdrop-blur-sm overflow-y-auto"
             @click.self="closeAddPersonaModal()">
          <div class="bg-white rounded-xl shadow-xl w-full max-w-lg my-8 overflow-hidden"
               @click.stop>
            <div class="px-5 py-3.5 border-b border-gray-100 flex items-center justify-between">
              <div class="min-w-0">
                <h3 class="text-base font-bold text-charcoal-dark">Add a custom persona</h3>
                <p class="text-xs text-charcoal-light mt-0.5">
                  on topic <span class="font-medium text-charcoal-dark" x-text="addPersonaModal.topic?.topic_name"></span>
                </p>
              </div>
              <button type="button" @click="closeAddPersonaModal()"
                      class="shrink-0 w-7 h-7 rounded-md text-charcoal-light hover:bg-gray-100 hover:text-charcoal-dark transition-colors flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>

            <form @submit.prevent="submitAddPersona()" class="px-5 py-4 space-y-4">
              {/* Required: name */}
              <div>
                <label for="add-persona-name-input" class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Name <span class="text-red-500">*</span></label>
                <input id="add-persona-name-input"
                       type="text"
                       x-model="addPersonaModal.name"
                       required
                       placeholder="e.g. Marie, busy mom, dry-skin baby"
                       class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 mt-1 outline-none focus:border-coral" />
                <p class="text-[10px] text-charcoal-light/70 mt-1">A short identity — first name + 1-line description works well.</p>
              </div>

              {/* Optional context — collapsible to keep quick-add fast */}
              <div class="rounded-lg border border-gray-100 bg-gray-50/40">
                <button type="button" @click="addPersonaModal.showOptional = !addPersonaModal.showOptional"
                        class="w-full px-3 py-2 flex items-center gap-2 text-xs text-charcoal-dark hover:bg-gray-100/60 transition-colors rounded-lg">
                  <svg class="w-3 h-3 text-charcoal-light shrink-0 transition-transform"
                       :class="addPersonaModal.showOptional ? 'rotate-90' : ''"
                       fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                  <span class="font-medium">Optional context</span>
                  <span class="text-[10px] text-charcoal-light/80">— helps generate more relevant questions</span>
                </button>

                <div x-show="addPersonaModal.showOptional" x-collapse class="px-3 pb-3 pt-1 space-y-3">
                  {/* Profil démo: 3 inline fields */}
                  <div>
                    <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Profile</label>
                    <div class="grid grid-cols-3 gap-2 mt-1">
                      <input type="text" x-model="addPersonaModal.age" placeholder="Age (e.g. 28)"
                             class="text-xs border border-gray-200 rounded-md px-2 py-1.5 outline-none focus:border-coral" />
                      <input type="text" x-model="addPersonaModal.situation" placeholder="Situation (e.g. mère 2 enfants)"
                             class="text-xs border border-gray-200 rounded-md px-2 py-1.5 outline-none focus:border-coral" />
                      <select x-model="addPersonaModal.niveau"
                              class="text-xs border border-gray-200 rounded-md px-2 py-1.5 outline-none focus:border-coral bg-white">
                        <option value="debutant">Débutant</option>
                        <option value="intermediaire">Intermédiaire</option>
                        <option value="expert">Expert</option>
                      </select>
                    </div>
                  </div>

                  {/* Intentions de recherche */}
                  <div>
                    <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Intentions de recherche</label>
                    <textarea x-model="addPersonaModal.intentions" rows="2"
                              placeholder="One per line — e.g.&#10;Trouver une crème adaptée&#10;Comprendre les actifs hydratants"
                              class="w-full text-xs border border-gray-200 rounded-md px-2 py-1.5 mt-1 outline-none focus:border-coral resize-y font-mono"></textarea>
                  </div>

                  {/* Points de douleur */}
                  <div>
                    <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Points de douleur</label>
                    <textarea x-model="addPersonaModal.pain" rows="2"
                              placeholder="One per line — e.g.&#10;Peau qui tire après la douche&#10;Routine trop compliquée"
                              class="w-full text-xs border border-gray-200 rounded-md px-2 py-1.5 mt-1 outline-none focus:border-coral resize-y font-mono"></textarea>
                  </div>

                  {/* Keywords */}
                  <div>
                    <label class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold">Keywords (comma-separated)</label>
                    <input type="text" x-model="addPersonaModal.keywords"
                           placeholder="crème hydratante, peau sèche, acide hyaluronique"
                           class="w-full text-xs border border-gray-200 rounded-md px-2 py-1.5 mt-1 outline-none focus:border-coral" />
                  </div>

                  <p class="text-[10px] text-charcoal-light/80 italic pt-1">
                    Leave any field empty if you don't have data — empty fields are simply ignored when generating the 15 questions.
                  </p>
                </div>
              </div>
            </form>

            <div class="px-5 py-3 border-t border-gray-100 flex items-center justify-end gap-2">
              <button type="button" @click="closeAddPersonaModal()"
                      class="text-sm text-charcoal-light hover:text-charcoal-dark px-3 py-1.5 rounded-md hover:bg-gray-50 transition-colors">
                Cancel
              </button>
              <button type="button" @click="submitAddPersona()"
                      :disabled="!addPersonaModal.name.trim() || addPersonaModal.submitting"
                      :class="(!addPersonaModal.name.trim() || addPersonaModal.submitting) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                      class="text-sm bg-coral text-white px-4 py-1.5 rounded-md font-medium transition-colors">
                <span x-show="!addPersonaModal.submitting">Add persona &amp; generate questions</span>
                <span x-show="addPersonaModal.submitting">Adding...</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Failed -->
    {scan.status === 'failed' && (() => {
      const isPermanent = scan.summary && scan.summary.retryable === false;
      return (
        <div class="bg-red-50 border border-red-200 rounded-xl p-6" x-data="{ retrying: false, error: '' }">
          <h2 class="text-lg font-bold text-red-700 mb-2">Scan failed</h2>
          <p class="text-sm text-red-600 whitespace-pre-line">{scan.error_message || 'An unexpected error occurred.'}</p>
          <p x-show="error" x-text="error" class="text-sm text-red-700 mt-2 font-medium"></p>
          <div class="mt-4 flex gap-3">
            {!isPermanent && (
              <button type="button"
                      @click={`retrying = true; error = ''; fetch('/api/scans/${id}/retry', {method:'POST'}).then(async r => { if (r.ok) { location.reload(); } else { const j = await r.json().catch(()=>({})); error = j.detail?.message || j.detail || 'Retry failed'; retrying = false; } }).catch(e => { error = e.message; retrying = false; });`}
                      :disabled="retrying"
                      :class="retrying ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark hover:shadow-md hover:scale-[1.02]'"
                      class="px-4 py-2 bg-coral text-white rounded-lg text-sm font-medium transition-all">
                <span x-show="!retrying">Retry from where it failed</span>
                <span x-show="retrying">Retrying…</span>
              </button>
            )}
            <a href="/app/scans/new"
               class={`px-4 py-2 ${isPermanent ? 'bg-coral text-white hover:bg-coral-dark hover:shadow-md hover:scale-[1.02]' : 'border border-gray-300 text-charcoal-dark hover:bg-gray-50'} rounded-lg text-sm font-medium transition-all`}>
              {isPermanent ? 'Try a different domain' : 'Start a new scan instead'}
            </a>
          </div>
        </div>
      );
    })()}
  </div>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('topicsWizard', (initialTopics, scanId) => ({
        topics: initialTopics,
        expanded: null,
        scanId: scanId,
        moveModal: { open: false, type: '', item: null, sourceTopic: null, search: '', selectedIdx: 0 },

        openMove(type, item, sourceTopic) {
          this.moveModal.open = true;
          this.moveModal.type = type;
          this.moveModal.item = item;
          this.moveModal.sourceTopic = sourceTopic;
          this.moveModal.search = '';
          this.moveModal.selectedIdx = 0;
          this.$nextTick(() => {
            if (this.$refs.moveSearch) this.$refs.moveSearch.focus();
          });
        },

        closeMove() {
          this.moveModal.open = false;
        },

        moveFilteredTopics() {
          if (!this.moveModal.sourceTopic) return [];
          const q = (this.moveModal.search || '').toLowerCase();
          const srcId = this.moveModal.sourceTopic.id;
          return this.topics
            .filter(t => t.id !== srcId && t.active)
            .filter(t => !q || (t.name || '').toLowerCase().includes(q) || (t.description || '').toLowerCase().includes(q));
        },

        moveMdlPath(page) {
          const u = typeof page === 'string' ? page : page.url;
          try {
            return new URL(u.startsWith('http') ? u : 'https://' + u).pathname;
          } catch (e) {
            return u;
          }
        },

        moveMdlMeta() {
          const m = this.moveModal;
          if (!m.item) return '';
          if (m.type === 'keyword') {
            const pages = m.item.pages_count || 0;
            const traffic = (m.item.traffic || 0).toLocaleString();
            const pos = m.item.position || '—';
            return pages + ' page' + (pages > 1 ? 's' : '') + ' · ' + traffic + ' traffic · position ' + pos;
          } else {
            const kwC = m.item.keywords_count || 0;
            const traffic = (m.item.traffic || 0).toLocaleString();
            return kwC + ' keywords · ' + traffic + ' traffic';
          }
        },

        executeMove(targetTopic) {
          const { type, item, sourceTopic } = this.moveModal;
          if (!targetTopic || !sourceTopic) return;
          const src = sourceTopic;
          const tgt = targetTopic;
          const sid = this.scanId;

          if (type === 'keyword') {
            const k = item.keyword;
            const kwObj = { ...item };
            fetch('/api/scans/' + sid + '/topics/' + tgt.id + '/move-keyword', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ keyword: k, source_topic_id: src.id }),
            })
              .then(r => r.json())
              .then(data => {
                src.top_keywords = src.top_keywords.filter(x => x.keyword !== k);
                if (src.allKeywords) src.allKeywords = src.allKeywords.filter(x => x.keyword !== k);
                src.keyword_count = data.source_count;
                tgt.keyword_count = data.target_count;
                src.total_urls = data.source_total_urls;
                tgt.total_urls = data.target_total_urls;
                tgt.top_keywords = [...tgt.top_keywords, kwObj];
                if (tgt.allKeywords) tgt.allKeywords = [...tgt.allKeywords, kwObj];
                return Promise.all([
                  fetch('/api/scans/' + sid + '/topics/' + src.id + '/urls').then(r => r.json()),
                  fetch('/api/scans/' + sid + '/topics/' + tgt.id + '/urls').then(r => r.json()),
                ]);
              })
              .then(([srcData, tgtData]) => {
                src.top_urls = (srcData.urls || []).slice(0, 5);
                src.allUrls = src.allUrls ? srcData.urls : null;
                tgt.top_urls = (tgtData.urls || []).slice(0, 5);
                tgt.allUrls = tgt.allUrls ? tgtData.urls : null;
              })
              .catch(e => console.error('Move keyword failed:', e));
          } else if (type === 'page') {
            const u = typeof item === 'string' ? item : item.url;
            const moved = typeof item === 'object' ? { ...item } : item;
            fetch('/api/scans/' + sid + '/topics/' + tgt.id + '/move-url', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ url: u }),
            })
              .then(r => r.json())
              .then(data => {
                src.top_urls = src.top_urls.filter(p => (typeof p === 'string' ? p : p.url) !== u);
                if (src.allUrls) src.allUrls = src.allUrls.filter(p => (typeof p === 'string' ? p : p.url) !== u);
                src.total_urls--;
                if (data.source_counts && data.source_counts[src.id] !== undefined) {
                  src.keyword_count = data.source_counts[src.id];
                }
                tgt.top_urls = [...tgt.top_urls, moved];
                if (tgt.allUrls) tgt.allUrls = [...tgt.allUrls, moved];
                tgt.total_urls++;
                tgt.keyword_count = data.target_count;
              })
              .catch(e => console.error('Move page failed:', e));
          }
          this.closeMove();
        },

        async toggleTopic(topic) {
          topic.active = !topic.active;
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/topics/' + topic.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_active: topic.active }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
          } catch (e) {
            topic.active = !topic.active; // revert
            console.error('Toggle topic failed:', e);
          }
        },

        async validateTopics() {
          const inactive = this.topics.filter(t => !t.active);
          for (const t of inactive) {
            await fetch('/api/scans/' + this.scanId + '/topics/' + t.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_active: false }),
            });
          }
          const res = await fetch('/api/scans/' + this.scanId + '/topics/validate', { method: 'POST' });
          if (res.ok) {
            location.href = '/app/scans/' + this.scanId;
          } else {
            alert('Validation failed: ' + res.status);
          }
        },
      }));

      // Pipeline timeline — polls /pipeline every 3 s and renders the per-step
       // status. Auto-reloads the page when the scan flips to a terminal status
       // (completed/failed) so the user lands on Results without F5.
      window.Alpine.data('scanPipeline', (scanId) => ({
        scanId,
        steps: [],
        scanStatus: 'scanning',
        overallPct: 0,
        summary: { completed: 0, total: 0, eta: '' },
        elapsedMs: 0,
        _pollTimer: null,
        _clockTimer: null,

        start() {
          this.fetchPipeline();
          this._pollTimer = setInterval(() => this.fetchPipeline(), 3000);
          // Sub-second clock for the running step's elapsed counter — feels
          // alive even between 3-second polls.
          this._clockTimer = setInterval(() => {
            for (const s of this.steps) {
              if (s.status === 'running' && s.elapsed_ms != null) s.elapsed_ms += 1000;
            }
            this.elapsedMs += 1000;
          }, 1000);
        },

        async fetchPipeline() {
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/pipeline');
            if (!res.ok) return;
            const data = await res.json();
            this.steps = data.steps || [];
            this.scanStatus = data.scan_status;
            this.elapsedMs = data.total_elapsed_ms || 0;
            // Add the live elapsed of any running step to the running total
            for (const s of this.steps) {
              if (s.status === 'running' && s.elapsed_ms) this.elapsedMs += s.elapsed_ms;
            }
            this.summary = {
              completed: data.completed_steps,
              total: data.total_steps,
              eta: this.formatDuration(data.remaining_eta_seconds * 1000),
            };
            // Compute overall pct from steps (completed = full weight, running = half).
            // Pure-progress UX trick: each step contributes evenly, running adds 50%
            // of its weight so we don't ever look stuck at integer percentages.
            const total = Math.max(1, data.total_steps);
            const done = data.completed_steps;
            const partial = this.steps.filter(s => s.status === 'running').length * 0.5;
            this.overallPct = Math.min(99, Math.round(((done + partial) / total) * 100));
            if (data.scan_status === 'completed') {
              this.overallPct = 100;
              this._stopPolling();
              setTimeout(() => window.location.reload(), 1200);
            } else if (data.scan_status === 'failed') {
              this._stopPolling();
              setTimeout(() => window.location.reload(), 1500);
            }
          } catch (e) {
            console.error('pipeline poll failed', e);
          }
        },

        _stopPolling() {
          if (this._pollTimer) { clearInterval(this._pollTimer); this._pollTimer = null; }
          if (this._clockTimer) { clearInterval(this._clockTimer); this._clockTimer = null; }
        },

        formatDuration(ms) {
          if (!ms || ms < 0) return '';
          const s = Math.round(ms / 1000);
          if (s < 60) return s + 's';
          const m = Math.floor(s / 60);
          const r = s % 60;
          if (m < 60) return r === 0 ? m + 'm' : m + 'm ' + r + 's';
          const h = Math.floor(m / 60);
          return h + 'h ' + (m % 60) + 'm';
        },

        formatStepTime(step) {
          if (step.status === 'completed' && step.duration_ms != null) {
            return this.formatDuration(step.duration_ms);
          }
          if (step.status === 'running') {
            const elapsed = this.formatDuration(step.elapsed_ms);
            const eta = step.eta_seconds ? ' · ETA ' + this.formatDuration(step.eta_seconds * 1000) : '';
            return elapsed + eta;
          }
          if (step.status === 'pending' || step.status === 'queued') {
            return step.eta_seconds ? '~' + this.formatDuration(step.eta_seconds * 1000) : '';
          }
          if (step.status === 'failed') {
            return 'Failed';
          }
          return '';
        },

        get elapsedDisplay() {
          return this.formatDuration(this.elapsedMs) || '0s';
        },
      }));

      window.Alpine.data('scanBrands', (initialData, scanId) => ({
        scanId: scanId,
        buckets: {
          my_brand: (initialData.buckets && initialData.buckets.my_brand) || [],
          competitor: (initialData.buckets && initialData.buckets.competitor) || [],
          ignored: (initialData.buckets && initialData.buckets.ignored) || [],
          unclassified: (initialData.buckets && initialData.buckets.unclassified) || [],
        },
        focusBrandId: initialData.focus_brand_id || null,
        dragOver: null,
        dragged: null,
        draggedFrom: null,

        // Expand/collapse state for parent brands.
        // Default: my_brand + ignored stay expanded (showing the user's
        // own product lines is informative); competitors start COLLAPSED
        // (when a brief surfaces 30+ competitors with 5 gammes each, an
        // expanded tree would push the page below the fold and dilute
        // the focus signal). Users still click the chevron to expand.
        collapsedBrandIds: Object.fromEntries(
          ((initialData.buckets && initialData.buckets.competitor) || [])
            .filter(b => b.children && b.children.length > 0)
            .map(b => [b.brand_id, true])
        ),
        isBrandExpanded(brandId) {
          return !this.collapsedBrandIds[brandId];
        },
        toggleBrandExpand(brandId) {
          if (this.collapsedBrandIds[brandId]) {
            delete this.collapsedBrandIds[brandId];
          } else {
            this.collapsedBrandIds[brandId] = true;
          }
        },
        // Mark every competitor parent (that has children) as collapsed.
        // Used after refreshFromBrief / classify changes that may add new
        // competitor rows — keeps the bucket compact by default.
        _collapseAllCompetitorParents() {
          for (const b of (this.buckets.competitor || [])) {
            if (b.children && b.children.length > 0) {
              this.collapsedBrandIds[b.brand_id] = true;
            }
          }
        },

        // Count items (parents + nested children) in a given bucket
        bucketCount(name) {
          return (this.buckets[name] || []).reduce(
            (sum, b) => sum + 1 + ((b.children && b.children.length) || 0),
            0
          );
        },

        get myBrandsCount() {
          return this.bucketCount('my_brand');
        },

        // Flattened view of unclassified for the inbox pill layout
        get flatUnclassified() {
          const out = [];
          for (const p of (this.buckets.unclassified || [])) {
            out.push(p);
            if (p.children && p.children.length) {
              for (const c of p.children) out.push(c);
            }
          }
          return out;
        },

        get hasFocus() {
          return this.focusBrandId !== null && this.focusBrandId !== undefined;
        },

        // Focus is always on a parent in my_brand (never a child — backend enforces this)
        getFocusName() {
          if (!this.hasFocus) return 'none selected';
          const b = this.buckets.my_brand.find(x => x.brand_id === this.focusBrandId);
          return b ? b.name : 'none selected';
        },

        // Remove a brand from ANY bucket (parent or child). Returns the removed item
        // (with children attached if it was a parent) or null if not found.
        _removeFromBucket(bucketName, brandId) {
          const arr = this.buckets[bucketName];
          if (!arr) return null;
          const parentIdx = arr.findIndex(b => b.brand_id === brandId);
          if (parentIdx >= 0) {
            return arr.splice(parentIdx, 1)[0];
          }
          for (const parent of arr) {
            if (!parent.children) continue;
            const childIdx = parent.children.findIndex(c => c.brand_id === brandId);
            if (childIdx >= 0) {
              return parent.children.splice(childIdx, 1)[0];
            }
          }
          return null;
        },

        // Insert an item into a target bucket, nesting it under its parent if that
        // parent is already present as a root in the same bucket; otherwise add as
        // a flat root. Mirrors the server-side nesting logic in GET /brands.
        _insertIntoBucket(bucketName, item) {
          const arr = this.buckets[bucketName];
          if (!arr) return;
          const pid = item.parent_id;
          if (pid) {
            const parent = arr.find(b => b.brand_id === pid);
            if (parent) {
              parent.children = [...(parent.children || []), item];
              return;
            }
          }
          // Add as root — ensure children array exists
          if (!item.children) item.children = [];
          // If this newly-arrived ROOT has orphan children already sitting flat in the
          // bucket (children whose parent_id matches this item's brand_id), absorb them.
          const orphans = arr.filter(b => b.parent_id === item.brand_id);
          if (orphans.length > 0) {
            for (const o of orphans) {
              const idx = arr.findIndex(x => x.brand_id === o.brand_id);
              if (idx >= 0) arr.splice(idx, 1);
            }
            item.children = [...item.children, ...orphans];
          }
          this.buckets[bucketName] = [...arr, item];
        },

        onDragStart(event, brand, fromBucket) {
          this.dragged = brand;
          this.draggedFrom = fromBucket;
          if (event.dataTransfer) {
            event.dataTransfer.effectAllowed = 'move';
            try { event.dataTransfer.setData('text/plain', brand.brand_id); } catch (e) {}
          }
        },

        onDrop(targetBucket) {
          this.dragOver = null;
          const brand = this.dragged;
          const fromBucket = this.draggedFrom;
          this.dragged = null;
          this.draggedFrom = null;
          if (!brand || !fromBucket || fromBucket === targetBucket) return;

          // Optimistic local move — remove from source, re-nest into target
          const moved = this._removeFromBucket(fromBucket, brand.brand_id) || { ...brand };

          // If this brand was a root WITH children and it's being reclassified, its
          // children stay attached to it (they move WITH the parent into the target bucket).
          // If it was a child being moved alone, moved.children is empty/undefined (as expected).

          // Clear focus state if moving out of my_brand
          if (moved.is_focus && targetBucket !== 'my_brand') {
            moved.is_focus = false;
            if (this.focusBrandId === moved.brand_id) this.focusBrandId = null;
          }
          if (targetBucket !== 'my_brand') moved.is_focus = false;

          this._insertIntoBucket(targetBucket, moved);

          // Persist — note: if moved had children, they don't get individual classify calls
          // because their SBC rows are unchanged. The parent's classify is enough.
          // If user wants children to move WITH parent, we'd need a cascade endpoint.
          // For now, children SBC rows stay as-is on the server → on next page reload,
          // the orphaned children re-nest under parent in the new bucket if their SBC
          // classification matches. Else they become orphans in their own classification.
          fetch('/api/scans/' + this.scanId + '/brands/classify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ brand_id: brand.brand_id, classification: targetBucket }),
          }).catch(e => console.error('Classify failed:', e));
        },

        async toggleFocus(brand) {
          // Already focus → no-op (user must star a different brand to unset)
          if (brand.is_focus) return;

          // Snapshot prior focus so we can revert if the backend refuses
          // (e.g. brand has parent_id ≠ NULL → "must be a root brand" 400).
          const priorFocusId = this.focusBrandId;
          this.buckets.my_brand = this.buckets.my_brand.map(b => ({
            ...b,
            is_focus: b.brand_id === brand.brand_id,
          }));
          this.focusBrandId = brand.brand_id;

          try {
            const res = await fetch('/api/scans/' + this.scanId + '/brands/classify', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ brand_id: brand.brand_id, classification: 'my_brand', is_focus: true }),
            });
            if (!res.ok) {
              const t = await res.text();
              // Revert optimistic state — the star never persisted.
              this.buckets.my_brand = this.buckets.my_brand.map(b => ({
                ...b,
                is_focus: b.brand_id === priorFocusId,
              }));
              this.focusBrandId = priorFocusId;
              alert('Cannot set focus: ' + res.status + ' ' + t);
            }
          } catch (e) {
            console.error('Set focus failed:', e);
            this.buckets.my_brand = this.buckets.my_brand.map(b => ({
              ...b,
              is_focus: b.brand_id === priorFocusId,
            }));
            this.focusBrandId = priorFocusId;
            alert('Set focus failed: ' + e.message);
          }
        },

        removeBrand(brand, fromBucket) {
          if (fromBucket === 'ignored') return;
          const moved = this._removeFromBucket(fromBucket, brand.brand_id) || { ...brand };
          moved.is_focus = false;
          if (this.focusBrandId === brand.brand_id) {
            this.focusBrandId = null;
          }
          this._insertIntoBucket('ignored', moved);

          fetch('/api/scans/' + this.scanId + '/brands/classify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ brand_id: brand.brand_id, classification: 'ignored' }),
          }).catch(e => console.error('Remove brand failed:', e));
        },

        // Count of inbox items the LLM flagged as "commercial brand but not
        // in your watchlist" (source = 'auto_discovered'). Drives the dedicated
        // "Promote all 🔍 to Competitors" CTA so the user can opt in to track
        // them without manually drag-and-dropping each one.
        get discoveredCount() {
          return this.flatUnclassified.filter(b => b.source === 'auto_discovered').length;
        },

        // Free-text filter applied to inbox names (case-insensitive substring).
        inboxFilter: '',

        // Group inbox brands by name-prefix overlap. If "Bondi Sands" + "Bondi
        // Sands Technocolor ..." both exist, the second nests under the first.
        // Generic algo — purely string-based, multi-vertical safe.
        get discoveredGrouped() {
          const filter = (this.inboxFilter || '').trim().toLowerCase();
          let items = this.flatUnclassified;
          if (filter) items = items.filter(b => (b.name || '').toLowerCase().includes(filter));
          // Sort shortest first — shorter names become parents, longer "{parent} suffix" become children
          const sorted = [...items].sort((a, b) => (a.name || '').length - (b.name || '').length);
          const families = [];
          const childrenByParentId = new Map();
          for (const item of sorted) {
            const lname = (item.name || '').toLowerCase();
            let parent = null;
            for (const f of families) {
              const pname = (f.parent.name || '').toLowerCase();
              if (!pname) continue;
              // Match when item's name starts with "{parent} " (parent is a true prefix-word)
              if (lname.startsWith(pname + ' ') || lname.startsWith(pname + '-')) {
                parent = f;
                break;
              }
            }
            if (parent) {
              parent.children.push(item);
            } else {
              families.push({ parent: item, children: [] });
            }
          }
          // Stable sort: discovered (🔍) first, then by name asc, so the user
          // sees actionable rows at the top.
          families.sort((a, b) => {
            const ad = a.parent.source === 'auto_discovered' ? 0 : 1;
            const bd = b.parent.source === 'auto_discovered' ? 0 : 1;
            if (ad !== bd) return ad - bd;
            return (a.parent.name || '').localeCompare(b.parent.name || '');
          });
          return families;
        },

        // Per-row actions — wraps the existing bulk-classify endpoint with a
        // single-item array. Optimistic UI: remove from inbox first, rollback
        // on backend error.
        async _classifyOne(brand, target_bucket) {
          this._removeFromBucket('unclassified', brand.brand_id);
          brand.children = [];
          this._insertIntoBucket(target_bucket, brand);
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/bulk-classify',
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  brand_ids: [brand.brand_id],
                  classification: target_bucket,
                }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Action failed: ' + res.status + ' ' + t);
              this._removeFromBucket(target_bucket, brand.brand_id);
              this._insertIntoBucket('unclassified', brand);
            }
          } catch (e) {
            console.error('_classifyOne failed:', e);
            this._removeFromBucket(target_bucket, brand.brand_id);
            this._insertIntoBucket('unclassified', brand);
          }
        },
        promoteOne(brand) { return this._classifyOne(brand, 'competitor'); },
        ignoreOne(brand)  { return this._classifyOne(brand, 'ignored'); },

        // Family actions — apply to parent + all its inbox children in one
        // call. Server-side bulk-classify is N→1 SQL update so the cost is
        // identical regardless of family size.
        async _classifyFamily(family, target_bucket) {
          const items = [family.parent, ...family.children];
          for (const b of items) {
            this._removeFromBucket('unclassified', b.brand_id);
            b.children = [];
            this._insertIntoBucket(target_bucket, b);
          }
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/bulk-classify',
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  brand_ids: items.map(b => b.brand_id),
                  classification: target_bucket,
                }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Family action failed: ' + res.status + ' ' + t);
            }
          } catch (e) {
            console.error('_classifyFamily failed:', e);
            alert('Family action failed: ' + e.message);
          }
        },
        promoteFamily(family) { return this._classifyFamily(family, 'competitor'); },
        ignoreFamily(family)  { return this._classifyFamily(family, 'ignored'); },

        // Empty the Ignored bucket — drops the per-scan classification rows
        // for everything currently ignored on this scan. The client_brands
        // catalog stays intact; if a rescan re-surfaces the same name it
        // re-appears in the inbox for fresh triage.
        emptyingIgnored: false,
        async emptyIgnored() {
          if (this.emptyingIgnored) return;
          const count = this.bucketCount('ignored');
          if (count === 0) return;
          if (!confirm(`Empty Ignored (${count} brand${count > 1 ? 's' : ''})?\n\nThis clears them from THIS scan only. The brand catalog stays — they may reappear on a rescan if detected again.`)) return;
          this.emptyingIgnored = true;
          const snapshot = this.buckets.ignored;
          this.buckets.ignored = [];  // optimistic
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/empty-bucket',
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ classification: 'ignored' }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Empty failed: ' + res.status + ' ' + t);
              this.buckets.ignored = snapshot;  // rollback
            }
          } catch (e) {
            console.error('emptyIgnored failed:', e);
            alert('Empty failed: ' + e.message);
            this.buckets.ignored = snapshot;
          } finally {
            this.emptyingIgnored = false;
          }
        },

        // Bulk-promote the discovered set to Competitors. Calls the existing
        // bulk-classify endpoint with classification='competitor'. Optimistic UI:
        // moves the pills locally first, rolls back on backend failure.
        promotingDiscovered: false,
        async promoteAllDiscovered() {
          if (this.promotingDiscovered) return;
          const items = this.flatUnclassified.filter(b => b.source === 'auto_discovered');
          if (items.length === 0) return;
          if (!confirm(`Promote ${items.length} discovered brand${items.length > 1 ? 's' : ''} to Competitors?\n\nThey become tracked alongside your watchlist competitors.`)) return;
          this.promotingDiscovered = true;
          // Optimistic
          for (const b of items) {
            this._removeFromBucket('unclassified', b.brand_id);
            b.children = [];
            this._insertIntoBucket('competitor', b);
          }
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/bulk-classify',
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  brand_ids: items.map(b => b.brand_id),
                  classification: 'competitor',
                }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Promote failed: ' + res.status + ' ' + t);
            }
          } catch (e) {
            console.error('promoteAllDiscovered failed:', e);
            alert('Promote failed: ' + e.message);
          } finally {
            this.promotingDiscovered = false;
          }
        },

        // Bulk-ignore every brand currently sitting in the amber inbox.
        // Mirrors what cleanup_brands does for noise items, but exposed as a
        // user gesture for scans where cleanup_brands either failed or where
        // the user wants instant triage without waiting for the LLM pass.
        // Posts ONE call instead of N (avoids 2000+ classify POSTs).
        bulkIgnoringUnclassified: false,
        async bulkIgnoreUnclassified() {
          if (this.bulkIgnoringUnclassified) return;
          const items = [...this.flatUnclassified];
          if (items.length === 0) return;
          if (!confirm(`Mark ${items.length} brand${items.length > 1 ? 's' : ''} as ignored?\n\nThis moves them out of the inbox. You can still drag them back later.`)) return;
          this.bulkIgnoringUnclassified = true;
          // Optimistic: drain inbox + drop everything in Ignored
          this.buckets.unclassified = [];
          for (const b of items) {
            b.children = []; // flat now — bulk ignore doesn't preserve nesting
            this._insertIntoBucket('ignored', b);
          }
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/bulk-classify',
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  brand_ids: items.map(b => b.brand_id),
                  classification: 'ignored',
                }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Bulk ignore failed: ' + res.status + ' ' + t);
            }
          } catch (e) {
            console.error('bulkIgnoreUnclassified failed:', e);
            alert('Bulk ignore failed: ' + e.message);
          } finally {
            this.bulkIgnoringUnclassified = false;
          }
        },

        // × on Ignored — really remove the brand from this scan (deletes the
        // per-scan classification row). The client_brands row stays so future
        // scans / other workspaces aren't affected.
        async deleteBrandFromScan(brand, fromBucket) {
          this._removeFromBucket(fromBucket, brand.brand_id);
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/' + brand.brand_id,
              { method: 'DELETE' },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Could not remove brand: ' + res.status + ' ' + t);
              // Best-effort re-insert so the UI doesn't lie about the state
              this._insertIntoBucket(fromBucket, brand);
            }
          } catch (e) {
            console.error('deleteBrandFromScan failed:', e);
            this._insertIntoBucket(fromBucket, brand);
          }
        },

        // Drag-to-parent — when a brand is dropped onto a root row in the same
        // bucket, nest it under that root. The hierarchy lives on
        // client_brands.parent_id (client-scoped), so the change applies to
        // every scan in the workspace — that's the intended behaviour, the
        // brand catalogue is canonical.
        dragOverParent: null,  // brand_id of the parent the cursor is hovering
        async reparentBrand(brand, targetParent, bucket) {
          if (!brand || !targetParent) return;
          if (brand.brand_id === targetParent.brand_id) return;
          // Optimistic UI: detach from current location, nest under target
          const moved = this._removeFromBucket(bucket, brand.brand_id) || { ...brand };
          moved.parent_id = targetParent.brand_id;
          // Drop any focus / children — children of children isn't supported
          moved.is_focus = false;
          moved.children = [];
          if (!targetParent.children) targetParent.children = [];
          targetParent.children.push(moved);
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/brands/' + brand.brand_id + '/parent',
              {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ parent_id: targetParent.brand_id }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Could not reparent: ' + res.status + ' ' + t);
              // Roll back: pop the optimistic child and put back at root
              const idx = targetParent.children.findIndex(c => c.brand_id === moved.brand_id);
              if (idx >= 0) targetParent.children.splice(idx, 1);
              moved.parent_id = null;
              this._insertIntoBucket(bucket, moved);
            }
          } catch (e) {
            console.error('reparent failed:', e);
          }
        },

        // Used by the @drop on a parent row: extract the dragged brand from
        // dataTransfer + current state and ask reparentBrand to nest it.
        onDropOnParent(event, targetParent, bucket) {
          this.dragOverParent = null;
          const brand = this.dragged;
          const fromBucket = this.draggedFrom;
          this.dragged = null;
          this.draggedFrom = null;
          if (!brand || !targetParent) return;
          // Same-bucket only — cross-bucket reparent isn't supported (backend
          // rejects it with 400 anyway, the early return keeps UX honest).
          if (fromBucket !== bucket) return;
          this.reparentBrand(brand, targetParent, bucket);
        },

        // Idempotent re-sync against the current Domain Brief. The first
        // import happens automatically when the brief is generated (see
        // worker/handlers/generate_domain_brief.py). This button is for the
        // case where the user edits the brief after Gate 2 is reachable.
        refreshingFromBrief: false,
        async refreshFromBrief() {
          if (this.refreshingFromBrief) return;
          this.refreshingFromBrief = true;
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/brands/import-from-brief', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
            });
            if (!res.ok) {
              const t = await res.text();
              alert('Refresh failed: ' + res.status + ' ' + t);
              return;
            }
            const data = await res.json();
            // Reload bucket state from server (single source of truth re. parent_id nesting)
            const brandsRes = await fetch('/api/scans/' + this.scanId + '/brands');
            if (brandsRes.ok) {
              const fresh = await brandsRes.json();
              this.buckets.my_brand = fresh.buckets?.my_brand || [];
              this.buckets.competitor = fresh.buckets?.competitor || [];
              this.buckets.ignored = fresh.buckets?.ignored || [];
              this.buckets.unclassified = fresh.buckets?.unclassified || [];
              this.focusBrandId = fresh.focus_brand_id || null;
              // Keep competitor parents collapsed after refresh — same default
              // as initial page load (avoids the bucket exploding to N×5 rows
              // when a brief surfaces a long competitor list).
              this._collapseAllCompetitorParents();
            }
            const parts = [];
            if (data.created_brands) parts.push(data.created_brands + ' new competitor' + (data.created_brands > 1 ? 's' : ''));
            if (data.created_gammes) parts.push(data.created_gammes + ' product line' + (data.created_gammes > 1 ? 's' : ''));
            const msg = parts.length
              ? 'Added ' + parts.join(' + ') + ' from brief'
              : 'Already in sync with the brief';
            console.info('[brands] ' + msg);
          } catch (e) {
            console.error('refreshFromBrief failed:', e);
            alert('Refresh failed: ' + e.message);
          } finally {
            this.refreshingFromBrief = false;
          }
        },

        validateBrands() {
          if (!this.hasFocus || this.myBrandsCount === 0) {
            alert('Pick at least one My Brand and set a focus brand before continuing.');
            return;
          }
          if (this.flatUnclassified.length > 0) {
            alert('Please classify all brands in the amber inbox before continuing.');
            return;
          }
          fetch('/api/scans/' + this.scanId + '/brands/validate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
          }).then(res => {
            if (res.ok) {
              location.href = '/app/scans/' + this.scanId;
            } else {
              return res.text().then(t => { alert('Validation failed: ' + res.status + ' ' + t); });
            }
          }).catch(e => {
            console.error('Validate brands failed:', e);
            alert('Validation failed: ' + e.message);
          });
        },
      }));

      window.Alpine.data('personasWizard', (initialData, scanId, initialProviders) => ({
        scanId: scanId,
        // Annotate each topic with `editing` so the in-place rename UI in the
        // topic header has a flag to toggle. Mirrors topicsWizard's pattern.
        topics: ((initialData && initialData.topics) || []).map(t => ({ ...t, editing: false })),
        orphanPersonas: (initialData && initialData.orphan_personas) || [],
        totals: (initialData && initialData.totals) || { total_personas: 0, active_personas: 0, total_questions: 0, active_questions: 0 },
        selectedProviders: initialProviders || ['openai'],
        savingProviders: false,
        expandedTopic: null,
        expandedPersona: {},
        editingPersonaId: null,
        editingPersonaName: '',
        editingQuestionId: null,
        editingQuestionText: '',
        generatingPersonaId: null,
        expandedTypeGroups: {},  // { 'personaId:type': true }

        // Rename a topic from the Personas page. Same endpoint as the Topics
        // page edit. Idempotent + tolerates double-fire (Enter+blur cascade)
        // by checking that the local name actually changed.
        _lastSavedTopicName: {},
        async saveTopicName(topic) {
          topic.editing = false;
          const text = (topic.topic_name || '').trim();
          if (!text) {
            alert('Topic name cannot be empty.');
            return;
          }
          topic.topic_name = text;
          if (this._lastSavedTopicName[topic.topic_id] === text) return;
          this._lastSavedTopicName[topic.topic_id] = text;
          try {
            const res = await fetch(
              '/api/scans/' + this.scanId + '/topics/' + topic.topic_id,
              {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: text }),
              },
            );
            if (!res.ok) {
              const t = await res.text();
              alert('Could not rename topic: ' + res.status + ' ' + t);
            }
          } catch (e) {
            console.error('saveTopicName failed:', e);
            alert('Rename failed: ' + e.message);
          }
        },

        // "+ Add persona" modal — replaces the old prompt() with a structured form
        // so users can OPTIONALLY pre-fill profile / intentions / pain points / keywords.
        // Empty optional fields → questions generated from topic context only (legacy behavior).
        addPersonaModal: {
          open: false,
          topic: null,           // the topic object we're adding to (carries name + topic_id)
          name: '',
          showOptional: false,   // collapsed by default — quick add stays one-field
          age: '',
          situation: '',
          niveau: 'intermediaire',
          intentions: '',        // multiline, 1 per line
          pain: '',              // multiline, 1 per line
          keywords: '',          // comma-separated
          submitting: false,
        },

        get canLaunch() {
          return this.totals.active_personas > 0 && this.totals.active_questions > 0 && this.selectedProviders.length > 0;
        },

        // Recompute totals + per-topic stats from the current nested state
        // A question is "effectively active" only when BOTH its persona AND itself
        // are active — run_llm_tests.py filters on ScanPersona.is_active AND
        // ScanQuestion.is_active. Counting q.is_active alone would inflate the
        // total when personas are toggled off.
        _recomputeStats() {
          let totalP = 0, activeP = 0, totalQ = 0, activeQ = 0;
          for (const t of this.topics) {
            let tTotalP = 0, tActiveP = 0, tTotalQ = 0, tActiveQ = 0;
            for (const p of t.personas) {
              tTotalP += 1;
              const pActive = !!p.is_active;
              if (pActive) tActiveP += 1;
              let pTotalQ = 0, pActiveQ = 0;
              for (const q of p.questions) {
                pTotalQ += 1;
                // Only count as active if BOTH persona AND question are ON
                if (q.is_active && pActive) pActiveQ += 1;
              }
              p.stats = { total_questions: pTotalQ, active_questions: pActiveQ };
              tTotalQ += pTotalQ;
              tActiveQ += pActiveQ;
            }
            t.stats = {
              total_personas: tTotalP,
              active_personas: tActiveP,
              total_questions: tTotalQ,
              active_questions: tActiveQ,
            };
            totalP += tTotalP; activeP += tActiveP;
            totalQ += tTotalQ; activeQ += tActiveQ;
          }
          for (const p of this.orphanPersonas) {
            totalP += 1;
            const pActive = !!p.is_active;
            if (pActive) activeP += 1;
            for (const q of p.questions) {
              totalQ += 1;
              if (q.is_active && pActive) activeQ += 1;
            }
          }
          this.totals = { total_personas: totalP, active_personas: activeP, total_questions: totalQ, active_questions: activeQ };
        },

        async togglePersona(topic, persona) {
          // Optimistic flip
          persona.is_active = !persona.is_active;
          this._recomputeStats();
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/personas/' + persona.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_active: persona.is_active }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
          } catch (e) {
            // Revert on failure
            persona.is_active = !persona.is_active;
            this._recomputeStats();
            console.error('Toggle persona failed:', e);
            alert('Failed to toggle persona. Please refresh.');
          }
        },

        async toggleQuestion(persona, question) {
          question.is_active = !question.is_active;
          this._recomputeStats();
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/questions/' + question.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_active: question.is_active }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
          } catch (e) {
            question.is_active = !question.is_active;
            this._recomputeStats();
            console.error('Toggle question failed:', e);
            alert('Failed to toggle question. Please refresh.');
          }
        },

        async bulkToggleTopic(topic) {
          // If any persona is active, turn all off. Otherwise turn all on.
          const targetState = topic.stats.active_personas === 0;
          const updates = [];
          for (const p of topic.personas) {
            if (p.is_active !== targetState) {
              p.is_active = targetState;
              updates.push(
                fetch('/api/scans/' + this.scanId + '/personas/' + p.id, {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ is_active: targetState }),
                })
              );
            }
          }
          // Sync topic-level is_active so the Topics page reflects the change.
          // Without this, disabling all personas here leaves the topic toggle
          // ON in Gate 1 — the two pages would silently disagree.
          updates.push(
            fetch('/api/scans/' + this.scanId + '/topics/' + topic.topic_id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ is_active: targetState }),
            })
          );
          topic.is_active = targetState;
          this._recomputeStats();
          try {
            const results = await Promise.all(updates);
            const bad = results.find(r => !r.ok);
            if (bad) throw new Error('HTTP ' + bad.status);
          } catch (e) {
            console.error('Bulk toggle topic failed:', e);
            alert('Some updates failed. Please refresh.');
          }
        },

        // --- Inline edit persona name ---
        startEditPersona(persona) {
          this.editingPersonaId = persona.id;
          this.editingPersonaName = persona.name;
        },
        async savePersonaName(topic, persona) {
          const name = (this.editingPersonaName || '').trim();
          this.editingPersonaId = null;
          if (!name || name === persona.name) return;
          const oldName = persona.name;
          persona.name = name;
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/personas/' + persona.id, {
              method: 'PATCH', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
          } catch (e) {
            persona.name = oldName;
            alert('Failed to rename: ' + e.message);
          }
        },

        // --- Inline edit question text ---
        startEditQuestion(q) {
          this.editingQuestionId = q.id;
          this.editingQuestionText = q.question;
        },
        async saveQuestionText(persona, q) {
          const text = (this.editingQuestionText || '').trim();
          this.editingQuestionId = null;
          if (!text || text === q.question) return;
          const oldText = q.question;
          q.question = text;
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/questions/' + q.id, {
              method: 'PATCH', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ question: text }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
          } catch (e) {
            q.question = oldText;
            alert('Failed to edit: ' + e.message);
          }
        },

        // --- Question type grouping (Miller's Law + Common Region) ---
        groupQuestionsByType(questions) {
          const typeOrder = ['basique', 'technique', 'comparative', 'urgente'];
          const groups = {};
          for (const q of questions) {
            const t = q.type_question || 'other';
            if (!groups[t]) groups[t] = { type: t, questions: [], activeCount: 0 };
            groups[t].questions.push(q);
            if (q.is_active) groups[t].activeCount++;
          }
          // Sort: known types first in order, then unknowns alphabetically
          return Object.values(groups).sort((a, b) => {
            const ai = typeOrder.indexOf(a.type), bi = typeOrder.indexOf(b.type);
            if (ai !== -1 && bi !== -1) return ai - bi;
            if (ai !== -1) return -1;
            if (bi !== -1) return 1;
            return a.type.localeCompare(b.type);
          });
        },

        toggleTypeGroup(personaId, type) {
          const key = personaId + ':' + type;
          this.expandedTypeGroups[key] = !this.expandedTypeGroups[key];
        },

        isTypeGroupOpen(personaId, type) {
          return !!this.expandedTypeGroups[personaId + ':' + type];
        },

        async bulkToggleTypeGroup(persona, group) {
          const targetState = group.activeCount === 0;
          const updates = [];
          for (const q of group.questions) {
            if (q.is_active !== targetState) {
              q.is_active = targetState;
              updates.push(
                fetch('/api/scans/' + this.scanId + '/questions/' + q.id, {
                  method: 'PATCH',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ is_active: targetState }),
                })
              );
            }
          }
          this._recomputeStats();
          try {
            const results = await Promise.all(updates);
            const bad = results.find(r => !r.ok);
            if (bad) throw new Error('HTTP ' + bad.status);
          } catch (e) {
            console.error('Bulk toggle type failed:', e);
            alert('Some updates failed. Please refresh.');
          }
        },

        // --- Delete persona ---
        async deletePersona(topic, persona) {
          if (!confirm('Delete "' + persona.name + '" and all its questions?')) return;
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/personas/' + persona.id, { method: 'DELETE' });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const idx = topic.personas.indexOf(persona);
            if (idx !== -1) topic.personas.splice(idx, 1);
            this._recomputeStats();
          } catch (e) { alert('Delete failed: ' + e.message); }
        },

        // --- Delete question ---
        async deleteQuestion(persona, q) {
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/questions/' + q.id, { method: 'DELETE' });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const idx = persona.questions.indexOf(q);
            if (idx !== -1) persona.questions.splice(idx, 1);
            this._recomputeStats();
          } catch (e) { alert('Delete failed: ' + e.message); }
        },

        // --- Add persona — opens the modal, real submission lives in submitAddPersona() ---
        addPersona(topic) {
          this.addPersonaModal.open = true;
          this.addPersonaModal.topic = topic;
          this.addPersonaModal.name = '';
          this.addPersonaModal.showOptional = false;
          this.addPersonaModal.age = '';
          this.addPersonaModal.situation = '';
          this.addPersonaModal.niveau = 'intermediaire';
          this.addPersonaModal.intentions = '';
          this.addPersonaModal.pain = '';
          this.addPersonaModal.keywords = '';
          this.addPersonaModal.submitting = false;
          // Focus name field on next tick
          this.$nextTick(() => {
            const el = document.getElementById('add-persona-name-input');
            if (el) el.focus();
          });
        },

        closeAddPersonaModal() {
          this.addPersonaModal.open = false;
          this.addPersonaModal.topic = null;
        },

        // Build the persona.data dict from form fields. Only includes optional fields
        // that the user actually filled — empty fields stay omitted so the worker can
        // distinguish "user explicitly left blank" from "user provided context".
        _buildPersonaDataFromModal() {
          const m = this.addPersonaModal;
          const name = m.name.trim();
          const data = { nom: name, segment_principal: m.topic.topic_name };
          // Profil démographique : only include if at least one subfield filled
          const profile = {};
          if (m.age.trim()) profile.age = m.age.trim();
          if (m.situation.trim()) profile.situation_professionnelle = m.situation.trim();
          if (m.niveau && m.niveau !== 'intermediaire') profile.niveau_expertise = m.niveau;
          if (Object.keys(profile).length > 0) data.profil_demographique = profile;
          // Multiline → array, drop empty lines
          const splitLines = (txt) => txt.split('\n').map(s => s.trim()).filter(Boolean);
          const intents = splitLines(m.intentions);
          if (intents.length) data.intentions_recherche = intents;
          const pains = splitLines(m.pain);
          if (pains.length) data.points_douleur = pains;
          // Keywords: comma-separated → array
          const kws = m.keywords.split(',').map(s => s.trim()).filter(Boolean);
          if (kws.length) data.mots_cles_associes = kws;
          return data;
        },

        async submitAddPersona() {
          const m = this.addPersonaModal;
          const name = m.name.trim();
          if (!name) { alert('Persona name is required'); return; }
          m.submitting = true;
          const topic = m.topic;
          const data = this._buildPersonaDataFromModal();
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/personas', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                topic_id: topic.topic_id,
                name: name,
                data: data,
              }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const responseData = await res.json();
            const newPersona = {
              id: responseData.id, name: responseData.name, topic_id: topic.topic_id,
              is_active: true,
              data: data,
              questions: [], stats: { total_questions: 0, active_questions: 0 },
            };
            topic.personas.push(newPersona);
            this._recomputeStats();
            this.expandedPersona[responseData.id] = true;
            this.closeAddPersonaModal();
            // Auto-generate 15 questions via worker
            this.generatingPersonaId = responseData.id;
            fetch('/api/scans/' + this.scanId + '/personas/' + responseData.id + '/generate-questions', { method: 'POST' })
              .then(() => this._pollQuestions(responseData.id, newPersona))
              .catch(e => { this.generatingPersonaId = null; console.error(e); });
          } catch (e) {
            alert('Add failed: ' + e.message);
          } finally {
            this.addPersonaModal.submitting = false;
          }
        },

        _pollQuestions(personaId, personaObj) {
          const poll = async () => {
            try {
              const res = await fetch('/api/scans/' + this.scanId + '/personas');
              if (!res.ok) return;
              const data = await res.json();
              for (const t of (data.topics || [])) {
                const p = t.personas.find(p => p.id === personaId);
                if (p && p.questions && p.questions.length > 0) {
                  // Replace the persona IN PLACE in the local topics array via splice so
                  // Alpine's array proxy detects the change and re-renders the row.
                  // Mutating personaObj.questions directly doesn't propagate reliably
                  // (objects pushed manually into a tracked array are not always
                  // recursively proxied in Alpine v3).
                  for (const localTopic of this.topics) {
                    const localIdx = localTopic.personas.findIndex(x => x.id === personaId);
                    if (localIdx !== -1) {
                      localTopic.personas.splice(localIdx, 1, p);
                      break;
                    }
                  }
                  // Also update personaObj for any caller still holding the original ref.
                  personaObj.questions = p.questions;
                  personaObj.stats = p.stats;
                  this.generatingPersonaId = null;
                  this._recomputeStats();
                  return;
                }
              }
            } catch {}
            if (this.generatingPersonaId === personaId) setTimeout(poll, 3000);
          };
          setTimeout(poll, 3000);
        },

        // --- Add question (manual) ---
        async addQuestion(persona) {
          const text = prompt('Question text:');
          if (!text || !text.trim()) return;
          try {
            const res = await fetch('/api/scans/' + this.scanId + '/questions', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ persona_id: persona.id, question: text.trim(), type_question: 'basique' }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            persona.questions.push({ id: data.id, question: data.question, type_question: 'basique', is_active: true });
            this._recomputeStats();
          } catch (e) { alert('Add failed: ' + e.message); }
        },

        async toggleProvider(provider) {
          const idx = this.selectedProviders.indexOf(provider);
          if (idx >= 0) {
            if (this.selectedProviders.length <= 1) return; // must keep at least 1
            this.selectedProviders.splice(idx, 1);
          } else {
            this.selectedProviders.push(provider);
          }
          this.savingProviders = true;
          try {
            await fetch('/api/scans/' + this.scanId + '/config', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ providers: [...this.selectedProviders] }),
            });
          } catch (e) { console.error('Save providers failed:', e); }
          this.savingProviders = false;
        },

        launchScan() {
          if (!this.canLaunch) return;
          const providerNames = this.selectedProviders.join(' + ');
          const apiCalls = this.totals.active_questions * this.selectedProviders.length;
          if (!confirm('Launch AI Scan?\n\n' + this.totals.active_personas + ' personas · ' + this.totals.active_questions + ' questions · ' + providerNames + '\n' + apiCalls + ' API calls · ' + this.totals.active_questions + ' scan credits')) return;
          fetch('/api/scans/' + this.scanId + '/launch', { method: 'POST' })
            .then(async res => {
              if (res.ok) {
                location.reload();
              } else if (res.status === 402) {
                const err = await res.json().catch(() => ({}));
                const detail = err.detail || {};
                alert('Not enough scan credits.\nNeed: ' + (detail.need || '?') + '\nHave: ' + (detail.have || '?') + '\n\nGo to Settings → Buy credits.');
              } else {
                return res.text().then(t => { alert('Launch failed: ' + res.status + ' ' + t); });
              }
            })
            .catch(e => {
              console.error('Launch failed:', e);
              alert('Launch failed: ' + e.message);
            });
        },
      }));
    });
  </script>

  <style>
    /* Brief coral flash + ring on Add-persona buttons when triggered from the
       info banner link. Catches the eye without being intrusive. */
    @keyframes flash-coral {
      0%   { box-shadow: 0 0 0 0 rgba(232, 112, 122, 0.0); border-color: rgb(229 231 235); }
      30%  { box-shadow: 0 0 0 6px rgba(232, 112, 122, 0.35); border-color: rgb(232 112 122); }
      100% { box-shadow: 0 0 0 0 rgba(232, 112, 122, 0.0); border-color: rgb(229 231 235); }
    }
    .animate-flash-coral {
      animation: flash-coral 1.6s ease-out;
    }
  </style>
</DashboardLayout>
