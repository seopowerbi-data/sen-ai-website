    .article-rendered.prose mark.brand-mention.own,
    .article-rendered.prose mark.brand-mention {
      background-color: #d1fae5 !important;
      color: #065f46 !important;
      padding: 0.05rem 0.3rem;
      border-radius: 0.2rem;
      font-weight: 600;
    }
    .article-rendered.prose mark.brand-mention.competitor {
      background-color: #ffedd5 !important;
      color: #9a3412 !important;
      padding: 0.05rem 0.3rem;
      border-radius: 0.2rem;
      font-weight: 600;
