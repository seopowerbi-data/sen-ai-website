        sourcesGroupedByType() {
          const used = (this.item.content_metadata || {}).sources_used || [];
          if (!used.length) return [];
          const order = ['brand', 'scientific', 'institutional', 'review', 'editorial', 'competitor'];
          const groups = {};
          used.forEach(s => {
            const t = (s.type || s.org_type || 'editorial').toLowerCase();
            if (!groups[t]) groups[t] = [];
            groups[t].push(s);
          });
          const labelMap = {
            brand: 'Brand', scientific: 'Scientific', institutional: 'Institutional',
            review: 'Review platforms', editorial: 'Editorial / press', competitor: 'Competitor',
            reference: 'Cited URLs',
          };
          const out = [];
          order.forEach(k => {
            if (groups[k]) out.push({ type: k, label: labelMap[k] || k, items: groups[k] });
          });
          Object.keys(groups).forEach(k => {
            if (!order.includes(k)) out.push({ type: k, label: labelMap[k] || k, items: groups[k] });
          });
          return out;
        },
        // C.1.11 — 2-level expand state helpers for sources.
        toggleSourceType(type) {
          this.expandedSourceTypes = {
            ...this.expandedSourceTypes,
            [type]: !this.expandedSourceTypes[type],
          };
        },
        isSourceTypeExpanded(type) {
          return !!this.expandedSourceTypes[type];
        },
        sourceTypeColorClass(type) {
          // C.1.10 — colour-coding stays semantic (Von Restorff). Review was
          // amber which implied "warning" — reviews are POSITIVE E-E-A-T,
          // demote to neutral charcoal. Reserve amber+red for true warnings.
          const map = {
            brand:         'text-emerald-700',
            scientific:    'text-blue-700',
            institutional: 'text-purple-700',
            review:        'text-charcoal-dark',
            editorial:     'text-charcoal-dark',
            competitor:    'text-red-700',
          };
          return map[type] || 'text-charcoal-dark';
        },
        // ── Sources breakdown ─────────────────────────────────────
        // C.1.8 — show a per-type split (Brand · Scientific · Review …) only
        // when the classification is meaningful. Legacy items generated before
        // C.1.8 have every source tagged 'reference' — in that case (or any
        // single-type case) we fall back to a neutral "unique URLs" caption.
        sourcesBreakdownLine() {
          // C.1.10 — return '' (not "unique URLs") for single-type so the
          // caption can be hidden by x-show. "Distinct" in the label already
          // implies deduplicated — no need to say it twice.
          const m = this.item.content_metadata || {};
          const used = m.sources_used || [];
          if (!used.length) return '';
          const counts = {};
          used.forEach(s => {
            const t = (s.type || s.org_type || 'editorial').toLowerCase();
            counts[t] = (counts[t] || 0) + 1;
          });
          const keys = Object.keys(counts);
          if (keys.length === 1) return '';  // no meaningful breakdown
          const ordered = ['brand', 'scientific', 'review', 'editorial', 'institutional', 'competitor'];
          const parts = [];
          ordered.forEach(k => {
            if (counts[k]) parts.push(k.charAt(0).toUpperCase() + k.slice(1) + ' ' + counts[k]);
          });
          Object.keys(counts).forEach(k => {
            if (!ordered.includes(k)) parts.push(k.charAt(0).toUpperCase() + k.slice(1) + ' ' + counts[k]);
          });
          return parts.join(' · ');
        },
        saveStateClass() {
          return {
            'text-charcoal-light': this.saveState === 'idle',
            'text-amber-600 font-medium': this.saveState === 'unsaved' || this.saveState === 'saving',
            'text-emerald-600': this.saveState === 'saved',
            'text-red-600 font-medium': this.saveState === 'error',
          };
        },
        saveStateLabel() {
          if (this.saveState === 'idle') return '';
          if (this.saveState === 'unsaved') return '⚠ Unsaved changes';
          if (this.saveState === 'saving') return '💾 Saving…';
          if (this.saveState === 'saved') {
            if (!this.savedAt) return '✓ Saved';
            const sec = Math.floor((Date.now() - this.savedAt) / 1000);
            if (sec < 5) return '✓ Just saved';
            if (sec < 60) return '✓ Saved ' + sec + 's ago';
            return '✓ Saved ' + Math.floor(sec / 60) + 'm ago';
          }
          if (this.saveState === 'error') return '⚠ Save failed';
          return '';
        },

        // ─── content_metadata renderers (migration 024, generator v1) ────
        // qualityBadgeClass / qualityBadgeTooltip / sourceTypeClass /
        // sourceTypeLabel are pure derived state — they read item.content_metadata
        // and return Tailwind class strings or labels. No side effects.
        qualityBadgeClass() {
          const q = (this.item && this.item.content_metadata && this.item.content_metadata.quality_score) || 0;
          if (q >= 80) return 'bg-emerald-50 text-emerald-700 border-emerald-200';
          if (q >= 60) return 'bg-amber-50 text-amber-700 border-amber-200';
          return 'bg-red-50 text-red-700 border-red-200';
        },
        qualityBadgeTooltip() {
          const md = (this.item && this.item.content_metadata) || {};
          const q = md.quality_score || 0;
          const sources = md.sources_count || 0;
          const tier = q >= 80 ? '✓ on target' : (q >= 60 ? '⚠ acceptable but below target' : '⚠ below target');
          const dur = md.duration_ms ? Math.round(md.duration_ms / 100) / 10 : null;
          const lines = [
            'Quality score : ' + q + '/100 — ' + tier,
            'Computed by seo_llm: schema validity + Q/A length + brand presence + source diversity.',
            '',
            'This run : ' + sources + ' source(s) cited, ' +
              (md.faq_count || 0) + ' Q/R generated' +
              (dur ? ' in ' + dur + 's' : '') + '.',
          ];
          if (md.competitor_drops > 0) {
            lines.push('Brand-bias filter blocked ' + md.competitor_drops + ' competitor URL(s) before generation.');
          }
          return lines.join('\n');
        },
        sourceTypeClass(t) {
          // Pastel-pop palette matching the rest of the design — coral/emerald/sky/amber.
          // Distinct enough on a glance, never aggressive (Von Restorff applied
          // sparingly so the badges don't fight the prose).
          const map = {
            authority: 'bg-emerald-50 text-emerald-700 border-emerald-200',
            society: 'bg-sky-50 text-sky-700 border-sky-200',
            journal: 'bg-violet-50 text-violet-700 border-violet-200',
            research: 'bg-amber-50 text-amber-700 border-amber-200',
            reference: 'bg-gray-50 text-gray-700 border-gray-200',
            brand_site: 'bg-coral/10 text-coral border-coral/30',
            other: 'bg-gray-50 text-gray-500 border-gray-200',
          };
          return map[t] || map.other;
        },
        sourceTypeLabel(t) {
          const map = {
            authority: 'Authority',
            society: 'Society',
            journal: 'Journal',
            research: 'Research',
            reference: 'Reference',
            brand_site: 'Brand',
            other: 'Other',
          };
          return map[t] || 'Source';
        },

        // Client-side URL validation — three signals, no LLM call.
        // Returns { level, message, borderClass, textClass } for the URL input.
        // 'ok'    : deep page on a primary brand domain
        // 'warn'  : valid URL but off-brand or shallow path
        // 'error' : doesn't parse
        // 'empty' : no URL set yet (banner handles this)
        urlValidation() {
          const url = (this.item.target_url || '').trim();
          if (!url) {
            return { level: 'empty', message: '', borderClass: 'border-amber-300', textClass: '' };
          }
          // Parse
          let parsed;
          try {
            parsed = new URL(url);
            if (!parsed.protocol.startsWith('http')) throw new Error('non-http');
          } catch (_) {
            return {
              level: 'error',
              message: '⚠ Doesn\'t look like a valid URL — must start with https://',
              borderClass: 'border-red-400',
              textClass: 'text-red-700',
            };
          }
          const host = parsed.hostname.toLowerCase().replace(/^www\./, '');
          const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
          const segments = path ? path.split('/').filter(Boolean) : [];

          // Brand domain checks below are FAQ-specific (FAQ lives on the
          // user's brand site). For netlinking_article, the URL points to
          // a third-party MEDIA PARTNER — the warnings would be exactly
          // backwards. Skip them for article items.
          if (this.item.content_type === 'netlinking_article') {
            // Optional : warn if user accidentally typed a brand domain
            // (publishing your own sponsored article on your own brand site
            // makes no sense — that's just a regular page update).
            const brandDomainsArt = (this.item.primary_brand_domains || []).map(d =>
              (d || '').toLowerCase().replace(/^www\./, '')
            );
            const isOwnBrand = brandDomainsArt.some(d => host === d || host.endsWith('.' + d));
            if (isOwnBrand) {
              return {
                level: 'warn',
                message: '⚠ This is one of your own brand sites. Netlinking articles are meant to publish on third-party MEDIA PARTNERS (e.g. doctissimo.fr) to recapture citation share — publishing on your own site is just a page update, not netlinking.',
                borderClass: 'border-amber-300',
                textClass: 'text-amber-800',
              };
            }
            return { level: 'ok', message: '', shortMessage: '' };
          }

          // Brand domain match (case-insensitive, ignoring www.)
          const brandDomains = (this.item.primary_brand_domains || []).map(d =>
            (d || '').toLowerCase().replace(/^www\./, '')
          );
          const matchesBrand = brandDomains.length === 0
            ? null  // can't check, skip the warning
            : brandDomains.some(d => host === d || host.endsWith('.' + d));

          if (matchesBrand === false) {
            const list = brandDomains.slice(0, 3).join(', ');
            return {
              level: 'warn',
              message: '⚠ This URL isn\'t on your brand site (' + list + '). The FAQ promotes your brand only if it\'s hosted on your own pages.',
              borderClass: 'border-amber-300',
              textClass: 'text-amber-800',
            };
          }

          // Depth check
          if (segments.length < 2) {
            return {
              level: 'warn',
              message: '⚠ Looks like a homepage or top-level category. FAQ works best on a specific topic page (deeper URL with ≥ 2 path segments).',
              borderClass: 'border-amber-300',
              textClass: 'text-amber-800',
            };
          }

          // All checks pass
          return {
            level: 'ok',
            message: matchesBrand === null
              ? '✓ Deep page detected. Add primary brands in workspace settings to enable on-brand check.'
              : '✓ Looks good — deep page on your brand domain.',
            // shortMessage is the compact label used by the icon-line variant
            // when the result is positive — keeps the chrome quiet, full text
            // surfaces in the title tooltip.
            shortMessage: 'Valid deep page on your brand',
            borderClass: 'border-emerald-200',
            textClass: 'text-emerald-700',
          };
        },

        nextStepHint() {
          const s = this.item.status;
          if (s === 'identified') {
            if (!this.item.target_url) return 'Set a target URL above, then click Generate';
            if (this.item.content_type === 'faq') return 'Ready to generate FAQ';
            return 'Awaiting content generation (Phase C)';
          }
          if (s === 'generating') return 'Generation in progress (~60s)…';
          if (s === 'draft' || s === 'in_review') return 'Awaiting your approval';
          if (s === 'approved') return 'Awaiting publish — set the live URL';
          return '';
        },

        markUnsaved() { this.saveState = 'unsaved'; },

        // Phase D top-3 picker — switch target_url to a candidate in 1 click.
        // PATCH endpoint auto-flips target_url_source -> 'user_input' when
        // target_url is set via PATCH, so we just send the URL and rely on
        // the server convention (see content_items.py line ~558).
        async usePickerCandidate(c) {
          if (!c || !c.url || c.url === this.item.target_url) return;
          // Optimistic UI : flip locally so the ★ + emerald ring move
          // immediately; the PATCH response will sync the truth.
          this.item.target_url = c.url;
          this.item.target_page_title = c.title || this.item.target_page_title;
          await this.save({
            target_url: c.url,
            target_page_title: c.title || null,
          });
        },

        // Phase B Tier A signal — prefer the Haiku classifier output
        // (content_metadata.intent_category, populated by the worker's
        // classify_question_intent handler) when present. Returns the
        // raw category string or '' if unclassified.
        intentCategory() {
          const meta = this.item.content_metadata || {};
          return meta.intent_category || '';
        },

        // Phase B Tier B — heuristic safety-intent detector. Used as a
        // fallback when intent_category is missing (legacy scan before
        // Tier A shipped, or classification skipped due to missing API
        // key). Multi-lingual best-effort regex covering FR + EN.
        // Returns false when the question is empty.
        hasSafetyIntent(question) {
          // Prefer the classifier's verdict when available.
          const cat = this.intentCategory();
          if (cat) {
            return ['safety_warning', 'side_effects', 'contre_indication', 'complaint_sav'].includes(cat);
          }
          if (!question) return false;
          const q = String(question).toLowerCase();
          const patterns = [
            /\bdois[- ]je arr[eê]ter\b/,
            /\best[- ]ce dangereux\b/,
            /\bp[èe]le\b/,
            /\brougit\b/,
            /\beffets? ind[eé]sirables?\b/,
            /\bcontre[- ]indications?\b/,
            /\br[eé]agit mal\b/,
            /\birritation\b/,
            /\binflammation\b/,
            /\bshould i stop\b/,
            /\bside effects?\b/,
            /\badverse (effects?|reactions?)\b/,
            /\bis it (safe|dangerous|harmful)\b/,
            /\ballergic reaction\b/,
          ];
          return patterns.some(re => re.test(q));
        },

        // Phase B Tier A — chip metadata for the Question label.
        // Returns { label, cls } when the question has a non-trivial
        // classification; null otherwise (chip stays hidden).
        intentChip() {
          const cat = this.intentCategory();
          if (!cat || cat === 'promotional_fit' || cat === 'other') return null;
          const map = {
            informational_neutral: { label: 'Informational', cls: 'bg-blue-100 text-blue-800' },
            safety_warning:        { label: 'Safety',        cls: 'bg-amber-100 text-amber-800' },
            side_effects:          { label: 'Side effects',  cls: 'bg-amber-100 text-amber-800' },
            contre_indication:     { label: 'Contre-indication', cls: 'bg-amber-100 text-amber-800' },
            complaint_sav:         { label: 'SAV',           cls: 'bg-amber-100 text-amber-800' },
          };
          return map[cat] || null;
        },

        // Short URL helper for the picker cards : strips scheme + host,
        // keeps path + query. '/' becomes '/' so a homepage stays visible.
        pickerShortUrl(u) {
          if (!u) return '';
          try {
            const url = new URL(u);
            const path = url.pathname + (url.search || '');
            return path === '/' ? '/' : path;
          } catch { return u; }
        },

        scheduleSave() {
          if (this.saveTimer) clearTimeout(this.saveTimer);
          this.saveTimer = setTimeout(() => this.save(), 2000);
        },

        // contenteditable swallows the link-follow behavior on <a> elements
        // — the browser places the caret instead of opening the URL. The
        // earlier @click-only handler missed the click in some browsers
        // because contenteditable consumes the gesture during mousedown,
        // BEFORE click fires. We hook mousedown to beat the caret-placement
        // and call window.open directly. The @click handler stays as a
        // belt-and-braces fallback for browsers that still bubble click.
        // Edit gestures (text selection drag, double-click) still work
        // because we only act on left-click that landed inside an <a>.
        _findAnchorFromEvent(e) {
          let el = e.target;
          if (el && el.nodeType === 3 /* TEXT_NODE */) el = el.parentElement;
          if (!el || !el.closest) return null;
          return el.closest('a[href]');
        },
        _isPlainLeftClick(e) {
          return e.button === 0 && !e.ctrlKey && !e.metaKey && !e.shiftKey && !e.altKey;
        },
        onContentMouseDown(e) {
          const a = this._findAnchorFromEvent(e);
          if (!a) return;
          if (!this._isPlainLeftClick(e)) return;
          // preventDefault here stops contenteditable from placing the caret
          // inside the anchor — the subsequent click would still fire but
          // the link is already opened in a new tab.
          e.preventDefault();
          e.stopPropagation();
          window.open(a.href, '_blank', 'noopener,noreferrer');
        },
        onContentClick(e) {
          // Belt-and-braces : if mousedown didn't catch (e.g. touchscreen
          // synthesizes click without a preceding mousedown), we still try
          // here. _isPlainLeftClick + the prior preventDefault on mousedown
          // means this rarely fires for already-handled clicks.
          const a = this._findAnchorFromEvent(e);
          if (!a) return;
          if (!this._isPlainLeftClick(e)) return;
          e.preventDefault();
          e.stopPropagation();
          window.open(a.href, '_blank', 'noopener,noreferrer');
        },

        onVisualEdit(e) {
          // Brand-mention marks are a render-time overlay only — strip them
          // before persisting back to state so item.content_html stays clean
          // (idempotent : the next render re-injects from promoted_brand_names).
          this.item.content_html = this.stripBrandMarks(e.target.innerHTML);
          this.markUnsaved();
          this.scheduleSave();
        },

        // --- Brand mention highlighting (Von Restorff)
        // Wraps occurrences of promoted_brand_names in <mark class="brand-mention">
        // so the user sees where the LLM placed the brand at a glance. DOM-based
        // walk avoids tag attributes (e.g. won't touch text inside href="...").
        // Marks are NEVER persisted : strip on save, re-inject on render.
        _escapeRegex(s) {
          return (s || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        },
        stripBrandMarks(html) {
          if (!html) return html;
          // Only strip our own class to avoid disturbing other <mark> usage
          return html.replace(/<mark\s+class="brand-mention">([\s\S]*?)<\/mark>/g, '$1');
        },
        // Names treated as the user's own brands for the green highlight.
        // Union of the workspace-level signal (promoted_brand_names from
        // client.primary_brand_ids — stable, edited via settings) AND the
        // per-scan signal (own_brand_names from SBC classification 'my_brand'
        // — covers gammes/children like XERACALM A.D + aliases that aren't
        // primary brands themselves). Workspace wins on conflicts; per-scan
        // enriches.
        _ownBrandNames() {
          const seen = new Set();
          const out = [];
          const collect = (arr) => {
            for (const n of (arr || [])) {
              if (!n || n.length < 2) continue;
              const k = n.toLowerCase();
              if (seen.has(k)) continue;
              seen.add(k);
              out.push(n);
            }
          };
          collect(this.item.promoted_brand_names);
          collect(this.item.own_brand_names);
          return out;
        },
        // Competitor list filtered to exclude anything classified as own at
        // the workspace level OR per-scan. Prevents an old/wrongly-classified
        // SBC row (e.g. a user's own brand mis-tagged as competitor on a
        // pre-fix scan) from triggering a false "leak" alarm. Authority
        // hierarchy : promoted_brand_names + own_brand_names always win.
        _competitorBrandNames() {
          const ownSet = new Set(this._ownBrandNames().map(n => n.toLowerCase()));
          return (this.item.competitor_brand_names || [])
            .filter(n => n && n.length >= 2 && !ownSet.has(n.toLowerCase()));
        },
        renderedContentHtml() {
          const raw = this.item.content_html || ('<p>' + (this.item.content_text || '') + '</p>');
          // While the editor has focus, skip mark injection so typing doesn't
          // cause cursor jumps from reactive re-renders. Marks come back on
          // blur, when the user is reviewing again.
          if (this.visualEditingActive) return this.stripBrandMarks(raw);
          const own = this._ownBrandNames();
          const competitor = this._competitorBrandNames();
          if (own.length === 0 && competitor.length === 0) return this.stripBrandMarks(raw);
          try {
            const dom = new DOMParser().parseFromString(this.stripBrandMarks(raw), 'text/html');
            const walker = document.createTreeWalker(
              dom.body, NodeFilter.SHOW_TEXT, null
            );
            const targets = [];
            let n; while ((n = walker.nextNode())) targets.push(n);
            // Reuse the Citations module's regex pattern : sort by length desc
            // so "XERACALM A.D" wins over "AD", word-boundary not enforced (gammes
            // contain dots/spaces). Two passes (own first, then competitor) so
            // ambiguous names — same word in both lists — get the "own" class.
            const buildPattern = (names) => {
              if (!names.length) return null;
              const sorted = names.slice().sort((a, b) => b.length - a.length);
              return new RegExp(
                '(' + sorted.map(s => this._escapeRegex(s)).join('|') + ')',
                'gi'
              );
            };
            const passes = [
              { pat: buildPattern(own), cls: 'brand-mention own' },
              { pat: buildPattern(competitor), cls: 'brand-mention competitor' },
            ];
            for (const node of targets) {
              if (!node.parentNode) continue;
              const parentTag = (node.parentNode.tagName || '').toLowerCase();
              if (parentTag === 'mark' || parentTag === 'a') continue;
              let text = node.textContent;
              let changed = false;
              for (const { pat, cls } of passes) {
                if (!pat) continue;
                pat.lastIndex = 0;
                if (!pat.test(text)) continue;
                pat.lastIndex = 0;
                text = text.replace(pat, '<mark class="' + cls + '">$1</mark>');
                changed = true;
              }
              if (changed) {
                const wrapper = dom.createElement('span');
                wrapper.innerHTML = text;
                node.replaceWith(...wrapper.childNodes);
              }
            }
            return dom.body.innerHTML;
          } catch (e) {
            console.warn('brand-mark inject failed', e);
            return raw;
          }
        },
        // Per-brand mention count for the audit panel (Goal-Gradient :
        // shows the user the promotion is actually landing in the content).
        brandMentionCounts() {
          const out = {};
          const names = (this.item.promoted_brand_names || []).filter(n => n && n.length >= 2);
          if (names.length === 0) return out;
          const text = (this.item.content_html || this.item.content_text || '')
            .replace(/<[^>]+>/g, ' ');  // strip tags so attribute text doesn't count
          for (const name of names) {
            const re = new RegExp('\\b' + this._escapeRegex(name) + '\\b', 'gi');
            const m = text.match(re);
            out[name] = m ? m.length : 0;
          }
          return out;
        },
        // Pilier 5 — freshness label / color for the AI snapshot chip.
        // Computes from competitor_snapshot.latest_snapshot_at.
        aiSnapshotAgeDays() {
          const iso = this.item?.competitor_snapshot?.latest_snapshot_at;
          if (!iso) return null;
          const t = Date.parse(iso);
          if (Number.isNaN(t)) return null;
          return Math.floor((Date.now() - t) / 86_400_000);
        },
        aiSnapshotAgeLabel(verbose) {
          const days = this.aiSnapshotAgeDays();
          if (days === null) return '';
          if (days <= 0) return verbose ? 'today (less than 24h ago)' : 'today';
          if (days === 1) return verbose ? '1 day ago' : '1 day ago';
          if (days < 7) return days + (verbose ? ' days ago' : 'd ago');
          if (days < 30) {
            const w = Math.floor(days / 7);
            return w + (verbose ? ' week' + (w > 1 ? 's' : '') + ' ago' : 'w ago');
          }
          const m = Math.floor(days / 30);
          return m + (verbose ? ' month' + (m > 1 ? 's' : '') + ' ago' : 'mo ago');
        },
        aiSnapshotAgeClass() {
          const days = this.aiSnapshotAgeDays();
          if (days === null) return 'bg-gray-100 text-charcoal-light';
          if (days < 7) return 'bg-emerald-50 text-emerald-700';
          if (days < 30) return 'bg-amber-50 text-amber-800';
          return 'bg-red-50 text-red-700';
        },

        // Pilier 5 — POST refresh + poll until the worker completes.
        // Two stop conditions (defensive — either fires) :
        //   1. in_flight_refresh_job_id clears in the GET response, AND
        //   2. latest_snapshot_at advances past the snapshot we recorded
        //      before the POST.
        // The original implementation only checked (1) but a buggy in-flight
        // filter could leave the UI permanently 'Refreshing…' even after
        // the job completed — (2) is the positive signal that catches it.
        // Phase C.1.3 — re-fetch LinkFinder enrichment on existing candidates.
        // Article items only. Sync endpoint (no job). Mutates item.target_url_candidates
        // in place with the refreshed DA / TF / price / platform_url values.
        async refreshMediaEnrichment() {
          if (this.refreshingMedia) return;
          if (this.item.content_type !== 'netlinking_article') return;
          this.refreshingMedia = true;
          this.refreshMediaError = '';
          try {
            const r = await fetch('/api/content-items/' + this.item.id + '/refresh-media-enrichment', {
              method: 'POST',
            });
            if (!r.ok) {
              const body = await r.json().catch(() => ({}));
              this.refreshMediaError = body.detail?.message || body.detail || ('HTTP ' + r.status);
              return;
            }
            const data = await r.json();
            if (data.candidates) {
              this.item.target_url_candidates = data.candidates;
            }
          } catch (e) {
            this.refreshMediaError = e.message || 'Refresh failed';
          } finally {
            this.refreshingMedia = false;
          }
        },

        async refreshAiSnapshot() {
          if (this.aiSnapshotRefreshing) return;
          this.aiSnapshotRefreshing = true;
          this.aiSnapshotRefreshError = '';
          const baselineAt = this.item?.competitor_snapshot?.latest_snapshot_at || '';
          try {
            const res = await fetch(
              '/api/content-items/' + this.item.id + '/refresh-ai-snapshot',
              { method: 'POST', headers: { 'Content-Type': 'application/json' } }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            const startedAt = Date.now();
            const tick = async () => {
              try {
                const r = await fetch('/api/content-items/' + this.item.id);
                if (r.ok) {
                  const data = await r.json();
                  this.item = data;
                  const stillRunning = !!(data.competitor_snapshot && data.competitor_snapshot.in_flight_refresh_job_id);
                  const newAt = data.competitor_snapshot && data.competitor_snapshot.latest_snapshot_at;
                  const dataAdvanced = newAt && newAt !== baselineAt;
                  // Stop when job is finished (in_flight cleared) AND fresh
                  // data is visible. Either signal alone may lag the other
                  // because the in_flight query reads from `jobs` and the
                  // snapshot query reads from `scan_llm_results` — they can
                  // briefly disagree at the moment the worker commits.
                  if (!stillRunning && dataAdvanced) {
                    this.aiSnapshotRefreshing = false;
                    this._aiSnapshotPollHandle = null;
                    return;
                  }
                }
              } catch {}
              if (Date.now() - startedAt > 90_000) {
                this.aiSnapshotRefreshing = false;
                this.aiSnapshotRefreshError = 'Refresh taking longer than expected — reload the page to see the latest snapshot.';
                return;
              }
              this._aiSnapshotPollHandle = setTimeout(tick, 4_000);
            };
            this._aiSnapshotPollHandle = setTimeout(tick, 3_000);
          } catch (e) {
            this.aiSnapshotRefreshing = false;
            this.aiSnapshotRefreshError = e.message;
          }
        },

        // Pilier 5 — citation labels. Gemini returns grounding-redirect URLs
        // (vertexaisearch.cloud.google.com/grounding-api-redirect/...) which
        // are opaque to the user. We surface the source domain when available
        // (Gemini also provides a 'title' on each citation), and tag known
        // proxy URLs so the user knows the underlying source is hidden until
        // they click through.
        prettyCitationLabel(c) {
          if (!c) return '';
          const url = c.url || '';
          const title = (c.title || '').trim();
          const domain = (c.domain || '').trim();
          const isProxy = /vertexaisearch\.cloud\.google\.com\/grounding-api-redirect/.test(url);
          if (title) {
            return isProxy ? title + ' · (Gemini grounding redirect)' : title;
          }
          if (domain) return domain;
          if (isProxy) return '(Gemini grounding redirect — click to follow)';
          try { return new URL(url).hostname; } catch { return url; }
        },

        // Pilier 5 — pretty provider label for the competitor snapshot card.
        providerLabel(p) {
          switch ((p || '').toLowerCase()) {
            case 'openai': return 'ChatGPT';
            case 'gemini': return 'Gemini';
            case 'anthropic': return 'Claude';
            case 'perplexity': return 'Perplexity';
            default: return p || 'AI';
          }
        },

        // Pilier 7 — measurement banner colors + tooltip
        deltaMetricsBannerClass() {
          const m = this.item?.competitor_snapshot?.delta_metrics;
          if (!m) return 'bg-gray-50 border-gray-200';
          if (m.newly_cited || (m.best_delta || 0) > 0) return 'bg-emerald-50 border-emerald-200';
          if ((m.best_delta || 0) < 0) return 'bg-amber-50 border-amber-300';
          return 'bg-gray-50 border-gray-200';
        },
        deltaMetricsTextClass() {
          const m = this.item?.competitor_snapshot?.delta_metrics;
          if (!m) return 'text-charcoal-light';
          if (m.newly_cited || (m.best_delta || 0) > 0) return 'text-emerald-800';
          if ((m.best_delta || 0) < 0) return 'text-amber-800';
          return 'text-charcoal-dark';
        },
        deltaMetricsTooltip() {
          const m = this.item?.competitor_snapshot?.delta_metrics;
          if (!m) return '';
          const parts = ['Compared to your scan-time baseline.'];
          for (const [prov, p] of Object.entries(m.per_provider || {})) {
            const label = this.providerLabel(prov);
            if (p.baseline_cited && p.latest_cited) {
              parts.push(`${label} : #${p.baseline_position} → #${p.latest_position} (${p.delta > 0 ? '+' : ''}${p.delta})`);
            } else if (!p.baseline_cited && p.latest_cited) {
              parts.push(`${label} : absent → #${p.latest_position} ✨`);
            } else if (p.baseline_cited && !p.latest_cited) {
              parts.push(`${label} : #${p.baseline_position} → absent`);
            } else {
              parts.push(`${label} : still absent`);
            }
          }
          return parts.join('\n');
        },

        // Pilier 5 — strip Gemini's trailing 'Sources' block from the
        // displayed response text. Gemini routinely appends 20+ lines of
        // bullets like '*   https://vertexaisearch.cloud.google.com/grounding-api-redirect/...'
        // which is :
        //   (a) cryptic — opaque proxy URLs, unreadable
        //   (b) redundant — we render citations separately below in the
        //       'Sources cited' list
        //   (c) takes huge vertical space (sometimes 50% of the card)
        // We drop any line that's mostly a vertexaisearch grounding redirect.
        // Also a trailing 'Sources :' / 'Citations :' header if it left
        // behind once the bullets are stripped.
        cleanResponseText(text) {
          if (!text) return '';
          let out = String(text);

          // Gemini often inlines its citations as Markdown links where the
          // visible label is the real URL and the link target is an opaque
          // 'vertexaisearch.cloud.google.com/grounding-api-redirect/...'
          // proxy. Example :
          //   [https://naitreetgrandir.com/.../eczema/](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQ...)
          // Collapsed to the visible label (the real URL is already what the
          // user wants to read).
          out = out.replace(
            /\[([^\]]+)\]\(\s*https?:\/\/vertexaisearch\.cloud\.google\.com\/grounding-api-redirect\/[^\)]*\)/gs,
            '$1'
          );

          // Strip lines that are JUST a bullet + vertexaisearch URL, or a
          // bare vertexaisearch URL — leftover when Gemini renders a 'sources'
          // list outside of Markdown links.
          out = out
            .replace(/^[ \t]*[\*\-•·\d+\.]+[ \t]*https?:\/\/vertexaisearch\.cloud\.google\.com\/grounding-api-redirect\/[^\s]*[ \t]*$/gim, '')
            .replace(/^[ \t]*https?:\/\/vertexaisearch\.cloud\.google\.com\/grounding-api-redirect\/[^\s]*[ \t]*$/gim, '');

          // Trailing orphan 'Sources :' / 'Citations :' / 'Références :'
          // header that's left empty after its bullets were stripped.
          out = out.replace(
            /\n+\s*\**\s*(?:Sources?|Citations?|R[ée]f[ée]rences?)(?:\s*\([^)]*\))?\s*:?\s*\**\s*$/i,
            ''
          );

          // Collapse blank line runs left by strips.
          out = out.replace(/\n{3,}/g, '\n\n');
          return out.trim();
        },

        // Pilier 5 — highlight competitor + own brands in an LLM response.
        // Coral for own brands, red for competitor (Von Restorff pattern,
        // same colors used elsewhere on the page so the user reads the
        // signal at a glance). HTML-escape input first so we never inject
        // user-controlled markup, then wrap matched brand names in <mark>.
        // Pre-cleans Gemini source-bullet noise (see cleanResponseText).
        highlightBrandsInResponse(text) {
          if (!text) return '';
          const cleaned = this.cleanResponseText(text);
          let escaped = String(cleaned)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
          const ownBrands = (this.item.own_brand_names || [])
            .concat(this.item.promoted_brand_names || [])
            .filter(n => n && n.length >= 2);
          const compBrands = (this.item.competitor_brand_names || []);
          const compSnapName = this.item.competitor_snapshot && this.item.competitor_snapshot.competitor_brand_name;
          const allComp = compBrands.slice();
          if (compSnapName && !allComp.includes(compSnapName)) allComp.push(compSnapName);
          // Longer names first so 'XeraCalm AD' wraps before 'Avene'
          const ownDedup = [...new Set(ownBrands)].sort((a, b) => b.length - a.length);
          const compDedup = [...new Set(allComp)].filter(n => n && n.length >= 2).sort((a, b) => b.length - a.length);
          for (const name of compDedup) {
            const re = new RegExp('\\b(' + this._escapeRegex(name) + ')\\b', 'gi');
            escaped = escaped.replace(re, '<mark class="bg-red-100 text-red-800 rounded px-0.5">$1</mark>');
          }
          for (const name of ownDedup) {
            const re = new RegExp('\\b(' + this._escapeRegex(name) + ')\\b', 'gi');
            escaped = escaped.replace(re, '<mark class="bg-coral/15 text-coral rounded px-0.5">$1</mark>');
          }
          return escaped;
        },

        // Count of non-LEAD promoted brands that have 0 mentions in the
        // current content. Drives the 'Show N more brands not mentioned'
        // expand toggle in the Brand promotion panel.
        unmentionedNonLeadCount() {
          const names = this.item.promoted_brand_names || [];
          if (names.length < 2) return 0;
          const counts = this.brandMentionCounts();
          let n = 0;
          for (let i = 1; i < names.length; i++) {
            if ((counts[names[i]] || 0) === 0) n++;
          }
          return n;
        },
        // Competitor leak detection : count occurrences of each competitor
        // brand in the rendered content. Any count > 0 is a leak signal
        // (Von Restorff red chip in the Brand promotion panel below).
        competitorLeakCounts() {
          const out = {};
          const names = this._competitorBrandNames();
          if (names.length === 0) return out;
          const text = (this.item.content_html || this.item.content_text || '')
            .replace(/<[^>]+>/g, ' ');
          for (const name of names) {
            const re = new RegExp('\\b' + this._escapeRegex(name) + '\\b', 'gi');
            const m = text.match(re);
            if (m && m.length > 0) out[name] = m.length;
          }
          return out;
        },
        hasCompetitorLeaks() {
          return Object.keys(this.competitorLeakCounts()).length > 0;
        },

        // --- Per-item LEAD brand picker ----------------------------------
        // Star toggle mirrors Gate 3 focus-star pattern (scans/[id]). Click
        // ☆ on a non-lead brand → reorders promoted_brand_ids client-side
        // (optimistic), PATCHes the new order, surfaces a banner inviting
        // the user to re-match the target URL on the new LEAD's domain.
        //
        // Why locked on approved/published : the promoted_brand_ids array
        // is the audit trail of WHAT WAS PROMOTED at gen time. Once the
        // content is shipped, that record must stay immutable.
        canEditLead() {
          const s = this.item.status;
          return s === 'identified' || s === 'draft'
              || s === 'in_review' || s === 'rejected';
        },
        // True when the current LEAD was auto-suggested by the materialize
        // handler and the user hasn't overridden yet. The server flips
        // lead_suggestion.source to 'user' on first PATCH that changes the
        // lead — so checking source === 'auto' is sufficient, but we ALSO
        // confirm the suggested brand_id is still the lead (defense in depth
        // against stale metadata after a manual PATCH that didn't go through
        // promoted_brand_ids).
        isAutoLead() {
          const meta = this.item.content_metadata || {};
          const sug = meta.lead_suggestion || null;
          if (!sug || sug.source !== 'auto') return false;
          const leadId = (this.item.promoted_brand_ids || [])[0];
          return !!leadId && leadId === sug.brand_id;
        },
        autoLeadTooltip() {
          const meta = this.item.content_metadata || {};
          const sug = meta.lead_suggestion || null;
          if (!sug) return 'Auto-suggested LEAD';
          const reason = (sug.reason || '').trim();
          const tail = ' — click ☆ on another brand to override.';
          return reason ? ('Auto-suggested LEAD: ' + reason + tail) : ('Auto-suggested LEAD' + tail);
        },
        async setLead(idx) {
          if (!this.canEditLead()) return;
          if (this.leadSaving) return;
          if (idx === 0) return;  // already lead, no-op
          const names = (this.item.promoted_brand_names || []).slice();
          const ids = (this.item.promoted_brand_ids || []).slice();
          if (idx < 0 || idx >= names.length || idx >= ids.length) return;

          // Optimistic reorder : pull the clicked brand to position 0,
          // everyone else shifts down by one (preserves the rest of the
          // priority order). Mirrors how Gate 3 toggleFocus reassigns the
          // is_focus flag — exclusive lead.
          const newName = names.splice(idx, 1)[0];
          const newId = ids.splice(idx, 1)[0];
          names.unshift(newName);
          ids.unshift(newId);
          this.item.promoted_brand_names = names;
          this.item.promoted_brand_ids = ids;

          this.leadSaving = true;
          try {
            const r = await fetch('/api/content-items/' + this.item.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ promoted_brand_ids: ids }),
            });
            if (!r.ok) {
              const body = await r.json().catch(() => ({}));
              const msg = body.detail?.message || body.detail || ('HTTP ' + r.status);
              throw new Error(msg);
            }
            const updated = await r.json();
            this.item = updated;
            // Show the "URL still on old brand" banner so the user can act
            // on the Goal-Gradient (lead changed → next step is rematch).
            this.leadJustChanged = newName;
          } catch (e) {
            // Rollback : reverse the optimistic reorder.
            const restoredNames = (this.item.promoted_brand_names || []).slice();
            const restoredIds = (this.item.promoted_brand_ids || []).slice();
            const movedName = restoredNames.shift();
            const movedId = restoredIds.shift();
            restoredNames.splice(idx, 0, movedName);
            restoredIds.splice(idx, 0, movedId);
            this.item.promoted_brand_names = restoredNames;
            this.item.promoted_brand_ids = restoredIds;
            alert('Failed to change lead: ' + (e.message || 'unknown'));
          } finally {
            this.leadSaving = false;
          }
        },

        async save(extraPatch) {
          if (this.saving) return;
          this.saving = true;
          this.saveState = 'saving';
          const body = {
            content_html: this.item.content_html,
            content_text: this.item.content_text,
            target_url: this.item.target_url || null,
            ...(extraPatch || {}),
          };
          try {
            const r = await fetch('/api/content-items/' + this.item.id, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            const updated = await r.json();
            this.item = updated;
            this.saveState = 'saved';
            this.savedAt = Date.now();
          } catch (e) {
            this.saveState = 'error';
            console.error('save failed', e);
          } finally {
            this.saving = false;
          }
        },

        async approve() {
          await this.save({ validation: 'approved', status: 'approved' });
        },

        canRematch() {
          // Hidden once item is past 'identified'/'draft' — manual override only.
          if (this.item.status !== 'identified' && this.item.status !== 'draft') return false;
          // Two paths :
          // - FAQ items rematch via sitemap_matcher + FAQPageMatcher (brand site)
          // - Article items rematch via media_picker (third-party media partners)
          // Both routed by worker/handlers/rematch_target_url.py based on content_type.
          if (this.item.content_type === 'netlinking_article') {
            // Show whenever picker discovered candidates OR user already rejected some
            if (this.item.target_url_source === 'media_picker') return true;
            if ((this.item.rejected_target_urls || []).length > 0) return true;
            return false;
          }
          // FAQ path
          if (this.item.target_url_source === 'auto_suggest') return true;
          if ((this.item.rejected_target_urls || []).length > 0) return true;
          return false;
        },
        rematchCount() {
          return (this.item.rejected_target_urls || []).length;
        },
        rematchAttemptsLeft() {
          return Math.max(0, this.MAX_REMATCHES - this.rematchCount());
        },
        canRematchMore() {
          // Hard cap : once the user has exhausted the budget, the button
          // disables and we route them to the manual-pick path. Mirrors the
          // 429 the API endpoint will return as defense in depth.
          return this.rematchAttemptsLeft() > 0;
        },
        rematchTooltip() {
          const n = this.rematchCount();
          const left = this.rematchAttemptsLeft();
          const isArticle = this.item.content_type === 'netlinking_article';
          const base = isArticle
            ? 'Re-queries scan_llm_results citations + LinkFinder catalog to find a different media partner for this article, excluding domains already rejected. Sub-second (cached). '
            : 'Searches Google on your brand site (site:yourbrand.com + this question) for the most relevant page to answer it, skipping URLs already proposed. Takes 5-10s. ';
          if (n === 0) return base + 'Capped at ' + this.MAX_REMATCHES + ' attempts per item — past that, pick a URL manually.';
          if (left === 0) {
            const exhaustedMsg = isArticle
              ? 'attempts used. No more media candidates with citation signal — pick a media URL manually below.'
              : 'attempts used. We\'ve explored what your brand site offers — please pick a URL manually below.';
            return n + '/' + this.MAX_REMATCHES + ' ' + exhaustedMsg;
          }
          return n + '/' + this.MAX_REMATCHES + ' attempts used, ' + left + ' left. ' + base;
        },
        async rematchUrl() {
          if (this.rematching) return;
          if (this.item.status !== 'identified' && this.item.status !== 'draft') return;
          this.rematching = true;
          this.rematchError = '';
          const previousUrl = this.item.target_url || '';
          const previousSource = this.item.target_url_source || '';
          try {
            const r = await fetch('/api/content-items/' + this.item.id + '/rematch-target-url', {
              method: 'POST',
            });
            if (!r.ok) {
              const body = await r.json().catch(() => ({}));
              this.rematchError = body.detail?.message || body.detail || ('HTTP ' + r.status);
              this.rematching = false;
              return;
            }
            // Poll for change: either target_url moved OR source flipped to
            // pending_user (matcher exhausted). Hard stop at 45s — web_search
            // shouldn't take that long; if it does, surface as a soft error.
            const startedAt = Date.now();
            const poll = async () => {
              try {
                const pr = await fetch('/api/content-items/' + this.item.id);
                if (pr.ok) {
                  const d = await pr.json();
                  const moved = (d.target_url || '') !== previousUrl
                                || (d.target_url_source || '') !== previousSource;
                  if (moved) {
                    this.item = d;
                    this.rematching = false;
                    if (this.rematchTimeoutTimer) clearTimeout(this.rematchTimeoutTimer);
                    if (!d.target_url && d.target_url_source === 'pending_user') {
                      this.rematchError = 'No alternative page found — pick a URL manually.';
                    }
                    return;
                  }
                }
              } catch (_) {}
              if (Date.now() - startedAt < 45000) {
                this.rematchPollTimer = setTimeout(poll, 1500);
              }
            };
            this.rematchPollTimer = setTimeout(poll, 1500);
            this.rematchTimeoutTimer = setTimeout(() => {
              if (this.rematching) {
                this.rematching = false;
                this.rematchError = 'Search timed out — try again or pick a URL manually.';
              }
            }, 45000);
          } catch (e) {
            this.rematchError = e.message || 'Request failed';
            this.rematching = false;
          }
        },

        _stopGenerateTimers() {
          if (this.generateTickTimer) { clearInterval(this.generateTickTimer); this.generateTickTimer = null; }
          if (this.generatePollTimer) { clearTimeout(this.generatePollTimer); this.generatePollTimer = null; }
        },
        // Unified regenerate path : works from draft, in_review, OR rejected.
        // The user might trigger this when (a) the LLM output is poor and
        // they want a second roll, (b) they changed the target_url and want
        // a fresh FAQ matching the new page, or (c) the item was rejected
        // and they want to reopen it. Costs 1 content credit regardless of
        // origin (it's a fresh LLM call).
        async regenerate() {
          if (!this.item.target_url) return;
          if (this.generating || this.saving) return;
          const wasRejected = this.item.status === 'rejected';
          const hasContent = !!(this.item.content_html || this.item.content_text);
          let prompt = "Regenerate this FAQ from scratch?\n\n• Costs 1 content credit\n";
          if (wasRejected) {
            prompt += "• Reopens the item — previous rejection stays in the timeline\n";
          } else if (hasContent) {
            prompt += "• Current content will be overwritten\n";
          }
          prompt += "• Make sure the Target URL above is the page you actually want this FAQ for";
          if (!confirm(prompt)) return;
          // Reset the item so the generate endpoint accepts the call.
          // identified is the only status the generate API allows alongside
          // draft, but starting from draft also works — the worker re-runs
          // and overwrites content_html on success. Empty-string validation
          // is the API sentinel for "clear field" (added in the same patch).
          const patch = { status: 'identified' };
          if (this.item.validation) {
            patch.validation = '';  // clear any prior approve/needs_revision/reject
          }
          try {
            await this.save(patch);
          } catch (e) {
            this.generateError = 'Failed to reset: ' + (e.message || 'unknown');
            return;
          }
          await this.generate();
        },

        _expectedSecFor(contentType) {
          // Article runs the full GEO pipeline (YTG + Serper grounding +
          // section-by-section writing + validation + rephrase) — typically
          // 5-15 min. FAQ is one OpenAI web_search + composition pass, ~60s.
          return contentType === 'netlinking_article' ? 600 : 60;
        },

        progressPhaseLabel() {
          // Surface the worker's phase signal (set via content_metadata.
          // in_progress.phase_label by worker/handlers/generate_article.py
          // _update_progress at each macroscopic phase). Returns '' when
          // not available so the UI degrades gracefully to elapsed-only.
          const ip = (this.item && this.item.content_metadata && this.item.content_metadata.in_progress) || {};
          if (!ip.phase_label) return '';
          const n = ip.phase_num || 1;
          const t = ip.phase_total || 5;
          return n + '/' + t + ' · ' + ip.phase_label;
        },

        progressPhasesTooltip() {
          // C.1.12 — plain-language explanation of the 5 article-gen phases
          // for curious users hovering the live progress chip.
          // C.2.6 — terse rewrite : browser native title tooltips truncate
          // past ~1024 chars on most OSes, so one tight sentence per phase.
          // Markers : ▸ current · ✓ done · empty for upcoming.
          const ip = (this.item && this.item.content_metadata && this.item.content_metadata.in_progress) || {};
          const current = ip.phase_num || 0;
          const phases = [
            ['Preparing brand context', '~30s – 2m',
             'Load brand, competitors, target media profile (tone + length envelope).'],
            ['Fetching grounding sources', '~2-4m',
             'Scrape brand site, scientific papers, user reviews, SERP competitors.'],
            ['Writing article sections', '~3-6m',
             'LLM composes section by section, weaving keywords, citations, brand voice and media tone. Longest phase.'],
            ['Validating quality', '~1-4m',
             '7-criteria editorial review. Auto-rewrites sections that miss the per-topic SEO targets.'],
            ['Finalizing HTML', '~30s',
             'Schema.org wrapping + cleanup (strip artefacts, dedup sources, restore links).'],
          ];
          const lines = phases.map((p, i) => {
            const num = i + 1;
            const marker = num === current ? '▸' : (num < current ? '✓' : ' ');
            return marker + ' ' + num + '. ' + p[0] + '  (' + p[1] + ')\n   ' + p[2];
          });
          return '5 phases · typical 6-15 min total\n\n' + lines.join('\n\n');
        },

        init() {
          // Resume generating UI if the page was loaded mid-generation
          // (user refresh during article gen, or returning to an in-flight
          // tab). The server-side ScanContentItem.content_metadata.
          // in_progress.started_at tells us when the worker began ; we
          // backfill local timers from it so the elapsed counter is
          // accurate, then resume polling. Without this, a page refresh
          // during a 10-min article gen would lose all progress feedback
          // and the user would think the job stalled.
          const ip = (this.item && this.item.content_metadata && this.item.content_metadata.in_progress) || {};
          if (this.item.status === 'generating') {
            this.generating = true;
            this.generateStartedAt = ip.started_at
              ? new Date(ip.started_at).getTime()
              : Date.now();
            this.generateExpectedSec = ip.estimated_total_seconds
              || this._expectedSecFor(this.item.content_type);
            this.generateElapsedSec = Math.max(0,
              Math.floor((Date.now() - this.generateStartedAt) / 1000));
            this.generateTickTimer = setInterval(() => {
              this.generateElapsedSec = Math.floor(
                (Date.now() - this.generateStartedAt) / 1000);
            }, 1000);
            // Resume polling — schedule first poll in 3s
            this.generatePollTimer = setTimeout(() => this._pollGeneration(), 3000);
          }
        },

        async _pollGeneration() {
          try {
            const pr = await fetch('/api/content-items/' + this.item.id);
            if (pr.ok) {
              const d = await pr.json();
              this.item = d;
              if (d.status !== 'identified' && d.status !== 'generating') {
                this.generating = false;
                this._stopGenerateTimers();
                window.location.reload();
                return;
              }
            }
          } catch (_) {}
          this.generatePollTimer = setTimeout(() => this._pollGeneration(), 3000);
        },

        async generate() {
          if (this.generating || !this.item.target_url) return;
          // Flush any pending URL edit so the worker sees the committed target_url.
          if (this.saveState === 'unsaved') {
            await this.save();
          }
          this.generating = true;
          this.generateError = '';
          this.generateStartedAt = Date.now();
          this.generateElapsedSec = 0;
          this.generateExpectedSec = this._expectedSecFor(this.item.content_type);
          // Tick once per second so the elapsed counter + progress bar update
          // in real time (Doherty Threshold). Cheap, no fetch.
          this.generateTickTimer = setInterval(() => {
            this.generateElapsedSec = Math.floor((Date.now() - this.generateStartedAt) / 1000);
          }, 1000);
          try {
            const r = await fetch('/api/content-items/' + this.item.id + '/generate', {
              method: 'POST',
            });
            if (!r.ok) {
              const body = await r.json().catch(() => ({}));
              const msg = body.detail?.message || body.detail || ('HTTP ' + r.status);
              this.generateError = msg;
              this.generating = false;
              this._stopGenerateTimers();
              return;
            }
            // Poll item every 3s — when status flips away from generating/identified, reload.
            // Once the worker writes content_metadata.in_progress.estimated_total_seconds,
            // adjust the expected sec to match (initial 600s default may be off).
            const adjustExpected = () => {
              const ip = (this.item && this.item.content_metadata && this.item.content_metadata.in_progress) || {};
              if (ip.estimated_total_seconds) {
                this.generateExpectedSec = ip.estimated_total_seconds;
              }
            };
            const poll = async () => {
              try {
                const pr = await fetch('/api/content-items/' + this.item.id);
                if (pr.ok) {
                  const d = await pr.json();
                  this.item = d;
                  adjustExpected();
                  if (d.status !== 'identified' && d.status !== 'generating') {
                    this.generating = false;
                    this._stopGenerateTimers();
                    window.location.reload();
                    return;
                  }
                }
              } catch (_) {}
              this.generatePollTimer = setTimeout(poll, 3000);
            };
            this.generatePollTimer = setTimeout(poll, 3000);
          } catch (e) {
            this.generateError = e.message || 'Request failed';
            this.generating = false;
            this._stopGenerateTimers();
          }
        },
        async setValidation(v) {
          await this.save({ validation: v });
        },
        async reject() {
          await this.save({ validation: 'rejected', status: 'rejected' });
          this.openRejectModal = false;
        },
        async publish() {
          if (!this.publishUrl.trim()) return;
          await this.save({ published_url: this.publishUrl.trim(), status: 'published' });
          this.openPublishModal = false;
          this.publishUrl = '';
        },

        handleShortcut(e) {
          if (e.key === 'a' || e.key === 'A') {
            if (this.item.status === 'draft' || this.item.status === 'in_review') {
              e.preventDefault();
              this.approve();
            }
          } else if (e.key === 'r' || e.key === 'R') {
            if (this.item.status !== 'rejected' && this.item.status !== 'published') {
              e.preventDefault();
              this.openRejectModal = true;
            }
          } else if (e.key === 'e' || e.key === 'E') {
            e.preventDefault();
            this.editorMode = 'html';
            setTimeout(() => {
              const ta = document.querySelector('textarea[x-model="item.content_html"]');
              if (ta) ta.focus();
            }, 50);
          } else if (e.key === 'Escape') {
            window.location.href = '/app/content';
          }
        },
      }));
    });

    // Refresh "Saved Xs ago" label every 10s for liveness
    setInterval(() => {
      const ev = new CustomEvent('save-tick');
      window.dispatchEvent(ev);
    }, 10000);
  </script>

</DashboardLayout>
