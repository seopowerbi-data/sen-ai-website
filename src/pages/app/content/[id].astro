  <script is:inline>
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('contentItem', (initial) => ({
        item: initial,
        editorMode: 'visual',
        saveState: 'idle',  // 'idle' | 'unsaved' | 'saving' | 'saved' | 'error'
        savedAt: null,
        saving: false,
        saveTimer: null,
        openRejectModal: false,
        openPublishModal: false,
        publishUrl: '',
        // C.1.9 — KPI card expandables (fan-out list, sources by type).
        // C.1.11 — sources is now 2-level : `expandSources` shows the type
        // headers, `expandedSourceTypes[type]` controls each per-type URL list.
        expandFanouts: false,
        expandSources: false,
        expandedSourceTypes: {},
        generating: false,
        generateError: '',
        generatePollTimer: null,
        generateStartedAt: null,
        generateElapsedSec: 0,
        generateTickTimer: null,
        // Typical generation wall time, denominator for the progress bar.
        // FAQ ~60s (prod smoke ~55s on Avène). Article = 5-15 min, default
        // 600s ; overridden per-call to estimated_total_seconds from the
        // worker's content_metadata.in_progress payload when available.
        // Overshoot doesn't fail, just flips the bar amber to set expectation.
        generateExpectedSec: 60,
        rematching: false,
        rematchError: '',
        rematchPollTimer: null,
        rematchTimeoutTimer: null,
        visualEditingActive: false,
        // Hard cap on automatic rematch attempts per item. Each click costs
        // one OpenAI web_search call (~$0.01-0.02) and 5-10s of latency, so
        // we bound the search budget and route the user to manual picking
        // once the matcher has clearly exhausted the brand's eligible pages.
        // Server-side enforces the same limit (defense in depth).
        MAX_REMATCHES: 10,
        // Per-item LEAD picker state (Brand promotion star toggle).
        leadSaving: false,
        leadJustChanged: null,  // brand name : shows the "rematch URL" banner
        showAllPromotedBrands: false,  // expand non-LEAD 0-mention brands
        competitorPanelOpen: false,    // Pilier 5 — collapsed by default
        expandedCitations: {},          // {scan_llm_result_id: bool} — show all citations
        aiSnapshotRefreshing: false,    // true between POST and completion poll
        aiSnapshotRefreshError: '',
        _aiSnapshotPollHandle: null,
        // Phase C.1.3 — refresh LinkFinder enrichment on existing media candidates
        // (article items only). Synchronous endpoint, no polling needed.
        refreshingMedia: false,
        refreshMediaError: '',

        statusLabelOf(s) {
          const m = { identified: 'IDENTIFIED', generating: 'GENERATING', draft: 'DRAFT', in_review: 'IN REVIEW', approved: 'APPROVED', published: 'PUBLISHED', rejected: 'REJECTED' };
          return m[s] || (s || '').toUpperCase();
        },
        fmtDateOf(iso) {
          if (!iso) return '—';
          return new Date(iso).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        },
        // C.1.6 / C.1.8 — KPI card helpers (Generation Quality).
        // Plain-language status labels + dynamic SERP-derived targets.
        // All helpers degrade gracefully when content_metadata is partial.
        formatWordCount(targetWordCount, html) {
          if (typeof targetWordCount === 'number' && targetWordCount > 0) {
            return targetWordCount.toLocaleString('fr-FR') + ' words';
          }
          if (!html) return '— words';
          const txt = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
          if (!txt) return '— words';
          const n = txt.split(' ').length;
          return n.toLocaleString('fr-FR') + ' words';
        },
        formatDurationMs(ms) {
          if (!ms || ms < 0) return '—';
          const sec = Math.floor(ms / 1000);
          if (sec < 60) return sec + 's';
          const m = Math.floor(sec / 60);
          const s = sec % 60;
          return m + 'm' + (s > 0 ? s.toString().padStart(2, '0') + 's' : '');
        },
        // ── Verdict ────────────────────────────────────────────────
        qualityVerdictLabel() {
          const v = (this.item.content_metadata || {}).validation_verdict || '—';
          const map = {
            APPROVED: '✓ Approved',
            NEEDS_REVISION: '⚠ Needs revision',
            REJECTED: '✗ Rejected',
            ERROR: '✗ Error',
          };
          return map[v] || v;
        },
        qualityVerdictTooltip() {
          // C.1.10 — tooltip adds context the pill alone doesn't carry
          // (threshold value, what happens next). Don't repeat "approved".
          const v = (this.item.content_metadata || {}).validation_verdict;
          if (v === 'APPROVED') return 'All 7 editorial criteria scored above the 8/10 threshold. Ready to publish.';
          if (v === 'NEEDS_REVISION') return 'At least one criterion scored below 8/10. Usable but worth a human pass.';
          if (v === 'REJECTED') return 'Multiple criteria failed. Regenerate or edit substantially before publishing.';
          if (v === 'ERROR') return 'Pipeline error — no verdict computed. Check Sentry or regenerate.';
          return '';
        },
        editorialValidatorLine() {
          // C.1.10 — terse caption ; the 7-criteria list lives in the ⓘ tooltip
          // (was duplicated body + tooltip, against Jakob's Law of consistency).
          const score = (this.item.content_metadata || {}).validation_score;
          if (typeof score !== 'number' || score <= 0) return 'Validator score unavailable.';
          const pass = score >= 8;
          return pass
            ? 'Validator: ' + score.toFixed(1) + ' / 10 (passes the ≥ 8 threshold).'
            : 'Validator: ' + score.toFixed(1) + ' / 10 — below the ≥ 8 approval threshold.';
        },
        // ── Keyword coverage (SOSEO) ──────────────────────────────
        soseoTarget() {
          // Per-guide competitor median if available, else hardcoded fallback.
          const t = (this.item.content_metadata || {}).target_soseo;
          return (typeof t === 'number' && t > 0) ? Math.round(t) : 80;
        },
        soseoStatusLabel() {
          const v = (this.item.content_metadata || {}).ytg_soseo || 0;
          const tgt = this.soseoTarget();
          if (v >= tgt) return '✓ Strong';
          if (v >= tgt - 20) return '⚠ Near target';
          return '✗ Weak';
        },
        soseoStatusClass() {
          const v = (this.item.content_metadata || {}).ytg_soseo || 0;
          const tgt = this.soseoTarget();
          if (v >= tgt) return 'text-emerald-700';
          if (v >= tgt - 20) return 'text-amber-700';
          return 'text-red-700';
        },
        soseoBarClass() {
          const v = (this.item.content_metadata || {}).ytg_soseo || 0;
          const tgt = this.soseoTarget();
          if (v >= tgt) return 'bg-emerald-500';
          if (v >= tgt - 20) return 'bg-amber-500';
          return 'bg-red-500';
        },
        soseoTargetLine() {
          // C.1.10 — drop internal version codes from user-facing copy.
          const m = this.item.content_metadata || {};
          const tgt = this.soseoTarget();
          const hasSerpTarget = (typeof m.target_soseo === 'number' && m.target_soseo > 0);
          return hasSerpTarget
            ? 'Target ≥ ' + tgt + ' · top SERP median for this topic'
            : 'Target ≥ ' + tgt + ' (default) · no SERP analysis on this item';
        },
        // ── Topic diversity (DSEO) ────────────────────────────────
        dseoStatusLabel() {
          const v = (this.item.content_metadata || {}).ytg_dseo || 0;
          if (v >= 30 && v <= 70) return '✓ Balanced';
          if (v < 30) return '⚠ Slightly thin';
          if (v <= 85) return '⚠ Dense';
          return '✗ Over-stuffed';
        },
        dseoStatusClass() {
          const v = (this.item.content_metadata || {}).ytg_dseo || 0;
          if (v >= 30 && v <= 70) return 'text-emerald-700';
          if (v >= 20 && v <= 85) return 'text-amber-700';
          return 'text-red-700';
        },
        dseoBarClass() {
          const v = (this.item.content_metadata || {}).ytg_dseo || 0;
          if (v >= 30 && v <= 70) return 'bg-emerald-500';
          if (v >= 20 && v <= 85) return 'bg-amber-500';
          return 'bg-red-500';
        },
        dseoTargetLine() {
          // C.1.10 — terser, no jargon repetition (tooltip explains stuffing).
          const m = this.item.content_metadata || {};
          const hasSerpTarget = (typeof m.target_dseo === 'number' && m.target_dseo > 0);
          return hasSerpTarget
            ? 'Competitor median ' + Math.round(m.target_dseo) + ' · sweet spot 30–70'
            : 'Sweet spot 30–70 (default)';
        },
        // ── AI fan-out coverage ───────────────────────────────────
        fanoutCoverageLabel() {
          const m = this.item.content_metadata || {};
          const covered = (m.fanout_covered || []).length;
          const total = (m.fan_outs_used || []).length;
          if (total > 0) return covered + ' / ' + total;
          if (typeof m.fanout_coverage === 'number') return String(m.fanout_coverage);
          return '—';
        },
        fanoutCoverageStatusLabel() {
          const m = this.item.content_metadata || {};
          const covered = (m.fanout_covered || []).length;
          const total = (m.fan_outs_used || []).length;
          if (total === 0) return ((m.fanout_coverage || 0) > 0) ? '✓ Covered' : '— None';
          if (covered >= total) return '✓ All answered';
          if (covered >= total - 1) return '✓ Almost all';
          if (covered >= Math.ceil(total / 2)) return '⚠ Partial';
          return '✗ Sparse';
        },
        fanoutCoverageOk() {
          const m = this.item.content_metadata || {};
          const covered = (m.fanout_covered || []).length;
          const total = (m.fan_outs_used || []).length;
          if (total === 0) return (m.fanout_coverage || 0) >= 1;
          return covered >= Math.max(1, total - 1);
