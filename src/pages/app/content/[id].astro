  <style is:global>
    [x-cloak] { display: none !important; }
    /* --- FAQ-rendered content (Schema.org FAQPage microdata) ---
       Visual hierarchy mirrors the semantic structure :
       - section > h2     = FAQ block title  (Law of Proximity)
       - div mainEntity   = Q/A card         (Common Region)
       - h3 itemprop name = Question         (Aesthetic-Usability)
       - acceptedAnswer p = Answer           (Doherty - readable density)
       - mark.brand-mention = highlighted    (Von Restorff)
    */
    .faq-rendered.prose { font-size: 0.875rem; color: #2d2d2d; }
    .faq-rendered.prose section[itemtype*="FAQPage"] > h2 {
      font-size: 1rem; font-weight: 600; color: #2d2d2d;
