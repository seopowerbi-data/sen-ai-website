    .article-rendered.prose table {
      width: 100%; margin: 1rem 0;
      border-collapse: collapse;
      font-size: 0.85rem;
      border: 1px solid #e5e7eb;
    }
    .article-rendered.prose thead {
      background-color: #f9fafb;
    }
    .article-rendered.prose th,
    .article-rendered.prose td {
      padding: 0.5rem 0.75rem;
      text-align: left;
      border: 1px solid #e5e7eb;
    }
    .article-rendered.prose th {
      font-weight: 600; color: #1a1a1a;
    }
    /* Schema.org Article wrapper — section[itemtype*="Article"] sometimes
