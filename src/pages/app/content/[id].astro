      color: #4a4a4a; font-style: italic;
    }
    .article-rendered.prose a {
      color: #ff7066; text-decoration: underline; font-weight: 500;
    }
    .article-rendered.prose a[target="_blank"]::after,
    .article-rendered.prose a[href^="http"]:not([href*="sen-ai.fr"])::after {
      content: " ↗"; font-size: 0.85em;
    }
    /* Tables — the seo-llm article emits a non-Markdown table for reviews
