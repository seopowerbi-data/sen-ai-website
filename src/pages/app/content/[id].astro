        fanoutCoverageDetail() {
          const m = this.item.content_metadata || {};
          const total = (m.fan_outs_used || []).length;
          if (total === 0) return 'AI-extracted question variants from your scan.';
          return total + ' question variant' + (total > 1 ? 's' : '')
