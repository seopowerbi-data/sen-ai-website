        // When target is missing (legacy items), display industry baseline.
        _currentWordCount() {
          const m = this.item.content_metadata || {};
          if (typeof m.target_word_count === 'number' && m.target_word_count > 0 && m.target_word_count !== m.actual_word_count) {
            // target_word_count may also be persisted as the *computed* count
            // depending on the seo-llm output shape ; prefer the actual
            // article HTML count for the LEFT side, target for comparison.
          }
          const html = this.item.content_html || '';
          if (!html) return 0;
          const txt = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
          return txt ? txt.split(' ').length : 0;
        },
        wordCountCurrentLabel() {
          const n = this._currentWordCount();
          return n > 0 ? n.toLocaleString('fr-FR') + ' words' : '— words';
        },
        wordCountStatusLabel() {
          const m = this.item.content_metadata || {};
          const tgt = (typeof m.target_word_count === 'number' && m.target_word_count > 0) ? m.target_word_count : 0;
          const n = this._currentWordCount();
          if (!n) return '—';
          if (!tgt) {
            // No SERP target → industry baseline
            if (n < 800) return '⚠ Short';
            if (n <= 3500) return '✓ Long-form';
            return '⚠ Very long';
          }
          const delta = ((n - tgt) / tgt) * 100;
          if (delta >= -15 && delta <= 15) return '✓ On target';
          if (delta > 15) return (delta > 50 ? '⚠ Over (+' : '✓ Above (+') + delta.toFixed(0) + '%)';
          return '⚠ Below (' + delta.toFixed(0) + '%)';
        },
        wordCountStatusClass() {
          const m = this.item.content_metadata || {};
          const tgt = (typeof m.target_word_count === 'number' && m.target_word_count > 0) ? m.target_word_count : 0;
          const n = this._currentWordCount();
          if (!n) return 'text-charcoal-light';
          if (!tgt) {
            if (n < 800) return 'text-amber-700';
            if (n <= 3500) return 'text-emerald-700';
            return 'text-amber-700';
          }
          const delta = ((n - tgt) / tgt) * 100;
          if (delta >= -15 && delta <= 15) return 'text-emerald-700';
          if (delta > 50 || delta < -30) return 'text-amber-700';
          return 'text-emerald-700';
        },
        wordCountTargetLine() {
          // C.1.10 — terser, "Top SERP median" instead of "median of top 10…".
          const m = this.item.content_metadata || {};
