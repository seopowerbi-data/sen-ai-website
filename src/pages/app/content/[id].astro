---
/**
 * Content Item Validation/Detail page — `/app/content/{id}`
 *
 * Single-item review screen for one ScanContentItem (FAQ or article).
 * Sister page to /app/content (Kanban). Reached by clicking a card.
 *
 * UX Laws applied :
 * - Fitts's Law: sticky header carries the primary CTA, always visible while scrolling
 * - Peak-End: contextual primary CTA changes per status (Approve / Mark published / Reload)
 * - Doherty Threshold: auto-save 2s after last keystroke + persistent save indicator
 * - Hick's Law: ONE primary CTA at a time, secondary actions visually de-emphasized
 * - Law of Proximity: Source / Brand promotion / Content / Workflow grouped as 4 cards
 * - Miller's Law: source shows 5 fields max, rest behind "Show more"
 * - Postel's: Visual/HTML toggle for content editor (liberal display, conservative storage)
 * - Jakob's: breadcrumb navigation matches webapp convention
 * - Goal-Gradient: activity timeline shows journey done + step ahead
 * - Aesthetic-Usability: confirmation modal for destructive actions (Reject)
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const { id: itemId } = Astro.params;

let item: any = null;
let notFound = false;

try {
  const res = await fetch(`http://api:8000/api/content-items/${itemId}`, {
    headers: { Cookie: `token=${token}` },
    signal: AbortSignal.timeout(5000),
  });
  if (res.status === 404) {
    notFound = true;
  } else if (res.ok) {
    item = await res.json();
  }
} catch (e) {}

// Lifecycle/status meta
function statusLabel(s: string): string {
  const m: Record<string, string> = {
    identified: 'IDENTIFIED', generating: 'GENERATING',
    draft: 'DRAFT', in_review: 'IN REVIEW',
    approved: 'APPROVED', published: 'PUBLISHED', rejected: 'REJECTED',
  };
  return m[s] || (s || '').toUpperCase();
}
function statusBadge(s: string): string {
  if (s === 'identified' || s === 'generating') return 'bg-red-100 text-red-700';
  if (s === 'draft' || s === 'in_review') return 'bg-amber-100 text-amber-700';
  if (s === 'approved') return 'bg-blue-100 text-blue-700';
  if (s === 'published') return 'bg-emerald-100 text-emerald-700';
  if (s === 'rejected') return 'bg-gray-200 text-gray-600';
  return 'bg-gray-100 text-gray-600';
}
function priorityClass(p: string): string {
  if (p === 'critique') return 'bg-red-100 text-red-700';
  if (p === 'haute') return 'bg-amber-100 text-amber-700';
  if (p === 'moyenne') return 'bg-blue-100 text-blue-700';
  return 'bg-gray-100 text-gray-600';
}
function typeLabel(t: string): string {
  if (t === 'faq') return 'FAQ';
  if (t === 'netlinking_article') return 'ARTICLE';
  return t || '—';
}
function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
---

<DashboardLayout title="Content item" activeSection="content">

{notFound ? (
  <div class="p-8 max-w-3xl">
    <h1 class="text-xl font-bold text-charcoal-dark mb-2">Content item not found</h1>
    <p class="text-sm text-charcoal-light mb-6">This item may have been deleted, or the URL is wrong.</p>
    <a href="/app/content" class="inline-flex items-center gap-2 px-4 py-2 bg-coral text-white rounded-lg text-sm font-medium hover:bg-coral-dark">
      ← Back to Content pipeline
    </a>
  </div>
) : item ? (
  <div x-data={`contentItem(${JSON.stringify(item)})`}
       @keydown.window={`(e.target.tagName !== 'TEXTAREA' && e.target.tagName !== 'INPUT') && handleShortcut(e)`}>

    {/* ═══════ STICKY HEADER (Fitts's + Peak-End) ═══════ */}
    <div class="sticky top-0 z-20 bg-white border-b border-gray-200 shadow-sm">
      <div class="px-8 py-3 max-w-7xl">
        {/* Breadcrumb (Jakob's) — each level is clickable + scoped to current
             type/scan so user can navigate up without losing context. */}
        <div class="flex items-center gap-2 text-xs text-charcoal-light mb-2">
          <a href="/app/content" class="hover:text-coral">Content</a>
          <span>›</span>
          <a :href="'/app/content?content_type=' + (item.content_type || 'faq')"
             class="hover:text-coral"
             x-text={`'${typeLabel(item.content_type)}'`}></a>
          <span>›</span>
          <a :href="'/app/content?content_type=' + (item.content_type || 'faq') + '&scan_id=' + item.scan_id"
             class="text-charcoal-dark hover:text-coral truncate max-w-md"
             x-text={`item.topic_name || 'Untitled'`}></a>
        </div>

        {/* Status row + primary CTA + save indicator */}
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <div class="flex items-center gap-3 flex-wrap">
            <span class={`text-[10px] font-bold rounded px-2 py-1 ${statusBadge(item.status)}`}
                  x-text={`statusLabelOf(item.status)`}></span>
            {item.priority && (
              <span class={`text-[10px] font-bold rounded px-2 py-1 ${priorityClass(item.priority)}`}>
                {item.priority?.toUpperCase()}
              </span>
            )}
            <span class="text-xs text-charcoal-light">
              <span class="font-medium text-charcoal-dark" x-text="item.scan_domain"></span>
              <span class="mx-1">·</span>
              <a href={`/app/scans/${item.scan_id}/results`} class="text-coral hover:underline" x-text={`'scan: ' + (item.scan_name || 'untitled')`}></a>
            </span>
          </div>

          <div class="flex items-center gap-3">
            {/* Save indicator (Doherty) */}
            <span class="text-[11px] tabular-nums" :class="saveStateClass()" x-text="saveStateLabel()"></span>

            {/* Three-action cluster on draft/in_review (Hick's hierarchy
                 preserved : Approve is the SINGLE primary action, Reject +
                 Regenerate are de-emphasized outlines). Regenerate gives the
                 user a re-roll without going through Reject first — common
                 case when the LLM output is off but the opportunity is fine
                 (Postel's, Goal-Gradient). Order = destructive | undo | accept,
                 from left = "softest" risk to right = "commits forward". */}
            <template x-if="item.status === 'draft' || item.status === 'in_review'">
              <span class="inline-flex items-center gap-2">
                <button @click="openRejectModal = true" :disabled="saving"
                        class="px-3 py-2 text-sm font-medium text-red-600 bg-white border border-red-200 rounded-lg hover:bg-red-50 hover:border-red-300 transition-all flex items-center gap-1.5"
                        title="R">
                  ✗ Reject
                </button>
                <button @click="regenerate()"
                        :disabled="saving || generating || !item.target_url"
                        :class="(saving || generating || !item.target_url) ? 'bg-gray-50 text-gray-400 border-gray-200 cursor-not-allowed' : (item.content_type === 'netlinking_article' ? 'text-purple-700 border-purple-300 hover:bg-purple-50 hover:border-purple-500' : 'text-coral border-coral/30 hover:bg-coral/10 hover:border-coral/50')"
                        class="px-3 py-2 text-sm font-medium bg-white border rounded-lg transition-all flex items-center gap-1.5"
                        :title="!item.target_url ? (item.content_type === 'netlinking_article' ? 'Set the media partner URL first (in Source above)' : 'Set a target URL first') : (item.content_type === 'netlinking_article' ? 'Regenerate article from scratch (~5-15 min, 3 content credits). Current content overwritten.' : 'Regenerate FAQ from scratch (~60s, 1 content credit). Current content will be overwritten — use this when the output is off-brand or low quality but the question is still worth answering.')">
                  <span x-show="!generating">🔄 Regenerate</span>
                  <span x-show="generating">⏳ Regenerating…</span>
                </button>
                <button @click="approve()" :disabled="saving"
                        :class="saving ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark hover:shadow-md'"
                        class="px-4 py-2 bg-coral text-white rounded-lg text-sm font-semibold transition-all flex items-center gap-2"
                        title="A">
                  ✓ Approve
                </button>
              </span>
            </template>
            <template x-if="item.status === 'approved'">
              <button @click="openPublishModal = true" :disabled="saving"
                      class="px-4 py-2 bg-coral text-white rounded-lg text-sm font-semibold hover:bg-coral-dark hover:shadow-md transition-all flex items-center gap-2">
                📤 Mark as published
              </button>
            </template>
            <template x-if="item.status === 'published'">
              <button class="px-4 py-2 bg-gray-100 text-gray-400 rounded-lg text-sm font-semibold cursor-not-allowed flex items-center gap-2"
                      disabled
                      title="Position tracking refresh — coming soon">
                🔄 Reload metrics
              </button>
            </template>
            <template x-if="(item.status === 'identified' || item.status === 'generating') && (item.content_type === 'faq' || item.content_type === 'netlinking_article')">
              <span class="inline-flex items-center gap-3">
                <button @click="generate()"
                        :disabled="generating || !item.target_url || item.status === 'generating'"
                        :class="(generating || !item.target_url) ? 'bg-gray-100 text-gray-400 cursor-not-allowed' : (item.content_type === 'netlinking_article' ? 'bg-purple-600 text-white hover:bg-purple-700 hover:shadow-md' : 'bg-coral text-white hover:bg-coral-dark hover:shadow-md')"
                        class="px-4 py-2 rounded-lg text-sm font-semibold transition-all flex items-center gap-2"
                        :title="!item.target_url ? (item.content_type === 'netlinking_article' ? 'Set the media partner URL first (in Source above)' : 'Set a target URL first') : (generating ? 'Generation in progress…' : (item.content_type === 'netlinking_article' ? 'Generate netlinking article (~5-15 min, 3 content credits)' : 'Generate FAQ content (~60s, 1 content credit)'))">
                  <span x-show="!generating" x-text="item.content_type === 'netlinking_article' ? '⚡ Generate Article' : '⚡ Generate FAQ'"></span>
                  <span x-show="generating">⏳ Generating…</span>
                </button>
                {/* Live progress indicator (Doherty Threshold + Goal-Gradient).
                     FAQ = ~60s typical, article = ~600s. Phase label streams
                     in via item.content_metadata.in_progress.phase_label
                     during polling. Soft-cap at 100% + colour change ("slower
                     than usual") sets expectations without claiming failure.
                     For article, also surface the 5-phase progress chip so
                     the user sees actual pipeline progression, not just an
                     elapsed counter. */}
                <template x-if="generating">
                  <span class="inline-flex flex-col gap-0.5 min-w-[180px]">
                    <span class="text-[10px] tabular-nums text-charcoal-light flex items-center justify-between gap-2">
                      {/* C.1.12 — Phase label is hoverable, exposes the full
                          5-phase pipeline explanation for curious users.
                          Article-only — FAQ gen has only one phase. */}
                      <span class="inline-flex items-center gap-1">
                        <span :class="item.content_type === 'netlinking_article' && progressPhaseLabel() ? 'cursor-help' : ''"
                              :title="item.content_type === 'netlinking_article' ? progressPhasesTooltip() : ''"
                              x-text="(progressPhaseLabel() ? progressPhaseLabel() + ' · ' : '') + generateElapsedSec + 's'"></span>
                      </span>
                      <span class="text-charcoal-light/70" x-text="'~' + generateExpectedSec + 's'"></span>
                    </span>
                    <span class="block h-1 w-full bg-gray-100 rounded-full overflow-hidden">
                      <span class="block h-full rounded-full transition-all duration-1000 ease-linear"
                            :class="generateElapsedSec >= generateExpectedSec ? 'bg-amber-500' : (item.content_type === 'netlinking_article' ? 'bg-purple-500' : 'bg-coral')"
                            :style="'width: ' + Math.min(100, (generateElapsedSec / generateExpectedSec) * 100) + '%'"></span>
                    </span>
                    <span x-show="generateElapsedSec >= generateExpectedSec"
                          class="text-[10px] text-amber-700 italic">Slower than usual — hold on.</span>
                    <span x-show="item.content_type === 'netlinking_article' && !generateError"
                          class="text-[10px] text-charcoal-light italic">You can leave this page — generation continues.</span>
                  </span>
                </template>
              </span>
            </template>
            <template x-if="generateError">
              <div class="text-[11px] text-red-700 bg-red-50 border border-red-200 rounded px-2 py-1 max-w-xs" x-text="generateError"></div>
            </template>
            {/* Rejected items still have valid source data — same Regenerate
                 entry-point as on draft/in_review, just unified through the
                 single regenerate() method (it detects rejected state and
                 resets validation transparently). Peak-End : the page ends
                 on a hopeful CTA, not a dead-end. */}
            <template x-if="item.status === 'rejected'">
              <span class="inline-flex items-center gap-2">
                <span class="text-xs text-gray-500 italic">Rejected</span>
                <button @click="regenerate()"
                        :disabled="generating || !item.target_url"
                        :class="(generating || !item.target_url) ? 'bg-gray-50 text-gray-400 border-gray-200 cursor-not-allowed' : (item.content_type === 'netlinking_article' ? 'text-purple-700 border-purple-300 hover:bg-purple-50 hover:border-purple-500' : 'text-coral border-coral/30 hover:bg-coral/10 hover:border-coral/50')"
                        class="px-3 py-2 text-sm font-medium bg-white border rounded-lg transition-all flex items-center gap-1.5"
                        :title="!item.target_url ? 'Pick a target URL first (edit in Source above)' : (item.content_type === 'netlinking_article' ? 'Reopen this item and generate a fresh article (~5-15 min, 3 content credits).' : 'Reopen this item and generate a fresh FAQ (~60s, 1 content credit). The previous rejection stays in the audit timeline.')">
                  <span x-show="!generating">🔄 Regenerate</span>
                  <span x-show="generating">⏳ Regenerating…</span>
                </button>
              </span>
            </template>
          </div>
        </div>
      </div>
    </div>

    {/* ═══════ MAIN GRID ═══════ */}
    <div class="px-8 py-6 max-w-7xl grid grid-cols-1 lg:grid-cols-3 gap-6">

      {/* Left column (2/3): source + content + workflow */}
      <div class="lg:col-span-2 space-y-6">

        {/* Source — flat, no Show more toggle. Previously the toggle only
             revealed Best competitor + Competitors cited (rest is null on
             FAQ items), which the user flagged as no-value friction. With
             those two fields always shown the section has 7-8 fields, within
             Miller's 5-9 range and clearer at-a-glance. */}
        <section class="bg-white rounded-xl border border-gray-200 p-5">
          <h2 class="text-sm font-semibold text-charcoal-dark mb-3">Source</h2>
          <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
            <div>
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Topic</dt>
              <dd class="text-charcoal-dark mt-0.5" x-text="item.topic_name || '—'"></dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Persona</dt>
              <dd class="text-charcoal-dark mt-0.5" x-text="item.persona_name || '—'"></dd>
            </div>
            <div class="sm:col-span-2">
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light flex items-center gap-2">
                <span>Question</span>
                {/* Phase B Tier A — intent chip from the Haiku
                    classifier. Hidden for promotional_fit / other
                    (the common case — no need to surface). */}
                <template x-if="intentChip()">
                  <span class="text-[9px] font-medium px-1.5 py-0.5 rounded normal-case tracking-normal"
                        :class="intentChip().cls"
                        :title="'Question intent: ' + intentChip().label + '. Classified by the scan pipeline so non-promotional questions stop burning content credits on LOW_QUALITY_SKIP.'">
                    <span x-text="intentChip().label"></span>
                  </span>
                </template>
              </dt>
              <dd class="text-charcoal-dark mt-0.5 italic" x-text="item.target_question || '—'"></dd>
            </div>

            {/* Phase B — safety-intent warning (Tier B patch ahead of the
                full intent classifier). Heuristic regex flags questions
                about side effects, contre-indications or "should I stop"
                framing where a third-party brand placement reads
                awkwardly. LLMs correctly stay conservative on pharma
                safety topics -> 0 brand mentions -> LOW_QUALITY_SKIP ->
                3 content_credits burned for nothing. The banner gives
                the user a chance to reject the opportunity before the
                debit, or generate anyway with eyes open.
                Mirrors the Tier A intent_category filter in
                worker/handlers/generate_opportunities.py once that
                ships; until then, this regex is the only signal. */}
            <template x-if="item.content_type === 'netlinking_article' && hasSafetyIntent(item.target_question)">
              <div class="sm:col-span-2 mt-2 p-3 bg-amber-50 border border-amber-300 rounded-md text-[12px] text-amber-900 leading-relaxed">
                <div class="flex items-start gap-2">
                  <span class="text-amber-600 mt-0.5">⚠</span>
                  <div class="space-y-2 flex-1">
                    <p>
                      <strong>This question reads as a safety or side-effect concern.</strong>
                      A third-party brand rarely fits naturally in the answer, so the
                      pipeline tends to skip the article and refund nothing.
                    </p>
                    <p class="text-amber-800/90">
                      Risk: <strong>LOW_QUALITY_SKIP</strong> + 3 content credits
                      burned on a draft the system rejects itself.
                    </p>
                    <template x-if="item.status === 'identified' || item.status === 'in_review'">
                      <div class="flex items-center gap-2 flex-wrap pt-1">
                        <button @click="openRejectModal = true"
                                :disabled="saving"
                                class="text-[11px] px-2 py-1 bg-white border border-amber-300 text-amber-900 hover:bg-amber-100 rounded font-medium disabled:opacity-40">
                          Reject this opportunity
                        </button>
                        <span class="text-[10px] text-amber-700/80">or scroll down and Generate anyway.</span>
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </template>
            <div class="sm:col-span-2">
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light flex items-center gap-2">
                <span x-text="item.content_type === 'netlinking_article' ? 'Media partner URL' : 'Target page'"></span>
                {/* Phase D : surface the matcher's confidence + source.
                    Only shown for FAQ items (matcher operates on brand-site
                    sitemap, N/A for articles published on third-party media). */}
                <template x-if="item.content_type === 'faq' && (item.target_url_candidates || []).length < 2 && item.target_url_source === 'sitemap_index' && item.target_url_score != null">
                  <span class="text-[9px] font-mono px-1.5 py-0.5 rounded"
                        :class="item.target_url_score >= 0.8 ? 'bg-emerald-50 text-emerald-700' : (item.target_url_score >= 0.6 ? 'bg-blue-50 text-blue-700' : 'bg-amber-50 text-amber-800')"
                        :title="'How well this page matches your question (cosine similarity on the indexed page content, weighted by the page authority).'">
                    Match <span x-text="Math.round(item.target_url_score * 100)"></span>%
                  </span>
                </template>
              </dt>
              {/* Empty-state banner — content_type-aware copy. FAQ lives on
                  YOUR site (matcher suggests pages on brand sitemaps).
                  Netlinking ARTICLE lives on a MEDIA PARTNER's site (no
                  matcher applicable — user supplies the URL after negotiating
                  the publication). */}
              <template x-if="!item.target_url && item.content_type !== 'netlinking_article'">
                <div class="mt-1 mb-2 p-2.5 bg-amber-50 border border-amber-200 rounded text-[11px] text-amber-900 leading-relaxed">
                  <strong>Pick a URL on your site</strong> where this FAQ should live. The page content drives the FAQ's voice and the citations the LLM uses, so this page must be on a brand you control.
                </div>
              </template>
              <template x-if="!item.target_url && item.content_type === 'netlinking_article'">
                <div class="mt-1 mb-2 p-2.5 bg-purple-50 border border-purple-200 rounded text-[11px] text-purple-900 leading-relaxed">
                  <strong>Set the media partner URL</strong> where this article will be published (e.g. <code class="bg-purple-100 px-1 rounded">https://www.doctissimo.fr/section/...</code>). The pipeline analyzes the top SERP results on this domain to tune the article's structure, tone and keyword density for that media's audience. The brand being promoted (your LEAD primary brand) is set separately in <em>Brand promotion</em> below.
                </div>
              </template>

              {/* Phase D top-3 picker — Pilier 3.
                  When the sitemap matcher returns ≥2 candidates, surface them
                  as 3 side-by-side cards (Common Region) so the user arbitrates
                  in 1 click instead of guessing. Active candidate gets emerald
                  ring + ★. "Use this →" on another card PATCHes target_url,
                  source auto-flips to user_input (audit signal). The plain URL
                  input below stays editable for free-form override (Postel).
                  Header line explains provenance + scoring so the numbers
                  inside the cards aren't cryptic (UX feedback 2026-05-14). */}
              {/* Top-3 picker — FAQ. Brand-site sitemap candidates. */}
              <template x-if="item.content_type === 'faq' && (item.target_url_candidates || []).length >= 2">
                <div class="mt-1 mb-3">
                  <div class="flex items-center gap-1.5 mb-1.5 text-[11px] text-charcoal-light">
                    <svg class="w-3.5 h-3.5 text-coral" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                    <strong class="text-charcoal-dark">3 suggestions for this question</strong>
                    <span class="cursor-help select-none ml-0.5"
                          title="3 pages indexed from your sitemap.xml that best match this question — pick one with 'Use this →', or type any URL manually below.&#10;&#10;HOW IT'S COMPUTED&#10;• Match % — semantic similarity between the page content and your question (cosine on text embeddings)&#10;• 🔗 backlinks — how many OTHER pages on your site link to this page; a 'hub-page' authority signal that boosts the score (more inlinks = more canonical for SEO)&#10;&#10;Source : your brand's sitemap.xml + linked pages. Refresh in Settings → Brand sitemaps if your site has changed.">ⓘ</span>
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                    <template x-for="c in item.target_url_candidates" :key="c.url">
                      <div class="relative p-2.5 rounded-lg border transition-all flex flex-col gap-1"
                           :class="c.url === item.target_url ? 'border-emerald-400 ring-2 ring-emerald-100 bg-emerald-50/50' : 'border-gray-200 bg-white hover:border-coral/40 hover:shadow-sm'">
                        <span x-show="c.url === item.target_url"
                              class="absolute top-1 right-2 text-emerald-600 text-sm leading-none"
                              title="Currently selected">★</span>
                        <a :href="c.url" target="_blank" rel="noopener"
                           :title="c.url"
                           class="text-[10px] font-mono text-charcoal-light hover:text-coral truncate block leading-tight"
                           x-text="pickerShortUrl(c.url)"></a>
                        <p class="text-xs font-medium text-charcoal-dark line-clamp-2 leading-snug"
                           :title="c.title || c.url"
                           x-text="c.title || c.url"></p>
                        <div class="flex items-center justify-between mt-auto pt-1 gap-2 flex-wrap">
                          <span class="text-[10px] inline-flex items-center gap-1.5">
                            <span class="font-semibold text-charcoal-dark"
                                  :title="'Match score — higher means the page content is closer to your question'">
                              Match <span x-text="Math.round(c.score * 100)"></span>%
                            </span>
                            <span x-show="c.inlink_count > 0"
                                  class="text-charcoal-light/80"
                                  :title="c.inlink_count + ' other pages on your site link to this page — strong hub-page signal'">
                              · 🔗 <span x-text="c.inlink_count"></span>
                            </span>
                          </span>
                          <button @click="usePickerCandidate(c)"
                                  x-show="c.url !== item.target_url"
                                  :disabled="saving"
                                  class="text-[10px] text-coral hover:text-coral-dark font-semibold whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed">
                            Use this →
                          </button>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </template>

              {/* Top-3 picker — NETLINKING ARTICLE. Media partners discovered
                  via scan_llm_results.citations + LinkFinder enrichment. Same
                  pattern as FAQ picker (Common Region, single-click pick) but
                  the chips reflect netlinking economics : citation_count,
                  provider diversity, DA, TF, price HT. Domains absent from
                  LinkFinder show "💬 Contact" — user knows to vet manually. */}
              <template x-if="item.content_type === 'netlinking_article' && (item.target_url_candidates || []).length >= 2">
                <div class="mt-1 mb-3">
                  <div class="flex items-center gap-1.5 mb-1.5 text-[11px] text-charcoal-light">
                    <svg class="w-3.5 h-3.5 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                    </svg>
                    <strong class="text-charcoal-dark">
                      <span x-text="(item.target_url_candidates || []).length"></span>
                      media partner<span x-show="(item.target_url_candidates || []).length > 1">s</span>
                      that already cite this topic
                    </strong>
                    <span class="cursor-help select-none ml-0.5"
                          title="Discovered from your scan : these are the third-party medias the LLMs ALREADY cite when answering this question. Publish a sponsored article there to recapture citation share.&#10;&#10;HOW IT'S COMPUTED&#10;• Citation count — total mentions across all LLM providers in the scan&#10;• DA (Domain Authority) — Majestic / Ahrefs-style authority score from LinkFinder (0-100, higher = stronger backlink profile)&#10;• Price € HT — published price for a sponsored placement on link-finder.net&#10;• Ranking : citation_count × log(DA+1) − price/1000&#10;&#10;Sources : citations table in scan_llm_results + LinkFinder catalog. Click 'Refresh prices' to re-query LinkFinder.">ⓘ</span>
                    <button @click="refreshMediaEnrichment()"
                            :disabled="refreshingMedia"
                            class="ml-auto text-[10px] text-purple-700 hover:text-purple-900 disabled:opacity-40 inline-flex items-center gap-1"
                            title="Re-fetch LinkFinder data (prices may have changed). LinkFinder serves a 7-day cache so this is cheap.">
                      <span x-show="!refreshingMedia">↻ Refresh prices</span>
                      <span x-show="refreshingMedia">⏳ Refreshing…</span>
                    </button>
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                    <template x-for="c in item.target_url_candidates" :key="c.url">
                      <div class="relative p-2.5 rounded-lg border transition-all flex flex-col gap-1"
                           :class="c.url === item.target_url ? 'border-purple-400 ring-2 ring-purple-100 bg-purple-50/50' : 'border-gray-200 bg-white hover:border-purple-400/40 hover:shadow-sm'">
                        <span x-show="c.url === item.target_url"
                              class="absolute top-1 right-2 text-purple-600 text-sm leading-none"
                              title="Currently selected">★</span>
                        <div class="flex items-center justify-between gap-1.5">
                          <a :href="c.url" target="_blank" rel="noopener"
                             :title="c.url"
                             class="text-[10px] font-mono text-charcoal-light hover:text-purple-700 truncate leading-tight"
                             x-text="c.domain"></a>
                          {/* Site-type chip (C.1.4) — explicit category badge so
                              user understands why this domain was kept and what
                              kind of publication they're targeting. Color-coded :
                              emerald=Health Media (premium), purple=Blog,
                              blue=News, gray=Other (shouldn't show — would have
                              been filtered out, but defensive). */}
                          <template x-if="c.site_type">
                            <span class="text-[9px] font-medium px-1.5 py-0.5 rounded whitespace-nowrap"
                                  :class="{
                                    'bg-emerald-100 text-emerald-800': c.site_type === 'Health & Beauty Media',
                                    'bg-purple-100 text-purple-800':   c.site_type === 'Blog',
                                    'bg-blue-100 text-blue-800':       c.site_type === 'News',
                                    'bg-gray-100 text-gray-700':       !['Health & Beauty Media','Blog','News'].includes(c.site_type)
                                  }"
                                  :title="'Site type : ' + c.site_type + '. Buyable sponsored placements : Health & Beauty Media, Blog, News. Classified by Gemini (cached globally across all clients).'">
                              <span x-text="c.site_type === 'Health & Beauty Media' ? 'Health Media' : c.site_type"></span>
                            </span>
                          </template>
                        </div>
                        <p class="text-xs font-medium text-charcoal-dark line-clamp-2 leading-snug"
                           :title="c.excerpt || c.domain"
                           x-text="c.name || c.domain"></p>
                        <div class="flex items-center justify-between mt-auto pt-1 gap-2 flex-wrap">
                          <span class="text-[10px] inline-flex items-center gap-1.5 flex-wrap">
                            <span class="font-semibold text-purple-700"
                                  :title="(c.providers_cited && c.providers_cited.length > 0 ? 'Cited by: ' + c.providers_cited.join(', ') : 'Citation count across all LLM providers in this scan')">
                              🎯 <span x-text="c.citation_count"></span>×
                            </span>
                            <template x-if="c.da != null">
                              <span class="text-charcoal-dark" title="Domain Authority (LinkFinder / Majestic)">
                                DA <span x-text="c.da"></span>
                              </span>
                            </template>
                            {/* C.1.14 — when LinkFinder enriched a platform_url
                                for this domain, the price chip becomes a direct
                                link to the order page on link-finder.net.
                                Fitts's Law : the price is what the user wants
                                to act on — make it the click target. Fallback
                                stays as plain span when no platform_url. */}
                            {/* C.1.14 — when the LinkFinder catalog has an order URL
                                for this domain (Develink / similar marketplace),
                                the price chip becomes a direct link to the order
                                page. Fitts's Law : the price is what the user
                                wants to act on — make it the click target. */}
                            <template x-if="c.price_eur != null && c.platform_url">
                              <a :href="c.platform_url"
                                 target="_blank" rel="noopener nofollow"
                                 class="text-amber-700 font-medium hover:text-amber-900 hover:underline inline-flex items-center gap-0.5"
                                 :title="'Order this sponsored placement on the partner marketplace — €' + Math.round(c.price_eur).toLocaleString('fr-FR') + ' HT. Opens in a new tab.'">
                                💰 €<span x-text="Math.round(c.price_eur).toLocaleString('fr-FR')"></span>
                                <span class="text-[9px] opacity-70">↗</span>
                              </a>
                            </template>
                            <template x-if="c.price_eur != null && !c.platform_url">
                              <span class="text-amber-700 font-medium"
                                    :title="'Sponsored placement price HT (catalog data). No direct order URL on this entry — search the media name on link-finder.net.'">
                                💰 €<span x-text="Math.round(c.price_eur).toLocaleString('fr-FR')"></span>
                              </span>
                            </template>
                            <template x-if="c.price_eur == null && c.da == null">
                              <span class="text-charcoal-light italic"
                                    title="Not in LinkFinder catalog — may still accept sponsored content, contact the media directly to ask about pricing.">
                                💬 Contact
                              </span>
                            </template>
                          </span>
                          <button @click="usePickerCandidate(c)"
                                  x-show="c.url !== item.target_url"
                                  :disabled="saving"
                                  class="text-[10px] text-purple-700 hover:text-purple-900 font-semibold whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed">
                            Use this →
                          </button>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </template>
              <dd class="mt-0.5 space-y-1">
                <input type="url"
                       inputmode="url"
                       :placeholder="item.content_type === 'netlinking_article' ? 'https://www.media-partner.fr/section-or-article-slug' : 'https://your-brand-site.com/page-that-should-answer-this'"
                       :value="item.target_url || ''"
                       @input="item.target_url = $event.target.value; markUnsaved(); scheduleSave();"
                       :disabled="item.status === 'published' || item.status === 'rejected'"
                       class="w-full text-sm border rounded px-2 py-1.5 focus:outline-none focus:border-coral disabled:bg-gray-50 disabled:text-gray-500"
                       :class="urlValidation().borderClass" />
                {/* Inline validation hint (client-side, Doherty <400ms) — Postel + Aesthetic-Usability.
                    UX clean-up : when the message is the routine "Looks good"
                    success, render a compact ✓ icon-line. Warnings/errors keep
                    their full text (high-signal information stays visible). */}
                <template x-if="item.target_url && urlValidation().message && urlValidation().level === 'ok'">
                  <p class="text-[10px] leading-snug inline-flex items-center gap-1"
                     :class="urlValidation().textClass"
                     :title="urlValidation().message">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span x-text="urlValidation().shortMessage || urlValidation().message"></span>
                  </p>
                </template>
                <template x-if="item.target_url && urlValidation().message && urlValidation().level !== 'ok'">
                  <p class="text-[11px] leading-snug" :class="urlValidation().textClass" x-text="urlValidation().message"></p>
                </template>
                <div class="flex items-center gap-3 flex-wrap">
                  <template x-if="item.target_url">
                    <a :href="item.target_url" target="_blank" rel="noopener"
                       class="text-[11px] text-coral hover:underline inline-flex items-center gap-1">
                      Open page in new tab ↗
                    </a>
                  </template>
                  {/* Find a different page — Postel + Tesler + Hick's Law.
                       Visible whenever the system has skin in the game (current
                       auto_suggest OR prior rejections). Hard-capped at
                       MAX_REMATCHES to bound LLM cost and route the user to
                       manual picking once the brand's pages are exhausted.
                       The ⓘ tooltip carries the explanation so the action
                       speaks for itself (Jakob's Law - standard help pattern). */}
                  <template x-if="canRematch()">
                    <span class="inline-flex items-center gap-1.5">
                      <button @click="rematchUrl()"
                              :disabled="rematching || item.status === 'generating' || !canRematchMore()"
                              :class="(rematching || !canRematchMore()) ? 'bg-gray-50 text-gray-400 border-gray-200 cursor-not-allowed' : (item.content_type === 'netlinking_article' ? 'text-purple-700 hover:bg-purple-50 border-purple-300' : 'text-coral hover:bg-coral/10 border-coral/30')"
                              class="text-[11px] px-2 py-0.5 border rounded inline-flex items-center gap-1 transition-colors"
                              :title="rematchTooltip()">
                        <span x-show="!rematching && canRematchMore()"
                              x-text="item.content_type === 'netlinking_article' ? '🔄 Find a different media' : '🔄 Find a different page'"></span>
                        <span x-show="!rematching && !canRematchMore()">🔄 Matcher exhausted</span>
                        <span x-show="rematching">⏳ Searching…</span>
                      </button>
                      {/* Attempts counter (Tesler's : surface the budget so user
                           knows when to stop, not after the cap fires). */}
                      <template x-if="rematchCount() > 0">
                        <span class="text-[10px] tabular-nums"
                              :class="rematchAttemptsLeft() === 0 ? 'text-red-600 font-medium' : (rematchAttemptsLeft() <= 3 ? 'text-amber-700' : 'text-charcoal-light')"
                              x-text="rematchCount() + '/' + MAX_REMATCHES + ' tried'"></span>
                      </template>
                      {/* Info icon - Jakob's. Hover-only, no modal. */}
                      <span class="text-[11px] text-charcoal-light cursor-help select-none"
                            :title="rematchTooltip()">ⓘ</span>
                    </span>
                  </template>
                  <template x-if="rematchError">
                    <span class="text-[11px] text-red-700 bg-red-50 border border-red-200 rounded px-2 py-0.5" x-text="rematchError"></span>
                  </template>
                  {/* Auto-suggest chip — only meaningful when the picker
                      cards aren't already saying "system suggested these".
                      Hidden when ≥2 candidates render (picker is the
                      stronger affordance — Aesthetic-Usability). */}
                  <template x-if="item.target_url_source === 'auto_suggest' && (item.target_url_candidates || []).length < 2">
                    <span class="text-[10px] text-emerald-700 bg-emerald-50 px-1.5 py-0.5 rounded">
                      ✨ Auto-suggested — review & edit if needed
                    </span>
                  </template>
                  {/* Diversity warning : same URL targeted by N other items in this scan.
                       SEO best practice = one FAQ per page (Google's guidance). Surface
                       the conflict so the user can either pick a different page or
                       consolidate the items elsewhere. */}
                  <template x-if="item.is_target_url_shared">
                    <span class="text-[10px] text-amber-800 bg-amber-50 px-1.5 py-0.5 rounded"
                          :title="(item.target_url_share_count) + ' other item(s) target this same page. Consider a different URL for SEO (one FAQ per page).'">
                      🔗 Also picked by <span x-text="item.target_url_share_count"></span> other item<span x-show="item.target_url_share_count > 1">s</span>
                    </span>
                  </template>
                  <template x-if="item.target_url_source === 'user_input'">
                    <span class="text-[10px] text-gray-500">
                      ✏ Set by you
                    </span>
                  </template>
                  <template x-if="item.target_url_source === 'scan_result' && (item.target_url_candidates || []).length < 2">
                    <span class="text-[10px] text-gray-500">
                      From scan results
                    </span>
                  </template>
                </div>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Opportunity score</dt>
              <dd class="text-charcoal-dark font-semibold mt-0.5" x-text="item.opportunity_score != null ? Math.round(item.opportunity_score) : '—'"></dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Brand position (before)</dt>
              <dd class="text-charcoal-dark mt-0.5" x-text="item.brand_position != null ? item.brand_position.toFixed(1) : '—'"></dd>
            </div>

            {/* Always visible scan-context fields (replace prior Show more toggle) */}
            <div>
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Best competitor</dt>
              <dd class="text-charcoal-dark mt-0.5" x-text="item.best_competitor || '—'"></dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Competitors cited</dt>
              <dd class="text-charcoal-dark mt-0.5" x-text="item.nb_competitors_cited != null ? item.nb_competitors_cited : '—'"></dd>
            </div>
            {/* Article-only fields — surface only when present (FAQ items leave them null) */}
            <template x-if="item.estimated_price != null">
              <div>
                <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Estimated price</dt>
                <dd class="text-charcoal-dark mt-0.5" x-text="'€' + item.estimated_price.toFixed(0)"></dd>
              </div>
            </template>
            <template x-if="item.platform_link">
              <div>
                <dt class="text-[10px] uppercase tracking-wide text-charcoal-light">Platform link</dt>
                <dd class="mt-0.5"><a :href="item.platform_link" target="_blank" rel="noopener" class="text-coral hover:underline" x-text="item.platform_link"></a></dd>
              </div>
            </template>
          </dl>
        </section>

        {/* Pilier 5 — Side-by-side competitor snapshot.
            What ChatGPT / Gemini actually say today about this question.
            Sits between Source (the brief) and Content (our generated FAQ)
            so the user reads top→bottom : "here's the problem the LLMs see"
            → "here's what you're publishing to displace it". Common Region
            layout per AI provider, brand mentions highlighted in coral
            (yours) and red (competitor). Button + x-show pattern to dodge
            the <details> + Alpine quirk we hit on the sitemap page. */}
        <template x-if="item.competitor_snapshot && item.competitor_snapshot.responses && item.competitor_snapshot.responses.length > 0">
          <section class="bg-white rounded-xl border border-gray-200">
            <button type="button"
                    @click="competitorPanelOpen = !competitorPanelOpen"
                    class="w-full px-5 py-3 cursor-pointer hover:bg-gray-50 transition-colors flex items-center gap-2 text-left">
              <svg class="w-4 h-4 text-charcoal-light shrink-0 transition-transform"
                   :class="competitorPanelOpen ? 'rotate-90' : ''"
                   fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
              <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
                <span>What AI assistants say</span>
                <span class="text-[11px] text-charcoal-light cursor-help select-none font-normal"
                      title="The raw responses LLMs (ChatGPT, Gemini, ...) actually returned for this question. Use this to see what content patterns and citations your FAQ needs to displace. Brand mentions are highlighted : coral = your brand, red = competitor.">ⓘ</span>
              </h2>
              <span class="text-[11px] text-charcoal-light italic ml-1">— what your FAQ is here to displace</span>
              {/* Freshness chip — colored by age of the latest snapshot.
                  Green if <7d, amber 7-30d, red >30d. Visible even when the
                  panel is collapsed so the user knows up-front if the data
                  is stale. Replaces the prior 'today' lie. */}
              <span x-show="item.competitor_snapshot.latest_snapshot_at"
                    class="text-[10px] px-1.5 py-0.5 rounded font-medium shrink-0"
                    :class="aiSnapshotAgeClass()"
                    :title="'Latest LLM responses captured ' + aiSnapshotAgeLabel(true)">
                AI snapshot · <span x-text="aiSnapshotAgeLabel(false)"></span>
              </span>
              {/* Peak-End delta chip (Phase E Pilier 7).
                  Visible even when the panel is collapsed so the user feels
                  the reward at a glance after the T+14 measurement lands.
                  Positive delta = improvement (rank went down numerically).
                  Newly-cited (was absent, now cited) trumps the numeric
                  delta — it's the clearest 'win' signal. */}
              <template x-if="item.competitor_snapshot.delta_metrics && (item.competitor_snapshot.delta_metrics.newly_cited || (item.competitor_snapshot.delta_metrics.best_delta || 0) > 0)">
                <span class="ml-auto text-[10px] bg-emerald-100 text-emerald-800 border border-emerald-300 px-2 py-0.5 rounded-full font-semibold shrink-0 inline-flex items-center gap-1"
                      :title="deltaMetricsTooltip()">
                  <span class="text-emerald-600">🎉</span>
                  <span x-show="item.competitor_snapshot.delta_metrics.newly_cited">Your brand now cited</span>
                  <span x-show="!item.competitor_snapshot.delta_metrics.newly_cited && item.competitor_snapshot.delta_metrics.best_delta > 0">
                    Improved by <span x-text="item.competitor_snapshot.delta_metrics.best_delta"></span>
                  </span>
                </span>
              </template>
              <template x-if="item.competitor_snapshot.delta_metrics && !item.competitor_snapshot.delta_metrics.newly_cited && (item.competitor_snapshot.delta_metrics.best_delta || 0) < 0">
                <span class="ml-auto text-[10px] bg-amber-50 text-amber-800 border border-amber-200 px-2 py-0.5 rounded-full font-medium shrink-0"
                      :title="deltaMetricsTooltip()">
                  Dropped by <span x-text="Math.abs(item.competitor_snapshot.delta_metrics.best_delta)"></span>
                </span>
              </template>
              <template x-if="!item.competitor_snapshot.delta_metrics && item.competitor_snapshot.competitor_brand_name">
                <span class="ml-auto text-[10px] bg-red-50 text-red-700 px-1.5 py-0.5 rounded font-medium shrink-0">
                  Currently favors <strong x-text="item.competitor_snapshot.competitor_brand_name"></strong>
                </span>
              </template>
            </button>
            <div x-show="competitorPanelOpen" x-transition.opacity class="px-5 py-4 border-t border-gray-100 bg-gray-50/30">
              {/* Phase E Pilier 7 — measurement-loop summary banner.
                  Renders the per-provider delta with a 'before → after'
                  line + days elapsed since publish. Peak-End micro-
                  celebration : emerald + checkmark when improved or newly
                  cited, amber when dropped. */}
              <template x-if="item.competitor_snapshot.delta_metrics">
                <div class="mb-3 px-3 py-2 rounded-lg border"
                     :class="deltaMetricsBannerClass()">
                  <p class="text-[11px] font-semibold mb-1 inline-flex items-center gap-1.5"
                     :class="deltaMetricsTextClass()">
                    <svg x-show="(item.competitor_snapshot.delta_metrics.best_delta || 0) > 0 || item.competitor_snapshot.delta_metrics.newly_cited"
                         class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span x-show="item.competitor_snapshot.delta_metrics.newly_cited">Your brand is now cited where it wasn't at publish time</span>
                    <span x-show="!item.competitor_snapshot.delta_metrics.newly_cited && (item.competitor_snapshot.delta_metrics.best_delta || 0) > 0">
                      Position improved by <span x-text="item.competitor_snapshot.delta_metrics.best_delta"></span> rank<span x-show="item.competitor_snapshot.delta_metrics.best_delta > 1">s</span> since publish
                    </span>
                    <span x-show="!item.competitor_snapshot.delta_metrics.newly_cited && (item.competitor_snapshot.delta_metrics.best_delta || 0) < 0">
                      Position dropped by <span x-text="Math.abs(item.competitor_snapshot.delta_metrics.best_delta)"></span> rank<span x-show="Math.abs(item.competitor_snapshot.delta_metrics.best_delta) > 1">s</span> since publish
                    </span>
                    <span x-show="(item.competitor_snapshot.delta_metrics.best_delta || 0) === 0 && !item.competitor_snapshot.delta_metrics.newly_cited">
                      No position change since publish
                    </span>
                  </p>
                  <div class="text-[10px] space-y-0.5"
                       :class="deltaMetricsTextClass()">
                    <template x-for="(m, prov) in item.competitor_snapshot.delta_metrics.per_provider" :key="prov">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="font-mono w-16" x-text="providerLabel(prov)"></span>
                        <span x-show="m.baseline_cited && m.latest_cited">
                          #<span x-text="m.baseline_position"></span>
                          <span class="opacity-60">→</span>
                          <strong>#<span x-text="m.latest_position"></span></strong>
                          <span x-show="m.delta > 0" class="text-emerald-700 font-semibold">(↑<span x-text="m.delta"></span>)</span>
                          <span x-show="m.delta < 0" class="text-amber-700 font-semibold">(↓<span x-text="Math.abs(m.delta)"></span>)</span>
                          <span x-show="m.delta === 0" class="text-charcoal-light/70">(=)</span>
                        </span>
                        <span x-show="!m.baseline_cited && m.latest_cited" class="text-emerald-700 font-semibold">
                          absent → cited at #<span x-text="m.latest_position"></span>
                        </span>
                        <span x-show="m.baseline_cited && !m.latest_cited" class="text-amber-700 font-semibold">
                          #<span x-text="m.baseline_position"></span> → absent
                        </span>
                        <span x-show="!m.baseline_cited && !m.latest_cited" class="text-charcoal-light italic">
                          still absent
                        </span>
                        <span class="text-charcoal-light/60 ml-auto">
                          <span x-text="m.elapsed_days_since_publish"></span>d after publish
                        </span>
                      </div>
                    </template>
                  </div>
                </div>
              </template>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <template x-for="r in item.competitor_snapshot.responses" :key="r.id">
                  <div class="border border-gray-200 rounded-lg p-3 bg-white min-w-0 overflow-hidden">
                    <div class="flex items-center justify-between mb-2 pb-2 border-b border-gray-100 gap-2 flex-wrap">
                      <span class="text-[11px] font-semibold inline-flex items-center gap-1.5">
                        <span :class="r.provider === 'openai' ? 'text-emerald-700' : (r.provider === 'gemini' ? 'text-violet-700' : 'text-charcoal-dark')"
                              x-text="providerLabel(r.provider)"></span>
                        <span class="text-charcoal-light/60 font-mono text-[9px]" x-text="r.model"></span>
                      </span>
                      <div class="flex items-center gap-1 text-[10px] flex-wrap">
                        <template x-if="r.your_brand_cited && r.your_brand_position">
                          <span class="bg-emerald-50 text-emerald-700 px-1.5 py-0.5 rounded font-medium inline-flex items-center gap-1"
                                :title="'A URL on ' + (r.your_brand_domain || 'your brand') + ' appears at position ' + r.your_brand_position + ' / ' + (r.total_citations || r.citations.length) + ' in the AI\\'s source citations. Click the badge to see the cited URL.'">
                            <span>Your brand cited <strong>#<span x-text="r.your_brand_position"></span></strong>
                              <span class="font-normal text-emerald-700/80"
                                    x-text="' / ' + (r.total_citations || r.citations.length)"></span>
                            </span>
                            <a x-show="r.your_brand_url" :href="r.your_brand_url" target="_blank" rel="noopener"
                               class="text-emerald-800 hover:underline font-mono text-[9px]"
                               :title="'Open ' + r.your_brand_url"
                               x-text="r.your_brand_domain ? ('· ' + r.your_brand_domain + ' ↗') : '↗'"></a>
                          </span>
                        </template>
                        <template x-if="!r.your_brand_cited">
                          <span class="bg-amber-50 text-amber-800 px-1.5 py-0.5 rounded font-medium"
                                title="No URL on any of your primary brand domains appears in this AI's citations. Edit your FAQ to include a deep link that the LLM is likely to surface, or set the right Target page in Source above.">Your brand absent</span>
                        </template>
                        <template x-if="r.competitor_cited">
                          <span class="bg-red-50 text-red-700 px-1.5 py-0.5 rounded font-medium"
                                :title="r.competitor_domains_count + ' competitor URL(s) cited in this response'">
                            Competitor URLs cited: <span x-text="r.competitor_domains_count"></span>
                          </span>
                        </template>
                      </div>
                    </div>
                    {/* `overflow-wrap: anywhere` so unbreakable Vertex tokens
                        wrap at character boundaries instead of stretching the
                        column past the OpenAI card next to it.
                        min-w-0 on the grid item lets the truncation actually
                        kick in (a flex/grid child won't shrink below its
                        intrinsic min-content otherwise). */}
                    <div class="text-xs text-charcoal-dark leading-relaxed whitespace-pre-wrap line-clamp-[15] hover:line-clamp-none transition-all cursor-pointer min-w-0"
                         style="overflow-wrap: anywhere; word-break: break-word;"
                         :title="'Click anywhere to expand the full response'"
                         x-html="highlightBrandsInResponse(r.response_text)"></div>
                    <template x-if="r.citations && r.citations.length > 0">
                      <div class="mt-2 pt-2 border-t border-gray-100">
                        <p class="text-[10px] text-charcoal-light/80 mb-1">Sources cited <span x-text="'(' + r.citations.length + ')'"></span> :</p>
                        <ul class="text-[10px] space-y-0.5">
                          <template x-for="c in (expandedCitations[r.id] ? r.citations : r.citations.slice(0, 5))" :key="c.url">
                            <li class="truncate">
                              <a :href="c.url" target="_blank" rel="noopener"
                                 class="text-coral hover:underline"
                                 :title="c.url"
                                 x-text="prettyCitationLabel(c)"></a>
                            </li>
                          </template>
                          <template x-if="r.citations.length > 5 && !expandedCitations[r.id]">
                            <li>
                              <button type="button"
                                      @click="expandedCitations[r.id] = true"
                                      class="text-charcoal-light hover:text-coral italic underline transition-colors"
                                      x-text="'+ ' + (r.citations.length - 5) + ' more — show all'"></button>
                            </li>
                          </template>
                          <template x-if="r.citations.length > 5 && expandedCitations[r.id]">
                            <li>
                              <button type="button"
                                      @click="expandedCitations[r.id] = false"
                                      class="text-charcoal-light hover:text-coral italic underline transition-colors">
                                Collapse to top 5
                              </button>
                            </li>
                          </template>
                        </ul>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
              {/* Refresh action — re-calls the LLMs for THIS question only
                  (~$0.04). Hard cap 5/24h to bound spend. Polls the item
                  endpoint until the in_flight_refresh_job clears. */}
              <div class="mt-4 pt-3 border-t border-gray-100 flex items-center gap-3 flex-wrap">
                <button type="button"
                        @click="refreshAiSnapshot()"
                        :disabled="aiSnapshotRefreshing || (item.competitor_snapshot && item.competitor_snapshot.in_flight_refresh_job_id)"
                        :class="(aiSnapshotRefreshing || (item.competitor_snapshot && item.competitor_snapshot.in_flight_refresh_job_id)) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                        class="text-xs bg-coral text-white px-3 py-1.5 rounded-md font-medium transition-all inline-flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5"
                       :class="aiSnapshotRefreshing ? 'animate-spin' : ''"
                       fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                  </svg>
                  <span x-show="!aiSnapshotRefreshing && !(item.competitor_snapshot && item.competitor_snapshot.in_flight_refresh_job_id)">Refresh AI snapshot</span>
                  <span x-show="aiSnapshotRefreshing || (item.competitor_snapshot && item.competitor_snapshot.in_flight_refresh_job_id)">Refreshing… (~30s)</span>
                </button>
                <span class="text-[11px] text-charcoal-light cursor-help select-none"
                      title="Re-calls ChatGPT + Gemini on this question only (~$0.04, ~30s). The panel shows the latest snapshot per provider. Capped at 5 refreshes per 24h per question to bound spend.">ⓘ Cost ~$0.04 · 5 refreshes/24h max</span>
                <span x-show="aiSnapshotRefreshError"
                      class="text-[11px] text-red-700 bg-red-50 border border-red-200 rounded px-2 py-0.5"
                      x-text="aiSnapshotRefreshError"></span>
              </div>
              <p class="text-[11px] text-charcoal-light/80 mt-2 italic">
                These responses come from the most recent LLM tests on this question. Click Refresh above to re-run them now.
              </p>
            </div>
          </section>
        </template>

        {/* Content editor (Postel's Law: Visual/HTML toggle) */}
        <section class="bg-white rounded-xl border border-gray-200">
          <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between gap-3">
            <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-1.5">
              <span>Content</span>
              {/* ⓘ tooltip — Jakob's. Explains the SEO/GEO writing rules so
                   the user understands what they're reviewing without leaving
                   the page. Hover-only, no modal (Doherty Threshold). */}
              <span class="text-[11px] text-charcoal-light cursor-help select-none font-normal"
                    title="How this FAQ is written for SEO + AI-search (GEO):&#10;&#10;• Schema.org FAQPage markup — Google needs this to surface the FAQ in rich results.&#10;• Each Q wrapped in itemprop=&quot;name&quot;, each A in itemprop=&quot;acceptedAnswer&quot; > itemprop=&quot;text&quot;. Same structure the seo-llm CLI ships.&#10;• 0% hallucination — every &quot;Source&quot; link is verified via web search before injection. No fake URLs.&#10;• Brand voice — your workspace brief is injected so the answer sounds like your brand even on competitor scans.&#10;• Your brands woven in naturally where the answer fits (highlighted in coral below). Never the competitors.&#10;• Quality score auto-audited (target ≥ 80/100 on schema validity + length + brand presence).&#10;&#10;Edit anywhere — switch to HTML view to see/tweak the raw microdata.">ⓘ</span>
            </h2>
            <div class="flex items-center gap-2">
              {/* Quality score chip — Von Restorff colour coding by tier.
                   Only rendered when the worker has populated content_metadata
                   (i.e. on items generated post-migration 024). Old items
                   surface no chip rather than a confusing "0/100". */}
              <template x-if="item.content_metadata && (item.content_metadata.quality_score || item.content_metadata.quality_score === 0) && item.content_metadata.faq_count">
                <span class="text-[11px] font-semibold px-2 py-1 rounded border select-none"
                      :class="qualityBadgeClass()"
                      :title="qualityBadgeTooltip()"
                      x-text="'Quality ' + item.content_metadata.quality_score + '/100'"></span>
              </template>
              <div class="flex items-center gap-1 bg-gray-100 rounded-md p-0.5">
                <button @click="editorMode = 'visual'"
                        :class="editorMode === 'visual' ? 'bg-white text-charcoal-dark shadow-sm' : 'text-charcoal-light'"
                        class="px-3 py-1 text-[11px] rounded font-medium transition-all">Visual</button>
                <button @click="editorMode = 'html'"
                        :class="editorMode === 'html' ? 'bg-white text-charcoal-dark shadow-sm' : 'text-charcoal-light'"
                        class="px-3 py-1 text-[11px] rounded font-medium transition-all">&lt;/&gt; HTML</button>
              </div>
            </div>
          </div>
          <div class="p-5">
            <template x-if="!item.content_html && !item.content_text">
              <div class="text-center py-12">
                <p class="text-sm text-charcoal-light italic">No content generated yet</p>
                <p class="text-[11px] text-charcoal-light mt-1">Phase B/C will populate this when content is generated for this opportunity.</p>
              </div>
            </template>

            <template x-if="item.content_html || item.content_text">
              <div>
                {/* Editability affordance — Postel's Law + Affordance discoverability.
                    The contenteditable div doesn't visually signal it's editable;
                    users routinely miss the fact they can click and rewrite any
                    Q/A on the spot. One short hint above + inline save state so
                    the user knows the edit landed (Doherty Threshold). Visible
                    in Visual mode only — HTML mode is the textarea pattern users
                    already recognize (Jakob's). */}
                <div x-show="editorMode === 'visual'"
                     class="mb-2 text-[11px] text-charcoal-light flex items-center gap-2 flex-wrap">
                  <span class="inline-flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-coral" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    <span><strong class="text-charcoal-dark">Click any answer to edit</strong> · changes auto-save</span>
                  </span>
                  <span :class="saveStateClass()" class="text-[10px] tabular-nums" x-text="saveStateLabel()"></span>
                </div>
                {/* contenteditable + Alpine pattern : x-html re-rendering on
                    every keystroke clobbers the browser's caret position
                    because innerHTML replacement destroys + recreates the DOM
                    tree (even when the new HTML is identical). Fix : use
                    x-init for the first paint and x-effect that runs ONLY when
                    the user is not actively editing — external state changes
                    (loading, save returning fresh server data) still refresh
                    the DOM, user typing doesn't. */}
                <div x-show="editorMode === 'visual'"
                     class="prose prose-sm max-w-none border border-gray-100 rounded-lg p-4 min-h-[300px] focus:outline-none focus:border-coral hover:border-gray-300 transition-colors cursor-text"
                     :class="item.content_type === 'netlinking_article' ? 'article-rendered' : 'faq-rendered'"
                     contenteditable="true"
                     x-ref="visualEditor"
                     x-init="$el.innerHTML = renderedContentHtml()"
                     x-effect="if (!visualEditingActive) $el.innerHTML = renderedContentHtml()"
                     @focusin="visualEditingActive = true"
                     @focusout="visualEditingActive = false"
                     @mousedown="onContentMouseDown($event)"
                     @click="onContentClick($event)"
                     @input.debounce.500ms="onVisualEdit($event)"></div>
                <div x-show="editorMode === 'html'">
                  <textarea x-model="item.content_html"
                            @input.debounce.500ms="markUnsaved(); scheduleSave()"
                            rows="20"
                            class="w-full font-mono text-xs border border-gray-200 rounded-lg p-3 focus:outline-none focus:border-coral"
                            placeholder="<h2>Question…</h2>&#10;<p>Answer…</p>"></textarea>
                </div>
              </div>
            </template>
          </div>
        </section>

        {/* Sources cited (Law of Common Region + Von Restorff for the
             brand-bias transparency signal). Lists the exact URLs the FAQ
             generator was allowed to use as grounding, with each source's
             org name and type tag. The "Brand-bias filter" banner makes
             the strategic differentiator visible : the user can see, on
             every regen, that competitor URLs were either dropped from
             the LLM context (denylist) or never even returned (prefer-hint
             worked). */}
        <template x-if="item.content_metadata && Array.isArray(item.content_metadata.sources_used) && item.content_metadata.sources_used.length > 0">
          <section class="bg-white rounded-xl border border-gray-200">
            <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between gap-3">
              <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-1.5">
                <span>Sources</span>
                <span class="text-[11px] text-charcoal-light font-normal" x-text="'(' + item.content_metadata.sources_used.length + ')'"></span>
                <span class="text-[11px] text-charcoal-light cursor-help select-none font-normal"
                      title="Sources cited in the generated FAQ. Every URL was verified by web search before being injected — no fake links.&#10;&#10;Brand-bias defense (the strategic differentiator) :&#10;• HARD denylist drops URLs on competitor brand domains (per-scan from scan_brand_classifications) plus universal e-commerce / cart / social patterns.&#10;• SOFT prefer-hint biases the search toward your client's discovered authoritative sources (HAS, ANSM, SFD, …) — non-listed authoritative URLs still pass when relevant.&#10;&#10;The 'kept N / dropped M' counters below show what the filter actually saw on this run. 0 drops doesn't mean no protection — it means the prefer-hint was strong enough that no competitor URLs were surfaced in the first place.">ⓘ</span>
              </h2>
            </div>
            <div class="p-5 space-y-3">
              {/* Brand-bias diagnostic banner */}
              <template x-if="item.content_metadata.competitor_drops > 0">
                <div class="rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-[12px] text-emerald-800 flex items-start gap-2">
                  <span aria-hidden="true">🛡</span>
                  <span><span class="font-semibold" x-text="item.content_metadata.competitor_drops"></span>
                    competitor URL(s) blocked before reaching the generator —
                    your FAQ stays on-brand by design.</span>
                </div>
              </template>
              <template x-if="item.content_metadata.competitor_drops === 0 && item.content_metadata.scientific_raw > 0">
                <div class="rounded-md border border-gray-200 bg-gray-50 px-3 py-2 text-[12px] text-charcoal-light flex items-start gap-2">
                  <span aria-hidden="true">✓</span>
                  <span>Brand-bias filter active.
                    <span x-text="item.content_metadata.scientific_kept"></span> /
                    <span x-text="item.content_metadata.scientific_raw"></span>
                    candidate URLs passed — no competitor citations were surfaced.</span>
                </div>
              </template>
              {/* Source cards */}
              <ul class="space-y-2">
                <template x-for="(s, i) in item.content_metadata.sources_used" :key="(s.url || '') + '-' + i">
                  <li class="border border-gray-100 rounded-md p-3 hover:border-gray-200 transition-colors">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 flex-wrap">
                          <span class="text-[12px] font-semibold text-charcoal-dark" x-text="s.org || s.domain || 'Source'"></span>
                          <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded border"
                                :class="sourceTypeClass(s.type)"
                                x-text="sourceTypeLabel(s.type)"></span>
                        </div>
                        <a :href="s.url" target="_blank" rel="noopener"
                           class="block text-[11px] text-charcoal-light hover:text-coral break-all mt-1"
                           x-text="s.url"></a>
                      </div>
                      <a :href="s.url" target="_blank" rel="noopener"
                         class="text-[11px] text-coral hover:underline shrink-0">↗</a>
                    </div>
                  </li>
                </template>
              </ul>
            </div>
          </section>
        </template>

        {/* Workflow buttons (Hick's: secondary actions de-emphasized) */}
        <section class="bg-white rounded-xl border border-gray-200 p-5">
          <h2 class="text-sm font-semibold text-charcoal-dark mb-3">Workflow</h2>
          <p class="text-[11px] text-charcoal-light mb-4">
            Validation: <span class="font-medium text-charcoal-dark" x-text="item.validation || 'pending'"></span>
            <template x-if="item.validated_by"><span> · by <span x-text="item.validated_by"></span> on <span x-text="fmtDateOf(item.validated_at)"></span></span></template>
          </p>
          <div class="flex items-center gap-2 flex-wrap">
            <template x-if="item.status !== 'approved' && item.status !== 'published' && item.status !== 'rejected'">
              <button @click="approve()" :disabled="saving"
                      class="px-3 py-1.5 bg-emerald-50 text-emerald-700 rounded-md text-xs font-medium hover:bg-emerald-100 border border-emerald-200">
                ✓ Approve <span class="opacity-60">(A)</span>
              </button>
            </template>
            <template x-if="item.status !== 'rejected'">
              <button @click="setValidation('needs_revision')" :disabled="saving"
                      class="px-3 py-1.5 bg-amber-50 text-amber-700 rounded-md text-xs font-medium hover:bg-amber-100 border border-amber-200">
                ↺ Request revision
              </button>
            </template>
            <template x-if="item.status !== 'rejected' && item.status !== 'published'">
              <button @click="openRejectModal = true" :disabled="saving"
                      class="px-3 py-1.5 bg-red-50 text-red-700 rounded-md text-xs font-medium hover:bg-red-100 border border-red-200">
                ✗ Reject <span class="opacity-60">(R)</span>
              </button>
            </template>
            {item.gdrive_doc_url && (
              <a href={item.gdrive_doc_url} target="_blank" rel="noopener"
                 class="ml-auto text-[11px] text-coral hover:underline">📄 Google Doc ↗</a>
            )}
          </div>
        </section>
      </div>

      {/* Right column (1/3): brand promotion + activity timeline */}
      <div class="space-y-6">

        {/* Brand promotion (Law of Proximity + Goal-Gradient + per-item override).
             Star toggle mirrors Gate 3 scan-classifier focus-star pattern
             (scans/[id]/index.astro:903-908) — Jakob's Law : same gesture, same
             meaning across the app. Star clickable only while the item is still
             in flight (identified/draft/in_review/rejected). Locked once
             approved/published — frozen audit trail. */}
        <section class="bg-white rounded-xl border border-gray-200 p-5">
          <h2 class="text-sm font-semibold text-charcoal-dark mb-1 flex items-center gap-1.5">
            <span>Brand promotion</span>
            <span class="text-[11px] text-charcoal-light cursor-help select-none font-normal"
                  title="The system pre-selects your workspace LEAD brand (from /app/settings/brands) as the brand to push in this FAQ. Click the ☆ next to another brand to override the LEAD for THIS item only — useful when one of your other brands is more relevant to this specific topic (e.g. Aderma's Exomega for eczema, Avène's XERACALM for atopic skin). The workspace default isn't touched. After overriding, click 🔄 Find a different page in Source to refresh the target URL on the new brand's site.">ⓘ</span>
          </h2>
          <p class="text-[11px] text-charcoal-light mb-3 italic">Brands instructed to promote &mdash; with how many times each is actually mentioned in the current content (Von Restorff highlight in the body).</p>

          {/* Contextual banner after a LEAD change : tells the user the URL
               on Source is now mismatched with the new LEAD's brand site, and
               links them straight to the rematch action (Goal-Gradient). The
               banner self-clears after a successful re-match (rejected_target_urls
               gets reset, see backend) or when the user dismisses. */}
          <template x-if="leadJustChanged">
            <div class="mb-3 p-2.5 bg-amber-50 border border-amber-200 rounded text-[11px] text-amber-900 leading-relaxed">
              <strong>Lead changed to <span x-text="leadJustChanged"></span>.</strong>
              The Target URL still points to the previous brand's site. Click
              <em>🔄 Find a different page</em> in the Source section above to
              rematch on <span x-text="leadJustChanged"></span>'s domain.
              <button @click="leadJustChanged = null"
                      class="ml-1 text-amber-700 underline hover:text-amber-900">Dismiss</button>
            </div>
          </template>

          <template x-if="item.promoted_brand_names && item.promoted_brand_names.length > 0">
            <div class="space-y-1.5">
              {/* Two-tier list (UX clean-up 2026-05-14) :
                   Tier 1 — always visible : LEAD (idx=0) + brands actually
                            mentioned in the content. These are the user's
                            'wins' or 'about-to-set' choices.
                   Tier 2 — collapsed by default : non-LEAD brands with 0
                            mentions. Hidden behind a 'Show N more brands' toggle.
                            Click to expand → all star toggles are still
                            available so the user can promote any of them to
                            LEAD even when collapsed by default. */}
              <template x-for="(name, idx) in item.promoted_brand_names" :key="name">
                <div x-show="idx === 0 || (brandMentionCounts()[name] || 0) > 0 || showAllPromotedBrands"
                     class="flex items-center gap-2 group/brandrow">
                  <span class="w-5 h-5 rounded-full bg-coral text-white text-[10px] font-bold flex items-center justify-center flex-shrink-0" x-text="idx + 1"></span>
                  <template x-if="idx === 0">
                    <span class="text-yellow-400 text-base leading-none shrink-0"
                          title="LEAD brand for this content item">★</span>
                  </template>
                  <template x-if="idx === 0 && isAutoLead()">
                    <span class="text-[9px] uppercase tracking-wide font-semibold px-1 py-0.5 rounded bg-blue-50 text-blue-700 border border-blue-100 shrink-0"
                          :title="autoLeadTooltip()">Auto</span>
                  </template>
                  <template x-if="idx !== 0">
                    <button @click="setLead(idx)"
                            :disabled="!canEditLead() || leadSaving"
                            :class="canEditLead() && !leadSaving ? 'text-gray-300 hover:text-yellow-400 cursor-pointer' : 'text-gray-200 cursor-not-allowed'"
                            class="text-base leading-none shrink-0 transition-colors"
                            :title="canEditLead() ? ('Make ' + name + ' the LEAD for this item. Your workspace default stays the same.') : 'Locked — lead can only be changed before the item is approved.'">☆</button>
                  </template>
                  <span class="text-xs text-charcoal-dark flex-1 truncate" x-text="name"></span>
                  <template x-if="(brandMentionCounts()[name] || 0) === 0">
                    <span class="text-[9px] font-medium text-amber-700 bg-amber-50 border border-amber-200 rounded px-1.5 py-0.5"
                          title="Not mentioned in the current content — consider editing to weave this brand in.">0 mentions</span>
                  </template>
                  <template x-if="(brandMentionCounts()[name] || 0) > 0">
                    <span class="text-[9px] font-medium text-emerald-700 bg-emerald-50 border border-emerald-200 rounded px-1.5 py-0.5"
                          :title="brandMentionCounts()[name] + ' mention(s) detected in the content body.'"
                          x-text="(brandMentionCounts()[name]) + 'x'"></span>
                  </template>
                  <span x-show="idx === 0" class="text-[9px] uppercase tracking-wide text-coral font-bold">lead</span>
                </div>
              </template>
              {/* Expand / collapse toggle — appears only when there are non-LEAD
                   brands with 0 mentions to hide. Aesthetic-Usability : reduce
                   noise by default, keep affordance one click away. */}
              <template x-if="unmentionedNonLeadCount() > 0">
                <button type="button"
                        @click="showAllPromotedBrands = !showAllPromotedBrands"
                        class="text-[11px] text-charcoal-light hover:text-coral inline-flex items-center gap-1 mt-1 transition-colors"
                        :title="showAllPromotedBrands ? 'Hide brands with no mention' : 'Show all brands (including those not mentioned in the current content)'">
                  <svg class="w-3 h-3 transition-transform"
                       :class="showAllPromotedBrands ? 'rotate-180' : ''"
                       fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                  <span x-show="!showAllPromotedBrands">
                    Show <span x-text="unmentionedNonLeadCount()"></span> brand<span x-show="unmentionedNonLeadCount() > 1">s</span> not mentioned
                  </span>
                  <span x-show="showAllPromotedBrands">Hide brands not mentioned</span>
                </button>
              </template>
              <template x-if="leadSaving">
                <p class="text-[10px] text-charcoal-light italic mt-1">Saving new lead…</p>
              </template>
            </div>
          </template>
          <template x-if="!item.promoted_brand_names || item.promoted_brand_names.length === 0">
            <p class="text-xs text-charcoal-light italic">No brands promoted on this item yet (will be set when content is generated by Phase B/C).</p>
          </template>
          {/* Competitor leak panel — only meaningful once content actually
               exists. Showing "promotion is clean" on an empty item is
               nonsensical (there's nothing to be clean about), so we gate
               on content_html OR content_text. Status === 'generating' also
               implies no content yet, the gate catches both.
               Peak-End : reassurance when clean (emerald), alarm when
               leaked (red + per-brand count). */}
          <template x-if="(item.content_html || item.content_text) && item.competitor_brand_names && item.competitor_brand_names.length > 0">
            <div class="mt-4 pt-3 border-t border-gray-100">
              <p class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light mb-2">Competitor leak check</p>
              <template x-if="!hasCompetitorLeaks()">
                <p class="text-[11px] text-emerald-700 bg-emerald-50 border border-emerald-200 rounded px-2 py-1.5 leading-relaxed">
                  ✓ No competitors mentioned in the content. Promotion is clean.
                </p>
              </template>
              <template x-if="hasCompetitorLeaks()">
                <div class="space-y-1.5">
                  <p class="text-[11px] text-red-800 bg-red-50 border border-red-200 rounded px-2 py-1.5 leading-relaxed">
                    ⚠ <strong>Competitor leak detected.</strong> Edit the FAQ to remove these mentions — they shouldn't appear in your branded content.
                  </p>
                  <template x-for="(count, name) in competitorLeakCounts()" :key="name">
                    <div class="flex items-center gap-2 text-[11px]">
                      <span class="font-medium text-red-800 truncate flex-1" x-text="name"></span>
                      <span class="text-[9px] font-medium text-orange-700 bg-orange-100 border border-orange-200 rounded px-1.5 py-0.5"
                            x-text="count + 'x'"></span>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </template>
        </section>

        {/* C.1.8 — Generation Quality KPI card (plain-language redesign).
            Law of UX activated :
              • Jakob's Law — every metric translated into user-vocabulary,
                no SOSEO / DSEO / RAPP / fan-out / grammes in the primary
                view. Acronyms surface only in hover for the SEO-savvy.
              • Doherty Threshold — Approve/Reject decision facts live in
                the visible card, not behind a tooltip.
              • Postel's Law — even a non-SEO user understands "Strong /
                Slightly thin / All answered" without a glossary.
              • Von Restorff — green/amber/red on each status badge so the
                weakest signal is the one the eye lands on.
              • Law of Proximity — 3 grouped sections (Overall / SEO /
                AI Search / Content) match the user's mental model :
                "is it good ? · will it rank ? · will AI cite it ?".
              • Tesler's Law — competitor-derived targets (target_soseo,
                target_dseo) are surfaced so the user sees WHY 110 is good
                here ("median competitor scored 95"). The hardcoded 80/30-70
                fallback is shown explicitly when SERP data is unavailable. */}
        <template x-if="item.content_metadata && item.content_metadata.quality_score != null">
          <section class="bg-white rounded-xl border border-gray-200 p-5">

            {/* ── Header — verdict + overall score ──────────────── */}
            <div class="flex items-center justify-between mb-1">
              <h2 class="text-sm font-semibold text-charcoal-dark">Generation quality</h2>
              <span class="text-[10px] uppercase tracking-wide font-semibold px-2 py-0.5 rounded"
                    :class="{
                      'bg-emerald-100 text-emerald-800': item.content_metadata.validation_verdict === 'APPROVED',
                      'bg-amber-100 text-amber-800':    item.content_metadata.validation_verdict === 'NEEDS_REVISION',
                      'bg-red-100 text-red-800':        ['ERROR','REJECTED'].includes(item.content_metadata.validation_verdict),
                    }"
                    :title="qualityVerdictTooltip()"
                    x-text="qualityVerdictLabel()"></span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl font-bold tabular-nums"
                    :class="item.content_metadata.quality_score >= 80 ? 'text-emerald-600'
                          : item.content_metadata.quality_score >= 60 ? 'text-amber-600'
                          : 'text-red-600'"
                    x-text="item.content_metadata.quality_score"></span>
              <span class="text-xs text-charcoal-light">/ 100 overall quality</span>
              <span class="cursor-help select-none text-charcoal-light text-[10px] ml-1"
                    title="SEO/editorial jargon : also called a RAPP validator (Relevance · Accuracy · Persona · Promotion). 7 criteria scored: clarity, factual accuracy, source quality, brand-bias compliance, freshness, tone consistency, fan-out coverage. Underlying score is on /10, displayed here × 10 → /100.">ⓘ</span>
            </div>
            <p class="text-[11px] text-charcoal-light mt-0.5"
               x-text="editorialValidatorLine()"></p>

            {/* ── SEO scoring (vs SERP competitors) ─────────────── */}
            {/* C.1.10 — section-header ⓘ removed : the per-metric ⓘ on
                "Keyword coverage" and "Topic diversity" already explain
                YTG / SOSEO / DSEO. The section header was repeating the
                same context 3× (against Jakob's Law of consistency). */}
            <div class="mt-4 pt-3 border-t border-gray-100">
              <p class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light mb-2">SEO scoring</p>

              {/* Keyword coverage (SOSEO) — versus competitor median target */}
              <template x-if="item.content_metadata.ytg_soseo != null">
                <div class="mb-3">
                  <div class="flex items-center justify-between text-[12px] mb-0.5">
                    <span class="text-charcoal-dark font-medium inline-flex items-center gap-1">
                      Keyword coverage
                      <span class="cursor-help select-none text-charcoal-light text-[10px]"
                            title="SEO jargon : SOSEO (Sémantique Optimization SEO) — YourTextGuru's score (0-130) measuring how many of the topic 'grammes' (semantic keyword stems extracted from top SERP competitors) appear in your article.&#10;&#10;Target = the median SOSEO of the top 10 Google SERP results for this exact query (dynamic per topic). Falls back to 80 when SERP analysis is unavailable.&#10;&#10;Higher = stronger semantic alignment with what currently ranks on Google.">ⓘ</span>
                    </span>
                    <span class="tabular-nums font-semibold"
                          :class="soseoStatusClass()">
                      <span x-text="soseoStatusLabel()"></span>
                      <span class="text-charcoal-light text-[11px] ml-1" x-text="item.content_metadata.ytg_soseo.toFixed(0)"></span>
                    </span>
                  </div>
                  <div class="h-1.5 bg-gray-100 rounded overflow-hidden relative">
                    {/* Target marker — vertical line at the competitor median */}
                    <div class="absolute top-0 bottom-0 w-px bg-charcoal-light/40 z-20"
                         :style="`left: ${Math.min(99, (soseoTarget() / 130) * 100)}%`"
                         :title="'Target: ' + soseoTarget()"></div>
                    <div class="h-full rounded transition-all"
                         :class="soseoBarClass()"
                         :style="`width: ${Math.min(100, (item.content_metadata.ytg_soseo / 130) * 100)}%`"></div>
                  </div>
                  <p class="text-[10px] text-charcoal-light mt-1" x-text="soseoTargetLine()"></p>
                </div>
              </template>

              {/* Topic diversity (DSEO) — sweet-spot band 30-70 */}
              <template x-if="item.content_metadata.ytg_dseo != null">
                <div class="mb-1">
                  <div class="flex items-center justify-between text-[12px] mb-0.5">
                    <span class="text-charcoal-dark font-medium inline-flex items-center gap-1">
                      Topic diversity
                      <span class="cursor-help select-none text-charcoal-light text-[10px]"
                            title="SEO jargon : DSEO (Diversity SEO) — YourTextGuru's lexical-spread score (0-100).&#10;&#10;• Below 30 — vocabulary too narrow, thin content → ranking risk on adjacent queries&#10;• 30-70 — sweet spot, natural language&#10;• Above 70 — keyword stuffing or off-topic drift&#10;• Above 85 — flagged as AI-detection risk&#10;&#10;The generator automatically rewrites overly dense passages above 70 to humanise the text before saving.">ⓘ</span>
                    </span>
                    <span class="tabular-nums font-semibold"
                          :class="dseoStatusClass()">
                      <span x-text="dseoStatusLabel()"></span>
                      <span class="text-charcoal-light text-[11px] ml-1" x-text="item.content_metadata.ytg_dseo.toFixed(0)"></span>
                    </span>
                  </div>
                  <div class="h-1.5 bg-gray-100 rounded overflow-hidden relative">
                    <div class="absolute top-0 h-full bg-emerald-50"
                         style="left: 30%; width: 40%;"></div>
                    <div class="h-full rounded transition-all relative z-10"
                         :class="dseoBarClass()"
                         :style="`width: ${Math.min(100, item.content_metadata.ytg_dseo)}%`"></div>
                  </div>
                  <p class="text-[10px] text-charcoal-light mt-1" x-text="dseoTargetLine()"></p>
                </div>
              </template>
            </div>

            {/* ── AI search readiness ──────────────────────────── */}
            {/* C.1.10 — section-header ⓘ removed : "Question coverage" ⓘ
                below already explains fan-outs. No need to duplicate. */}
            <div class="mt-4 pt-3 border-t border-gray-100">
              <p class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light mb-2">AI search readiness</p>
              <div class="flex items-center justify-between text-[12px]">
                <span class="text-charcoal-dark font-medium inline-flex items-center gap-1">
                  Question coverage
                  <span class="cursor-help select-none text-charcoal-light text-[10px]"
                        title="Also called fan-out coverage. Measures how many of the AI-reformulated sub-queries the article actually addresses.&#10;&#10;Baseline = whatever the LLMs ASKED during YOUR scan (variable per topic). 5/5 doesn't mean comprehensive topic coverage — it means the article covers everything Google SGE / ChatGPT / Claude currently reformulate the user's question into.">ⓘ</span>
                </span>
                <span class="tabular-nums font-semibold"
                      :class="fanoutCoverageOk() ? 'text-emerald-700' : 'text-amber-700'">
                  <span x-text="fanoutCoverageStatusLabel()"></span>
                  <span class="text-charcoal-light text-[11px] ml-1" x-text="fanoutCoverageLabel()"></span>
                </span>
              </div>
              <p class="text-[10px] text-charcoal-light mt-1" x-text="fanoutCoverageDetail()"></p>

              {/* Expandable fan-out list */}
              {/* C.1.10 — symmetric See/Hide verbs ; ★ Primary badge pinned
                  to row #1 (was orphan footer text). */}
              <template x-if="(item.content_metadata.fan_outs_used || []).length > 0">
                <div class="mt-2">
                  <button type="button"
                          @click="expandFanouts = !expandFanouts"
                          class="text-[10px] text-purple-700 hover:text-purple-900 inline-flex items-center gap-1">
                    <svg class="w-3 h-3 transition-transform"
                         :class="expandFanouts ? 'rotate-90' : ''"
                         fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span x-text="expandFanouts
                          ? 'Hide questions'
                          : 'See the ' + (item.content_metadata.fan_outs_used || []).length + ' questions'"></span>
                  </button>
                  <ol x-show="expandFanouts" x-collapse class="mt-2 space-y-1.5 text-[11px]">
                    <template x-for="(q, i) in (item.content_metadata.fan_outs_used || [])" :key="i">
                      <li class="flex items-start gap-2 leading-snug">
                        <span class="tabular-nums text-charcoal-light w-4 flex-shrink-0" x-text="(i + 1) + '.'"></span>
                        <span :class="isFanoutCovered(q) ? 'text-emerald-600' : 'text-amber-600'"
                              x-text="isFanoutCovered(q) ? '✓' : '○'"
                              class="flex-shrink-0"></span>
                        <span class="text-charcoal-dark flex-1" x-text="q"></span>
                        <template x-if="i === 0">
                          <span class="text-[9px] font-medium text-purple-700 bg-purple-50 border border-purple-100 rounded px-1 py-px whitespace-nowrap flex-shrink-0"
                                title="Primary fan-out — the query used to build the article's SEO brief (keyword grammes + competitor SOSEO/DSEO targets).">★ Primary</span>
                        </template>
                      </li>
                    </template>
                  </ol>
                </div>
              </template>
            </div>

            {/* ── Content makeup ──────────────────────────────── */}
            <div class="mt-4 pt-3 border-t border-gray-100">
              <p class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light mb-2">Content</p>

              {/* Length vs SERP-target median */}
              <div class="mb-3">
                <div class="flex items-baseline justify-between text-[12px]">
                  <span class="text-charcoal-dark font-medium inline-flex items-center gap-1">
                    Article length
                    <span class="cursor-help select-none text-charcoal-light text-[10px]"
                          title="SEO jargon : the target shown here is the median word count of the top 10 Google SERP results for this exact query (computed live, not hardcoded).&#10;&#10;Matching ±15% of the SERP median reads as 'naturally competitive length' to both Google and AI assistants. Far above can read as padded ; far below as thin.">ⓘ</span>
                  </span>
                  <span class="tabular-nums font-semibold" :class="wordCountStatusClass()">
                    <span x-text="wordCountStatusLabel()"></span>
                    <span class="text-charcoal-light text-[11px] ml-1" x-text="wordCountCurrentLabel()"></span>
                  </span>
                </div>
                <p class="text-[10px] text-charcoal-light mt-1" x-text="wordCountTargetLine()"></p>
              </div>

              {/* Sources — density rating + expandable by-type */}
              <div>
                <div class="flex items-baseline justify-between text-[12px]">
                  <span class="text-charcoal-dark font-medium inline-flex items-center gap-1">
                    Distinct sources
                    <span class="cursor-help select-none text-charcoal-light text-[10px]"
                          title="SEO/E-E-A-T jargon : every <a href> URL in the generated article, deduplicated. High source density signals editorial rigour (Google E-E-A-T : Experience, Expertise, Authoritativeness, Trustworthiness).&#10;&#10;Industry baseline for long-form (>1500 words):&#10;• &lt;5 : thin sourcing (E-E-A-T risk)&#10;• 5-9 : solid baseline&#10;• 10-15 : rich (long-form quality)&#10;• 16+ : reference-grade editorial density">ⓘ</span>
                  </span>
                  <span class="tabular-nums font-semibold" :class="sourcesDensityClass()">
                    <span x-text="sourcesDensityLabel()"></span>
                    <span class="text-charcoal-light text-[11px] ml-1"
                          x-text="(item.content_metadata.sources_count != null ? item.content_metadata.sources_count : (item.content_metadata.sources_used || []).length)"></span>
                  </span>
                </div>
                <p x-show="sourcesBreakdownLine()" class="text-[10px] text-charcoal-light mt-1" x-text="sourcesBreakdownLine()"></p>

                {/* C.1.11 — 2-level progressive disclosure for sources :
                    Level 1 = expand to see category headers (Brand / Scientific /
                    Review / Editorial / Institutional / Competitor) with counts.
                    Level 2 = click any category row to expand its URL list.
                    Rationale : 16 URLs all at once is a wall ; the user usually
                    wants to verify ONE category at a time (e.g. "are the
                    scientific sources real ?", "any competitor leaks ?"). */}
                <template x-if="(item.content_metadata.sources_used || []).length > 0">
                  <div class="mt-1.5">
                    <button type="button"
                            @click="expandSources = !expandSources"
                            class="text-[10px] text-purple-700 hover:text-purple-900 inline-flex items-center gap-1">
                      <svg class="w-3 h-3 transition-transform"
                           :class="expandSources ? 'rotate-90' : ''"
                           fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                      </svg>
                      <span x-text="expandSources
                            ? 'Hide source types'
                            : 'See the ' + sourcesGroupedByType().length + ' source type' + (sourcesGroupedByType().length > 1 ? 's' : '')"></span>
                    </button>
                    <div x-show="expandSources" x-collapse class="mt-2 space-y-1">
                      <template x-for="grp in sourcesGroupedByType()" :key="grp.type">
                        <div>
                          {/* Level 1 — category row (clickable, chevron) */}
                          <button type="button"
                                  @click="toggleSourceType(grp.type)"
                                  class="w-full flex items-center gap-1.5 py-1 px-1.5 rounded hover:bg-gray-50 text-left">
                            <svg class="w-2.5 h-2.5 transition-transform flex-shrink-0"
                                 :class="isSourceTypeExpanded(grp.type) ? 'rotate-90' : ''"
                                 fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                            </svg>
                            <span class="text-[11px] font-semibold flex-1"
                                  :class="sourceTypeColorClass(grp.type)"
                                  x-text="grp.label"></span>
                            <span class="text-[10px] text-charcoal-light tabular-nums"
                                  x-text="grp.items.length"></span>
                          </button>
                          {/* Level 2 — URL list (collapsed by default) */}
                          <ul x-show="isSourceTypeExpanded(grp.type)" x-collapse
                              class="ml-5 mt-0.5 space-y-0.5 text-[11px]">
                            <template x-for="s in grp.items" :key="s.url">
                              <li class="flex items-start gap-1.5">
                                <a :href="s.url" target="_blank" rel="noopener"
                                   class="text-purple-700 hover:text-purple-900 hover:underline truncate flex-1"
                                   :title="s.url"
                                   x-text="s.domain + (s.anchor ? ' — ' + s.anchor.slice(0, 50) : '')"></a>
                              </li>
                            </template>
                          </ul>
                        </div>
                      </template>
                    </div>
                  </div>
                </template>
              </div>
            </div>

            {/* ── Footer — duration + timestamp ──────────────── */}
            {/* C.1.10 — removed the useless title hint on duration. */}
            <div class="mt-4 pt-2 border-t border-gray-100 flex items-center justify-between text-[10px] text-charcoal-light">
              <span>⏱ <span x-text="formatDurationMs(item.content_metadata.duration_ms)"></span></span>
              <span x-show="item.content_metadata.generated_at" x-text="fmtDateOf(item.content_metadata.generated_at)"></span>
            </div>
          </section>
        </template>

        {/* Published URL + position tracking (only on published items) */}
        <template x-if="item.status === 'published'">
          <section class="bg-white rounded-xl border border-gray-200 p-5">
            <h2 class="text-sm font-semibold text-charcoal-dark mb-3">Live URL</h2>
            <template x-if="item.published_url">
              <a :href="item.published_url" target="_blank" rel="noopener" class="text-xs text-coral hover:underline break-all" x-text="item.published_url"></a>
            </template>
            <template x-if="!item.published_url">
              <p class="text-xs text-charcoal-light italic">No URL set</p>
            </template>
            <template x-if="item.latest_position != null">
              <div class="mt-3 pt-3 border-t border-gray-100">
                <p class="text-[10px] uppercase tracking-wide text-charcoal-light">Latest position</p>
                <p class="text-lg font-bold text-charcoal-dark" x-text="item.latest_position?.toFixed(1)"></p>
                <template x-if="item.position_delta != null">
                  <p class="text-[11px] font-medium" :class="item.position_delta > 0 ? 'text-emerald-600' : item.position_delta < 0 ? 'text-red-500' : 'text-charcoal-light'"
                     x-text="(item.position_delta > 0 ? '+' : '') + item.position_delta.toFixed(1) + ' vs before'"></p>
                </template>
              </div>
            </template>
          </section>
        </template>

        {/* Activity timeline (Goal-Gradient) */}
        <section class="bg-white rounded-xl border border-gray-200 p-5">
          <h2 class="text-sm font-semibold text-charcoal-dark mb-3">Timeline</h2>
          <ol class="relative border-l border-gray-200 ml-2 space-y-3 text-xs">
            <li class="ml-4">
              <span class="absolute -left-[5px] w-2.5 h-2.5 bg-emerald-500 rounded-full"></span>
              <p class="text-charcoal-dark">Identified</p>
              <p class="text-[10px] text-charcoal-light" x-text="fmtDateOf(item.identified_at)"></p>
            </li>
            <template x-if="item.ordered_at">
              <li class="ml-4">
                <span class="absolute -left-[5px] w-2.5 h-2.5 bg-emerald-500 rounded-full"></span>
                <p class="text-charcoal-dark">In review</p>
                <p class="text-[10px] text-charcoal-light" x-text="fmtDateOf(item.ordered_at)"></p>
              </li>
            </template>
            <template x-if="item.validated_at">
              <li class="ml-4">
                <span class="absolute -left-[5px] w-2.5 h-2.5 bg-emerald-500 rounded-full"></span>
                <p class="text-charcoal-dark" x-text="'Validation: ' + (item.validation || '?')"></p>
                <p class="text-[10px] text-charcoal-light" x-text="(item.validated_by || '?') + ' · ' + fmtDateOf(item.validated_at)"></p>
              </li>
            </template>
            <template x-if="item.published_at">
              <li class="ml-4">
                <span class="absolute -left-[5px] w-2.5 h-2.5 bg-emerald-500 rounded-full"></span>
                <p class="text-charcoal-dark">Published</p>
                <p class="text-[10px] text-charcoal-light" x-text="fmtDateOf(item.published_at)"></p>
              </li>
            </template>
            <template x-if="item.status !== 'published' && item.status !== 'rejected'">
              <li class="ml-4 opacity-50">
                <span class="absolute -left-[5px] w-2.5 h-2.5 border border-gray-300 bg-white rounded-full"></span>
                <p class="text-charcoal-light italic" x-text="nextStepHint()"></p>
              </li>
            </template>
          </ol>
        </section>

        {/* Keyboard shortcuts hint */}
        <div class="text-[10px] text-charcoal-light px-2">
          Shortcuts: <kbd class="px-1 py-0.5 bg-gray-100 border border-gray-200 rounded text-[9px] font-mono">A</kbd> approve · <kbd class="px-1 py-0.5 bg-gray-100 border border-gray-200 rounded text-[9px] font-mono">R</kbd> reject · <kbd class="px-1 py-0.5 bg-gray-100 border border-gray-200 rounded text-[9px] font-mono">E</kbd> edit · <kbd class="px-1 py-0.5 bg-gray-100 border border-gray-200 rounded text-[9px] font-mono">Esc</kbd> back
        </div>
      </div>
    </div>

    {/* ═══════ REJECT CONFIRMATION MODAL ═══════ */}
    <div x-show="openRejectModal" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
         @click.self="openRejectModal = false"
         @keydown.escape.window="openRejectModal = false">
      <div class="bg-white rounded-xl max-w-md w-full p-6 shadow-xl">
        <h3 class="text-lg font-bold text-charcoal-dark mb-2">Reject this content?</h3>
        <p class="text-sm text-charcoal-light mb-6">This will permanently mark the item as rejected and remove it from active workflow. Are you sure?</p>
        <div class="flex justify-end gap-3">
          <button @click="openRejectModal = false" class="px-4 py-2 text-sm text-charcoal-dark hover:bg-gray-50 rounded-md">Cancel</button>
          <button @click="reject()" :disabled="saving"
                  class="px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-md hover:bg-red-600">
            Yes, reject
          </button>
        </div>
      </div>
    </div>

    {/* ═══════ MARK PUBLISHED MODAL (asks for URL) ═══════ */}
    <div x-show="openPublishModal" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
         @click.self="openPublishModal = false"
         @keydown.escape.window="openPublishModal = false">
      <div class="bg-white rounded-xl max-w-md w-full p-6 shadow-xl">
        <h3 class="text-lg font-bold text-charcoal-dark mb-2">Mark as published</h3>
        <p class="text-sm text-charcoal-light mb-4">Enter the live URL where this content was published:</p>
        <input type="url" x-model="publishUrl"
               placeholder="https://your-site.com/article-url"
               class="w-full text-sm border border-gray-200 rounded-md px-3 py-2 mb-6 focus:outline-none focus:border-coral" />
        <div class="flex justify-end gap-3">
          <button @click="openPublishModal = false" class="px-4 py-2 text-sm text-charcoal-dark hover:bg-gray-50 rounded-md">Cancel</button>
