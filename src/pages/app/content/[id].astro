        // of indices into fan_outs_used. Handle both shapes defensively.
        isFanoutCovered(query) {
          const m = this.item.content_metadata || {};
          const covered = m.fanout_covered || [];
          if (!covered.length) return false;
          if (typeof covered[0] === 'number') {
            const idx = (m.fan_outs_used || []).indexOf(query);
