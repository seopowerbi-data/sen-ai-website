---
/**
 * Dashboard Home — Global overview of all scans and activity.
 *
 * UX Laws:
 * - Miller's Law: 4 KPI cards max
 * - Von Restorff: inbox badge stands out
 * - Goal-Gradient: score with "aim for B"
 * - Peak-End: clear CTA at bottom
 * - Cognitive Load: plain language, no jargon
 */
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Tip from '../../components/Tip.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

// Fetch scans and brands from API (server-side via Docker network)
let scans = [];
let scanCredits = 0;
let error = null;

const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
const upstreamCookie = [
  `token=${token}`,
  activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
  activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
].filter(Boolean).join('; ');

let hasNoClientAccess = false;
try {
  const clientsRes = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  const clients = clientsRes.ok ? await clientsRes.json() : [];
  hasNoClientAccess = clients.length === 0;
  const clientId = clients[0]?.id;

  if (clientId) {
    const scansRes = await fetch(`http://api:8000/api/scans?client_id=${clientId}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    scans = scansRes.ok ? await scansRes.json() : [];

    const creditsRes = await fetch(`http://api:8000/api/stripe/credits/${clientId}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (creditsRes.ok) {
      const credits = await creditsRes.json();
      scanCredits = credits.scan || 0;
    }
  }
} catch (e) {
  error = e.message;
}

// Check email verification for banner
let isEmailVerified = true;
try {
  const meRes = await fetch('http://api:8000/api/auth/me', {
    headers: { Cookie: `token=${token}` },
    signal: AbortSignal.timeout(3000),
  });
  if (meRes.ok) {
    const me = await meRes.json();
    isEmailVerified = me.is_email_verified;
  }
} catch {}

// First-time user → redirect to onboarding.
// Phase E.C.2/4 — only true first-timers go to the wizard. The wizard is
// the "create your first workspace" flow ; anyone who already belongs to
// an org (= came through an invite or backfill) has been onboarded and an
// empty dashboard for them means "ask your admin to grant you a workspace",
// not "set up your first scan". Without this guard :
//   - C.2 : switching to an empty agency org traps the user on /welcome
//   - C.4 : a freshly-invited member with 0 client access yet gets the
//           wizard meant for new-account self-signups
// /welcome has no DashboardLayout (no org switcher) so it's a dead-end.
let orgCount = 0;
try {
  const orgsRes = await fetch('http://api:8000/api/organizations/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  if (orgsRes.ok) {
    const orgs = await orgsRes.json();
    orgCount = Array.isArray(orgs) ? orgs.length : 0;
  }
} catch {}
if (scans.length === 0 && orgCount === 0) {
  // Forward the agency signup intent through to /welcome so the wizard
  // can surface the agency-aware banner instead of the generic single-
  // brand framing. The intent param rides in from the OAuth callback
  // for Google signups OR the /register?intent=agency flow.
  const intentForWizard = (Astro.url.searchParams.get('intent') || '').toLowerCase();
  if (intentForWizard === 'agency') {
    return Astro.redirect('/welcome?intent=agency');
  }
  return Astro.redirect('/welcome');
}

// Compute dashboard stats — only own-domain scans for the score (not competitive scans)
const completedScans = scans.filter(s => s.status === 'completed');
const ownScans = completedScans.filter(s => {
  const targets = s.config?.target_domains || [s.domain];
  return targets.includes(s.domain); // target = same as scanned domain = own scan
});
const competitiveScans = completedScans.filter(s => {
  const targets = s.config?.target_domains || [s.domain];
  return !targets.includes(s.domain);
});
const avgCitationRate = ownScans.length
  ? Math.round(ownScans.reduce((sum, s) => sum + (s.summary?.brand_mention_rate ?? s.summary?.citation_rate ?? 0), 0) / ownScans.length)
  : null;
const totalOpportunities = completedScans.reduce((sum, s) => sum + (s.summary?.opportunities?.critique || 0), 0);

function getGrade(rate) {
  if (rate === null) return { letter: '?', color: 'gray', label: 'No scan yet' };
  if (rate >= 50) return { letter: 'A', color: 'emerald', label: 'Excellent' };
  if (rate >= 30) return { letter: 'B', color: 'blue', label: 'Good' };
  if (rate >= 15) return { letter: 'C', color: 'amber', label: 'Average' };
  return { letter: 'D', color: 'red', label: 'Low' };
}
const grade = getGrade(avgCitationRate);

function statusLabel(status) {
  const labels = {
    draft: 'Draft', fetching_keywords: 'Fetching...', keywords_fetched: 'Keywords ready',
    topics_ready: 'Topics ready', assigning_keywords: 'Assigning...', generating_personas: 'Generating...',
    personas_ready: 'Ready to scan', scanning: 'Scanning...', completed: 'Completed', failed: 'Failed',
  };
  return labels[status] || status;
}

function statusColor(status) {
  if (status === 'completed') return 'emerald';
  if (status === 'failed') return 'red';
  if (status === 'scanning') return 'blue';
  return 'amber';
}

function timeAgo(dateStr) {
  if (!dateStr) return '';
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  return `${Math.floor(hours / 24)}d ago`;
}
---

<DashboardLayout title="Dashboard" activeSection="dashboard">
  <div class="p-8 max-w-6xl">

    {hasNoClientAccess && orgCount >= 1 && (
      <div class="bg-blue-50 border border-blue-200 rounded-xl px-5 py-4 mb-6">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <p class="text-sm font-medium text-blue-900">You haven't been added to a workspace yet</p>
            <p class="text-xs text-blue-800 mt-1">
              Ask your organization admin to grant you access to a workspace from the Members page. You'll see scans and content here once they do.
            </p>
          </div>
        </div>
      </div>
    )}

    {!isEmailVerified && !hasNoClientAccess && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-3 mb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-amber-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <div>
            <p class="text-sm font-medium text-amber-800">Verify your email to get 50 free scan credits</p>
            <p class="text-xs text-amber-700">Check your inbox for the verification link.</p>
          </div>
        </div>
        <button onclick="fetch('/api/auth/resend-verification',{method:'POST'}).then(()=>this.textContent='Sent!')" class="text-xs text-amber-700 underline hover:text-amber-900 shrink-0">Resend</button>
      </div>
    )}

    <!-- Greeting -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-charcoal-dark">Dashboard</h1>
      <p class="text-charcoal-light mt-1">Your AI visibility at a glance</p>
    </div>

    <!-- KPI Cards (Miller's Law: max 4) -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <!-- Score -->
      <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
        <p class="text-xs text-charcoal-light uppercase tracking-wide mb-2">
          <Tip id="visibility">AI Visibility</Tip>
        </p>
        <div class="flex items-end gap-3">
          <span class={`text-4xl font-black text-${grade.color}-600`}>{grade.letter}</span>
          <span class="text-sm text-charcoal-light mb-1">{avgCitationRate !== null ? `${avgCitationRate}%` : '—'}</span>
        </div>
        <p class={`text-xs text-${grade.color}-600 mt-1`}>{grade.label}</p>
      </div>

      <!-- Scans -->
      <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
        <p class="text-xs text-charcoal-light uppercase tracking-wide mb-2">
          <Tip id="scans">Scans</Tip>
        </p>
        <p class="text-4xl font-bold text-charcoal-dark">{scans.length}</p>
        <p class="text-xs text-charcoal-light mt-1">{completedScans.length} completed</p>
      </div>

      <!-- Opportunities -->
      <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
        <p class="text-xs text-charcoal-light uppercase tracking-wide mb-2">
          <Tip id="opportunities">Opportunities</Tip>
        </p>
        <p class="text-4xl font-bold text-red-500">{totalOpportunities}</p>
        <p class="text-xs text-red-400 mt-1">CRITICAL</p>
      </div>

      <!-- Credits -->
      <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
        <p class="text-xs text-charcoal-light uppercase tracking-wide mb-2">Scan Credits</p>
        <p class="text-4xl font-bold text-blue-600 tabular-nums">{scanCredits.toLocaleString('fr-FR')}</p>
        <a href="/app/settings" class="text-xs text-coral hover:underline mt-1 inline-block">Buy more</a>
      </div>
    </div>

    <!-- Recent scans -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-8">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-charcoal-dark">Recent Scans</h2>
        <a href="/app/scans" class="text-sm text-coral hover:underline">View all</a>
      </div>
      {scans.length === 0 ? (
        <div class="px-6 py-12 text-center">
          <p class="text-charcoal-light mb-4">No scans yet</p>
          <a href="/app/scans/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Run my first scan
          </a>
        </div>
      ) : (
        <div class="divide-y divide-gray-100">
          {scans.slice(0, 5).map(scan => (
            <a href={scan.status === 'completed' ? `/app/scans/${scan.id}/results` : `/app/scans/${scan.id}`}
               class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition-colors">
              <div class={`w-2 h-2 rounded-full bg-${statusColor(scan.status)}-500 shrink-0`}></div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-charcoal-dark truncate">{scan.domain}</p>
                <p class="text-xs text-charcoal-light">{statusLabel(scan.status)}</p>
              </div>
              {(scan.summary?.brand_mention_rate ?? scan.summary?.citation_rate) !== undefined && (
                <span class="text-sm font-semibold text-charcoal-dark">{scan.summary.brand_mention_rate ?? scan.summary.citation_rate}%</span>
              )}
              <span class="text-xs text-charcoal-light">{timeAgo(scan.created_at)}</span>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- CTA (Peak-End Rule: clear action at the end) -->
    {scans.length > 0 && (
      <div class="text-center">
        <a href="/app/scans/new" class="inline-flex items-center gap-2 px-6 py-3 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-colors shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          New Scan
        </a>
      </div>
    )}
  </div>
</DashboardLayout>
