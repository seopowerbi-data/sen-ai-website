---
/**
 * Settings — API keys, credits, account.
 *
 * UX Laws:
 * - Cognitive Load: grouped sections, clear labels
 * - Hick's Law: minimal options per section
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

let user = { email: '' };
try {
  const payload = JSON.parse(atob(token.split('.')[1]));
  user.email = payload.email || '';
} catch {}

// Get client_id for credit balance
let clientId = null;
try {
  const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
  const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
  const upstreamCookie = [
    `token=${token}`,
    activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
    activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
  ].filter(Boolean).join('; ');
  const res = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  const clients = res.ok ? await res.json() : [];
  clientId = clients[0]?.id;
} catch {}

// Get credit balances
let credits = { scan: 0, content: 0 };
if (clientId) {
  try {
    const res = await fetch(`http://api:8000/api/stripe/credits/${clientId}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (res.ok) credits = await res.json();
  } catch {}
}

const paymentStatus = Astro.url.searchParams.get('payment');
---

<DashboardLayout title="Settings" activeSection="settings">
  <div class="p-8 max-w-3xl">

    <h1 class="text-2xl font-bold text-charcoal-dark mb-8">Settings</h1>

    <!-- Account -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
      <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-4">Account</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-charcoal-light">Email</span>
          <span class="text-sm text-charcoal-dark">{user.email}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-charcoal-light">Password</span>
          <button class="text-sm text-coral hover:underline">Change</button>
        </div>
      </div>
    </div>

    <!-- Payment feedback -->
    {paymentStatus === 'success' && (
      <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-4 mb-6 text-sm text-emerald-700">
        Payment successful! Your credits have been added.
      </div>
    )}
    {paymentStatus === 'canceled' && (
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-700">
        Payment was canceled. No credits were charged.
      </div>
    )}

    <!-- Credits -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6" x-data={`creditsPanel('${clientId}')`}>
      <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-4">Credits</h2>

      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-blue-50 rounded-lg p-4">
          <p class="text-xs text-blue-600 font-medium mb-1">Scan credits</p>
          <p class="text-3xl font-bold text-blue-700 tabular-nums">{credits.scan.toLocaleString('fr-FR')}</p>
          <p class="text-[10px] text-blue-500 mt-1">1 credit = 1 AI question</p>
        </div>
        <div class="bg-emerald-50 rounded-lg p-4">
          <p class="text-xs text-emerald-600 font-medium mb-1">Content credits</p>
          <p class="text-3xl font-bold text-emerald-700 tabular-nums">{credits.content.toLocaleString('fr-FR')}</p>
          <p class="text-[10px] text-emerald-500 mt-1">1 credit = 1 FAQ · 3 credits = 1 article</p>
        </div>
      </div>

      <h3 class="text-xs font-semibold text-charcoal-dark uppercase tracking-wide mb-3">Buy credits</h3>
      <div class="grid grid-cols-2 gap-3">
        <div class="space-y-2">
          <p class="text-[10px] text-charcoal-light uppercase tracking-wide">Scan credits <span class="text-charcoal-light/70 normal-case">— 1 credit = 1 question tested</span></p>
          <button @click="buyPack('scan_starter')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <div>
                <span class="text-sm font-medium">200 credits</span>
                <span class="text-[10px] text-charcoal-light ml-1">· €0.10/q</span>
              </div>
              <span class="text-sm font-bold text-coral">€20</span>
            </div>
          </button>
          <button @click="buyPack('scan_pro')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <div>
                <span class="text-sm font-medium">1 000 credits</span>
                <span class="text-[10px] text-charcoal-light ml-1">· €0.08/q</span>
              </div>
              <span class="text-sm font-bold text-coral">€80</span>
            </div>
          </button>
          <button @click="buyPack('scan_agency')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <div>
                <span class="text-sm font-medium">5 000 credits</span>
                <span class="text-[10px] text-charcoal-light ml-1">· €0.06/q</span>
              </div>
              <span class="text-sm font-bold text-coral">€300</span>
            </div>
          </button>
          <button @click="buyPack('scan_enterprise')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <div>
                <span class="text-sm font-medium">20 000 credits</span>
                <span class="text-[10px] text-charcoal-light ml-1">· €0.05/q</span>
              </div>
              <span class="text-sm font-bold text-coral">€1 000</span>
            </div>
          </button>
        </div>
        <div class="space-y-2">
          <p class="text-[10px] text-charcoal-light uppercase tracking-wide">Content credits</p>
          <button @click="buyPack('content_10')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <span class="text-sm font-medium">10 credits</span>
              <span class="text-sm font-bold text-coral">€40</span>
            </div>
          </button>
          <button @click="buyPack('content_30')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <span class="text-sm font-medium">30 credits</span>
              <span class="text-sm font-bold text-coral">€100</span>
            </div>
          </button>
          <button @click="buyPack('content_100')" class="w-full text-left px-4 py-3 rounded-lg border border-gray-200 hover:border-coral hover:bg-coral/5 transition-all">
            <div class="flex justify-between items-center">
              <span class="text-sm font-medium">100 credits</span>
              <span class="text-sm font-bold text-coral">€250</span>
            </div>
          </button>
        </div>
      </div>

      <p class="text-[10px] text-charcoal-light mt-3">Payment via Stripe. Credits never expire.</p>
    </div>

    <!-- My primary brands -->
    <a href="/app/settings/brands" class="block bg-white rounded-xl border border-gray-200 p-6 mb-6 hover:border-coral/40 transition-colors group">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-1">My primary brands</h2>
          <p class="text-xs text-charcoal-light">Choose which brands content generation should promote — even on competitor scans.</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 group-hover:text-coral transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </a>

    <!-- Trust sources -->
    <a href="/app/settings/trust-sources" class="block bg-white rounded-xl border border-gray-200 p-6 mb-6 hover:border-coral/40 transition-colors group">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-1">Trust sources</h2>
          <p class="text-xs text-charcoal-light">Authoritative domains your content gen prefers to cite. Auto-discovered, you can add extras.</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 group-hover:text-coral transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </a>

    <!-- Brand sitemaps & pages -->
    <a href="/app/settings/sitemaps" class="block bg-white rounded-xl border border-gray-200 p-6 mb-6 hover:border-coral/40 transition-colors group">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-1">Brand sitemaps & pages</h2>
          <p class="text-xs text-charcoal-light">Pages we've indexed per primary brand — drives semantic target_url auto-suggest. Refresh sitemap or add pages manually.</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 group-hover:text-coral transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </a>

    <!-- Connected Accounts -->
    <a href="/app/settings/connections" class="block bg-white rounded-xl border border-gray-200 p-6 mb-6 hover:border-coral/40 transition-colors group">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-charcoal-dark uppercase tracking-wide mb-1">Connected Accounts</h2>
          <p class="text-xs text-charcoal-light">Link Google, Microsoft, or Notion accounts for data sync.</p>
        </div>
        <svg class="w-5 h-5 text-gray-400 group-hover:text-coral transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </a>

    <!-- Danger zone -->
    <div class="bg-white rounded-xl border border-red-200 p-6">
      <h2 class="text-sm font-semibold text-red-600 uppercase tracking-wide mb-3">Danger zone</h2>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-charcoal-dark">Delete account</p>
          <p class="text-xs text-charcoal-light">Permanently delete your account and all data</p>
        </div>
        <button class="px-4 py-2 border border-red-300 text-red-600 rounded-lg text-sm hover:bg-red-50">Delete</button>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      Alpine.data('creditsPanel', (clientId) => ({
        clientId,
        async buyPack(packId) {
          if (!this.clientId) { alert('No client found. Please contact support.'); return; }
          try {
            const res = await fetch('/api/stripe/checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ pack_id: packId, client_id: this.clientId }),
            });
            if (res.ok) {
              const data = await res.json();
              window.location.href = data.checkout_url;
            } else {
              const err = await res.json().catch(() => ({}));
              alert(err.detail || 'Checkout failed. Please try again.');
            }
          } catch (e) { alert('Network error: ' + e.message); }
        },
      }));
    });
  </script>
</DashboardLayout>
