---
/**
 * Workspace Settings → My primary brands
 *
 * UX Laws:
 * - Recognition over Recall: shows currently-selected brands at top, available below
 * - Aesthetic-Usability: chips style with explicit Add / Remove / Reorder buttons
 * - Hick's Law: only the brands of THIS client, not the world
 * - Postel's Law: server validates UUIDs against client membership
 *
 * Lets the user curate Client.primary_brand_ids — the workspace default for
 * content-gen brand promotion. Backed by GET/PUT /api/clients/{id}/promotion.
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

let clientId: string | null = null;
let clientName = '';
const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
const upstreamCookie = [
  `token=${token}`,
  activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
  activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
].filter(Boolean).join('; ');
try {
  const res = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  const clients = res.ok ? await res.json() : [];
  if (clients[0]) {
    clientId = clients[0].id;
    clientName = clients[0].name;
  }
} catch {}

let initialData: any = { primary_brand_ids: [], all_brands: [] };
let initialBrief: any = null;
let briefBudget: any = { generations_used: 0, generations_cap: 5, can_regenerate: true };
if (clientId) {
  try {
    const res = await fetch(`http://api:8000/api/clients/${clientId}/promotion`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (res.ok) initialData = await res.json();
  } catch {}
  try {
    const res = await fetch(`http://api:8000/api/clients/${clientId}/brief`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (res.ok) {
      const data = await res.json();
      initialBrief = data.brief;
      briefBudget = {
        generations_used: data.generations_used ?? 0,
        generations_cap: data.generations_cap ?? 5,
        can_regenerate: data.can_regenerate ?? true,
      };
    }
  } catch {}
}
---

<DashboardLayout title="My primary brands" activeSection="settings">
  <div class="p-8 max-w-4xl">

    <div class="mb-6">
      <a href="/app/settings" class="text-xs text-charcoal-light hover:text-coral inline-flex items-center gap-1 mb-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Settings
      </a>
      <h1 class="text-2xl font-bold text-charcoal-dark">My primary brands</h1>
      <p class="text-sm text-charcoal-light mt-1">
        For workspace <span class="font-medium text-charcoal-dark">{clientName || '?'}</span>. These are the brands that content generation (FAQ, articles) will <strong class="text-charcoal-dark">promote</strong> when you click "Generate" on any opportunity — even on a competitor scan.
      </p>
    </div>

    {/* Info banner */}
    <details class="mb-6 bg-blue-50/50 border border-blue-100 rounded-lg overflow-hidden group">
      <summary class="px-4 py-2.5 cursor-pointer hover:bg-blue-50 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-500 shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <span class="text-sm font-medium text-blue-900">Why does this matter ?</span>
      </summary>
      <div class="px-4 py-3 border-t border-blue-100 text-xs text-blue-900/90 leading-relaxed space-y-2">
        <p>When you scan a <strong>competitor</strong> (e.g., laroche-posay.fr) and click "Generate FAQ" on an opportunity, the generated content has to know which brands to push. Without this list, the system has to fall back on auto-detection per scan, which can miss your less-mentioned brands.</p>
        <p>The <strong>first brand</strong> in your list is treated as the <strong>lead brand</strong> — content gives it the spotlight. Other brands are co-promoted as "sister brands" when relevant. Reorder with <span class="font-medium">↑↓</span>.</p>
        <p>You can also <strong>override per scan</strong> later (e.g., "on this scan only push Avène") — that doesn't change this workspace default.</p>
      </div>
    </details>

    {!clientId ? (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-900">
        No workspace found. Create one first, then come back here.
      </div>
    ) : (
      <div x-data={`primaryBrands(${JSON.stringify(initialData)}, '${clientId}')`}>

        {/* Workspace brief panel — feeds Phase B/C content gen with brand voice context */}
        <div class="bg-white rounded-xl border border-gray-200 mb-6 overflow-hidden"
             x-data={`workspaceBrief(${JSON.stringify(initialBrief)}, '${clientId}', ${JSON.stringify(briefBudget)})`}>
          <div class="px-5 py-3 border-b border-gray-100 flex items-baseline justify-between gap-3">
            <div>
              <h2 class="text-sm font-semibold text-charcoal-dark">Workspace brief</h2>
              <p class="text-[11px] text-charcoal-light italic mt-0.5">
                Brand voice + positioning · injected into FAQ + article generation
              </p>
            </div>
            <div class="flex items-center gap-2">
              <span x-show="brief && !brief.edited_by_user" class="text-[10px] uppercase tracking-wide font-semibold px-2 py-1 rounded bg-blue-50 text-blue-700"
                    title="Auto-generated — regenerate to refresh">Auto</span>
              <span x-show="brief && brief.edited_by_user" class="text-[10px] uppercase tracking-wide font-semibold px-2 py-1 rounded bg-emerald-50 text-emerald-700"
                    title="You edited this — regeneration is blocked">Edited</span>
              {/* Regen budget counter (Tesler's : surface the budget before
                   cap fires). Same pattern as the FAQ rematch button. */}
              <template x-if="budget.generations_used > 0">
                <span class="text-[10px] tabular-nums"
                      :class="!budget.can_regenerate ? 'text-red-600 font-medium' : (budget.generations_cap - budget.generations_used <= 2 ? 'text-amber-700' : 'text-charcoal-light')"
                      :title="budget.generations_used + ' regenerations used out of ' + budget.generations_cap"
                      x-text="budget.generations_used + '/' + budget.generations_cap"></span>
              </template>
              <button type="button" @click="generate()"
                      :disabled="generating || (brief && brief.edited_by_user) || !budget.can_regenerate"
                      :class="(generating || (brief && brief.edited_by_user) || !budget.can_regenerate) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                      class="text-xs bg-coral text-white px-3 py-1 rounded-md font-medium transition-all"
                      :title="!budget.can_regenerate ? 'Regen cap reached — edit the brief manually below' : (brief && brief.edited_by_user ? 'You edited this — regeneration is blocked' : 'Regenerate the workspace brief from your primary brands (~10s, capped at ' + budget.generations_cap + ' per workspace)')">
                <span x-show="!generating && !brief">Generate</span>
                <span x-show="!generating && brief && budget.can_regenerate">Regenerate</span>
                <span x-show="!generating && brief && !budget.can_regenerate">Cap reached</span>
                <span x-show="generating">Generating…</span>
              </button>
              <span class="text-[11px] text-charcoal-light cursor-help select-none"
                    :title="'Workspace brief defines your company voice + positioning. It\\'s auto-injected when generating FAQs or articles so the output sounds like your brand. Regeneration capped at ' + budget.generations_cap + ' per workspace to bound LLM cost (~$0.05/call). Once exhausted, edit the brief inline.'">ⓘ</span>
            </div>
          </div>
          <div class="p-5 text-sm">
            <p x-show="!brief" class="text-charcoal-light italic">
              No workspace brief yet. Click Generate — uses your selected primary brands as input
              (web-searched via OpenAI, falls back to Gemini / Claude). Takes ~10s.
            </p>
            <div x-show="brief" class="space-y-3">
              <p><span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light">Industry</span><br/>
                <span class="text-charcoal-dark" x-text="brief?.industry"></span></p>
              <p><span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light">Overview</span><br/>
                <span class="text-charcoal-dark" x-text="brief?.company_overview"></span></p>
              <p><span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light">Positioning</span><br/>
                <span class="text-charcoal-dark" x-text="brief?.brand_positioning"></span></p>
              <p><span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light">Editorial voice</span><br/>
                <span class="text-charcoal-dark" x-text="brief?.editorial_voice"></span></p>
              <p><span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light">Target audience</span><br/>
                <span class="text-charcoal-dark" x-text="brief?.target_audience"></span></p>
              <p x-show="brief?.key_competitors?.length"><span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-light">Key competitors</span><br/>
                <span class="text-charcoal-dark" x-text="(brief?.key_competitors || []).join(', ')"></span></p>
              <p class="text-[10px] text-charcoal-light pt-2 border-t border-gray-100">
                Generated via <span x-text="brief?.generated_via"></span> — <span x-text="brief?.generated_at?.slice(0, 16)?.replace('T', ' ')"></span>
              </p>
            </div>
          </div>
        </div>

        {/* Selected (priority list) — Gate 3 hierarchical pattern.
             Parents are primary brands (drag-reorder ↑↓ for lead priority).
             Children = gammes / product lines (parent_id set). Drop an Available
             brand onto a parent row → makes it a gamme. Drop on the column
             header → adds as new primary. Drag a child to Available → detach. */}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6 overflow-hidden transition-all"
             @dragover.prevent="dragOver = 'selected'"
             @dragleave="dragOver = null"
             @drop.prevent="onDropSelected"
             :class="dragOver === 'selected' ? 'ring-2 ring-emerald-400' : ''">
          <div class="px-5 py-3 border-b border-gray-100 flex items-baseline justify-between">
            <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              <span>My Brands</span>
              <span class="text-charcoal-light text-xs font-normal">(<span x-text="selectedCount"></span>)</span>
            </h2>
            <p class="text-[11px] text-charcoal-light italic">First = lead · drag gammes onto parent · ↑↓ to reorder</p>
          </div>
          <div class="p-3">
            <p x-show="selected.length === 0" class="text-xs text-charcoal-light text-center py-6 italic">
              No primary brand set yet. Drag one from Available, or click +.
            </p>
            <div class="space-y-2">
              <template x-for="(b, i) in selected" :key="b.id">
                <div>
                  {/* Parent row */}
                  <div draggable="true"
                       @dragstart="onDragStart($event, b, 'selected')"
                       @dragover.prevent.stop="dragOverParent = b.id"
                       @dragleave.stop="dragOverParent = null"
                       @drop.prevent.stop="onDropOnParent($event, b)"
                       class="group flex items-center gap-2 bg-emerald-50/40 border border-emerald-100 rounded-lg px-3 py-2 cursor-move hover:border-emerald-300 hover:shadow-sm transition-all"
                       :class="dragOverParent === b.id ? 'ring-2 ring-emerald-400 border-emerald-300 bg-emerald-50/80' : ''">
                    <span class="text-[10px] font-mono text-charcoal-light w-5 text-center shrink-0">
                      <span x-text="i + 1"></span>
                    </span>
                    <!-- Expand/collapse chevron (only when children) -->
                    <button x-show="b.children && b.children.length > 0"
                            type="button"
                            @click.stop="toggleBrandExpand(b.id)"
                            :title="isBrandExpanded(b.id) ? 'Collapse gammes' : 'Expand gammes'"
                            class="shrink-0 text-charcoal-light hover:text-emerald-600 transition-colors">
                      <svg class="w-3 h-3 transition-transform"
                           :class="isBrandExpanded(b.id) ? 'rotate-90' : ''"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                      </svg>
                    </button>
                    <span class="text-sm font-medium text-charcoal-dark truncate min-w-[120px] max-w-[200px]" x-text="b.name"></span>
                    <input type="text"
                           :value="b.domain || ''"
                           @blur="saveDomain(b, $event.target.value)"
                           @keydown.enter="$event.target.blur()"
                           :placeholder="i === 0 ? 'e.g. eau-thermale-avene.fr (lead)' : 'e.g. ducray.com'"
                           class="flex-1 text-[11px] text-charcoal-light bg-transparent border border-transparent hover:border-gray-200 focus:border-coral focus:bg-white rounded px-2 py-1 outline-none min-w-0" />
                    <span x-show="domainSaveState[b.id]" class="text-[9px]" :class="domainSaveState[b.id] === 'saving' ? 'text-amber-600' : domainSaveState[b.id] === 'saved' ? 'text-emerald-600' : 'text-red-600'" x-text="domainSaveState[b.id] === 'saving' ? '...' : domainSaveState[b.id] === 'saved' ? '✓' : '✗'"></span>
                    <span x-show="(b.children || []).length > 0"
                          class="shrink-0 text-[9px] text-emerald-700 bg-emerald-100 px-1.5 py-0.5 rounded"
                          :title="(b.children || []).length + ' gamme(s) auto-included in this brand\\'s mentions'"
                          x-text="(b.children || []).length + ' gamme' + ((b.children || []).length > 1 ? 's' : '')"></span>
                    <span x-show="i === 0" class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded bg-coral/10 text-coral">Lead</span>
                    {/* Brief toggle — Phase BB per-brand brief, collapsed by default (Progressive Disclosure). */}
                    <button type="button" @click.stop="toggleBriefPanel(b.id)"
                            class="shrink-0 text-[10px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded border transition-colors"
                            :class="isBriefExpanded(b.id) ? 'bg-blue-50 text-blue-700 border-blue-200' : 'bg-white text-charcoal-light border-gray-200 hover:border-blue-300 hover:text-blue-600'"
                            :title="isBriefExpanded(b.id) ? 'Hide brand brief panel' : 'Show brand brief (voice + audience + competitors specific to this brand)'">
                      <span class="inline-flex items-center gap-1">
                        <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        Brief
                      </span>
                    </button>
                    <div class="flex items-center gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity">
                      <button type="button" @click.stop="moveUp(i)" :disabled="i === 0"
                              class="w-6 h-6 rounded text-charcoal-light hover:bg-gray-200 hover:text-charcoal-dark disabled:opacity-30 disabled:cursor-not-allowed flex items-center justify-center"
                              title="Move up">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
                      </button>
                      <button type="button" @click.stop="moveDown(i)" :disabled="i === selected.length - 1"
                              class="w-6 h-6 rounded text-charcoal-light hover:bg-gray-200 hover:text-charcoal-dark disabled:opacity-30 disabled:cursor-not-allowed flex items-center justify-center"
                              title="Move down">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                      </button>
                      <button type="button" @click.stop="remove(b)"
                              class="w-6 h-6 rounded text-charcoal-light hover:bg-red-100 hover:text-red-600 flex items-center justify-center ml-1"
                              title="Remove from primary brands (gammes detach)">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                      </button>
                    </div>
                  </div>

                  {/* Children (gammes, indented, NOT primary-promotable). Hidden
                       when the brand is collapsed (default state for parents with
                       children — Progressive Disclosure for the multi-brand case). */}
                  <template x-if="(b.children || []).length > 0 && isBrandExpanded(b.id)">
                    <div x-transition class="ml-4 mt-1 space-y-1 border-l-2 border-emerald-200 pl-3">
                      <template x-for="child in b.children" :key="child.id">
                        <div draggable="true"
                             @dragstart="onDragStart($event, child, 'child', b.id)"
                             class="group flex items-center gap-2 bg-emerald-50/20 border border-emerald-50 rounded-md px-2 py-1 cursor-move hover:border-emerald-200 transition-all">
                          <span class="text-[10px] text-emerald-600 shrink-0">↳</span>
                          <span class="text-xs text-charcoal-dark truncate flex-1" x-text="child.name"></span>
                          <span x-show="child.domain" class="text-[10px] text-charcoal-light/70 truncate max-w-[140px]" x-text="child.domain"></span>
                          <button type="button" @click.stop="detachChild(child, b)"
                                  title="Detach from this brand (back to Available)"
                                  class="shrink-0 w-5 h-5 rounded text-[10px] text-charcoal-light hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity">
                            &times;
                          </button>
                        </div>
                      </template>
                    </div>
                  </template>

                  {/* Per-brand brief panel — Phase BB. Collapsed by default ;
                       expands on Brief button click ; lazy-fetches on first open. */}
                  <template x-if="isBriefExpanded(b.id)">
                    <div x-transition class="ml-7 mt-2 mb-1 bg-blue-50/30 border border-blue-100 rounded-lg overflow-hidden">
                      {/* Header — status badge + Generate + cap counter (Tesler / Doherty) */}
                      <div class="px-3 py-2 border-b border-blue-100 flex items-center justify-between gap-2">
                        <div class="flex items-center gap-2">
                          <span class="text-[10px] uppercase tracking-wide font-semibold text-charcoal-dark">Brand brief</span>
                          <template x-if="briefLoading[b.id]">
                            <span class="text-[10px] text-charcoal-light italic">loading…</span>
                          </template>
                          <template x-if="!briefLoading[b.id] && !brandBriefs[b.id]?.brief">
                            <span class="text-[9px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-gray-100 text-charcoal-light">Not generated</span>
                          </template>
                          <template x-if="brandBriefs[b.id]?.brief && !brandBriefs[b.id]?.brief?.edited_by_user && !briefGenerating[b.id]">
                            <span class="text-[9px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-blue-50 text-blue-700"
                                  :title="'Auto-generated via ' + (brandBriefs[b.id]?.brief?.generated_via || 'unknown')">Ready</span>
                          </template>
                          <template x-if="brandBriefs[b.id]?.brief?.edited_by_user">
                            <span class="text-[9px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-emerald-50 text-emerald-700"
                                  title="You edited this — regeneration is blocked">Edited</span>
                          </template>
                          <template x-if="briefGenerating[b.id]">
                            <span class="text-[9px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-amber-50 text-amber-700 animate-pulse">Generating…</span>
                          </template>
                        </div>
                        <div class="flex items-center gap-2">
                          <template x-if="brandBriefs[b.id] && brandBriefs[b.id].generations_used > 0">
                            <span class="text-[10px] tabular-nums"
                                  :class="!brandBriefs[b.id].can_regenerate ? 'text-red-600 font-medium' : (brandBriefs[b.id].generations_cap - brandBriefs[b.id].generations_used <= 1 ? 'text-amber-700' : 'text-charcoal-light')"
                                  :title="brandBriefs[b.id].generations_used + ' of ' + brandBriefs[b.id].generations_cap + ' brand-brief generations used'"
                                  x-text="brandBriefs[b.id].generations_used + '/' + brandBriefs[b.id].generations_cap"></span>
                          </template>
                          <button type="button"
                                  @click.stop="generateBrandBrief(b.id)"
                                  :disabled="briefGenerating[b.id] || briefLoading[b.id] || (brandBriefs[b.id] && !brandBriefs[b.id].can_regenerate)"
                                  :class="(briefGenerating[b.id] || briefLoading[b.id] || (brandBriefs[b.id] && !brandBriefs[b.id].can_regenerate)) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                                  class="text-[10px] bg-coral text-white px-2.5 py-1 rounded font-medium transition-all"
                                  :title="brandBriefs[b.id] && !brandBriefs[b.id].can_regenerate ? (brandBriefs[b.id]?.brief?.edited_by_user ? 'You edited this — clear edits to regen' : 'Regen cap reached for this brand') : 'Generate the per-brand brief (web-searched, ~10s, $0.02-0.05)'">
                            <span x-show="!briefGenerating[b.id] && !brandBriefs[b.id]?.brief">Generate</span>
                            <span x-show="!briefGenerating[b.id] && brandBriefs[b.id]?.brief && brandBriefs[b.id]?.can_regenerate">Regenerate</span>
                            <span x-show="!briefGenerating[b.id] && brandBriefs[b.id]?.brief && !brandBriefs[b.id]?.can_regenerate">Capped</span>
                            <span x-show="briefGenerating[b.id]">Generating…</span>
                          </button>
                        </div>
                      </div>

                      {/* Body — read-only display when not editing, JSON editor when editing */}
                      <div class="p-3 text-xs space-y-2">
                        <template x-if="!brandBriefs[b.id]?.brief && !briefLoading[b.id] && !briefGenerating[b.id]">
                          <p class="text-charcoal-light italic">
                            No brand brief yet. Click Generate — uses this brand's name + workspace industry as input
                            (OpenAI web_search primary, Gemini / Claude fallback). Surcharges the workspace brief for
                            article + FAQ generation when this brand is in focus.
                          </p>
                        </template>

                        {/* Read mode */}
                        <template x-if="brandBriefs[b.id]?.brief && editingBrief[b.id] !== true">
                          <div class="space-y-2">
                            <template x-if="brandBriefs[b.id]?.brief?.description">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Description</span><br/>
                                <span class="text-charcoal-dark" x-text="brandBriefs[b.id]?.brief?.description"></span></p>
                            </template>
                            <template x-if="brandBriefs[b.id]?.brief?.parent_group">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Parent group</span>
                                <span class="text-charcoal-dark ml-1" x-text="brandBriefs[b.id]?.brief?.parent_group"></span></p>
                            </template>
                            <template x-if="brandBriefs[b.id]?.brief?.editorial_voice">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Editorial voice</span><br/>
                                <span class="text-charcoal-dark italic" x-text="brandBriefs[b.id]?.brief?.editorial_voice"></span></p>
                            </template>
                            <template x-if="brandBriefs[b.id]?.brief?.target_audience">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Target audience</span><br/>
                                <span class="text-charcoal-dark" x-text="brandBriefs[b.id]?.brief?.target_audience"></span></p>
                            </template>
                            <template x-if="brandBriefs[b.id]?.brief?.positioning_statement">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Positioning</span><br/>
                                <span class="text-charcoal-dark" x-text="brandBriefs[b.id]?.brief?.positioning_statement"></span></p>
                            </template>
                            <template x-if="(brandBriefs[b.id]?.brief?.differentiators || []).length > 0">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Differentiators</span>
                                <span class="text-charcoal-dark ml-1" x-text="(brandBriefs[b.id]?.brief?.differentiators || []).join(' · ')"></span></p>
                            </template>
                            <template x-if="(brandBriefs[b.id]?.brief?.direct_competitors || []).length > 0">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Direct competitors</span>
                                <span class="text-charcoal-dark ml-1" x-text="(brandBriefs[b.id]?.brief?.direct_competitors || []).map(c => c.name).join(' · ')"></span></p>
                            </template>
                            <template x-if="(brandBriefs[b.id]?.brief?.expertise_topics || []).length > 0">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Expertise topics</span>
                                <span class="text-charcoal-dark ml-1" x-text="(brandBriefs[b.id]?.brief?.expertise_topics || []).join(' · ')"></span></p>
                            </template>
                            <template x-if="(brandBriefs[b.id]?.brief?.regulatory_constraints || []).length > 0">
                              <p><span class="text-[9px] uppercase tracking-wide font-semibold text-charcoal-light">Regulatory</span>
                                <span class="text-charcoal-dark ml-1" x-text="(brandBriefs[b.id]?.brief?.regulatory_constraints || []).join(' · ')"></span></p>
                            </template>
                            <div class="flex items-center justify-between gap-2 pt-2 border-t border-blue-100/70">
                              <span class="text-[10px] text-charcoal-light">
                                <template x-if="brandBriefs[b.id]?.brief?.generated_via">
                                  <span>Generated via <span x-text="brandBriefs[b.id]?.brief?.generated_via"></span>
                                    <template x-if="brandBriefs[b.id]?.generated_at">
                                      <span> · <span x-text="(brandBriefs[b.id]?.generated_at || '').slice(0, 16).replace('T', ' ')"></span></span>
                                    </template>
                                  </span>
                                </template>
                              </span>
                              <button type="button" @click.stop="startEditBrief(b.id)"
                                      class="text-[10px] text-charcoal-light hover:text-blue-700 underline">
                                Edit (raw JSON)
                              </button>
                            </div>
                          </div>
                        </template>

                        {/* Edit mode — JSON textarea (per-field inline edit deferred) */}
                        <template x-if="editingBrief[b.id] === true">
                          <div class="space-y-2">
                            <p class="text-[10px] text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1">
                              Editing raw JSON. Saving marks the brief as user-edited (regeneration is blocked until you clear <code>edited_by_user</code>).
                            </p>
                            <textarea x-model="editBuffer[b.id]"
                                      rows="14"
                                      class="w-full text-[11px] font-mono text-charcoal-dark bg-white border border-gray-200 rounded p-2 outline-none focus:border-blue-400"></textarea>
                            <div class="flex items-center justify-end gap-2">
                              <button type="button" @click.stop="discardEditBrief(b.id)"
                                      class="text-[10px] text-charcoal-light hover:text-charcoal-dark px-2 py-1">
                                Discard
                              </button>
                              <button type="button" @click.stop="saveEditBrief(b.id)"
                                      class="text-[10px] bg-coral text-white px-3 py-1 rounded font-medium hover:bg-coral-dark">
                                Save changes
                              </button>
                            </div>
                          </div>
                        </template>
                      </div>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </div>
        </div>

        {/* Available — drop target for detaching children OR removing primaries */}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6 overflow-hidden transition-all"
             @dragover.prevent="dragOver = 'available'"
             @dragleave="dragOver = null"
             @drop.prevent="onDropAvailable"
             :class="dragOver === 'available' ? 'ring-2 ring-gray-300' : ''">
          <div class="px-5 py-3 border-b border-gray-100 flex items-baseline justify-between gap-3">
            <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-gray-400"></span>
              <span>Available brands</span>
              <span class="text-charcoal-light text-xs font-normal">(<span x-text="available.length"></span>)</span>
            </h2>
            <input type="text" x-model="search" placeholder="Search…"
                   class="text-xs border border-gray-200 rounded-md px-2 py-1 outline-none focus:border-coral w-48" />
          </div>
          <div class="p-3 max-h-96 overflow-y-auto">
            <p x-show="filteredAvailable.length === 0" class="text-xs text-charcoal-light text-center py-6 italic">
              <span x-show="search">No brand matches your search.</span>
              <span x-show="!search">All brands are already classified.</span>
            </p>
            <ul class="space-y-1">
              <template x-for="b in filteredAvailable" :key="b.id">
                <li draggable="true"
                    @dragstart="onDragStart($event, b, 'available')"
                    class="flex items-center gap-2 px-3 py-1.5 rounded-md hover:bg-gray-50 transition-colors cursor-move group/row">
                  <button type="button" @click.stop="add(b)"
                          class="shrink-0 w-6 h-6 rounded-md border border-gray-200 text-charcoal-light hover:border-coral hover:text-coral hover:bg-coral/5 transition-colors flex items-center justify-center"
                          title="Add to My Brands">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                  </button>
                  <span class="text-sm text-charcoal-dark flex-1 truncate" x-text="b.name"></span>
                  <span x-show="b.domain" class="text-[10px] text-charcoal-light/70 truncate max-w-[200px]" x-text="b.domain"></span>
                  <span x-show="b.is_suggested" class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded bg-amber-50 text-amber-700"
                        title="Auto-detected as your brand in past scans">Suggested</span>
                </li>
              </template>
            </ul>
          </div>
        </div>

        {/* Save bar */}
        <div class="sticky bottom-4 bg-white rounded-xl border border-gray-200 shadow-lg p-4 flex items-center justify-between gap-4">
          <div class="text-xs text-charcoal-light">
            <span x-show="!hasChanges" class="text-emerald-600">✓ Saved</span>
            <span x-show="hasChanges">Unsaved changes — selected: <span class="font-medium text-charcoal-dark" x-text="selected.length"></span></span>
          </div>
          <div class="flex items-center gap-2">
            <button type="button" @click="reset()" x-show="hasChanges"
                    class="text-sm text-charcoal-light hover:text-charcoal-dark px-3 py-1.5 rounded-md hover:bg-gray-50 transition-colors">
              Discard
            </button>
            <button type="button" @click="save()" :disabled="!hasChanges || saving"
                    :class="(!hasChanges || saving) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark hover:shadow-md'"
                    class="text-sm bg-coral text-white px-4 py-1.5 rounded-md font-medium transition-all">
              <span x-show="!saving">Save</span>
              <span x-show="saving">Saving…</span>
            </button>
          </div>
        </div>
      </div>
    )}

  </div>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('primaryBrands', (initial, clientId) => ({
        clientId,
        // Roots = primary brands + non-child non-primary brands. Children live
        // inside roots.children[]. Same shape as Gate 3 scan-classifier feeds.
        all: initial.all_brands || [],
        initial: (initial.primary_brand_ids || []).slice(),
        // Initial parent_id snapshot (for "Discard" rollback)
        initialParentMap: {},
        selected: [],
        search: '',
        saving: false,
        domainSaveState: {},
        // Drag-drop state (mirrors Gate 3's scanBrands component)
        dragOver: null,           // 'selected' | 'available' | null
        dragOverParent: null,     // id of parent currently hovered for child drop
        dragged: null,
        draggedFrom: null,        // 'selected' | 'available' | 'child'
        draggedFromParentId: null,

        // Collapse state for parent brands with children. Default = ALL collapsed
        // so a workspace with several brands × many gammes stays scannable.
        // Mirrors the Gate 2 scan-page pattern (commits 65cabae + 3d4fd5f) but
        // applies to My Brands here (the settings panel, not the per-scan view).
        collapsedBrandIds: {},
        isBrandExpanded(brandId) {
          return !this.collapsedBrandIds[brandId];
        },
        toggleBrandExpand(brandId) {
          if (this.collapsedBrandIds[brandId]) {
            delete this.collapsedBrandIds[brandId];
          } else {
            this.collapsedBrandIds[brandId] = true;
          }
        },

        // ── Phase BB per-brand brief state ──────────────────────────────
        // expandedBriefIds[brandId] = true → panel open (collapsed by default
        // for Progressive Disclosure). Briefs lazy-fetched on first expand
        // to keep page load light.
        expandedBriefIds: {},
        brandBriefs: {},          // brandId → { brief, generations_used, generations_cap, can_regenerate, generated_at }
        briefLoading: {},          // brandId → bool
        briefGenerating: {},       // brandId → bool
        editingBrief: {},          // brandId → bool
        editBuffer: {},            // brandId → string (raw JSON being edited)
        isBriefExpanded(brandId) {
          return !!this.expandedBriefIds[brandId];
        },
        async toggleBriefPanel(brandId) {
          if (this.expandedBriefIds[brandId]) {
            delete this.expandedBriefIds[brandId];
            return;
          }
          this.expandedBriefIds[brandId] = true;
          if (this.brandBriefs[brandId] === undefined) {
            await this._fetchBrandBrief(brandId);
          }
        },
        async _fetchBrandBrief(brandId) {
          this.briefLoading[brandId] = true;
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brandId}/brief`,
              { credentials: 'include' }
            );
            if (res.ok) {
              this.brandBriefs[brandId] = await res.json();
            } else {
              this.brandBriefs[brandId] = { brief: null, generations_used: 0,
                                            generations_cap: 3, can_regenerate: true };
            }
          } catch (e) {
            console.error('fetch brand brief failed', e);
          } finally {
            this.briefLoading[brandId] = false;
          }
        },
        async generateBrandBrief(brandId) {
          this.briefGenerating[brandId] = true;
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brandId}/brief/generate`,
              { method: 'POST', credentials: 'include' }
            );
            if (!res.ok) {
              let detail = '';
              try {
                const j = await res.json();
                detail = (j && j.detail && (j.detail.message || j.detail)) ||
                         j.message || JSON.stringify(j);
              } catch (e) { detail = res.statusText; }
              alert('Brand brief generation failed: ' + detail);
              return;
            }
            // Poll the GET endpoint until the brief becomes non-null OR the
            // generations_used counter bumps (Doherty's threshold ≤ 10s feels
            // alive, so poll every 3s for up to ~2 min — generate_brand_brief
            // typically completes in 15-60s).
            const before = this.brandBriefs[brandId]?.generations_used || 0;
            for (let i = 0; i < 40; i++) {
              await new Promise(r => setTimeout(r, 3000));
              const r2 = await fetch(
                `/api/clients/${this.clientId}/brands/${brandId}/brief`,
                { credentials: 'include' }
              );
              if (r2.ok) {
                const data = await r2.json();
                this.brandBriefs[brandId] = data;
                if (data.brief && (data.generations_used > before)) return;
              }
            }
          } catch (e) {
            console.error('generate brand brief failed', e);
          } finally {
            this.briefGenerating[brandId] = false;
          }
        },
        startEditBrief(brandId) {
          const current = this.brandBriefs[brandId]?.brief || {};
          this.editBuffer[brandId] = JSON.stringify(current, null, 2);
          this.editingBrief[brandId] = true;
        },
        discardEditBrief(brandId) {
          delete this.editingBrief[brandId];
          delete this.editBuffer[brandId];
        },
        async saveEditBrief(brandId) {
          let parsed;
          try {
            parsed = JSON.parse(this.editBuffer[brandId] || '{}');
          } catch (e) {
            alert('Invalid JSON: ' + e.message);
            return;
          }
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brandId}/brief`,
              {
                method: 'PATCH',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ brief: parsed }),
              }
            );
            if (!res.ok) {
              alert('Save failed: ' + res.statusText);
              return;
            }
            // Re-fetch to pick up the edited_by_user flag + can_regenerate
            await this._fetchBrandBrief(brandId);
            this.discardEditBrief(brandId);
          } catch (e) {
            alert('Save failed: ' + e.message);
          }
        },

        init() {
          this.selected = this.all.filter(b => b.is_primary);
          // Snapshot parent_id state for rollback. We snapshot only descendants
          // (parent_id != null) because top-level brands have nothing to revert.
          this.initialParentMap = {};
          for (const b of this.all) {
            for (const c of (b.children || [])) {
              this.initialParentMap[c.id] = b.id;
            }
          }
          // Seed collapsed state so every primary brand WITH children starts
          // folded. Re-applied after addBrand / drop so newly-added primaries
          // also start collapsed (see _collapseAllPrimaryParents()).
          this._collapseAllPrimaryParents();
        },

        // Mark every primary brand parent (with children) as collapsed.
        // Used at init + after drop / addBrand / promotion-from-available
        // so the bucket stays compact when fresh primaries arrive.
        _collapseAllPrimaryParents() {
          for (const b of (this.selected || [])) {
            if (b.children && b.children.length > 0) {
              this.collapsedBrandIds[b.id] = true;
            }
          }
        },

        get selectedCount() {
          return this.selected.reduce(
            (sum, b) => sum + 1 + ((b.children || []).length), 0
          );
        },

        // Available = non-primary, non-child. Children live under their parent
        // in `selected[].children`, so we exclude them from the flat catalog.
        get available() {
          const selectedIds = new Set();
          for (const b of this.selected) {
            selectedIds.add(b.id);
            for (const c of (b.children || [])) selectedIds.add(c.id);
          }
          return this.all.filter(b => !selectedIds.has(b.id) && !b.parent_id);
        },

        get filteredAvailable() {
          const q = this.search.trim().toLowerCase();
          if (!q) return this.available;
          return this.available.filter(b =>
            (b.name || '').toLowerCase().includes(q) ||
            (b.domain || '').toLowerCase().includes(q)
          );
        },

        get hasChanges() {
          const currentIds = this.selected.map(b => b.id).join(',');
          const initialIds = this.initial.join(',');
          return currentIds !== initialIds;
        },

        add(b) {
          if (!this.selected.find(x => x.id === b.id)) {
            if (!b.children) b.children = [];
            this.selected.push(b);
            // Newly-promoted primary with gammes starts collapsed
            if (b.children.length > 0) {
              this.collapsedBrandIds[b.id] = true;
            }
          }
        },

        remove(b) {
          const idx = this.selected.findIndex(x => x.id === b.id);
          if (idx === -1) return;
          // Detach any children first — they go back to Available with
          // parent_id = null (server PATCH). Mirrors Gate 3 behavior where
          // children move WITH the parent on reclassification; here removing
          // from primary should free the gammes so they're not orphaned.
          const children = [...(b.children || [])];
          for (const c of children) {
            c.parent_id = null;
            this._patchParent(c.id, null);
          }
          b.children = [];
          this.selected.splice(idx, 1);
        },

        moveUp(i) {
          if (i === 0) return;
          const tmp = this.selected[i];
          this.selected.splice(i, 1);
          this.selected.splice(i - 1, 0, tmp);
        },

        moveDown(i) {
          if (i >= this.selected.length - 1) return;
          const tmp = this.selected[i];
          this.selected.splice(i, 1);
          this.selected.splice(i + 1, 0, tmp);
        },

        // --- Drag and drop (Gate 3 mirror) ---------------------------------
        onDragStart(event, brand, fromBucket, fromParentId) {
          this.dragged = brand;
          this.draggedFrom = fromBucket;
          this.draggedFromParentId = fromParentId || null;
          if (event.dataTransfer) {
            event.dataTransfer.effectAllowed = 'move';
            try { event.dataTransfer.setData('text/plain', brand.id); } catch (e) {}
          }
        },

        // Drop on the Selected column header — adds as a new primary brand.
        onDropSelected() {
          this.dragOver = null;
          const brand = this.dragged;
          const from = this.draggedFrom;
          const fromParentId = this.draggedFromParentId;
          this.dragged = null;
          this.draggedFrom = null;
          this.draggedFromParentId = null;
          if (!brand) return;
          if (from === 'selected') return;  // already primary, no-op

          if (from === 'child' && fromParentId) {
            this._detachChildInline(brand.id, fromParentId);
            brand.parent_id = null;
            this._patchParent(brand.id, null);
            this.add(brand);
            return;
          }
          // From available → add as primary
          this.add(brand);
        },

        // Drop on a parent brand row — makes the dragged brand its gamme.
        onDropOnParent(event, parent) {
          event.stopPropagation();
          this.dragOverParent = null;
          this.dragOver = null;
          const brand = this.dragged;
          const from = this.draggedFrom;
          const fromParentId = this.draggedFromParentId;
          this.dragged = null;
          this.draggedFrom = null;
          this.draggedFromParentId = null;
          if (!brand) return;
          if (brand.id === parent.id) return;  // can't be own child
          // Grand-child guard (API enforces too) : a brand that's already a
          // parent (has children) can't become a child.
          if ((brand.children || []).length > 0) {
            alert("Can't nest a brand that already has gammes. Detach them first.");
            return;
          }

          if (from === 'selected') {
            // Demote primary → child of `parent`. Remove from primary list,
            // attach under parent.
            const idx = this.selected.findIndex(x => x.id === brand.id);
            if (idx !== -1) this.selected.splice(idx, 1);
            brand.parent_id = parent.id;
            parent.children = [...(parent.children || []), brand];
            // Auto-expand parent so the user sees where the brand landed
            delete this.collapsedBrandIds[parent.id];
            this._patchParent(brand.id, parent.id);
            return;
          }
          if (from === 'child' && fromParentId) {
            if (fromParentId === parent.id) return;  // same parent, no-op
            this._detachChildInline(brand.id, fromParentId);
          }
          brand.parent_id = parent.id;
          parent.children = [...(parent.children || []), brand];
          // Auto-expand target parent so the user sees the dropped row
          delete this.collapsedBrandIds[parent.id];
          this._patchParent(brand.id, parent.id);
        },

        // Drop on the Available column — detach (child) or remove (primary).
        onDropAvailable() {
          this.dragOver = null;
          const brand = this.dragged;
          const from = this.draggedFrom;
          const fromParentId = this.draggedFromParentId;
          this.dragged = null;
          this.draggedFrom = null;
          this.draggedFromParentId = null;
          if (!brand) return;
          if (from === 'available') return;

          if (from === 'child' && fromParentId) {
            this._detachChildInline(brand.id, fromParentId);
            brand.parent_id = null;
            this._patchParent(brand.id, null);
            return;
          }
          if (from === 'selected') {
            this.remove(brand);
          }
        },

        detachChild(child, parent) {
          this._detachChildInline(child.id, parent.id);
          child.parent_id = null;
          this._patchParent(child.id, null);
        },

        _detachChildInline(childId, parentId) {
          const parent = this.selected.find(b => b.id === parentId);
          if (!parent || !parent.children) return;
          const idx = parent.children.findIndex(c => c.id === childId);
          if (idx !== -1) parent.children.splice(idx, 1);
        },

        async _patchParent(brandId, parentId) {
          try {
            const res = await fetch(
              '/api/clients/' + this.clientId + '/brands/' + brandId + '/parent',
              {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ parent_id: parentId }),
              }
            );
            if (!res.ok) {
              const body = await res.json().catch(() => ({}));
              const msg = body.detail?.message || body.detail || ('HTTP ' + res.status);
              console.error('parent patch failed', msg);
              alert('Failed to update parent : ' + msg);
            }
          } catch (e) {
            console.error('parent patch error', e);
          }
        },

        reset() {
          // Restore selected from the all_brands list using stored initial order
          this.selected = this.initial
            .map(id => this.all.find(b => b.id === id))
            .filter(Boolean);
        },

        async save() {
          this.saving = true;
          try {
            const ids = this.selected.map(b => b.id);
            const res = await fetch(`/api/clients/${this.clientId}/promotion`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ primary_brand_ids: ids }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            this.initial = ids.slice();
          } catch (e) {
            alert('Save failed : ' + e.message);
          } finally {
            this.saving = false;
          }
        },

        async saveDomain(brand, newValue) {
          // Normalize: trim, drop leading scheme + www, drop trailing slash/path
          let domain = (newValue || '').trim().toLowerCase();
          domain = domain.replace(/^https?:\/\//, '').replace(/^www\./, '').split('/')[0];
          if (domain === (brand.domain || '')) return;  // no change

          this.domainSaveState[brand.id] = 'saving';
          try {
            const res = await fetch(`/api/clients/${this.clientId}/brands/${brand.id}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ domain: domain || null }),
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            // Mutate the in-memory brand record so all references reflect the new domain
            brand.domain = domain || null;
            this.domainSaveState[brand.id] = 'saved';
            setTimeout(() => { delete this.domainSaveState[brand.id]; }, 1500);
          } catch (e) {
            this.domainSaveState[brand.id] = 'error';
            console.error('domain save failed', e);
          }
        },
      }));

      window.Alpine.data('workspaceBrief', (initial, clientId, budget) => ({
        clientId,
        brief: initial,
        budget: budget || { generations_used: 0, generations_cap: 5, can_regenerate: true },
        generating: false,
        pollHandle: null,

        async generate() {
          if (this.generating) return;
          if (!this.budget.can_regenerate) return;
          this.generating = true;
          try {
            const res = await fetch(`/api/clients/${this.clientId}/brief/generate`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
            });
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              // 429 = cap reached. Reflect in budget so the button locks.
              if (res.status === 429) {
                const d = err.detail || err;
                this.budget = {
                  generations_used: d.generations_used ?? this.budget.generations_used,
                  generations_cap: d.cap ?? this.budget.generations_cap,
                  can_regenerate: false,
                };
              }
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            // Poll the brief endpoint until generated_at advances
            const previousAt = this.brief?.generated_at || '';
            const start = Date.now();
            const poll = async () => {
              if (Date.now() - start > 90000) {
                this.generating = false;
                alert('Generation taking longer than expected — check back in a moment.');
                return;
              }
              try {
                const r = await fetch(`/api/clients/${this.clientId}/brief`);
                if (r.ok) {
                  const data = await r.json();
                  if (data.brief && data.brief.generated_at !== previousAt) {
                    this.brief = data.brief;
                    // Refresh budget after a successful regen.
                    this.budget = {
                      generations_used: data.generations_used ?? (this.budget.generations_used + 1),
                      generations_cap: data.generations_cap ?? this.budget.generations_cap,
                      can_regenerate: data.can_regenerate ?? (this.budget.generations_used + 1 < this.budget.generations_cap),
                    };
                    this.generating = false;
                    return;
                  }
                }
              } catch {}
              this.pollHandle = setTimeout(poll, 2000);
            };
            this.pollHandle = setTimeout(poll, 3000);
          } catch (e) {
            this.generating = false;
            alert('Generate failed : ' + e.message);
          }
        },
      }));
    });
  </script>
</DashboardLayout>
