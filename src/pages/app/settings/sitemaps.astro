---
/**
 * Workspace Settings → Brand sitemaps & pages
 *
 * Lets the user :
 *   - See, per primary brand, the page-index status (total / sitemap /
 *     manual / gone / error counts + last crawl timestamp)
 *   - Trigger a manual sitemap refresh — enqueues crawl_brand_sitemap
 *     which chains fetch_brand_pages (Day 2)
 *   - Add a page URL manually (e.g. when the brand has no sitemap.xml
 *     or the sitemap is incomplete) — the row enters the same fetch +
 *     embed pipeline but is exempt from sitemap-diff mark_gone
 *   - Hard-delete a manually-added page
 *
 * SSR loads the primary brands ordered + each brand's page summary.
 * Alpine handles refresh polling + add/remove without a full page reload.
 *
 * UX Laws :
 *   - Common Region : one card per brand, distinct from other brands
 *   - Recognition over Recall : domain + counts on the card heading,
 *     no buried tabs
 *   - Postel : manual URL form accepts user input even when the sitemap
 *     is present (mixed corpus is fine)
 *   - Doherty : refresh + add jobs poll for completion (~10-30s)
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const apiBase = 'http://api:8000';

let clientId: string | null = null;
let clientName = '';
try {
  const res = await fetch(`${apiBase}/api/clients/`, {
    headers: { Cookie: `token=${token}` },
    signal: AbortSignal.timeout(3000),
  });
  const clients = res.ok ? await res.json() : [];
  if (clients[0]) {
    clientId = clients[0].id;
    clientName = clients[0].name;
  }
} catch {}

type BrandSummary = {
  id: string;
  name: string;
  domain: string | null;
  stats: any;
  in_flight_job: any;
  pages: any[];
};

let primaryBrands: BrandSummary[] = [];
if (clientId) {
  let primaryIds: string[] = [];
  let brandById: Record<string, { name: string; domain: string | null }> = {};
  try {
    const res = await fetch(`${apiBase}/api/clients/${clientId}/promotion`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (res.ok) {
      const data = await res.json();
      primaryIds = (data.primary_brand_ids || []) as string[];
      for (const b of data.all_brands || []) {
        brandById[b.id] = { name: b.name, domain: b.domain };
      }
    }
  } catch {}

  primaryBrands = await Promise.all(
    primaryIds.map(async (bid) => {
      const meta = brandById[bid] || { name: '?', domain: null };
      try {
        const r = await fetch(
          `${apiBase}/api/clients/${clientId}/brands/${bid}/pages?source=manual&limit=200`,
          { headers: { Cookie: `token=${token}` }, signal: AbortSignal.timeout(3000) }
        );
        if (r.ok) {
          const data = await r.json();
          return {
            id: bid,
            name: meta.name,
            domain: meta.domain,
            stats: data.stats || {},
            in_flight_job: data.in_flight_job || null,
            pages: data.pages || [],
          };
        }
      } catch {}
      return { id: bid, name: meta.name, domain: meta.domain, stats: {}, in_flight_job: null, pages: [] };
    })
  );
}
---

<DashboardLayout title="Brand sitemaps" activeSection="settings">
  <div class="p-8 max-w-4xl">

    <div class="mb-6">
      <a href="/app/settings" class="text-xs text-charcoal-light hover:text-coral inline-flex items-center gap-1 mb-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Settings
      </a>
      <h1 class="text-2xl font-bold text-charcoal-dark">Brand sitemaps & pages</h1>
      <p class="text-sm text-charcoal-light mt-1">
        For workspace <span class="font-medium text-charcoal-dark">{clientName || '?'}</span>. Pages we've indexed for each <strong class="text-charcoal-dark">primary brand</strong> — drives semantic <code class="text-[11px] bg-gray-100 px-1 py-0.5 rounded">target_url</code> auto-suggest when generating FAQ / articles.
      </p>
    </div>

    {/* Info banner */}
    <details class="mb-6 bg-blue-50/50 border border-blue-100 rounded-lg overflow-hidden group">
      <summary class="px-4 py-2.5 cursor-pointer hover:bg-blue-50 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-500 shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span class="text-sm font-medium text-blue-900">How does this work ?</span>
      </summary>
      <div class="px-4 py-3 border-t border-blue-100 text-xs text-blue-900/90 leading-relaxed space-y-2">
        <p><strong>Sitemap-discovered pages</strong> are crawled from <code class="text-[11px] bg-white/60 px-1 py-0.5 rounded">https://&lt;your-domain&gt;/sitemap.xml</code> (with index recursion). We fetch each page's title, meta description, h1 and a short body excerpt, then embed it semantically so future FAQ questions can auto-match the most relevant page on your site.</p>
        <p><strong>Manually-added pages</strong> are useful when your site has no sitemap, or when the sitemap misses pages you care about (a new landing page, a hidden gamme hub…). They go through the same fetch + embed pipeline and aren't removed by the next sitemap diff.</p>
        <p>Pages that disappear from the sitemap get marked <em>gone</em> and are hard-deleted after 30 days. Manual pages stay until you delete them yourself.</p>
        <p class="text-blue-800/70 italic">Refresh re-runs the full crawl. Adding a page enqueues a single-page fetch. The semantic embedding step is queued automatically.</p>
      </div>
    </details>

    {!clientId ? (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-900">
        No workspace found. Create one first, then come back here.
      </div>
    ) : primaryBrands.length === 0 ? (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-900">
        <p class="font-medium mb-1">No primary brands set yet.</p>
        <p>Pick the brands content generation should promote in
          <a href="/app/settings/brands" class="text-coral underline hover:text-coral-dark">My primary brands</a>
          first — then come back here to index their pages.
        </p>
      </div>
    ) : (
      <div x-data={`sitemapsPage(${JSON.stringify(primaryBrands)}, '${clientId}')`} class="space-y-5">
        <template x-for="brand in brands" :key="brand.id">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            {/* Card header */}
            <div class="px-5 py-3 border-b border-gray-100 flex items-baseline justify-between gap-3">
              <div class="min-w-0">
                <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full"
                        :class="brandDotClass(brand)"></span>
                  <span x-text="brand.name" class="truncate"></span>
                  <span class="text-charcoal-light text-xs font-normal">
                    (<span x-text="(brand.stats.total || 0)"></span> pages)
                  </span>
                </h2>
                <p class="text-[11px] text-charcoal-light mt-0.5 flex items-center gap-2">
                  <span x-show="brand.domain" class="font-mono" x-text="brand.domain"></span>
                  <span x-show="!brand.domain" class="text-amber-700">No domain set</span>
                  <span x-show="brand.stats.last_crawled_at" class="text-charcoal-light/70">
                    · last crawl <span x-text="formatRelative(brand.stats.last_crawled_at)"></span>
                  </span>
                  <span x-show="brand.in_flight_job"
                        class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-amber-100 text-amber-800 text-[10px] font-medium">
                    <svg class="w-2.5 h-2.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="4" class="opacity-75"></path></svg>
                    <span x-text="brand.in_flight_job?.type === 'crawl_brand_sitemap' ? 'Refreshing sitemap…' : 'Indexing pages…'"></span>
                  </span>
                </p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <button type="button" @click="refresh(brand)"
                        :disabled="!brand.domain || brand.in_flight_job || refreshing[brand.id]"
                        :class="(!brand.domain || brand.in_flight_job || refreshing[brand.id]) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                        class="text-xs bg-coral text-white px-3 py-1 rounded-md font-medium transition-all"
                        :title="!brand.domain ? 'Set the brand domain first' : 'Re-crawl the sitemap'">
                  <span x-show="!refreshing[brand.id]">Refresh sitemap</span>
                  <span x-show="refreshing[brand.id]">Queued…</span>
                </button>
              </div>
            </div>

            {/* Stats strip */}
            <div class="px-5 py-2 border-b border-gray-100 flex flex-wrap items-center gap-2 text-[11px]">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-emerald-50 text-emerald-800">
                <span class="font-semibold" x-text="(brand.stats.by_status?.embedded || 0)"></span>
                <span>embedded</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-sky-50 text-sky-800">
                <span class="font-semibold" x-text="(brand.stats.by_status?.fetched || 0)"></span>
                <span>fetched</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-gray-100 text-charcoal-light"
                    x-show="(brand.stats.by_status?.pending_fetch || 0) > 0">
                <span class="font-semibold" x-text="(brand.stats.by_status?.pending_fetch || 0)"></span>
                <span>pending</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-red-50 text-red-700"
                    x-show="(brand.stats.by_status?.error || 0) > 0">
                <span class="font-semibold" x-text="(brand.stats.by_status?.error || 0)"></span>
                <span>errors</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-amber-50 text-amber-700"
                    x-show="(brand.stats.by_status?.gone || 0) > 0">
                <span class="font-semibold" x-text="(brand.stats.by_status?.gone || 0)"></span>
                <span>gone</span>
              </span>
              <span class="text-charcoal-light/60 ml-auto">
                Sources :
                <span class="font-medium" x-text="(brand.stats.by_source?.sitemap || 0)"></span> sitemap ·
                <span class="font-medium" x-text="(brand.stats.by_source?.manual || 0)"></span> manual
              </span>
            </div>

            {/* Empty / no-sitemap hint */}
            <div x-show="(brand.stats.total || 0) === 0"
                 class="px-5 py-4 text-xs text-charcoal-light border-b border-gray-100 leading-relaxed">
              <p x-show="!brand.in_flight_job">
                No pages indexed yet for this brand.
                <span x-show="brand.domain">Click Refresh sitemap above — or add a page manually below if your site has no sitemap.xml.</span>
                <span x-show="!brand.domain">Set the brand domain first, then refresh.</span>
              </p>
              <p x-show="brand.in_flight_job">Indexing in progress — page list will appear here.</p>
            </div>

            {/* Manual URL form + list */}
            <div class="p-4">
              <div class="flex items-center gap-2 mb-3 px-1">
                <input type="text" x-model="addUrl[brand.id]" @keydown.enter="addManual(brand)"
                       :placeholder="brand.domain ? `https://${brand.domain.replace(/^www\\./, '')}/your-page` : 'Set brand domain first'"
                       :disabled="!brand.domain || adding[brand.id]"
                       class="flex-1 text-sm border border-gray-200 rounded-md px-3 py-1.5 outline-none focus:border-coral font-mono disabled:opacity-50 disabled:bg-gray-50" />
                <button type="button" @click="addManual(brand)"
                        :disabled="!brand.domain || adding[brand.id] || !(addUrl[brand.id]||'').trim()"
                        :class="(!brand.domain || adding[brand.id] || !(addUrl[brand.id]||'').trim()) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                        class="text-xs bg-coral text-white px-3 py-1.5 rounded-md font-medium transition-all whitespace-nowrap">
                  <span x-show="!adding[brand.id]">Add page</span>
                  <span x-show="adding[brand.id]">Adding…</span>
                </button>
              </div>
              <p x-show="addError[brand.id]" class="text-xs text-red-600 mb-2 px-1" x-text="addError[brand.id]"></p>

              <p x-show="brand.pages.length === 0" class="text-xs text-charcoal-light text-center py-3 italic">
                No manually-added pages.
              </p>
              <ul class="space-y-1" x-show="brand.pages.length > 0">
                <template x-for="p in brand.pages" :key="p.url">
                  <li class="group flex items-center gap-3 px-2 py-1.5 rounded-md hover:bg-gray-50 transition-colors">
                    <span class="text-sm font-mono text-charcoal-dark flex-1 truncate" :title="p.url" x-text="shortUrl(p.url, brand.domain)"></span>
                    <span class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded"
                          :class="statusChipClass(p.status)"
                          x-text="p.status === 'embedded' ? 'embedded' : p.status === 'fetched' ? 'fetched' : p.status === 'pending_fetch' ? 'pending' : p.status === 'error' ? 'error' : p.status">
                    </span>
                    <span class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded bg-blue-50 text-blue-700">Manual</span>
                    <button type="button" @click="removeManual(brand, p.url)"
                            :disabled="removing[p.url]"
                            class="w-6 h-6 rounded text-charcoal-light hover:bg-red-100 hover:text-red-600 opacity-0 group-hover:opacity-100 disabled:opacity-30 transition-all flex items-center justify-center"
                            title="Remove from index">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </li>
                </template>
              </ul>
              <p x-show="brand.pages.length > 0 && brand.pages[0]?.fetch_error" class="text-[11px] text-red-600 mt-2 px-1 italic">
                Some pages failed to fetch — hover the row for the URL, the error appears in the index audit.
              </p>
            </div>
          </div>
        </template>
      </div>
    )}
  </div>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('sitemapsPage', (initialBrands, clientId) => ({
        clientId,
        brands: initialBrands || [],
        refreshing: {},        // {brand_id: bool}
        adding: {},            // {brand_id: bool}
        addUrl: {},            // {brand_id: string}
        addError: {},          // {brand_id: string}
        removing: {},          // {url: bool}
        pollHandles: {},       // {brand_id: timeoutHandle}

        brandDotClass(brand) {
          if (!brand.domain) return 'bg-amber-400';
          if ((brand.stats?.by_status?.error || 0) > 0) return 'bg-red-500';
          if ((brand.stats?.by_status?.embedded || 0) > 0) return 'bg-emerald-500';
          if ((brand.stats?.total || 0) > 0) return 'bg-sky-400';
          return 'bg-gray-300';
        },

        statusChipClass(status) {
          switch (status) {
            case 'embedded':      return 'bg-emerald-50 text-emerald-700';
            case 'fetched':       return 'bg-sky-50 text-sky-700';
            case 'pending_fetch': return 'bg-gray-100 text-charcoal-light';
            case 'error':         return 'bg-red-50 text-red-700';
            case 'gone':          return 'bg-amber-50 text-amber-700';
            default:              return 'bg-gray-100 text-charcoal-light';
          }
        },

        formatRelative(iso) {
          if (!iso) return '—';
          try {
            const d = new Date(iso);
            const diff = (Date.now() - d.getTime()) / 1000;
            if (diff < 60) return 'just now';
            if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
            if (diff < 86400) return Math.floor(diff / 3600) + ' h ago';
            return Math.floor(diff / 86400) + ' d ago';
          } catch { return ''; }
        },

        shortUrl(url, domain) {
          if (!url) return '';
          try {
            const u = new URL(url);
            const path = u.pathname + (u.search || '');
            return path === '/' ? '/' : path;
          } catch { return url; }
        },

        async reloadBrand(brandId) {
          try {
            const r = await fetch(`/api/clients/${this.clientId}/brands/${brandId}/pages?source=manual&limit=200`);
            if (!r.ok) return;
            const data = await r.json();
            const idx = this.brands.findIndex(b => b.id === brandId);
            if (idx < 0) return;
            this.brands[idx] = {
              ...this.brands[idx],
              stats: data.stats || {},
              in_flight_job: data.in_flight_job || null,
              pages: data.pages || [],
            };
          } catch {}
        },

        startPoll(brandId, untilCleared = true) {
          const tick = async () => {
            await this.reloadBrand(brandId);
            const brand = this.brands.find(b => b.id === brandId);
            if (brand && brand.in_flight_job) {
              this.pollHandles[brandId] = setTimeout(tick, 4000);
            } else {
              this.refreshing[brandId] = false;
              this.pollHandles[brandId] = null;
            }
          };
          if (this.pollHandles[brandId]) clearTimeout(this.pollHandles[brandId]);
          this.pollHandles[brandId] = setTimeout(tick, 2500);
        },

        async refresh(brand) {
          if (!brand.domain || this.refreshing[brand.id]) return;
          this.refreshing[brand.id] = true;
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/sitemap/refresh`,
              { method: 'POST', headers: { 'Content-Type': 'application/json' } }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            this.startPoll(brand.id);
          } catch (e) {
            this.refreshing[brand.id] = false;
            alert('Refresh failed : ' + e.message);
          }
        },

        async addManual(brand) {
          const raw = (this.addUrl[brand.id] || '').trim();
          if (!raw || this.adding[brand.id]) return;
          this.adding[brand.id] = true;
          this.addError[brand.id] = '';
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/pages/manual`,
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: raw }),
              }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            this.addUrl[brand.id] = '';
            await this.reloadBrand(brand.id);
            this.startPoll(brand.id);
          } catch (e) {
            this.addError[brand.id] = e.message;
          } finally {
            this.adding[brand.id] = false;
          }
        },

        async removeManual(brand, url) {
          if (this.removing[url]) return;
          if (!confirm('Remove this page from the index ?')) return;
          this.removing[url] = true;
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/pages/manual`,
              {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url }),
              }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            await this.reloadBrand(brand.id);
          } catch (e) {
            alert('Delete failed : ' + e.message);
          } finally {
            this.removing[url] = false;
          }
        },
      }));
    });
  </script>
</DashboardLayout>
