---
/**
 * Workspace Settings → Brand sitemaps & pages
 *
 * Lets the user :
 *   - See, per primary brand, the page-index status (total / sitemap /
 *     manual / gone / error counts + last crawl timestamp)
 *   - Trigger a manual sitemap refresh — enqueues crawl_brand_sitemap
 *     which chains fetch_brand_pages (Day 2)
 *   - Add a page URL manually (e.g. when the brand has no sitemap.xml
 *     or the sitemap is incomplete) — the row enters the same fetch +
 *     embed pipeline but is exempt from sitemap-diff mark_gone
 *   - Hard-delete a manually-added page
 *
 * SSR loads the primary brands ordered + each brand's page summary.
 * Alpine handles refresh polling + add/remove without a full page reload.
 *
 * UX Laws :
 *   - Common Region : one card per brand, distinct from other brands
 *   - Recognition over Recall : domain + counts on the card heading,
 *     no buried tabs
 *   - Postel : manual URL form accepts user input even when the sitemap
 *     is present (mixed corpus is fine)
 *   - Doherty : refresh + add jobs poll for completion (~10-30s)
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const apiBase = 'http://api:8000';

let clientId: string | null = null;
let clientName = '';
try {
  const res = await fetch(`${apiBase}/api/clients/`, {
    headers: { Cookie: `token=${token}` },
    signal: AbortSignal.timeout(3000),
  });
  const clients = res.ok ? await res.json() : [];
  if (clients[0]) {
    clientId = clients[0].id;
    clientName = clients[0].name;
  }
} catch {}

type BrandSummary = {
  id: string;
  name: string;
  domain: string | null;
  stats: any;
  in_flight_job: any;
  pages: any[];
};

let primaryBrands: BrandSummary[] = [];
if (clientId) {
  let primaryIds: string[] = [];
  let brandById: Record<string, { name: string; domain: string | null }> = {};
  try {
    const res = await fetch(`${apiBase}/api/clients/${clientId}/promotion`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (res.ok) {
      const data = await res.json();
      primaryIds = (data.primary_brand_ids || []) as string[];
      for (const b of data.all_brands || []) {
        brandById[b.id] = { name: b.name, domain: b.domain };
      }
    }
  } catch {}

  primaryBrands = await Promise.all(
    primaryIds.map(async (bid) => {
      const meta = brandById[bid] || { name: '?', domain: null };
      try {
        const r = await fetch(
          `${apiBase}/api/clients/${clientId}/brands/${bid}/pages?source=manual&limit=200`,
          { headers: { Cookie: `token=${token}` }, signal: AbortSignal.timeout(3000) }
        );
        if (r.ok) {
          const data = await r.json();
          return {
            id: bid,
            name: meta.name,
            domain: meta.domain,
            stats: data.stats || {},
            in_flight_job: data.in_flight_job || null,
            pages: data.pages || [],
            locale_path_prefix: data.brand?.locale_path_prefix || null,
            sitemap_urls_override: data.brand?.sitemap_urls_override || [],
          };
        }
      } catch {}
      return { id: bid, name: meta.name, domain: meta.domain, stats: {}, in_flight_job: null, pages: [] };
    })
  );
}
---

<DashboardLayout title="Brand sitemaps" activeSection="settings">
  <div class="p-8 max-w-4xl">

    <div class="mb-6">
      <a href="/app/settings" class="text-xs text-charcoal-light hover:text-coral inline-flex items-center gap-1 mb-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Settings
      </a>
      <h1 class="text-2xl font-bold text-charcoal-dark">Brand sitemaps & pages</h1>
      <p class="text-sm text-charcoal-light mt-1">
        For workspace <span class="font-medium text-charcoal-dark">{clientName || '?'}</span>. Pages we've indexed for each <strong class="text-charcoal-dark">primary brand</strong> — drives semantic <code class="text-[11px] bg-gray-100 px-1 py-0.5 rounded">target_url</code> auto-suggest when generating FAQ / articles.
      </p>
    </div>

    {/* Info banner */}
    <details class="mb-6 bg-blue-50/50 border border-blue-100 rounded-lg overflow-hidden group">
      <summary class="px-4 py-2.5 cursor-pointer hover:bg-blue-50 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-500 shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span class="text-sm font-medium text-blue-900">How does this work ?</span>
      </summary>
      <div class="px-4 py-3 border-t border-blue-100 text-xs text-blue-900/90 leading-relaxed space-y-2">
        <p><strong>Sitemap-discovered pages</strong> are crawled from <code class="text-[11px] bg-white/60 px-1 py-0.5 rounded">https://&lt;your-domain&gt;/sitemap.xml</code> (with index recursion). We fetch each page's title, meta description, h1 and a short body excerpt, then embed it semantically so future FAQ questions can auto-match the most relevant page on your site.</p>
        <p><strong>Manually-added pages</strong> are useful when your site has no sitemap, or when the sitemap misses pages you care about (a new landing page, a hidden gamme hub…). They go through the same fetch + embed pipeline and aren't removed by the next sitemap diff.</p>
        <p>Pages that disappear from the sitemap get marked <em>gone</em> and are hard-deleted after 30 days. Manual pages stay until you delete them yourself.</p>
        <p class="text-blue-800/70 italic">Refresh re-runs the full crawl. Adding a page enqueues a single-page fetch. The semantic embedding step is queued automatically.</p>
      </div>
    </details>

    {!clientId ? (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-900">
        No workspace found. Create one first, then come back here.
      </div>
    ) : primaryBrands.length === 0 ? (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-sm text-amber-900">
        <p class="font-medium mb-1">No primary brands set yet.</p>
        <p>Pick the brands content generation should promote in
          <a href="/app/settings/brands" class="text-coral underline hover:text-coral-dark">My primary brands</a>
          first — then come back here to index their pages.
        </p>
      </div>
    ) : (
      <div x-data={`sitemapsPage(${JSON.stringify(primaryBrands)}, '${clientId}')`} class="space-y-5">
        <template x-for="brand in brands" :key="brand.id">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            {/* Card header */}
            <div class="px-5 py-3 border-b border-gray-100 flex items-baseline justify-between gap-3">
              <div class="min-w-0">
                <h2 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full"
                        :class="brandDotClass(brand)"></span>
                  <span x-text="brand.name" class="truncate"></span>
                  <span class="text-charcoal-light text-xs font-normal">
                    (<span x-text="(brand.stats.total || 0)"></span> pages)
                  </span>
                </h2>
                <p class="text-[11px] text-charcoal-light mt-0.5 flex items-center gap-2 flex-wrap">
                  <span x-show="brand.domain" class="font-mono" x-text="brand.domain"></span>
                  <span x-show="!brand.domain" class="text-amber-700">No domain set</span>
                  {/* Persistent locale filter chip — visible at-a-glance signal that
                      this brand has a non-default sitemap config. */}
                  <span x-show="brand.locale_path_prefix"
                        class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-blue-50 text-blue-700 font-mono text-[10px]"
                        :title="`Crawling only URLs containing ${brand.locale_path_prefix}`">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
                    <span x-text="brand.locale_path_prefix"></span>
                  </span>
                  <span x-show="brand.sitemap_urls_override && brand.sitemap_urls_override.length > 0"
                        class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-blue-50 text-blue-700 font-mono text-[10px]"
                        :title="`Crawler uses ${brand.sitemap_urls_override.length} user-specified sitemap URL(s) instead of auto-discovery`"
                        x-text="`${brand.sitemap_urls_override.length} sitemap URL${brand.sitemap_urls_override.length === 1 ? '' : 's'} (override)`"></span>
                  <span x-show="brand.stats.last_crawled_at" class="text-charcoal-light/70">
                    · last crawl <span x-text="formatRelative(brand.stats.last_crawled_at)"></span>
                  </span>
                  <span x-show="brand.in_flight_job"
                        class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-amber-100 text-amber-800 text-[10px] font-medium">
                    <svg class="w-2.5 h-2.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="4" class="opacity-75"></path></svg>
                    <span x-text="brand.in_flight_job?.type === 'crawl_brand_sitemap' ? 'Refreshing sitemap…' : 'Indexing pages…'"></span>
                  </span>
                </p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <button type="button" @click="refresh(brand)"
                        :disabled="!brand.domain || brand.in_flight_job || refreshing[brand.id]"
                        :class="(!brand.domain || brand.in_flight_job || refreshing[brand.id]) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                        class="text-xs bg-coral text-white px-3 py-1 rounded-md font-medium transition-all"
                        :title="!brand.domain ? 'Set the brand domain first' : 'Re-crawl the sitemap'">
                  <span x-show="!refreshing[brand.id]">Refresh sitemap</span>
                  <span x-show="refreshing[brand.id]">Queued…</span>
                </button>
              </div>
            </div>

            {/* Sitemap config panel (collapsible) — Phase D multi-locale support
                Visually mirrors the <details>/<summary> + chevron pattern used
                elsewhere in the project, but driven by Alpine state so x-model
                inside the panel reacts correctly. <details> + nested x-model
                inside <template x-for> has a known reactivity quirk that left
                the input non-responsive (observed 2026-05-14 Ducray /fr-fr/). */}
            <div class="border-b border-gray-100">
              <button type="button"
                      @click="configOpen[brand.id] = !configOpen[brand.id]; if (configOpen[brand.id]) loadConfig(brand.id)"
                      class="w-full px-5 py-2.5 cursor-pointer hover:bg-gray-50 transition-colors flex items-center gap-2 text-xs text-charcoal-light text-left">
                <svg class="w-3.5 h-3.5 shrink-0 transition-transform"
                     :class="configOpen[brand.id] ? 'rotate-90' : ''"
                     fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
                <span class="font-medium">Sitemap configuration</span>
                <span x-show="brand.locale_path_prefix || (brand.sitemap_urls_override && brand.sitemap_urls_override.length > 0) || (cfgPrefix[brand.id] || '').trim() || (cfgUrls[brand.id] || '').trim()"
                      class="text-[10px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded bg-blue-50 text-blue-700">Custom</span>
              </button>
              <div x-show="configOpen[brand.id]" x-transition.opacity class="px-5 py-4 border-t border-gray-100 bg-gray-50/40">
                <div class="text-[11px] text-charcoal-light mb-3 leading-relaxed">
                  <p><strong>Locale path filter</strong> : when set (e.g. <code class="bg-white/80 px-1 rounded">/fr-fr/</code>) we only crawl URLs whose path contains that fragment. Use it for multi-locale brands to scope to one language.</p>
                  <p class="mt-1"><strong>Sitemap URLs (override)</strong> : when set, we crawl exactly these URLs and skip auto-discovery via robots.txt / <code class="bg-white/80 px-1 rounded">/sitemap.xml</code>. One URL per line, must be on this brand's domain.</p>
                </div>
                <div class="space-y-3">
                  <div>
                    <label class="block text-[10px] uppercase tracking-wide font-semibold text-charcoal-light mb-1">Locale path filter</label>
                    <input type="text"
                           x-init="$el.value = cfgPrefix[brand.id] || ''"
                           x-effect="if (document.activeElement !== $el) $el.value = cfgPrefix[brand.id] || ''"
                           @input="cfgPrefix[brand.id] = $event.target.value; cfgDirty[brand.id] = true"
                           @blur="if (cfgDirty[brand.id]) saveConfig(brand)"
                           :placeholder="brand.domain ? '/fr-fr/' : 'Set domain first'"
                           :disabled="!brand.domain || !!savingCfg[brand.id]"
                           class="w-48 text-sm text-charcoal-dark border border-gray-200 rounded-md px-3 py-1.5 outline-none focus:border-coral font-mono disabled:opacity-50 bg-white" />
                  </div>
                  <div>
                    <label class="block text-[10px] uppercase tracking-wide font-semibold text-charcoal-light mb-1">Sitemap URLs (override, one per line)</label>
                    <textarea x-init="$el.value = cfgUrls[brand.id] || ''"
                              x-effect="if (document.activeElement !== $el) $el.value = cfgUrls[brand.id] || ''"
                              @input="cfgUrls[brand.id] = $event.target.value; cfgDirty[brand.id] = true"
                              @blur="if (cfgDirty[brand.id]) saveConfig(brand)"
                              :placeholder="brand.domain ? `https://www.${brand.domain.replace(/^www\\./,'')}/fr-fr/site.xml\nhttps://www.${brand.domain.replace(/^www\\./,'')}/fr-fr/product.xml` : ''"
                              :disabled="!brand.domain || !!savingCfg[brand.id]"
                              rows="4"
                              class="w-full text-sm text-charcoal-dark border border-gray-200 rounded-md px-3 py-2 outline-none focus:border-coral font-mono disabled:opacity-50 bg-white"></textarea>
                  </div>
                  <p x-show="cfgError[brand.id]" class="text-xs text-red-600" x-text="cfgError[brand.id]"></p>
                  {/* Combined Save & Refresh CTA — clearer intent than two separate buttons.
                      When config is dirty, primary action is "Save & Refresh". When clean,
                      plain "Save config" lets the user re-save without crawling (no-op cost). */}
                  <div class="flex items-center gap-3">
                    <button type="button" @click="saveAndRefresh(brand)"
                            :disabled="!!savingCfg[brand.id]"
                            :class="savingCfg[brand.id] ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                            class="text-xs bg-coral text-white px-3 py-1.5 rounded-md font-semibold transition-all inline-flex items-center gap-1.5">
                      <svg x-show="!savingCfg[brand.id]" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                      </svg>
                      <svg x-show="savingCfg[brand.id]" class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="4" class="opacity-75"></path></svg>
                      <span x-show="!savingCfg[brand.id]">Save & Refresh sitemap</span>
                      <span x-show="savingCfg[brand.id]">Saving…</span>
                    </button>
                    <button type="button" @click="saveConfig(brand)"
                            x-show="cfgDirty[brand.id] && !savingCfg[brand.id]"
                            class="text-[11px] text-charcoal-light hover:text-coral underline">
                      Save without re-crawling
                    </button>
                    <span x-show="cfgDirty[brand.id] && !savingCfg[brand.id] && !cfgSaved[brand.id]"
                          class="text-[11px] text-amber-700 italic inline-flex items-center gap-1">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                      Unsaved changes
                    </span>
                  </div>
                  {/* Persistent confirmation banner — full-width so it's not lost in the
                      controls row. Shows for 8s after save (longer than the prior 4s). */}
                  <div x-show="cfgSaved[brand.id]" x-transition
                       class="mt-2 px-3 py-2 rounded bg-emerald-50 border border-emerald-200 text-xs text-emerald-800 inline-flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span>Config saved <span x-show="cfgSavedRefreshed[brand.id]">· crawl re-queued with the new config</span></span>
                  </div>
                </div>
              </div>
            </div>

            {/* Stats strip */}
            <div class="px-5 py-2 border-b border-gray-100 flex flex-wrap items-center gap-2 text-[11px]">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-emerald-50 text-emerald-800">
                <span class="font-semibold" x-text="(brand.stats.by_status?.embedded || 0)"></span>
                <span>embedded</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-sky-50 text-sky-800">
                <span class="font-semibold" x-text="(brand.stats.by_status?.fetched || 0)"></span>
                <span>fetched</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-gray-100 text-charcoal-light"
                    x-show="(brand.stats.by_status?.pending_fetch || 0) > 0">
                <span class="font-semibold" x-text="(brand.stats.by_status?.pending_fetch || 0)"></span>
                <span>pending</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-red-50 text-red-700"
                    x-show="(brand.stats.by_status?.error || 0) > 0">
                <span class="font-semibold" x-text="(brand.stats.by_status?.error || 0)"></span>
                <span>errors</span>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-amber-50 text-amber-700"
                    x-show="(brand.stats.by_status?.gone || 0) > 0">
                <span class="font-semibold" x-text="(brand.stats.by_status?.gone || 0)"></span>
                <span>gone</span>
              </span>
              <span class="text-charcoal-light/60 ml-auto">
                Sources :
                <span class="font-medium" x-text="(brand.stats.by_source?.sitemap || 0)"></span> sitemap ·
                <span class="font-medium" x-text="(brand.stats.by_source?.manual || 0)"></span> manual
              </span>
            </div>

            {/* Empty / no-sitemap hint */}
            <div x-show="(brand.stats.total || 0) === 0"
                 class="px-5 py-4 text-xs text-charcoal-light border-b border-gray-100 leading-relaxed">
              <p x-show="!brand.in_flight_job">
                No pages indexed yet for this brand.
                <span x-show="brand.domain">Click Refresh sitemap above — or add a page manually below if your site has no sitemap.xml.</span>
                <span x-show="!brand.domain">Set the brand domain first, then refresh.</span>
              </p>
              <p x-show="brand.in_flight_job">Indexing in progress — page list will appear here.</p>
            </div>

            {/* View all indexed pages (collapsible) — search/sort/paginated.
                Same toggle button + x-show pattern as the Sitemap config panel
                above. Mirrors the project's <details> convention visually
                without the Alpine reactivity quirks inside <template x-for>. */}
            <div x-show="(brand.stats.total || 0) > 0" class="border-b border-gray-100">
              <button type="button"
                      @click="pagesOpen[brand.id] = !pagesOpen[brand.id]; if (pagesOpen[brand.id]) loadPagesList(brand.id, true)"
                      class="w-full px-5 py-2.5 cursor-pointer hover:bg-gray-50 transition-colors flex items-center gap-2 text-xs text-charcoal-light text-left">
                <svg class="w-3.5 h-3.5 shrink-0 transition-transform"
                     :class="pagesOpen[brand.id] ? 'rotate-90' : ''"
                     fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
                <span class="font-medium">View all indexed pages</span>
                <span class="text-charcoal-light/70" x-text="`(${brand.stats.total || 0})`"></span>
              </button>
              <div x-show="pagesOpen[brand.id]" x-transition.opacity class="px-5 py-4 border-t border-gray-100 bg-gray-50/30">
                {/* Search + sort controls */}
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <input type="text"
                         x-init="$el.value = pageQuery[brand.id] || ''"
                         @input="pageQuery[brand.id] = $event.target.value"
                         @keydown.enter="loadPagesList(brand.id, true)"
                         @input.debounce.500ms="loadPagesList(brand.id, true)"
                         placeholder="Search URL or title…"
                         class="flex-1 min-w-[180px] text-sm text-charcoal-dark border border-gray-200 rounded-md px-3 py-1.5 outline-none focus:border-coral bg-white" />
                  <select :value="pageSort[brand.id] || 'inlinks_desc'"
                          @change="pageSort[brand.id] = $event.target.value; loadPagesList(brand.id, true)"
                          class="text-xs border border-gray-200 rounded-md px-2 py-1.5 bg-white">
                    <option value="inlinks_desc">Sort : Most inlinked</option>
                    <option value="status">Sort : By status</option>
                    <option value="first_seen">Sort : Oldest first</option>
                    <option value="last_embedded">Sort : Recently embedded</option>
                  </select>
                </div>

                {/* Table — bordered, monospace URL column, status + source chips */}
                <div class="rounded-md border border-gray-200 bg-white overflow-hidden">
                  <div class="grid grid-cols-[1fr_auto_auto_auto] gap-3 px-3 py-2 text-[10px] uppercase tracking-wide font-semibold text-charcoal-light/70 border-b border-gray-200 bg-gray-50/50">
                    <span>Page</span>
                    <span class="text-right">Status</span>
                    <span class="text-right">Source</span>
                    <span class="text-right" title="Internal inlinks count (authority signal)">Inlinks</span>
                  </div>
                  <p x-show="pagesLoading[brand.id] && (pageList[brand.id] || []).length === 0"
                     class="text-xs text-charcoal-light italic text-center py-6">Loading…</p>
                  <p x-show="!pagesLoading[brand.id] && (pageList[brand.id] || []).length === 0"
                     class="text-xs text-charcoal-light italic text-center py-6">No matching pages.</p>
                  <ul>
                    <template x-for="p in (pageList[brand.id] || [])" :key="p.id">
                      <li class="grid grid-cols-[1fr_auto_auto_auto] gap-3 px-3 py-2 border-b border-gray-100 last:border-b-0 hover:bg-gray-50/60 transition-colors text-xs">
                        <div class="min-w-0">
                          <a :href="p.url" target="_blank" rel="noopener" :title="p.url"
                             class="block font-mono text-charcoal-dark hover:text-coral truncate"
                             x-text="shortUrl(p.url, brand.domain)"></a>
                          <span x-show="p.title" :title="p.title"
                                class="block text-charcoal-light truncate" x-text="p.title"></span>
                          <span x-show="p.fetch_error" class="block text-red-600 italic" x-text="p.fetch_error"></span>
                        </div>
                        <span class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded self-center"
                              :class="statusChipClass(p.status)" x-text="p.status"></span>
                        <span class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded self-center"
                              :class="p.source === 'manual' ? 'bg-blue-50 text-blue-700' : 'bg-gray-100 text-charcoal-light'"
                              x-text="p.source"></span>
                        <span class="shrink-0 self-center font-mono text-charcoal-light"
                              :class="p.internal_inlink_count >= 50 ? 'font-semibold text-charcoal-dark' : ''"
                              :title="p.internal_inlink_count >= 50 ? 'Hub page — strong authority signal' : ''"
                              x-text="p.internal_inlink_count"></span>
                      </li>
                    </template>
                  </ul>
                </div>

                {/* Pagination footer */}
                <div class="flex items-center justify-between mt-3 text-[11px] text-charcoal-light">
                  <span x-text="`Showing ${(pageList[brand.id] || []).length} of ${pageTotal[brand.id] ?? 0}`"></span>
                  <button type="button" @click="loadPagesList(brand.id, false)"
                          x-show="pageHasMore[brand.id]"
                          :disabled="pagesLoading[brand.id]"
                          :class="pagesLoading[brand.id] ? 'opacity-50 cursor-not-allowed' : 'hover:bg-gray-100'"
                          class="text-xs border border-gray-200 px-2 py-1 rounded">
                    <span x-show="!pagesLoading[brand.id]">Load more</span>
                    <span x-show="pagesLoading[brand.id]">Loading…</span>
                  </button>
                </div>
              </div>
            </div>

            {/* Manual URL form + list */}
            <div class="p-4">
              <div class="flex items-center gap-2 mb-3 px-1">
                <input type="text" x-model="addUrl[brand.id]" @keydown.enter="addManual(brand)"
                       :placeholder="brand.domain ? `https://${brand.domain.replace(/^www\\./, '')}/your-page` : 'Set brand domain first'"
                       :disabled="!brand.domain || adding[brand.id]"
                       class="flex-1 text-sm border border-gray-200 rounded-md px-3 py-1.5 outline-none focus:border-coral font-mono disabled:opacity-50 disabled:bg-gray-50" />
                <button type="button" @click="addManual(brand)"
                        :disabled="!brand.domain || adding[brand.id] || !(addUrl[brand.id]||'').trim()"
                        :class="(!brand.domain || adding[brand.id] || !(addUrl[brand.id]||'').trim()) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-coral-dark'"
                        class="text-xs bg-coral text-white px-3 py-1.5 rounded-md font-medium transition-all whitespace-nowrap">
                  <span x-show="!adding[brand.id]">Add page</span>
                  <span x-show="adding[brand.id]">Adding…</span>
                </button>
              </div>
              <p x-show="addError[brand.id]" class="text-xs text-red-600 mb-2 px-1" x-text="addError[brand.id]"></p>

              <p x-show="brand.pages.length === 0" class="text-xs text-charcoal-light text-center py-3 italic">
                No manually-added pages.
              </p>
              <ul class="space-y-1" x-show="brand.pages.length > 0">
                <template x-for="p in brand.pages" :key="p.url">
                  <li class="group flex items-center gap-3 px-2 py-1.5 rounded-md hover:bg-gray-50 transition-colors">
                    <span class="text-sm font-mono text-charcoal-dark flex-1 truncate" :title="p.url" x-text="shortUrl(p.url, brand.domain)"></span>
                    <span class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded"
                          :class="statusChipClass(p.status)"
                          x-text="p.status === 'embedded' ? 'embedded' : p.status === 'fetched' ? 'fetched' : p.status === 'pending_fetch' ? 'pending' : p.status === 'error' ? 'error' : p.status">
                    </span>
                    <span class="shrink-0 text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded bg-blue-50 text-blue-700">Manual</span>
                    <button type="button" @click="removeManual(brand, p.url)"
                            :disabled="removing[p.url]"
                            class="w-6 h-6 rounded text-charcoal-light hover:bg-red-100 hover:text-red-600 opacity-0 group-hover:opacity-100 disabled:opacity-30 transition-all flex items-center justify-center"
                            title="Remove from index">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </li>
                </template>
              </ul>
              <p x-show="brand.pages.length > 0 && brand.pages[0]?.fetch_error" class="text-[11px] text-red-600 mt-2 px-1 italic">
                Some pages failed to fetch — hover the row for the URL, the error appears in the index audit.
              </p>
            </div>
          </div>
        </template>
      </div>
    )}
  </div>

  <script is:inline>
    document.addEventListener('alpine:init', () => {
      window.Alpine.data('sitemapsPage', (initialBrands, clientId) => {
        // Pre-populate per-brand config state from the SSR payload so the
        // "CUSTOM" badge + textarea/input contents are visible immediately,
        // without waiting for the user to open the config panel and trigger
        // a GET /sitemap-config round-trip.
        const cfgPrefix = {};
        const cfgUrls = {};
        const cfgLoaded = {};
        for (const b of (initialBrands || [])) {
          cfgPrefix[b.id] = b.locale_path_prefix || '';
          cfgUrls[b.id] = (b.sitemap_urls_override || []).join('\n');
          cfgLoaded[b.id] = true;  // already loaded from SSR — skip lazy GET
        }
        return {
        clientId,
        brands: initialBrands || [],
        refreshing: {},        // {brand_id: bool}
        adding: {},            // {brand_id: bool}
        addUrl: {},            // {brand_id: string}
        addError: {},          // {brand_id: string}
        removing: {},          // {url: bool}
        pollHandles: {},       // {brand_id: timeoutHandle}
        // Sitemap config panel state (Phase D multi-locale)
        configOpen: {},        // {brand_id: bool}
        cfgPrefix,             // pre-populated from SSR
        cfgUrls,               // pre-populated from SSR
        cfgLoaded,             // pre-populated from SSR
        savingCfg: {},         // {brand_id: bool}
        cfgError: {},          // {brand_id: string}
        cfgSaved: {},          // {brand_id: bool} — fades after a few seconds
        cfgSavedRefreshed: {}, // {brand_id: bool} — Refresh was chained after save
        cfgDirty: {},          // {brand_id: bool} — true when user has typed since last save
        // View-pages panel state
        pagesOpen: {},         // {brand_id: bool}
        pageList: {},          // {brand_id: array of page objects}
        pageTotal: {},         // {brand_id: int}
        pageOffset: {},        // {brand_id: int}
        pageHasMore: {},       // {brand_id: bool}
        pageQuery: {},         // {brand_id: string}
        pageSort: {},          // {brand_id: string sort key}
        pagesLoading: {},      // {brand_id: bool}

        brandDotClass(brand) {
          if (!brand.domain) return 'bg-amber-400';
          if ((brand.stats?.by_status?.error || 0) > 0) return 'bg-red-500';
          if ((brand.stats?.by_status?.embedded || 0) > 0) return 'bg-emerald-500';
          if ((brand.stats?.total || 0) > 0) return 'bg-sky-400';
          return 'bg-gray-300';
        },

        statusChipClass(status) {
          switch (status) {
            case 'embedded':      return 'bg-emerald-50 text-emerald-700';
            case 'fetched':       return 'bg-sky-50 text-sky-700';
            case 'pending_fetch': return 'bg-gray-100 text-charcoal-light';
            case 'error':         return 'bg-red-50 text-red-700';
            case 'gone':          return 'bg-amber-50 text-amber-700';
            default:              return 'bg-gray-100 text-charcoal-light';
          }
        },

        formatRelative(iso) {
          if (!iso) return '—';
          try {
            const d = new Date(iso);
            const diff = (Date.now() - d.getTime()) / 1000;
            if (diff < 60) return 'just now';
            if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
            if (diff < 86400) return Math.floor(diff / 3600) + ' h ago';
            return Math.floor(diff / 86400) + ' d ago';
          } catch { return ''; }
        },

        shortUrl(url, domain) {
          if (!url) return '';
          try {
            const u = new URL(url);
            const path = u.pathname + (u.search || '');
            return path === '/' ? '/' : path;
          } catch { return url; }
        },

        async reloadBrand(brandId) {
          try {
            const r = await fetch(`/api/clients/${this.clientId}/brands/${brandId}/pages?source=manual&limit=200`);
            if (!r.ok) return;
            const data = await r.json();
            const idx = this.brands.findIndex(b => b.id === brandId);
            if (idx < 0) return;
            this.brands[idx] = {
              ...this.brands[idx],
              stats: data.stats || {},
              in_flight_job: data.in_flight_job || null,
              pages: data.pages || [],
            };
          } catch {}
        },

        startPoll(brandId, untilCleared = true) {
          const tick = async () => {
            await this.reloadBrand(brandId);
            const brand = this.brands.find(b => b.id === brandId);
            if (brand && brand.in_flight_job) {
              this.pollHandles[brandId] = setTimeout(tick, 4000);
            } else {
              this.refreshing[brandId] = false;
              this.pollHandles[brandId] = null;
            }
          };
          if (this.pollHandles[brandId]) clearTimeout(this.pollHandles[brandId]);
          this.pollHandles[brandId] = setTimeout(tick, 2500);
        },

        async loadConfig(brandId) {
          if (this.cfgLoaded[brandId]) return;
          try {
            const r = await fetch(`/api/clients/${this.clientId}/brands/${brandId}/sitemap-config`);
            if (r.ok) {
              const data = await r.json();
              this.cfgPrefix[brandId] = data.locale_path_prefix || '';
              this.cfgUrls[brandId] = (data.sitemap_urls_override || []).join('\n');
              this.cfgLoaded[brandId] = true;
            }
          } catch {}
        },

        async loadPagesList(brandId, reset) {
          // `reset=true` zeroes the offset and replaces the list (used on
          // first open + on every search/sort change). `reset=false` is
          // the "Load more" button — appends the next page.
          if (this.pagesLoading[brandId]) return;
          this.pagesLoading[brandId] = true;
          try {
            if (reset) {
              this.pageOffset[brandId] = 0;
              this.pageList[brandId] = [];
            }
            const offset = this.pageOffset[brandId] || 0;
            const params = new URLSearchParams({
              source: 'all',
              offset: String(offset),
              limit: '50',
              sort: this.pageSort[brandId] || 'inlinks_desc',
            });
            const q = (this.pageQuery[brandId] || '').trim();
            if (q) params.set('q', q);
            const r = await fetch(`/api/clients/${this.clientId}/brands/${brandId}/pages?${params.toString()}`);
            if (!r.ok) throw new Error('HTTP ' + r.status);
            const data = await r.json();
            const newRows = data.pages || [];
            this.pageList[brandId] = reset ? newRows : [...(this.pageList[brandId] || []), ...newRows];
            this.pageTotal[brandId] = data.page_info?.total ?? 0;
            this.pageHasMore[brandId] = !!data.page_info?.has_more;
            this.pageOffset[brandId] = (this.pageOffset[brandId] || 0) + newRows.length;
          } catch (e) {
            console.error('loadPagesList failed', e);
          } finally {
            this.pagesLoading[brandId] = false;
          }
        },

        async saveConfig(brand) {
          this.savingCfg[brand.id] = true;
          this.cfgError[brand.id] = '';
          this.cfgSaved[brand.id] = false;
          try {
            const urls = (this.cfgUrls[brand.id] || '')
              .split(/\r?\n/).map(s => s.trim()).filter(Boolean);
            const body = {
              sitemap_urls_override: urls,
              locale_path_prefix: (this.cfgPrefix[brand.id] || '').trim() || null,
            };
            const r = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/sitemap-config`,
              {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
              }
            );
            if (!r.ok) {
              const err = await r.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + r.status));
            }
            const data = await r.json();
            this.cfgPrefix[brand.id] = data.locale_path_prefix || '';
            this.cfgUrls[brand.id] = (data.sitemap_urls_override || []).join('\n');
            this.cfgDirty[brand.id] = false;
            this.cfgSavedRefreshed[brand.id] = false;
            this.cfgSaved[brand.id] = true;
            // Mirror the saved state onto the brand object so the persistent
            // header chip ("/fr-fr/" + "N sitemap URLs (override)") reflects
            // the new config immediately, without a page reload.
            const idx = this.brands.findIndex(b => b.id === brand.id);
            if (idx >= 0) {
              this.brands[idx] = {
                ...this.brands[idx],
                locale_path_prefix: data.locale_path_prefix || null,
                sitemap_urls_override: data.sitemap_urls_override || [],
              };
            }
            setTimeout(() => { this.cfgSaved[brand.id] = false; }, 8000);
          } catch (e) {
            this.cfgError[brand.id] = e.message;
          } finally {
            this.savingCfg[brand.id] = false;
          }
        },

        async saveAndRefresh(brand) {
          // Combined CTA : save the config, then immediately enqueue a
          // crawl_brand_sitemap so the user doesn't have to chase the
          // Refresh button as a second step. Refresh is skipped only if
          // the brand has no domain — saveConfig would have surfaced an
          // error in that case anyway.
          await this.saveConfig(brand);
          if (this.cfgError[brand.id]) return;       // save failed → don't crawl
          if (!brand.domain) return;
          this.cfgSavedRefreshed[brand.id] = true;
          await this.refresh(brand);
        },

        async refresh(brand) {
          if (!brand.domain || this.refreshing[brand.id]) return;
          this.refreshing[brand.id] = true;
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/sitemap/refresh`,
              { method: 'POST', headers: { 'Content-Type': 'application/json' } }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            this.startPoll(brand.id);
          } catch (e) {
            this.refreshing[brand.id] = false;
            alert('Refresh failed : ' + e.message);
          }
        },

        async addManual(brand) {
          const raw = (this.addUrl[brand.id] || '').trim();
          if (!raw || this.adding[brand.id]) return;
          this.adding[brand.id] = true;
          this.addError[brand.id] = '';
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/pages/manual`,
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: raw }),
              }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            this.addUrl[brand.id] = '';
            await this.reloadBrand(brand.id);
            this.startPoll(brand.id);
          } catch (e) {
            this.addError[brand.id] = e.message;
          } finally {
            this.adding[brand.id] = false;
          }
        },

        async removeManual(brand, url) {
          if (this.removing[url]) return;
          if (!confirm('Remove this page from the index ?')) return;
          this.removing[url] = true;
          try {
            const res = await fetch(
              `/api/clients/${this.clientId}/brands/${brand.id}/pages/manual`,
              {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url }),
              }
            );
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail?.message || err.detail || ('HTTP ' + res.status));
            }
            await this.reloadBrand(brand.id);
          } catch (e) {
            alert('Delete failed : ' + e.message);
          } finally {
            this.removing[url] = false;
          }
        },
      };
      });
    });
  </script>
</DashboardLayout>
