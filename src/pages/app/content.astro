---
/**
 * Content Pipeline — Kanban board for FAQ and netlinking articles.
 *
 * Reads from `scan_content_items` table via the new content_items API.
 * Lifecycle columns: TO CREATE → IN REVIEW → APPROVED → PUBLISHED.
 *
 * UX Laws applied :
 * - Goal-Gradient: lifecycle left→right shows progress, status-colored counts
 * - Jakob's Law: Trello-like Kanban convention
 * - Zeigarnik: counts per column keep incomplete tasks visible
 * - Von Restorff: priority badges (red for critique) stand out
 * - Law of Common Region: bordered columns + cards group naturally
 * - Hick's Law: Generate dropdown (FAQ/Article) instead of two side buttons
 * - Serial Position: TO CREATE sorted by priority desc (critique first)
 * - Postel's Law: hover tooltips on truncated questions
 * - Aesthetic-Usability: empty columns explain what'll appear (mental model)
 * - Fitts's Law: filter pills above dropdowns (1-click vs 2-click)
 */
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

// Read filter from query params for SSR-friendly state (browser back/forward)
const ctParam = Astro.url.searchParams.get('content_type') || 'all';
const scanParam = Astro.url.searchParams.get('scan_id') || '';

let clientId: string | null = null;
let kanban: any = { items: [], by_column: {}, counts: {}, total: 0 };
let scans: any[] = [];

try {
  const clientsRes = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: `token=${token}` },
    signal: AbortSignal.timeout(3000),
  });
  const clients = clientsRes.ok ? await clientsRes.json() : [];
  clientId = clients[0]?.id || null;

  if (clientId) {
    // Fetch scans for filter dropdown (latest 20)
    const scansRes = await fetch(`http://api:8000/api/scans?client_id=${clientId}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (scansRes.ok) {
      scans = (await scansRes.json()).slice(0, 20);
    }

    // Build content-items query
    const params = new URLSearchParams();
    if (ctParam !== 'all') params.set('content_type', ctParam);
    if (scanParam) params.set('scan_id', scanParam);
    const qs = params.toString();
    const url = `http://api:8000/api/clients/${clientId}/content-items${qs ? '?' + qs : ''}`;
    const itemsRes = await fetch(url, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(5000),
    });
    if (itemsRes.ok) {
      kanban = await itemsRes.json();
    }
  }
} catch (e) {}

const columns = [
  {
    key: 'to_create',
    label: 'To create',
    badge: 'bg-red-100 text-red-700',
    emptyMsg: 'Generated content suggestions will land here. Run a scan to discover opportunities.',
    helpMsg: 'Click Generate to create FAQ or article from an opportunity.',
  },
  {
    key: 'in_review',
    label: 'In review',
    badge: 'bg-amber-100 text-amber-700',
    emptyMsg: 'Items move here once content is generated, awaiting your review.',
    helpMsg: 'Click a card to review and edit before approving.',
  },
  {
    key: 'approved',
    label: 'Approved',
    badge: 'bg-blue-100 text-blue-700',
    emptyMsg: 'Approved items appear here, ready to publish.',
    helpMsg: 'Click a card to mark as published.',
  },
  {
    key: 'published',
    label: 'Published',
    badge: 'bg-emerald-100 text-emerald-700',
    emptyMsg: 'Published content with live URLs and tracking will be visible here.',
    helpMsg: 'Click a card to see latest position metrics.',
  },
];

const totalAcrossAll = (kanban.counts?.to_create || 0) + (kanban.counts?.in_review || 0)
  + (kanban.counts?.approved || 0) + (kanban.counts?.published || 0);

// Priority pill colors
function priorityClass(p: string): string {
  if (p === 'critique') return 'bg-red-100 text-red-700';
  if (p === 'haute') return 'bg-amber-100 text-amber-700';
  if (p === 'moyenne') return 'bg-blue-100 text-blue-700';
  return 'bg-gray-100 text-gray-600';
}
function priorityLabel(p: string): string {
  if (p === 'critique') return 'CRITICAL';
  if (p === 'haute') return 'HIGH';
  if (p === 'moyenne') return 'MEDIUM';
  return p?.toUpperCase() || '—';
}

// Content type pill colors (FAQ = teal, Article = purple)
function typeClass(t: string): string {
  if (t === 'faq') return 'bg-teal-100 text-teal-700';
  if (t === 'netlinking_article') return 'bg-purple-100 text-purple-700';
  return 'bg-gray-100 text-gray-600';
}
function typeLabel(t: string): string {
  if (t === 'faq') return 'FAQ';
  if (t === 'netlinking_article') return 'ARTICLE';
  return t || '—';
}

function ageLabel(iso: string | null): string {
  if (!iso) return '';
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.floor(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  const d = Math.floor(h / 24);
  return `${d}d ago`;
}
---

<DashboardLayout title="Content" activeSection="content">
  <div class="p-8 max-w-7xl">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-charcoal-dark">Content Pipeline</h1>
        <p class="text-charcoal-light mt-1 text-sm">Track FAQ and articles from creation to publication</p>
      </div>
    </div>

    <!-- Filter bar (Fitts's Law: pills first for 1-click, dropdowns for less common) -->
    <div class="bg-white rounded-xl border border-gray-200 px-4 py-3 mb-6 flex items-center gap-4 flex-wrap">
      <div class="flex items-center gap-1.5">
        <span class="text-[11px] uppercase tracking-wide font-semibold text-charcoal-light mr-1">Type:</span>
        <a href={`?${scanParam ? `scan_id=${scanParam}` : ''}`}
           class={`px-2.5 py-1 text-xs rounded-md font-medium ${ctParam === 'all' ? 'bg-coral text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'}`}>All</a>
        <a href={`?content_type=faq${scanParam ? `&scan_id=${scanParam}` : ''}`}
           class={`px-2.5 py-1 text-xs rounded-md font-medium ${ctParam === 'faq' ? 'bg-coral text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'}`}>FAQ</a>
        <a href={`?content_type=netlinking_article${scanParam ? `&scan_id=${scanParam}` : ''}`}
           class={`px-2.5 py-1 text-xs rounded-md font-medium ${ctParam === 'netlinking_article' ? 'bg-coral text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'}`}>Articles</a>
      </div>

      {scans.length > 0 && (
        <div class="flex items-center gap-2">
          <span class="text-[11px] uppercase tracking-wide font-semibold text-charcoal-light">Scan:</span>
          <select onchange="const u=new URL(window.location); this.value ? u.searchParams.set('scan_id', this.value) : u.searchParams.delete('scan_id'); window.location = u.toString();"
                  class="text-xs border border-gray-200 rounded-md px-2 py-1 bg-white">
            <option value="">All scans</option>
            {scans.map((s: any) => (
              <option value={s.id} selected={scanParam === s.id}>{s.name || s.domain}</option>
            ))}
          </select>
        </div>
      )}

      <div class="flex-1 min-w-[200px]" x-data="{ q: '' }">
        <input type="text" placeholder="Search topic, question, persona…"
               x-model="q"
               @input.debounce.200ms="document.querySelectorAll('[data-card]').forEach(c => { const haystack = c.getAttribute('data-haystack') || ''; c.style.display = haystack.toLowerCase().includes(q.toLowerCase()) ? '' : 'none'; })"
               class="w-full text-sm border border-gray-200 rounded-md px-3 py-1.5 focus:outline-none focus:border-coral" />
      </div>

      <div class="text-[11px] text-charcoal-light">
        <strong class="text-charcoal-dark">{totalAcrossAll}</strong> total
      </div>
    </div>

    {totalAcrossAll === 0 && !scanParam && ctParam === 'all' ? (
      <!-- Global empty state -->
      <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
        <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="text-charcoal-dark font-medium mb-2">No content yet</p>
        <p class="text-sm text-charcoal-light mb-6 max-w-md mx-auto">Run a scan to discover opportunities, then generate FAQ or articles to fill this pipeline.</p>
        <a href="/app/scans/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all">
          Run a scan
        </a>
      </div>
    ) : (
      <!-- Kanban grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {columns.map(col => {
          const items = (kanban.by_column?.[col.key] || []) as any[];
          const count = items.length;
          return (
            <div class="bg-white rounded-xl border border-gray-200 flex flex-col min-h-[400px]">
              <!-- Column header -->
              <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between sticky top-0 bg-white rounded-t-xl">
                <h3 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
                  {col.label}
                  <span class={`text-[10px] font-bold rounded-full px-1.5 py-0.5 ${col.badge}`}>{count}</span>
                </h3>
              </div>

              <!-- Cards or empty state -->
              <div class="p-3 space-y-2 flex-1 overflow-y-auto">
                {count === 0 ? (
                  <div class="py-8 px-2 text-center">
                    <p class="text-[11px] text-gray-400 leading-relaxed">{col.emptyMsg}</p>
                  </div>
                ) : items.map((item: any) => {
                  const haystack = [item.topic_name, item.persona_name, item.target_question, item.scan_domain].filter(Boolean).join(' ');
                  const isToCreate = col.key === 'to_create';
                  const isPublished = col.key === 'published';
                  return (
                    <div data-card data-haystack={haystack}
                         class="block bg-gray-50 hover:bg-white border border-gray-100 hover:border-gray-200 hover:shadow-sm rounded-lg p-3 transition-all">
                      <!-- Top row: badges -->
                      <div class="flex items-center gap-1.5 mb-2 flex-wrap">
                        {item.priority && (
                          <span class={`text-[9px] font-bold rounded px-1.5 py-0.5 ${priorityClass(item.priority)}`}>
                            {priorityLabel(item.priority)}
                          </span>
                        )}
                        {item.content_type && (
                          <span class={`text-[9px] font-bold rounded px-1.5 py-0.5 ${typeClass(item.content_type)}`}>
                            {typeLabel(item.content_type)}
                          </span>
                        )}
                        {item.scan_domain && (
                          <span class="text-[10px] text-charcoal-light truncate max-w-[140px]" title={item.scan_domain}>
                            {item.scan_domain}
                          </span>
                        )}
                      </div>

                      <!-- Topic + question (clickable to detail) -->
                      <a href={`/app/content/${item.id}`} class="block">
                        {item.topic_name && (
                          <p class="text-xs font-medium text-charcoal-dark mb-1 truncate" title={item.topic_name}>
                            {item.topic_name}
                          </p>
                        )}
                        {item.target_question && (
                          <p class="text-[11px] text-charcoal-light line-clamp-2 mb-2" title={item.target_question}>
                            {item.target_question}
                          </p>
                        )}
                      </a>

                      <!-- Per-status footer -->
                      {isToCreate && (
                        <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between gap-2"
                             x-data={`{ generating: ${item.status === 'generating'}, error: '' }`}>
                          {item.opportunity_score != null && (
                            <span class="text-[10px] text-charcoal-light">Score <strong class="text-charcoal-dark">{Math.round(item.opportunity_score)}</strong></span>
                          )}
                          {item.content_type === 'faq' ? (
                            <button @click={`generating = true; error = ''; fetch('/api/content-items/${item.id}/generate', {method:'POST'}).then(async r => { if (r.ok) { /* poll for completion */ const poll = async () => { const pr = await fetch('/api/content-items/${item.id}'); if (pr.ok) { const d = await pr.json(); if (d.status !== 'identified' && d.status !== 'generating') { window.location.reload(); return; } } setTimeout(poll, 3000); }; setTimeout(poll, 3000); } else { const j = await r.json().catch(()=>({})); error = j.detail?.message || j.detail || 'Failed'; generating = false; } }).catch(e => { error = e.message; generating = false; });`}
                                    :disabled="generating"
                                    :class="generating ? 'bg-coral/40 text-white cursor-wait' : 'bg-coral text-white hover:bg-coral-dark'"
                                    class="text-[10px] rounded px-2 py-1 font-medium transition-all"
                                    title="Generate FAQ content (~60s)">
                              <span x-show="!generating">⚡ Generate FAQ</span>
                              <span x-show="generating">⏳ Generating…</span>
                            </button>
                          ) : (
                            <button title="Article generation — coming in Phase C"
                                    disabled
                                    class="text-[10px] bg-gray-200 text-gray-400 cursor-not-allowed rounded px-2 py-1 font-medium">
                              ⚡ Generate (Phase C)
                            </button>
                          )}
                          <p x-show="error" x-text="error" class="text-[9px] text-red-600 absolute mt-8"></p>
                        </div>
                      )}

                      {!isToCreate && !isPublished && (
                        <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between text-[10px] text-charcoal-light">
                          <span>{ageLabel(item.identified_at)}</span>
                          {item.promoted_brand_names?.length > 0 && (
                            <span class="truncate max-w-[120px]" title={item.promoted_brand_names.join(', ')}>
                              ✓ {item.promoted_brand_names[0]}{item.promoted_brand_names.length > 1 ? ` +${item.promoted_brand_names.length - 1}` : ''}
                            </span>
                          )}
                        </div>
                      )}

                      {isPublished && (
                        <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between text-[10px]">
                          {item.published_url ? (
                            <a href={item.published_url} target="_blank" rel="noopener" @click.stop
                               class="text-coral hover:underline truncate max-w-[150px]" title={item.published_url}>
                              🔗 {item.published_url.replace(/^https?:\/\//, '').slice(0, 25)}…
                            </a>
                          ) : <span class="text-gray-400">No URL set</span>}
                          {item.position_delta != null && (
                            <span class={`font-medium ${item.position_delta > 0 ? 'text-emerald-600' : item.position_delta < 0 ? 'text-red-500' : 'text-charcoal-light'}`}>
                              {item.position_delta > 0 ? '+' : ''}{item.position_delta.toFixed(1)} pos
                            </span>
                          )}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</DashboardLayout>
