---
/**
 * Content Pipeline — Kanban board for FAQ and netlinking articles.
 *
 * Reads from `scan_content_items` table via the new content_items API.
 * Lifecycle columns: TO CREATE → IN REVIEW → APPROVED → PUBLISHED.
 *
 * UX Laws applied :
 * - Goal-Gradient: lifecycle left→right shows progress, status-colored counts
 * - Jakob's Law: Trello-like Kanban convention
 * - Zeigarnik: counts per column keep incomplete tasks visible
 * - Von Restorff: priority badges (red for critique) stand out
 * - Law of Common Region: bordered columns + cards group naturally
 * - Hick's Law: Generate dropdown (FAQ/Article) instead of two side buttons
 * - Serial Position: TO CREATE sorted by priority desc (critique first)
 * - Postel's Law: hover tooltips on truncated questions
 * - Aesthetic-Usability: empty columns explain what'll appear (mental model)
 * - Fitts's Law: filter pills above dropdowns (1-click vs 2-click)
 */
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

// Read filter from query params for SSR-friendly state (browser back/forward)
const ctParam = Astro.url.searchParams.get('content_type') || 'all';
const scanParam = Astro.url.searchParams.get('scan_id') || '';
// "show_rejected=1" surfaces the Rejected column. Off by default — rejected
// is a soft-delete signal so most users don't want noise. But we MUST expose
// the column on demand because Reject is reversible (Regenerate from validation
// page), and otherwise the only way to find a rejected item is the direct URL.
const showRejected = Astro.url.searchParams.get('show_rejected') === '1';

let clientId: string | null = null;
let kanban: any = { items: [], by_column: {}, counts: {}, total: 0 };
let scans: any[] = [];

try {
  const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
  const activeClientCookie = Astro.cookies.get('active_client_id')?.value;
  const upstreamCookie = [
    `token=${token}`,
    activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null,
    activeClientCookie ? `active_client_id=${activeClientCookie}` : null,
  ].filter(Boolean).join('; ');
  const clientsRes = await fetch('http://api:8000/api/clients/', {
    headers: { Cookie: upstreamCookie },
    signal: AbortSignal.timeout(3000),
  });
  const clients = clientsRes.ok ? await clientsRes.json() : [];
  clientId = clients[0]?.id || null;

  if (clientId) {
    // Fetch scans for filter dropdown (latest 20)
    const scansRes = await fetch(`http://api:8000/api/scans?client_id=${clientId}`, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(3000),
    });
    if (scansRes.ok) {
      scans = (await scansRes.json()).slice(0, 20);
    }

    // Build content-items query
    const params = new URLSearchParams();
    if (ctParam !== 'all') params.set('content_type', ctParam);
    if (scanParam) params.set('scan_id', scanParam);
    if (showRejected) params.set('include_rejected', 'true');
    const qs = params.toString();
    const url = `http://api:8000/api/clients/${clientId}/content-items${qs ? '?' + qs : ''}`;
    const itemsRes = await fetch(url, {
      headers: { Cookie: `token=${token}` },
      signal: AbortSignal.timeout(5000),
    });
    if (itemsRes.ok) {
      kanban = await itemsRes.json();
    }
  }
} catch (e) {}

const baseColumns = [
  {
    key: 'to_create',
    label: 'To create',
    badge: 'bg-red-100 text-red-700',
    emptyMsg: 'Generated content suggestions will land here. Run a scan to discover opportunities.',
    helpMsg: 'Click Generate to create FAQ or article from an opportunity.',
  },
  {
    key: 'in_review',
    label: 'In review',
    badge: 'bg-amber-100 text-amber-700',
    emptyMsg: 'Items move here once content is generated, awaiting your review.',
    helpMsg: 'Click a card to review and edit before approving.',
  },
  {
    key: 'approved',
    label: 'Approved',
    badge: 'bg-blue-100 text-blue-700',
    emptyMsg: 'Approved items appear here, ready to publish.',
    helpMsg: 'Click a card to mark as published.',
  },
  {
    key: 'published',
    label: 'Published',
    badge: 'bg-emerald-100 text-emerald-700',
    emptyMsg: 'Published content with live URLs and tracking will be visible here.',
    helpMsg: 'Click a card to see latest position metrics.',
  },
];
const rejectedColumn = {
  key: 'rejected',
  label: 'Rejected',
  badge: 'bg-gray-200 text-gray-600',
  emptyMsg: 'No rejected items.',
  helpMsg: 'Click a card to regenerate (gives the LLM another shot) or leave as-is.',
};
const columns = showRejected ? [...baseColumns, rejectedColumn] : baseColumns;

const totalAcrossAll = (kanban.counts?.to_create || 0) + (kanban.counts?.in_review || 0)
  + (kanban.counts?.approved || 0) + (kanban.counts?.published || 0);

// Priority pill colors
function priorityClass(p: string): string {
  if (p === 'critique') return 'bg-red-100 text-red-700';
  if (p === 'haute') return 'bg-amber-100 text-amber-700';
  if (p === 'moyenne') return 'bg-blue-100 text-blue-700';
  return 'bg-gray-100 text-gray-600';
}
function priorityLabel(p: string): string {
  if (p === 'critique') return 'CRITICAL';
  if (p === 'haute') return 'HIGH';
  if (p === 'moyenne') return 'MEDIUM';
  return p?.toUpperCase() || '—';
}

// Content type pill colors (FAQ = teal, Article = purple)
function typeClass(t: string): string {
  if (t === 'faq') return 'bg-teal-100 text-teal-700';
  if (t === 'netlinking_article') return 'bg-purple-100 text-purple-700';
  return 'bg-gray-100 text-gray-600';
}
function typeLabel(t: string): string {
  if (t === 'faq') return 'FAQ';
  if (t === 'netlinking_article') return 'ARTICLE';
  return t || '—';
}

function ageLabel(iso: string | null): string {
  if (!iso) return '';
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.floor(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  const d = Math.floor(h / 24);
  return `${d}d ago`;
}
---

<DashboardLayout title="Content" activeSection="content">
  <div class="p-8 max-w-7xl">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-charcoal-dark">Content Pipeline</h1>
        <p class="text-charcoal-light mt-1 text-sm">Track FAQ and articles from creation to publication</p>
      </div>
    </div>

    <!-- Filter bar (Fitts's Law: pills first for 1-click, dropdowns for less common) -->
    <div class="bg-white rounded-xl border border-gray-200 px-4 py-3 mb-6 flex items-center gap-4 flex-wrap">
      <div class="flex items-center gap-1.5">
        <span class="text-[11px] uppercase tracking-wide font-semibold text-charcoal-light mr-1">Type:</span>
        <a href={`?${scanParam ? `scan_id=${scanParam}` : ''}`}
           class={`px-2.5 py-1 text-xs rounded-md font-medium ${ctParam === 'all' ? 'bg-coral text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'}`}>All</a>
        <a href={`?content_type=faq${scanParam ? `&scan_id=${scanParam}` : ''}`}
           class={`px-2.5 py-1 text-xs rounded-md font-medium ${ctParam === 'faq' ? 'bg-coral text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'}`}>FAQ</a>
        <a href={`?content_type=netlinking_article${scanParam ? `&scan_id=${scanParam}` : ''}`}
           class={`px-2.5 py-1 text-xs rounded-md font-medium ${ctParam === 'netlinking_article' ? 'bg-coral text-white' : 'bg-gray-100 text-charcoal-light hover:bg-gray-200'}`}>Articles</a>
      </div>

      {scans.length > 0 && (
        <div class="flex items-center gap-2">
          <span class="text-[11px] uppercase tracking-wide font-semibold text-charcoal-light">Scan:</span>
          <select onchange="const u=new URL(window.location); this.value ? u.searchParams.set('scan_id', this.value) : u.searchParams.delete('scan_id'); window.location = u.toString();"
                  class="text-xs border border-gray-200 rounded-md px-2 py-1 bg-white max-w-[320px]">
            <option value="">All scans</option>
            {(() => {
              // Disambiguate labels when multiple scans share the same name
              // (common with "test 1", "test 2", etc. created during dev).
              // Always append the domain when the name alone doesn't make
              // the scan unique, and prepend a short id suffix when the
              // domain ALSO collides (rare but happens).
              const nameCount: any = {};
              for (const s of scans) {
                const k = ((s.name || s.domain || '') as string).trim();
                nameCount[k] = (nameCount[k] || 0) + 1;
              }
              return scans.map((s: any) => {
                const name = (s.name || '').trim();
                const domain = (s.domain || '').trim();
                const isAmbiguous = nameCount[name] > 1;
                let label = name || domain;
                if (name && isAmbiguous) {
                  label = `${name} · ${domain || s.id.slice(0, 6)}`;
                }
                return <option value={s.id} selected={scanParam === s.id}>{label}</option>;
              });
            })()}
          </select>
        </div>
      )}

      <div class="flex-1 min-w-[200px]" x-data="{ q: '' }">
        <input type="text" placeholder="Search topic, question, persona…"
               x-model="q"
               @input.debounce.200ms="document.querySelectorAll('[data-card]').forEach(c => { const haystack = c.getAttribute('data-haystack') || ''; c.style.display = haystack.toLowerCase().includes(q.toLowerCase()) ? '' : 'none'; })"
               class="w-full text-sm border border-gray-200 rounded-md px-3 py-1.5 focus:outline-none focus:border-coral" />
      </div>

      {/* Show rejected toggle — Postel's : let users opt into seeing the
           soft-deleted items so they can regenerate or audit. Off by default
           (Hick's : reduce columns shown). */}
      <a href={(() => {
            const u = new URL(Astro.url);
            if (showRejected) u.searchParams.delete('show_rejected');
            else u.searchParams.set('show_rejected', '1');
            return u.pathname + (u.searchParams.toString() ? '?' + u.searchParams.toString() : '');
          })()}
         title={showRejected ? 'Hide rejected items' : 'Show rejected items (regenerable from their detail page)'}
         class={`text-[11px] px-2 py-1 rounded-md font-medium border transition-colors ${showRejected ? 'bg-gray-200 text-charcoal-dark border-gray-300' : 'bg-white text-charcoal-light border-gray-200 hover:border-gray-300'}`}>
        {showRejected ? '✓ Showing rejected' : 'Show rejected'}
      </a>

      <div class="text-[11px] text-charcoal-light">
        <strong class="text-charcoal-dark">{totalAcrossAll}</strong> total
      </div>
    </div>

    {totalAcrossAll === 0 && !scanParam && ctParam === 'all' ? (
      <!-- Global empty state -->
      <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
        <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="text-charcoal-dark font-medium mb-2">No content yet</p>
        <p class="text-sm text-charcoal-light mb-6 max-w-md mx-auto">Run a scan to discover opportunities, then generate FAQ or articles to fill this pipeline.</p>
        <a href="/app/scans/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-coral text-white rounded-lg font-medium hover:bg-coral-dark hover:shadow-md hover:scale-[1.02] transition-all">
          Run a scan
        </a>
      </div>
    ) : (
      <!-- Kanban grid — 4 cols default, 5 when Rejected toggle is on -->
      <div class={`grid grid-cols-1 md:grid-cols-2 ${showRejected ? 'lg:grid-cols-5' : 'lg:grid-cols-4'} gap-4`}>
        {columns.map(col => {
          const items = (kanban.by_column?.[col.key] || []) as any[];
          const count = items.length;
          return (
            <div class="bg-white rounded-xl border border-gray-200 flex flex-col min-h-[400px]">
              <!-- Column header -->
              <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between sticky top-0 bg-white rounded-t-xl">
                <h3 class="text-sm font-semibold text-charcoal-dark flex items-center gap-2">
                  {col.label}
                  <span class={`text-[10px] font-bold rounded-full px-1.5 py-0.5 ${col.badge}`}>{count}</span>
                </h3>
              </div>

              <!-- Cards or empty state -->
              <div class="p-3 space-y-2 flex-1 overflow-y-auto">
                {count === 0 ? (
                  <div class="py-8 px-2 text-center">
                    <p class="text-[11px] text-gray-400 leading-relaxed">{col.emptyMsg}</p>
                  </div>
                ) : items.map((item: any) => {
                  const haystack = [item.topic_name, item.persona_name, item.target_question, item.scan_domain].filter(Boolean).join(' ');
                  const isToCreate = col.key === 'to_create';
                  const isPublished = col.key === 'published';
                  return (
                    <div data-card data-haystack={haystack}
                         class="block bg-gray-50 hover:bg-white border border-gray-100 hover:border-gray-200 hover:shadow-sm rounded-lg p-3 transition-all">
                      <!-- Top row: badges -->
                      <div class="flex items-center gap-1.5 mb-2 flex-wrap">
                        {item.priority && (
                          <span class={`text-[9px] font-bold rounded px-1.5 py-0.5 ${priorityClass(item.priority)}`}>
                            {priorityLabel(item.priority)}
                          </span>
                        )}
                        {item.content_type && (
                          <span class={`text-[9px] font-bold rounded px-1.5 py-0.5 ${typeClass(item.content_type)}`}>
                            {typeLabel(item.content_type)}
                          </span>
                        )}
                        {col.key === 'to_create' && !item.target_url && (
                          <span class="text-[9px] font-bold rounded px-1.5 py-0.5 bg-amber-100 text-amber-800"
                                title={item.content_type === 'netlinking_article'
                                  ? 'Set the media partner URL where this article will be published (e.g. https://www.doctissimo.fr/...), then click Generate.'
                                  : 'Pick a URL on your site where this FAQ should live, then click Generate.'}>
                            ⚠ {item.content_type === 'netlinking_article' ? 'NEEDS MEDIA URL' : 'NEEDS URL'}
                          </span>
                        )}
                        {/* Phase B Tier A — intent chip from the Haiku
                            classifier (content_metadata.intent_category).
                            Hidden for promotional_fit and other (no signal
                            value). Safety categories are filtered out
                            upstream so they normally don't appear here at
                            all — defensive render in case a legacy item
                            survives. */}
                        {(() => {
                          const cat = item.content_metadata?.intent_category;
                          if (!cat || cat === 'promotional_fit' || cat === 'other') return null;
                          const map = {
                            informational_neutral: { label: 'Informational', cls: 'bg-blue-100 text-blue-800' },
                            safety_warning:        { label: 'Safety',        cls: 'bg-amber-100 text-amber-800' },
                            side_effects:          { label: 'Side effects',  cls: 'bg-amber-100 text-amber-800' },
                            contre_indication:     { label: 'Contre-indication', cls: 'bg-amber-100 text-amber-800' },
                            complaint_sav:         { label: 'SAV',           cls: 'bg-amber-100 text-amber-800' },
                          } as const;
                          const m = (map as any)[cat];
                          if (!m) return null;
                          return (
                            <span class={`text-[9px] font-medium rounded px-1.5 py-0.5 ${m.cls}`}
                                  title={`Question intent: ${m.label}. Classified by the scan pipeline.`}>
                              {m.label}
                            </span>
                          );
                        })()}
                        {/* Scan-domain chip — labelled by intent : on FAQ scans
                            it's the user's own brand site (where the FAQ will
                            live), on netlinking_article it's the competitor's
                            scanned domain (the OPPORTUNITY source — what made
                            us identify this article need). Different mental
                            model, different prefix. */}
                        {item.scan_domain && (
                          <span class="text-[10px] text-charcoal-light truncate max-w-[180px]"
                                title={item.content_type === 'netlinking_article'
                                  ? `Scanned (competitor): ${item.scan_domain} — article will publish on a media partner, not here.`
                                  : item.scan_domain}>
                            {item.content_type === 'netlinking_article' ? '🔍 ' : ''}{item.scan_domain}
                          </span>
                        )}
                      </div>

                      {/* Phase C.1.3 — Article media-partner top candidate
                          chip. Show the picked media + LinkFinder price (if
                          enriched) so user sees the "real" target at a glance
                          without opening validation page. FAQ items show
                          target_url in the existing layout below. */}
                      {item.content_type === 'netlinking_article' && item.target_url && item.target_url_source === 'media_picker' && (
                        <div class="mb-2 -mt-1 inline-flex items-center gap-1.5 text-[11px] text-purple-700 font-medium">
                          <span>→ {(item.target_page_title || item.target_url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '').slice(0, 30))}</span>
                          {item.target_url_candidates?.[0]?.price_eur != null && (
                            <span class="text-amber-700 text-[10px]" title="LinkFinder published price (HT) for a sponsored placement">
                              💰 €{Math.round(item.target_url_candidates[0].price_eur).toLocaleString('fr-FR')}
                            </span>
                          )}
                          {item.target_url_candidates?.[0]?.da != null && (
                            <span class="text-charcoal-light text-[10px]" title="Domain Authority (LinkFinder / Majestic)">
                              DA {item.target_url_candidates[0].da}
                            </span>
                          )}
                        </div>
                      )}

                      <!-- Topic + question (clickable to detail) -->
                      <a href={`/app/content/${item.id}`} class="block">
                        {item.topic_name && (
                          <p class="text-xs font-medium text-charcoal-dark mb-1 truncate" title={item.topic_name}>
                            {item.topic_name}
                          </p>
                        )}
                        {item.target_question && (
                          <p class="text-[11px] text-charcoal-light line-clamp-2 mb-2" title={item.target_question}>
                            {item.target_question}
                          </p>
                        )}
                      </a>

                      <!-- Per-status footer -->
                      {isToCreate && (
                        <div class="mt-2 pt-2 border-t border-gray-100"
                             x-data={`{
                               generating: ${item.status === 'generating' ? 'true' : 'false'},
                               error: '',
                               meta: ${JSON.stringify(item.content_metadata || {})},
                               tick: Date.now(),
                               progress() {
                                 const ip = (this.meta && this.meta.in_progress) || {};
                                 const startedAt = ip.started_at ? new Date(ip.started_at).getTime() : null;
                                 const elapsedSec = startedAt ? Math.max(0, Math.floor((this.tick - startedAt) / 1000)) : 0;
                                 const totalSec = ip.estimated_total_seconds || 600;
                                 return {
                                   phase_label: ip.phase_label || 'Generating',
                                   phase_num: ip.phase_num || 1,
                                   phase_total: ip.phase_total || 5,
                                   elapsed: elapsedSec,
                                   total: totalSec,
                                   pct: Math.min(95, Math.floor((elapsedSec / totalSec) * 100))
                                 };
                               },
                               async _poll() {
                                 try {
                                   const pr = await fetch('/api/content-items/${item.id}');
                                   if (pr.ok) {
                                     const d = await pr.json();
                                     this.meta = d.content_metadata || {};
                                     if (d.status !== 'identified' && d.status !== 'generating') {
                                       window.location.reload();
                                       return;
                                     }
                                   }
                                 } catch(e) {}
                                 setTimeout(() => this._poll(), 3000);
                               },
                               async startGen() {
                                 this.generating = true;
                                 this.error = '';
                                 try {
                                   const r = await fetch('/api/content-items/${item.id}/generate', { method: 'POST' });
                                   if (r.ok) {
                                     this._poll();
                                   } else {
                                     const j = await r.json().catch(() => ({}));
                                     this.error = j.detail?.message || j.detail || 'Failed';
                                     this.generating = false;
                                   }
                                 } catch (e) {
                                   this.error = e.message;
                                   this.generating = false;
                                 }
                               }
                             }`}
                             x-init="setInterval(() => tick = Date.now(), 1000); if (generating) _poll();">
                          <!-- Generating : show progress (phase + elapsed + bar) -->
                          <div x-show="generating" class="space-y-1.5">
                            <div class="flex items-center justify-between text-[10px]">
                              <span class={item.content_type === 'netlinking_article' ? 'text-purple-700 font-medium' : 'text-coral-dark font-medium'}>
                                ⚙️ <span x-text="progress().phase_num + '/' + progress().phase_total + ' — ' + progress().phase_label"></span>
                              </span>
                              <span class="text-charcoal-light" x-text="progress().elapsed + 's / ~' + progress().total + 's'"></span>
                            </div>
                            <div class="w-full bg-gray-100 h-1 rounded overflow-hidden">
                              <div class={`h-1 transition-all ${item.content_type === 'netlinking_article' ? 'bg-purple-500' : 'bg-coral'}`}
                                   :style="'width: ' + progress().pct + '%'"></div>
                            </div>
                            <p class="text-[9px] text-charcoal-light italic">
                              {item.content_type === 'netlinking_article'
                                ? 'Article gen takes 5-15 min. You can leave this page.'
                                : 'FAQ gen takes ~60s.'}
                            </p>
                          </div>

                          <!-- Idle : score + Generate button -->
                          <div x-show="!generating" class="flex items-center justify-between gap-2">
                            {item.opportunity_score != null && (
                              <span class="text-[10px] text-charcoal-light">Score <strong class="text-charcoal-dark">{Math.round(item.opportunity_score)}</strong></span>
                            )}
                            {item.target_url ? (
                              item.content_type === 'faq' ? (
                                <button @click="startGen()" type="button"
                                        class="text-[10px] rounded px-2 py-1 font-medium bg-coral text-white hover:bg-coral-dark transition-all"
                                        title="Generate FAQ content (~60s, 1 content credit)">
                                  ⚡ Generate FAQ
                                </button>
                              ) : item.content_type === 'netlinking_article' ? (
                                <button @click="startGen()" type="button"
                                        class="text-[10px] rounded px-2 py-1 font-medium bg-purple-600 text-white hover:bg-purple-700 transition-all"
                                        title="Generate netlinking article (~5-15 min, 3 content credits)">
                                  ⚡ Generate Article
                                </button>
                              ) : (
                                <span class="text-[10px] text-gray-400 italic">Unsupported content_type</span>
                              )
                            ) : (
                              <a href={`/app/content/${item.id}`}
                                 class="text-[10px] rounded px-2 py-1 font-medium bg-amber-100 text-amber-800 hover:bg-amber-200 transition-all"
                                 title={item.content_type === 'netlinking_article'
                                   ? 'Open validation page → set the media partner URL where the article will be published, then Generate.'
                                   : 'Open validation page → set a target URL on your site, then Generate.'}>
                                {item.content_type === 'netlinking_article' ? 'Set media URL →' : 'Set URL →'}
                              </a>
                            )}
                            <p x-show="error" x-text="error" class="text-[9px] text-red-600"></p>
                          </div>
                        </div>
                      )}

                      {!isToCreate && !isPublished && (
                        <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between text-[10px] text-charcoal-light">
                          <span>{ageLabel(item.identified_at)}</span>
                          {item.promoted_brand_names?.length > 0 && (
                            <span class="truncate max-w-[120px]" title={item.promoted_brand_names.join(', ')}>
                              ✓ {item.promoted_brand_names[0]}{item.promoted_brand_names.length > 1 ? ` +${item.promoted_brand_names.length - 1}` : ''}
                            </span>
                          )}
                        </div>
                      )}

                      {isPublished && (
                        <div class="mt-2 pt-2 border-t border-gray-100 flex items-center justify-between text-[10px]">
                          {item.published_url ? (
                            <a href={item.published_url} target="_blank" rel="noopener" @click.stop
                               class="text-coral hover:underline truncate max-w-[150px]" title={item.published_url}>
                              🔗 {item.published_url.replace(/^https?:\/\//, '').slice(0, 25)}…
                            </a>
                          ) : <span class="text-gray-400">No URL set</span>}
                          {item.position_delta != null && (
                            <span class={`font-medium ${item.position_delta > 0 ? 'text-emerald-600' : item.position_delta < 0 ? 'text-red-500' : 'text-charcoal-light'}`}>
                              {item.position_delta > 0 ? '+' : ''}{item.position_delta.toFixed(1)} pos
                            </span>
                          )}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</DashboardLayout>
