---
/**
 * Bulk add client workspaces - S15.4
 *
 * For agencies onboarding a portfolio of brands. One domain per line ;
 * server derives a workspace name from each (first non-www label) and
 * auto-enqueues fetch_keywords so every workspace lands at Gate-2 by
 * the time the user comes back.
 *
 * UX Laws:
 * - Hick's Law : single textarea + single submit, no per-row form
 * - Aesthetic-Usability : live count + duplicate hint while typing
 * - Peak-End : success summary surfaces what landed + what was skipped
 */
export const prerender = false;
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('token')?.value;
if (!token) return Astro.redirect('/login');

const activeOrgCookie = Astro.cookies.get('active_organization_id')?.value;
const upstreamCookie = [`token=${token}`, activeOrgCookie ? `active_organization_id=${activeOrgCookie}` : null].filter(Boolean).join('; ');

type OrgItem = {
  id: string; name: string; is_personal: boolean; role: string | null; is_active: boolean;
};
let activeOrg: OrgItem | null = null;
try {
  const r = await fetch('http://api:8000/api/organizations/', { headers: { Cookie: upstreamCookie }, signal: AbortSignal.timeout(3000) });
  if (r.ok) {
    const list: OrgItem[] = await r.json();
    activeOrg = list.find(o => o.is_active) || list[0] || null;
  }
} catch {}

const isAgencyOrg = !!activeOrg && !activeOrg.is_personal && (activeOrg.role === 'owner' || activeOrg.role === 'admin');
const MAX_BATCH = 50;
---

<DashboardLayout title="Bulk add workspaces" activeSection="dashboard">
  <main class="px-6 py-8 max-w-4xl mx-auto">
    <div class="mb-6">
      <a href="/app/dashboard" class="text-xs text-charcoal-light hover:text-coral">&larr; Back to dashboard</a>
      <h1 class="text-2xl font-bold text-charcoal-dark mt-2">Bulk add workspaces</h1>
      <p class="text-sm text-charcoal-light mt-1">
        Paste one domain per line. We create a workspace for each (named after the domain) and start the analysis automatically.
        Max {MAX_BATCH} per batch.
      </p>
    </div>

    {!isAgencyOrg && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
        <p class="text-sm text-amber-800 font-medium mb-1">Agency org required</p>
        <p class="text-xs text-amber-700">
          Bulk creation only runs inside an agency organization. Switch to your agency from the header dropdown, or
          <a href="/agency" class="underline">read about agency mode</a>.
        </p>
      </div>
    )}

    {isAgencyOrg && (
      <div
        x-data={`{
          raw: '',
          loading: false,
          result: null,
          error: '',
          get lines() {
            return this.raw.split(/\\r?\\n/).map(l => l.trim()).filter(Boolean);
          },
          get count() { return this.lines.length; },
          get atLimit() { return this.count > ${MAX_BATCH}; },
          async submit() {
            this.error = '';
            this.result = null;
            if (this.count === 0 || this.atLimit) return;
            this.loading = true;
            try {
              const res = await fetch('/api/organizations/${activeOrg!.id}/clients/bulk', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ domains: this.lines }),
              });
              const data = await res.json();
              if (!res.ok) { this.error = data.detail || 'Bulk create failed'; this.loading = false; return; }
              this.result = data;
            } catch (e) { this.error = (e && e.message) || 'Network error'; }
            this.loading = false;
          },
        }`}
        class="bg-white rounded-xl border border-gray-200 p-6"
      >
        <label class="block text-xs uppercase tracking-wide text-charcoal-light font-semibold mb-2">Domains</label>
        <textarea
          x-model="raw"
          rows="10"
          placeholder={"eau-thermale-avene.fr\naderma.fr\nklorane.com"}
          class="w-full px-3 py-2 text-sm font-mono border border-gray-300 rounded-lg focus:outline-none focus:border-coral resize-y"
        ></textarea>

        <div class="flex items-center justify-between mt-3 text-xs">
          <div>
            <span x-show="count === 0" class="text-charcoal-light">Paste your domains above</span>
            <span x-show="count > 0 && !atLimit" class="text-charcoal-dark"><span x-text="count" class="font-semibold"></span> domain(s) ready</span>
            <span x-show="atLimit" class="text-red-600 font-semibold">Over the {MAX_BATCH} per-batch limit. Trim to <span x-text={MAX_BATCH}></span> or fewer.</span>
          </div>
          <button
            @click="submit()"
            :disabled="loading || count === 0 || atLimit"
            class="px-4 py-2 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark disabled:bg-gray-300 disabled:text-gray-500 transition-all text-sm"
          >
            <span x-show="!loading">Create <span x-text="count"></span> workspace(s)</span>
            <span x-show="loading">Creating&hellip;</span>
          </button>
        </div>

        <p x-show="error" x-text="error" class="mt-3 text-xs text-red-600"></p>

        <!-- Result panel -->
        <template x-if="result">
          <div class="mt-6 border-t border-gray-100 pt-6 space-y-4">
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-3 text-center">
                <p class="text-2xl font-bold text-emerald-700" x-text="result.summary.created"></p>
                <p class="text-[10px] uppercase tracking-wide text-emerald-600 mt-1">Created</p>
              </div>
              <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-center">
                <p class="text-2xl font-bold text-amber-700" x-text="result.summary.skipped"></p>
                <p class="text-[10px] uppercase tracking-wide text-amber-600 mt-1">Skipped</p>
              </div>
              <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-center">
                <p class="text-2xl font-bold text-red-700" x-text="result.summary.errors"></p>
                <p class="text-[10px] uppercase tracking-wide text-red-600 mt-1">Errors</p>
              </div>
            </div>

            <template x-if="result.created.length > 0">
              <div>
                <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">Created workspaces (analysis started)</p>
                <ul class="space-y-1">
                  <template x-for="c in result.created" :key="c.client_id">
                    <li class="flex items-center justify-between bg-gray-50 rounded px-3 py-2 text-xs">
                      <span class="text-charcoal-dark"><span class="font-medium" x-text="c.name"></span> <span class="text-charcoal-light" x-text="c.domain"></span></span>
                      <a :href="'/app/scans/' + c.scan_id + '/index'" class="text-coral hover:underline">Open &rarr;</a>
                    </li>
                  </template>
                </ul>
              </div>
            </template>

            <template x-if="result.skipped.length > 0">
              <div>
                <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">Skipped (duplicates)</p>
                <ul class="space-y-1">
                  <template x-for="(s, i) in result.skipped" :key="i">
                    <li class="text-xs text-charcoal-light"><span class="font-medium" x-text="s.input"></span> &mdash; already in this org as <span x-text="s.name"></span></li>
                  </template>
                </ul>
              </div>
            </template>

            <template x-if="result.errors.length > 0">
              <div>
                <p class="text-[10px] uppercase tracking-wide text-charcoal-light font-semibold mb-2">Errors</p>
                <ul class="space-y-1">
                  <template x-for="(e, i) in result.errors" :key="i">
                    <li class="text-xs text-red-600"><span class="font-medium" x-text="e.input"></span> &mdash; <span x-text="e.message"></span></li>
                  </template>
                </ul>
              </div>
            </template>

            <div class="pt-2">
              <a href="/app/dashboard" class="inline-flex items-center gap-2 text-sm text-coral hover:text-coral-dark font-medium">Go to dashboard &rarr;</a>
            </div>
          </div>
        </template>
      </div>
    )}
  </main>
</DashboardLayout>
