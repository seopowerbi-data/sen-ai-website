---
import site from '../content/site.json';
const { hero } = site;

const trustIcons: Record<string, string> = {
  clock: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />',
  shield: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M3.75 12c0 4.142 3.358 7.5 7.5 7.5s7.5-3.358 7.5-7.5-3.358-7.5-7.5-7.5-7.5 3.358-7.5 7.5Z" />',
  check: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />'
};
---

<section class="relative min-h-screen flex items-center py-24 sm:py-16 overflow-hidden bg-gradient-to-br from-white via-white to-coral/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Texte - gauche -->
      <div class="max-w-xl">
        <!-- Tagline -->
        <p class="text-coral uppercase tracking-[0.25em] text-sm font-medium mb-6">
          {hero.tagline}
        </p>

        <!-- H1 produit-centric : question hooky qui dit ce que le produit fait -->
        <h1 class="text-4xl sm:text-5xl lg:text-[3.25rem] font-bold text-charcoal-dark leading-[1.1] mb-5">
          Que disent <span class="text-coral">ChatGPT et Gemini</span> de votre marque ?
        </h1>

        <!-- Description -->
        <p class="text-lg text-charcoal-light/80 leading-relaxed mb-8">
          AI Scan mesure votre visibilité dans les IA génératives, sur un sujet précis. <strong class="text-charcoal font-medium">Audit gratuit en 24h</strong>, calibré sur vos produits, vos segments, vos concurrents.
        </p>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-start gap-4 mb-6">
          <button
            id="hero-audit-cta"
            class="inline-flex items-center px-7 py-3.5 bg-coral text-white font-medium rounded-lg hover:bg-coral-dark transition-colors text-base shadow-lg shadow-coral/20 cursor-pointer"
          >
            {hero.cta_primary}
          </button>
          <a
            href="#ai-scan"
            class="inline-flex items-center px-7 py-3.5 border-2 border-charcoal-light/30 text-charcoal font-medium rounded-lg hover:border-coral hover:text-coral transition-colors text-base"
          >
            {hero.cta_secondary}
          </a>
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-charcoal-light">
          {hero.trust_signals.map((t) => (
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-charcoal-light/70 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                <Fragment set:html={trustIcons[t.icon]} />
              </svg>
              {t.label}
            </span>
          ))}
        </div>
      </div>

      <!-- Visuel - droite -->
      <div class="hidden lg:flex items-center justify-center relative" aria-hidden="true">
        <div class="relative w-80 h-80">
          <!-- Cercles décoratifs -->
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-coral/10 to-coral/5 animate-pulse-slow"></div>
          <div class="absolute inset-6 rounded-full bg-gradient-to-tr from-coral/8 to-transparent"></div>
          <div class="absolute inset-12 rounded-full bg-white/80 backdrop-blur-sm shadow-inner"></div>

          <!-- Logo central -->
          <div class="absolute inset-0 flex items-center justify-center">
            <img src="/logo-sen-ai-fr.png" alt="" class="w-32 h-32 object-contain drop-shadow-lg" />
          </div>

          <!-- Points orbitaux -->
          <div class="absolute top-4 right-8 w-3 h-3 rounded-full bg-coral/40"></div>
          <div class="absolute bottom-12 left-2 w-2 h-2 rounded-full bg-coral/30"></div>
          <div class="absolute top-1/3 -right-2 w-4 h-4 rounded-full bg-coral/20"></div>
          <div class="absolute bottom-4 right-1/4 w-2.5 h-2.5 rounded-full bg-coral/25"></div>
        </div>
      </div>

    </div>
  </div>

  <!-- Subtle bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
</section>

<style>
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.04); opacity: 0.85; }
  }
  .animate-pulse-slow {
    animation: pulse-slow 6s ease-in-out infinite;
  }
</style>

<script>
  document.getElementById('hero-audit-cta')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-audit-modal'));
  });
</script>
