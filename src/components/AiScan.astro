---
import site from '../content/site.json';
const { aiscan } = site;

const iconMap: Record<string, string> = {
  user: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />',
  chat: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />',
  beaker: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />',
  chart: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />',
  document: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />'
};
---

<section id="ai-scan" class="py-20 sm:py-28 px-4 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <!-- Header de la solution -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-coral/10 text-coral text-sm font-bold rounded-full uppercase tracking-wide mb-4">
        Solution
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-dark mb-4">
        {aiscan.title}
      </h2>
      <p class="text-xl text-charcoal-light max-w-2xl mx-auto">
        {aiscan.tagline}
      </p>
    </div>

    <!-- Description -->
    <p class="text-center text-charcoal-light leading-relaxed max-w-3xl mx-auto mb-16">
      {aiscan.description}
    </p>

    <!-- Mindset / Démarche -->
    <div class="mb-20">
      <h3 class="text-2xl font-bold text-charcoal-dark text-center mb-3">
        {aiscan.mindset.title}
      </h3>
      <p class="text-charcoal-light text-center max-w-xl mx-auto mb-12">
        {aiscan.mindset.subtitle}
      </p>

      <!-- Pipeline verticale -->
      <div class="relative">
        <div class="absolute left-6 sm:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-coral/20 via-coral/40 to-emerald/40 hidden sm:block"></div>

        <div class="space-y-10 sm:space-y-14">
          {aiscan.mindset.steps.map((step) => (
            <div class="flex items-start gap-6 sm:gap-8 group">
              <div class="relative z-10 shrink-0 w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-white border-2 border-coral/30 group-hover:border-coral flex items-center justify-center transition-colors duration-300 shadow-sm">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-coral" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <Fragment set:html={iconMap[step.icon]} />
                </svg>
              </div>
              <div class="flex-1 pt-0.5 sm:pt-1">
                <h4 class="text-lg sm:text-xl font-bold text-charcoal-dark mb-2 group-hover:text-coral transition-colors duration-300">
                  {step.title}
                </h4>
                <p class="text-charcoal-light leading-relaxed max-w-xl">
                  {step.description}
                </p>

                {/* Example single text (persona) */}
                {step.example && step.example.text && (
                  <div class="mt-3 inline-flex items-start gap-2.5 bg-coral/5 border border-coral/15 rounded-lg px-3 py-2 max-w-lg">
                    <span class="text-[10px] font-bold text-coral uppercase tracking-wider shrink-0 mt-0.5">{step.example.label}</span>
                    <span class="text-xs text-charcoal-light italic leading-relaxed">{step.example.text}</span>
                  </div>
                )}

                {/* Example list (questions) */}
                {step.example && step.example.items && (
                  <div class="mt-3 max-w-xl">
                    <p class="text-[10px] font-bold text-coral uppercase tracking-wider mb-2">{step.example.label}</p>
                    <div class="space-y-1.5">
                      {step.example.items.map((ex) => (
                        <div class="flex items-start gap-2 text-xs leading-relaxed">
                          <span class="text-[9px] font-bold text-coral bg-coral/10 px-1.5 py-0.5 rounded shrink-0 mt-0.5 uppercase tracking-wider">{ex.tag}</span>
                          <span class="text-charcoal-light italic">"{ex.text}"</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Livrables -->
    <div class="mb-16">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        <!-- Newsletter -->
        <div class="bg-white rounded-2xl p-6 sm:p-8 border-2 border-coral/20 shadow-lg shadow-coral/5 hover:shadow-xl transition-shadow duration-300">
          <!-- Mini-mockup newsletter (visual proof) -->
          <div class="bg-gradient-to-br from-gray-50 to-white rounded-xl border border-gray-200 p-4 mb-6 shadow-sm">
            <div class="flex items-center justify-between pb-3 border-b border-gray-100 mb-3">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald shrink-0"></div>
                <p class="text-[10px] text-charcoal-light uppercase tracking-wider font-semibold">Newsletter mensuelle</p>
              </div>
              <span class="text-[9px] text-charcoal-light/60 font-mono">Avril 2026</span>
            </div>
            <p class="text-xs font-semibold text-charcoal-dark mb-2.5">Votre marque dans l'IA ce mois-ci</p>
            <ul class="space-y-1.5 mb-3">
              <li class="flex items-start gap-1.5 text-[11px] text-charcoal-light leading-snug">
                <span class="text-coral mt-0.5">▸</span>
                <span>Citée dans <strong class="text-charcoal-dark">68 %</strong> des réponses <span class="text-emerald font-medium">(+15 pts)</span></span>
              </li>
              <li class="flex items-start gap-1.5 text-[11px] text-charcoal-light leading-snug">
                <span class="text-coral mt-0.5">▸</span>
                <span>2 concurrents émergent sur <em>"anti-âge"</em></span>
              </li>
              <li class="flex items-start gap-1.5 text-[11px] text-charcoal-light leading-snug">
                <span class="text-coral mt-0.5">▸</span>
                <span>3 actions prioritaires identifiées</span>
              </li>
            </ul>
            <p class="text-[10px] text-coral hover:underline cursor-default">→ Voir le rapport complet</p>
          </div>

          <div class="w-12 h-12 rounded-xl bg-coral/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-coral" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal-dark mb-2">
            {aiscan.livrables.newsletter.title}
          </h3>
          <p class="text-charcoal-light mb-6 italic text-sm">
            {aiscan.livrables.newsletter.subtitle}
          </p>
          <ul class="space-y-3">
            {aiscan.livrables.newsletter.points.map((point) => (
              <li class="flex items-start gap-3 text-charcoal-light text-sm">
                <span class="text-coral mt-0.5 shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Dashboard -->
        <div class="bg-white rounded-2xl p-6 sm:p-8 border-2 border-emerald/20 shadow-lg shadow-emerald/5 hover:shadow-xl transition-shadow duration-300">
          <!-- Mini-mockup dashboard (visual proof) -->
          <div class="bg-gradient-to-br from-gray-50 to-white rounded-xl border border-gray-200 p-4 mb-6 shadow-sm">
            <div class="flex items-center justify-between pb-3 border-b border-gray-100 mb-3">
              <p class="text-[10px] text-charcoal-light uppercase tracking-wider font-semibold">Dashboard interactif</p>
              <span class="text-[9px] text-emerald bg-emerald/10 px-2 py-0.5 rounded font-semibold">Live</span>
            </div>
            <!-- KPI row -->
            <div class="grid grid-cols-3 gap-2 mb-4">
              <div>
                <p class="text-[8px] text-charcoal-light uppercase tracking-wide">Citation</p>
                <p class="text-base font-bold text-charcoal-dark leading-tight">68%</p>
              </div>
              <div>
                <p class="text-[8px] text-charcoal-light uppercase tracking-wide">Topics</p>
                <p class="text-base font-bold text-charcoal-dark leading-tight">12</p>
              </div>
              <div>
                <p class="text-[8px] text-charcoal-light uppercase tracking-wide">Trend</p>
                <p class="text-base font-bold text-emerald leading-tight">↑15</p>
              </div>
            </div>
            <!-- Mini bar chart -->
            <div class="space-y-1.5">
              <div class="flex items-center gap-2 text-[10px]">
                <span class="w-16 text-charcoal-light truncate">Anti-âge</span>
                <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald rounded-full" style="width: 78%"></div>
                </div>
                <span class="text-charcoal-dark font-semibold w-7 text-right">78%</span>
              </div>
              <div class="flex items-center gap-2 text-[10px]">
                <span class="w-16 text-charcoal-light truncate">Hydratation</span>
                <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald rounded-full" style="width: 64%"></div>
                </div>
                <span class="text-charcoal-dark font-semibold w-7 text-right">64%</span>
              </div>
              <div class="flex items-center gap-2 text-[10px]">
                <span class="w-16 text-charcoal-light truncate">Sensible</span>
                <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald rounded-full" style="width: 52%"></div>
                </div>
                <span class="text-charcoal-dark font-semibold w-7 text-right">52%</span>
              </div>
            </div>
          </div>

          <div class="w-12 h-12 rounded-xl bg-emerald/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-emerald" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal-dark mb-2">
            {aiscan.livrables.dashboard.title}
          </h3>
          <p class="text-charcoal-light mb-6 italic text-sm">
            {aiscan.livrables.dashboard.subtitle}
          </p>
          <ul class="space-y-3">
            {aiscan.livrables.dashboard.points.map((point) => (
              <li class="flex items-start gap-3 text-charcoal-light text-sm">
                <span class="text-emerald mt-0.5 shrink-0">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    {/* Logos clients AI Scan — temporairement caché, à réafficher plus tard */}
    {false && (
      <div>
        <p class="text-center text-charcoal-light text-sm font-medium uppercase tracking-wide mb-8">
          {aiscan.clients.title}
        </p>
        <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-9 items-center gap-8 lg:gap-6">
          {aiscan.clients.brands.map((brand) => (
            <div class="flex items-center justify-center group" title={brand.name}>
              <img
                src={brand.logo}
                alt={brand.name}
                class="h-8 sm:h-10 w-auto object-contain grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
