    + '<em>Higher = more required structured-data blocks present and valid against the schema.org spec.</em>',
  schema_missing_block: 'Recommended schema.org type for this page type that we did not detect in the page\'s JSON-LD.<br/>'
    + '<em>Copy the generated block below into &lt;head&gt; to fix.</em>',
  schema_existing_valid: 'A JSON-LD block of this type was found AND it has all the properties required by schema.org for its type.',
  schema_existing_invalid: 'A JSON-LD block of this type was found BUT it is missing one or more required properties — Google flags these as red errors.',

  // ── Sprint 7 — Competitor reverse-engineering ────────────────────────
  comp_wins: 'Questions where an LLM cited this competitor and your brand was absent from the response.<br/>'
    + '<em>Higher = they own more of your scan\'s question coverage.</em>',
  comp_pages: 'Pages of this competitor\'s site that an LLM cited at least once during the scan.<br/>'
    + '<em>Capped at 10 per competitor.</em>',
  comp_geo_avg: 'Average Princeton GEO content score across this competitor\'s cited pages.<br/>'
    + 'Measures statistics density, source citations, expert quotes, authoritative phrasing, fluency.<br/>'
    + '<em>Higher = stronger LLM-citation magnet.</em>',
  comp_schema_avg: 'Average schema.org structured-data score across this competitor\'s cited pages.<br/>'
    + '<em>Measures presence of Organization, Article, Product, FAQPage, BreadcrumbList JSON-LD blocks per page type.</em>',
