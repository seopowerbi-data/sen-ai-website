---
/**
 * Centralized tooltip — single source of truth for ALL tooltip text in the app.
 *
 * Usage (slot-based — preferred):
 *   <Tip id="status">Status</Tip>              → hover on "Status" shows the tooltip
 *   <Tip id="status" position="bottom">Status</Tip>
 *   <Tip text="Custom inline text">Label</Tip>
 *
 * Implementation note (2026-05-28) : tooltip uses `position: fixed` with
 * Alpine to compute viewport coordinates on hover. This escapes any
 * ancestor `overflow: hidden` (otherwise tooltips on chips inside
 * rounded cards were being clipped — visible truncation bug). The
 * `kpi-tip` legacy CSS class is preserved for the dashboard styles in
 * DashboardLayout.astro but new pages use the portal-style markup below.
 *
 * The TIPS dictionary below is the canonical vocabulary reference — add new
 * entries here rather than writing inline `text="..."` in call sites, so the
 * wording stays consistent across pages (see feedback_tooltips.md).
 */
interface Props {
  id?: string;
  text?: string;
  position?: 'top' | 'bottom';
}

const { id, text, position = 'top' } = Astro.props;

const TIPS: Record<string, string> = {
  // KPIs (dashboard)
