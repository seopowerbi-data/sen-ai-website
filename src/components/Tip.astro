  reddit_leverage: 'Composite score (0–100) blending engagement (upvotes × comments), classification (competitor_wins gets the boost) and sentiment (negative-about-competitor = highest opportunity).<br/>'
    + '<em>Higher = better thread to engage with first.</em>',
  reddit_competitor_wins: 'Threads where at least one competitor brand was named in the title, body or top comments AND your target brand was absent.<br/>'
    + '<em>Highest-opportunity conversations — you can step in with a better answer.</em>',
  reddit_you_win: 'Threads where your target brand was named.<br/>'
    + '<em>Positive footprint — monitor for sentiment shifts.</em>',
  reddit_neutral: 'Threads cited by an LLM but no in-scope brand was named in the visible text.<br/>'
    + '<em>Context only — low-priority for engagement.</em>',
  reddit_sentiment_pos: 'Haiku read the title, body and top comments and judged the overall tone toward the brand(s) as positive (recommendations, praise).',
  reddit_sentiment_neg: 'Haiku read the title, body and top comments and judged the overall tone toward the brand(s) as negative (complaints, warnings).<br/>'
    + '<em>If a competitor is in scope here, this is the strongest engagement signal.</em>',
  reddit_sentiment_neu: 'Haiku found the discussion factual / informational with no clear lean toward or against the brand(s).',
  reddit_sentiment_mix: 'Substantial pros AND cons in the same discussion. Read before engaging.',
  reddit_sentiment_unclear: 'The LLM citation snippets were too thin to determine sentiment.<br/>'
    + '<em>Often just a "[Source: reddit.com]" marker with no actual discussion content. Open the thread on Reddit to read it yourself.</em>',
  reddit_action: 'Recommended action derived from the row\'s classification × sentiment.<br/>'
    + '<em>Engage now / Add your perspective / Monitor / Skip - the closest one-word verdict on what to do with this thread.</em>',
  reddit_classification: 'Brand-mention status of the thread, derived from a whole-word regex match on the title + body + top 5 comments against your scan\'s brand list.',
  reddit_engagement: '<strong>↑ {0}</strong> upvotes · <strong>💬 {1}</strong> comments.<br/>'
    + '<em>Higher numbers = more visibility for whoever posts in this thread.</em>',
};

const tipText = text || TIPS[id || ''] || '';
// position: top opens the tooltip above the trigger ; bottom opens below.
// Both use viewport-fixed coordinates so they escape any ancestor
// `overflow: hidden` (which was clipping tooltips on chip-bearing cards).
const placeBelow = position === 'bottom';
---

{tipText ? (
  <span
    class="senai-tip-trigger relative inline"
    x-data={`{
      visible: false,
      x: 0, y: 0, side: '${placeBelow ? 'bottom' : 'top'}',
      reposition($el) {
        const r = $el.getBoundingClientRect();
        const margin = 8;
        const tipW = 280;
        // Center horizontally on the trigger, then clamp inside the viewport.
        let cx = r.left + r.width / 2;
        const half = tipW / 2;
        if (cx - half < margin) cx = half + margin;
        if (cx + half > window.innerWidth - margin) cx = window.innerWidth - half - margin;
        this.x = cx;
        // Vertical : 'bottom' anchors to trigger bottom ; default to top.
        // Flip if not enough room on the preferred side.
        if (this.side === 'bottom' && r.bottom + 80 > window.innerHeight) this.side = 'top';
        if (this.side === 'top' && r.top - 80 < 0) this.side = 'bottom';
        this.y = this.side === 'bottom' ? r.bottom + margin : r.top - margin;
      }
    }`}
    @mouseenter="reposition($el); visible = true"
    @mouseleave="visible = false"
    @focusin="reposition($el); visible = true"
    @focusout="visible = false"
  >
    <slot />
    <span
      class="senai-tip"
      x-show="visible"
      x-transition.opacity.duration.120ms
      x-cloak
      :style="`left:${x}px; top:${y}px; transform:${side === 'bottom' ? 'translateX(-50%)' : 'translate(-50%, -100%)'}`"
      set:html={tipText}
    ></span>
  </span>
) : (
  <slot />
)}

<style is:global>
  .senai-tip-trigger { cursor: help; }
  .senai-tip {
    position: fixed;
    z-index: 9999;
    background: #1E293B;
    color: white;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    width: 280px;
    text-align: left;
    text-transform: none;
    letter-spacing: normal;
    white-space: normal;
    word-break: normal;
    overflow-wrap: break-word;
    pointer-events: none;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }
  .senai-tip em { font-style: italic; opacity: 0.85; }
  .senai-tip strong { font-weight: 600; }
  [x-cloak] { display: none !important; }
</style>
