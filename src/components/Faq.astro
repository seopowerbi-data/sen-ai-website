---
import site from '../content/site.json';
const { faq } = site;
---

<section id="faq" class="py-16 sm:py-20 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-dark mb-3">
        {faq.title}
      </h2>
      <p class="text-charcoal-light">
        {faq.subtitle}
      </p>
    </div>

    <div class="space-y-3">
      {faq.items.map((item) => (
        <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group hover:border-coral/40 transition-colors">
          <summary class="px-5 sm:px-6 py-4 cursor-pointer text-sm sm:text-base font-medium text-charcoal-dark hover:bg-gray-50/60 transition-colors list-none flex justify-between items-center gap-4">
            <span>{item.q}</span>
            <svg class="w-4 h-4 text-charcoal-light shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-5 sm:px-6 pb-5 text-sm text-charcoal-light leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>

    <p class="text-center text-sm text-charcoal-light mt-8">
      Une autre question ? <a href="mailto:contact@sen-ai.fr" class="text-coral hover:underline font-medium">contact@sen-ai.fr</a>
    </p>
  </div>
</section>
