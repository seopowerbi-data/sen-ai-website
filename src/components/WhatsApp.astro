---
const phone = "33671738273";
const waMessage = "Bonjour, je souhaite en savoir plus sur vos solutions sen-ai.fr.";
const waUrl = `https://wa.me/${phone}?text=${encodeURIComponent(waMessage)}`;
const emailUrl = "mailto:contact@sen-ai.fr?subject=Contact%20sen-ai.fr&body=Bonjour%2C%20je%20souhaite%20en%20savoir%20plus%20sur%20vos%20solutions%20sen-ai.fr.";
---

<!-- Bouton flottant (desktop uniquement - sur mobile, le sticky audit bar prend la place) -->
<button
  id="contact-toggle"
  aria-label="Nous contacter"
  class="hidden md:flex fixed bottom-6 right-6 z-50 items-center justify-center w-14 h-14 bg-coral text-white rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300"
>
  <!-- Icône message -->
  <svg class="w-6 h-6 contact-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
  </svg>
  <!-- Icône fermer -->
  <svg class="w-6 h-6 contact-icon-close hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Popup choix -->
<div id="contact-popup" class="fixed bottom-24 right-6 z-50 hidden">
  <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-5 w-72">
    <p class="text-charcoal-dark font-bold text-base mb-1">Une question ?</p>
    <p class="text-charcoal-light text-sm mb-4">Choisissez votre moyen de contact.</p>

    <div class="flex flex-col gap-3">
      <!-- WhatsApp -->
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Nous contacter par WhatsApp"
        class="flex items-center gap-3 px-4 py-3 bg-[#25D366] text-white rounded-xl hover:bg-[#20bd5a] transition-colors"
      >
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="text-sm font-medium">WhatsApp</span>
      </a>

      <!-- Email -->
      <a
        href={emailUrl}
        aria-label="Nous contacter par email"
        class="flex items-center gap-3 px-4 py-3 bg-charcoal-dark text-white rounded-xl hover:bg-charcoal transition-colors"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span class="text-sm font-medium">Email</span>
      </a>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('contact-toggle')!;
  const popup = document.getElementById('contact-popup')!;
  const iconOpen = toggle.querySelector('.contact-icon-open')!;
  const iconClose = toggle.querySelector('.contact-icon-close')!;

  function openPopup() {
    popup.classList.remove('hidden');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
  }

  function closePopup() {
    popup.classList.add('hidden');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  toggle.addEventListener('click', () => {
    if (popup.classList.contains('hidden')) {
      openPopup();
    } else {
      closePopup();
    }
  });

  // Tous les boutons qui ouvrent la popup (Nav contact uniquement - le Hero CTA va maintenant sur le modal d'audit)
  document.querySelectorAll('#nav-contact-desktop, #nav-contact-mobile').forEach(btn => {
    btn.addEventListener('click', openPopup);
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    const isContactBtn = (target as Element).closest?.('#nav-contact-desktop, #nav-contact-mobile');
    if (!toggle.contains(target) && !popup.contains(target) && !isContactBtn) {
      closePopup();
    }
  });
</script>
