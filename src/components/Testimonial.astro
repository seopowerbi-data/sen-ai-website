---
import site from '../content/site.json';
const { testimonial } = site;
---

<section class="py-14 sm:py-16 px-4 bg-white border-y border-gray-100">
  <div class="max-w-3xl mx-auto">
    <p class="text-center text-coral uppercase tracking-[0.25em] text-xs font-medium mb-8">
      {testimonial.label}
    </p>

    <blockquote class="text-center">
      <!-- Big decorative quote mark -->
      <div class="text-6xl text-coral/20 leading-none mb-2 font-serif select-none" aria-hidden="true">"</div>

      <p class="text-xl sm:text-2xl text-charcoal-dark font-light leading-relaxed mb-8 px-4 sm:px-8">
        {testimonial.quote}
      </p>

      <footer class="flex items-center justify-center gap-3">
        <!-- Abstract avatar (intentionally generic - identité anonymisée) -->
        <div class="w-11 h-11 rounded-full bg-gradient-to-br from-coral/20 to-coral/40 flex items-center justify-center shrink-0 ring-2 ring-white shadow-sm">
          <svg class="w-5 h-5 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
        <div class="text-left">
          <p class="text-sm font-medium text-charcoal-dark">{testimonial.role}</p>
          <p class="text-xs text-charcoal-light">{testimonial.company}</p>
        </div>
      </footer>
    </blockquote>
  </div>
</section>
