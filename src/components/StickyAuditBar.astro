---
/**
 * StickyAuditBar — sticky bottom CTA on mobile only.
 *
 * Shows after scrolling past the hero (~400px) so it doesn't compete
 * with the hero CTA on first paint. Hidden on desktop where the hero
 * CTA stays visible longer and the floating WhatsApp covers contact.
 */
---

<div
  id="sticky-audit-bar"
  class="md:hidden fixed bottom-0 left-0 right-0 z-40 px-4 pb-4 pt-3 bg-gradient-to-t from-white via-white to-white/95 backdrop-blur-sm border-t border-gray-200/70 shadow-[0_-4px_20px_-8px_rgba(0,0,0,0.1)] translate-y-full transition-transform duration-300 ease-out"
>
  <button
    type="button"
    id="sticky-audit-cta"
    class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-coral text-white font-semibold rounded-lg hover:bg-coral-dark transition-colors text-base shadow-lg shadow-coral/30 cursor-pointer"
  >
    Mon audit gratuit en 24h
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
    </svg>
  </button>
</div>

<script>
  const bar = document.getElementById('sticky-audit-bar');
  const btn = document.getElementById('sticky-audit-cta');

  if (bar && btn) {
    const SHOW_AFTER_PX = 400;
    let visible = false;

    const update = () => {
      const shouldShow = window.scrollY > SHOW_AFTER_PX;
      if (shouldShow !== visible) {
        visible = shouldShow;
        bar.classList.toggle('translate-y-full', !visible);
      }
    };

    window.addEventListener('scroll', update, { passive: true });
    update();

    btn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-audit-modal'));
    });
  }
</script>
