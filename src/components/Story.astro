---
import site from '../content/site.json';
const { story } = site;
---

<section id="histoire" class="py-20 sm:py-28 px-4">
  <div class="max-w-3xl mx-auto">
    <!-- Header (cohérent avec les autres sections) -->
    <div class="text-center mb-10">
      <span class="inline-block px-4 py-1.5 bg-coral/10 text-coral text-sm font-bold rounded-full uppercase tracking-wide mb-4">
        Notre histoire
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-charcoal-dark">
        {story.title}
      </h2>
    </div>

    <!-- Prose -->
    <div class="space-y-5 mb-10">
      {story.paragraphs.map((paragraph) => (
        <p class="text-base sm:text-lg text-charcoal-light leading-relaxed text-center">
          {paragraph}
        </p>
      ))}
    </div>

    <!-- Citation stylisée (resserrée, moins poétique) -->
    <blockquote class="text-center">
      <p class="text-xl sm:text-2xl font-medium text-coral italic tracking-wide">
        &ldquo;{story.quote}&rdquo;
      </p>
    </blockquote>
  </div>
</section>
